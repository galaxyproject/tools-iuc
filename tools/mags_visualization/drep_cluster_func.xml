<tool id="mags_visualization_drep_cluster_func" name="MAGs-visualization drep-cluster-func" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Create a dRep cluster plot with functional annotation</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="version_command"/>
    <command detect_errors="exit_code"><![CDATA[
        mags-visualization drep-cluster-func
            --drep '$drep'
            --gtdb '$gtdb'
            --pathways '$pathways'
            --top_n '$top_n'
            --tax_levels_space '$tax_levels_space'
            --format '$format'
            --mode '$mode'
            --module_label '$module_label'
        
        #if $module_selection.selection_mode == "top"
            --top_modules "$module_selection.top_modules"
        #else
            --top_modules None
        #end if

        #if $tax_levels
            --tax_levels
            #for $tl in $tax_levels
                '$tl'
            #end for
        #end if

        @FIG_SIZE_COMMAND@

            -o outputs &&
        #if $mode == 'mean'
            cp outputs/drep_cluster_functional_core_*.${format} outputs/final_plot_core.png
        #elif $mode == 'variance'
            cp outputs/drep_cluster_functional_difference_*.${format} outputs/final_plot_difference.png
        #else
            cp outputs/drep_cluster_functional_core_*.${format} outputs/final_plot_core.png &&
            cp outputs/drep_cluster_functional_difference_*.${format} outputs/final_plot_difference.png
        #end if
    ]]></command>
    <inputs>
        <param argument="--drep" type="data" format="csv,tabular" label="dRep cluster table"/>
        <param argument="--gtdb" type="data" format="tabular" label="GTDB annotation table"/>
        <param argument="--pathways" type="data" format="tabular" label="Pathway completeness table"/>
        <param argument="--tax_levels" type="select" multiple="true" label="Taxonomy levels">
            <option value="domain">domain</option>
            <option value="phylum" selected="true">phylum</option>
            <option value="class">class</option>
            <option value="order">order</option>
            <option value="family">family</option>
            <option value="genus" selected="true">genus</option>
            <option value="species">species</option>
        </param>
        <param argument="--module_label" type="select" label="Module label style">
            <option value="id" selected="true">Module ID (e.g. M00001)</option>
            <option value="name">Module name</option>
            <option value="both">Module ID and name</option>
        </param>
        <param argument="--top_n" type="integer" value="30" min="1" max="1000" label="Top N clusters"/>
        <conditional name="module_selection">
            <param name="selection_mode" type="select" label="Module selection">
                <option value="top" selected="true">Show top modules</option>
                <option value="all">Show all modules</option>
            </param>
            <when value="top">
                <param name="top_modules" type="integer" value="35" min="1" max="500" label="Number of top modules"/>
            </when>
            <when value="all"/>
        </conditional>
        <param argument="--tax_levels_space" type="float" value="0.3" min="0.1" max="5.0" label="Spacing between taxonomy columns (inches)"/>
        <param argument="--mode" type="select" label="Functional module selection mode">
            <option value="mean" selected="true">mean (core modules)</option>
            <option value="variance">variance (differential modules)</option>
            <option value="both">both</option>
        </param>
        <expand macro="format_param"/>
        <expand macro="fig_size"/>
    </inputs>
    <outputs>
        <data name="plot_core" format="png" label="${tool.name} core on ${on_string}" from_work_dir="outputs/final_plot_core.png">
            <filter>mode == 'mean' or mode == 'both'</filter>
            <expand macro="format_change"/>
        </data>
        <data name="plot_difference" format="png" label="${tool.name} difference on ${on_string}" from_work_dir="outputs/final_plot_difference.png">
            <filter>mode == 'variance' or mode == 'both'</filter>
            <expand macro="format_change"/>
        </data>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="drep" value="drep.tsv"/>
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="pathways" value="kegg_pathway_completeness.tsv"/>
            <param name="mode" value="mean"/>
            <param name="top_n" value="30"/>
            <param name="module_selection|selection_mode" value="top"/>
            <param name="module_selection|top_modules" value="35"/>
            <param name="tax_levels" value="phylum,genus"/>
            <param name="format" value="png"/>
            <output name="plot_core" ftype="png">
                <assert_contents>
                    <has_size min="700000"/>
                    <has_image_width min="4100"/>
                    <has_image_height min="3000"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="drep" value="drep.csv"/>
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="pathways" value="kegg_pathway_completeness.tsv"/>
            <param name="mode" value="variance"/>
            <param name="top_n" value="30"/>
            <param name="module_selection|selection_mode" value="top"/>
            <param name="module_selection|top_modules" value="35"/>
            <param name="tax_levels" value="phylum,genus"/>
            <param name="format" value="pdf"/>
            <output name="plot_difference" ftype="pdf">
                <assert_contents>
                    <has_size min="42000"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="2">
            <param name="drep" value="drep.tsv"/>
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="pathways" value="kegg_pathway_completeness.tsv"/>
            <param name="mode" value="both"/>
            <param name="top_n" value="30"/>
            <param name="module_selection|selection_mode" value="top"/>
            <param name="module_selection|top_modules" value="35"/>
            <param name="tax_levels" value="phylum,genus"/>
            <param name="format" value="svg"/>
            <output name="plot_core" ftype="svg">
                <assert_contents>
                    <has_size min="220000"/>
                    <has_text text="Phylum"/>
                    <has_text text="Genus"/>
                    <has_text text="Amino acid metabolism"/>
                    <has_text text="Nucleotide metabolism"/>
                    <has_text text="Pathway completeness (%)"/>
                </assert_contents>
            </output>
            <output name="plot_difference" ftype="svg">
                <assert_contents>
                    <has_size min="220000"/>
                    <has_text text="Phylum"/>
                    <has_text text="Genus"/>
                    <has_text text="Amino acid metabolism"/>
                    <has_text text="Carbohydrate metabolism"/>
                    <has_text text="Pathway completeness (%)"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**MAGs-visualization: drep-cluster-func**

This tool generates dRep cluster plots with integrated functional annotation based on KEGG pathway completeness data.

Clusters are annotated with:

- taxonomic classification (GTDB)
- functional module completeness

Functional modules can be selected using different modes:

- **mean**: highlights core functional modules shared across clusters
- **variance**: highlights modules that vary most between clusters
- **both**: generates both plots for comparison

The module selection option allows either displaying the top-ranked modules or all available modules.

Requirements:

- dRep clustering table
- GTDB taxonomy table
- Pathway/module completeness table

Output:

- Cluster plots with functional module annotation

**Layout options:**
All size and spacing parameters (figure width, height, spacers) are specified in **inches**.

Example output plots are available in the MAGs-visualization use cases with example configurations and parameter choices:
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases

For a direct example (bee microbiome dataset):
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases/bee-use-case/plots
    ]]></help>
    <expand macro="citation"/>
</tool>
