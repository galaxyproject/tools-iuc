<tool id="mags_visualization_pathway_module_heatmap" name="MAGs-visualization pathway-module-heatmap" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Create a MAG vs pathway-module heatmap</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="version_command"/>
    <command detect_errors="exit_code"><![CDATA[
        mags-visualization pathway-module-heatmap
            --pathways '$pathways'
            --mode '$mode'
            --row_fontsize '$row_fontsize'
            --format '$format'
            -o outputs
        
        #if $module_selection.selection_mode == "top"
            --top_modules "$module_selection.top_modules"
        #else
            --top_modules None
        #end if
        
        #if $show_module_labels
            --show_module_labels
        #end if

        #if str($fig_size.width) != "" and str($fig_size.height) != ""
            --fig_size '$fig_size.width' '$fig_size.height'
        #end if

        #if $representatives.representatives_only
            --representatives_only
        #end if

        #if $representatives.drep
            --drep '$representatives.drep'
        #end if

        #if $representatives.gtdb
            --gtdb '$representatives.gtdb'
        #end if

        #if str($representatives.top_representatives) != ""
            --top_representatives '$representatives.top_representatives'
        #end if
    ]]></command>
    <inputs>
        <param name="pathways" type="data" format="tabular" label="Pathway completeness table"/>
        <conditional name="module_selection">
            <param name="selection_mode" type="select" label="Number of modules to display">
                <option value="top" selected="true">Show top modules</option>
                <option value="all">Show all modules</option>
            </param>
            <when value="top">
                <param name="top_modules" type="integer" value="30" min="1" label="Number of top modules"/>
            </when>
            <when value="all"/>
        </conditional>
        <param name="mode" type="select" label="Module ranking mode">
            <option value="mean" selected="true">mean (core modules)</option>
            <option value="variance">variance (differential modules)</option>
        </param>
        <param name="show_module_labels" type="boolean" checked="false" truevalue="true" falsevalue="" label="Show module labels on x-axis"/>
        <param name="row_fontsize" type="integer" value="8" min="1" label="Row label font size"/>
        <param name="format" type="select" label="Output format">
            <option value="png" selected="true">png</option>
            <option value="pdf">pdf</option>
            <option value="svg">svg</option>
        </param>
        <section name="representatives" title="Representative MAG selection (optional)" expanded="false">
            <param name="drep" type="data" format="csv,tabular" optional="true" label="dRep cluster table"/>
            <param name="gtdb" type="data" format="tabular" optional="true" label="GTDB annotation table"/>
            <param name="representatives_only" type="boolean" checked="false" truevalue="true" falsevalue="" label="Restrict heatmap to representative MAGs"/>
            <param name="top_representatives" type="integer" optional="true" min="1" label="Top representative MAGs"/>
        </section>
        <section name="fig_size" title="Figure size" expanded="false">
            <param name="width" type="float" optional="true" label="Figure width"/>
            <param name="height" type="float" optional="true" label="Figure height"/>
        </section>
    </inputs>
    <outputs>
        <collection name="plots" type="list" label="${tool.name} outputs">
            <discover_datasets directory="outputs" pattern="(?P&lt;designation&gt;.+)\.(?P&lt;ext&gt;png|pdf|svg)$" visible="true"/>
        </collection>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="pathways" value="kegg_pathway_completeness.tsv"/>
            <param name="mode" value="mean"/>
            <param name="module_selection|selection_mode" value="top"/>
            <param name="module_selection|top_modules" value="30"/>
            <param name="row_fontsize" value="8"/>
            <param name="format" value="png"/>
            <output_collection name="plots" type="list">
                <element name="pathway_module_heatmap_mean_all_mags_top30">
                    <assert_contents>
                        <has_size min="1"/>
                    </assert_contents>
                </element>
            </output_collection>
        </test>
        <test expect_num_outputs="1">
            <param name="pathways" value="kegg_pathway_completeness.tsv"/>
            <param name="mode" value="variance"/>
            <param name="module_selection|selection_mode" value="top"/>
            <param name="module_selection|top_modules" value="30"/>
            <param name="row_fontsize" value="8"/>
            <param name="format" value="png"/>
            <output_collection name="plots" type="list">
                <element name="pathway_module_heatmap_variance_all_mags_top30">
                    <assert_contents>
                        <has_size min="1"/>
                    </assert_contents>
                </element>
            </output_collection>
        </test>
        <test expect_num_outputs="1">
            <param name="pathways" value="kegg_pathway_completeness.tsv"/>
            <param name="mode" value="mean"/>
            <param name="module_selection|selection_mode" value="top"/>
            <param name="module_selection|top_modules" value="30"/>
            <param name="row_fontsize" value="8"/>
            <param name="format" value="png"/>
            <param name="representatives|drep" value="drep.csv"/>
            <param name="representatives|gtdb" value="gtdb.tsv"/>
            <param name="representatives|representatives_only" value="true"/>
            <param name="representatives|top_representatives" value="30"/>
            <output_collection name="plots" type="list">
                <element name="pathway_module_heatmap_mean_representatives_top30">
                    <assert_contents>
                        <has_size min="1"/>
                    </assert_contents>
                </element>
            </output_collection>
        </test>
    </tests>
    <help><![CDATA[
**MAGs-visualization: pathway-module-heatmap**

This tool generates a heatmap of KEGG pathway module completeness across MAGs, enabling comparison of functional profiles.

Modules can be selected using two modes:

- **mean**: highlights core modules shared across MAGs
- **variance**: highlights modules that vary most between MAGs

The module selection option allows either displaying the top-ranked modules or all available modules.

Optionally, the heatmap can be restricted to representative MAGs using dRep and GTDB input tables.
When dRep and GTDB tables are provided, the heatmap can be restricted to representative MAGs, similar to the representative selection used in the drep-cluster-func plot.

Requirements:

- Pathway/module completeness table

Output:

- Heatmap of functional profiles across MAGs

Example output plots are available in the MAGs-visualization use cases with example configurations and parameter choices:
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases

For a direct example (bee microbiome dataset):
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases/bee-use-case/plots
    ]]></help>
    <expand macro="citation"/>
</tool>
