<tool id="mags_visualization_sample_heatmap" name="MAGs-visualization sample-heatmap" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Create a sample heatmap plot</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="version_command"/>
    <command detect_errors="exit_code"><![CDATA[
        mags-visualization sample-heatmap
            --coverm '$coverm'
            --gtdb '$gtdb'
            --tax_level '$tax_level'
            --format '$format'
            --max_col '$max_col'
            -o outputs

        #if $metadata_cond.metadata
            --metadata '$metadata_cond.metadata'
            --meta_bin_width '$metadata_cond.meta_bin_width'
        #end if

        #if $metadata_cond.metadata and len($metadata_cond.meta_cols) > 0
            --meta_cols
            #for $mc in $metadata_cond.meta_cols
                '$mc.col'
            #end for
        #end if

        $no_log

        --top_bar_height '$layout.top_bar_height'
        --hspace '$layout.hspace'
        --heatmap_width '$layout.heatmap_width'
        --spacer_legend '$layout.spacer_legend'
        --spacer_meta '$layout.spacer_meta'
        --spacer_heatmap '$layout.spacer_heatmap'
        --legend '$layout.legend'
        --meta_bar_add '$layout.meta_bar_add'
        --top_bar_spacer '$layout.top_bar_spacer'
    ]]></command>
    <inputs>
        <param name="coverm" type="data" format="tabular" label="CoverM table"/>
        <param name="gtdb" type="data" format="tabular" label="GTDB annotation table"/>
        <section name="metadata_cond" title="Metadata options" expanded="false">
            <param name="metadata" type="data" format="tabular" optional="true" label="Metadata table"/>
            <repeat name="meta_cols" title="Metadata columns" min="0">
                <param name="col" type="text" label="Metadata column name"/>
            </repeat>
            <param name="meta_bin_width" type="float" value="5.0" min="0.1" label="Bin width for numeric metadata"/>
        </section>
        <param name="tax_level" type="select" label="Taxonomic level">
            <option value="domain">domain</option>
            <option value="phylum" selected="true">phylum</option>
            <option value="class">class</option>
            <option value="order">order</option>
            <option value="family">family</option>
            <option value="genus">genus</option>
            <option value="species">species</option>
        </param>
        <param name="format" type="select" label="Output format">
            <option value="png" selected="true">png</option>
            <option value="pdf">pdf</option>
            <option value="svg">svg</option>
        </param>
        <param name="max_col" type="integer" value="10" min="1" label="Maximum number of taxonomy labels"/>
        <param name="no_log" type="boolean" checked="false" truevalue="--no_log" falsevalue="" label="Disable log10 scaling for the top bar plot"/>
        <section name="layout" title="Heatmap layout options" expanded="false">
            <param name="top_bar_height" type="float" value="0.7" label="Top bar height"/>
            <param name="hspace" type="float" value="0.25" label="Vertical spacing between top bar and heatmap"/>
            <param name="heatmap_width" type="float" value="11.0" label="Heatmap width"/>
            <param name="spacer_legend" type="float" value="0.3" label="Spacer between legend and metadata bars"/>
            <param name="spacer_meta" type="float" value="2.0" label="Spacer between metadata bars and heatmap"/>
            <param name="spacer_heatmap" type="float" value="0.10" label="Spacer between heatmap and histogram"/>
            <param name="legend" type="float" value="2.5" label="Legend width"/>
            <param name="meta_bar_add" type="float" value="1.5" label="Additional width for metadata bars"/>
            <param name="top_bar_spacer" type="float" value="0.0" label="Spacer above top bar"/>
        </section>
    </inputs>
    <outputs>
        <collection name="plots" type="list">
            <discover_datasets directory="outputs" pattern="(?P&lt;designation&gt;.+)\.(?P&lt;ext&gt;png|pdf|svg)$" visible="true"/>
        </collection>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="coverm" value="coverm.tsv"/>
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="tax_level" value="phylum"/>
            <param name="format" value="png"/>
            <output_collection name="plots" type="list">
                <element name="heatmap_with_bars_phylum" ftype="png">
                    <assert_contents>
                        <has_size min="1"/>
                        <has_image_width min="100"/>
                        <has_image_height min="100"/>
                    </assert_contents>
                </element>
            </output_collection>
        </test>
        <test expect_num_outputs="1">
            <param name="coverm" value="coverm.tsv"/>
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="metadata_cond|metadata" value="metadata.tsv"/>
            <param name="metadata_cond|meta_cols_0|col" value="Infection by Nosema ceranae"/>
            <param name="metadata_cond|meta_cols_1|col" value="Chronic exposure to neonicotinoid"/>
            <param name="metadata_cond|meta_cols_2|col" value="Treatment with probiotic"/>
            <param name="tax_level" value="species"/>
            <param name="format" value="png"/>
            <output_collection name="plots" type="list">
                <element name="heatmap_with_bars_species" ftype="png">
                    <assert_contents>
                        <has_size min="1"/>
                        <has_image_width min="100"/>
                        <has_image_height min="100"/>
                    </assert_contents>
                </element>
            </output_collection>
        </test>
    </tests>
    <help><![CDATA[
**MAGs-visualization: sample-heatmap**

This tool generates a heatmap showing MAG detection patterns across samples based on MAG abundance estimates (CoverM) and GTDB taxonomy assignments.

Optional metadata columns can be added as annotation bars above the heatmap to facilitate comparison across samples.

Requirements:

- CoverM abundance table
- GTDB taxonomy table

Output:

- Heatmap visualizing MAG abundance across samples at the selected taxonomic level

Example output plots are available in the MAGs-visualization use cases with example configurations and parameter choices:
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases

For a direct example (bee microbiome dataset):
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases/bee-use-case/plots
    ]]></help>
    <expand macro="citation"/>
</tool>
