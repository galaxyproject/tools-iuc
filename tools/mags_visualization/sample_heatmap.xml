<tool id="mags_visualization_sample_heatmap" name="MAGs-visualization sample-heatmap" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Create a sample heatmap plot</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="version_command"/>
    <command detect_errors="exit_code"><![CDATA[
        mags-visualization sample-heatmap
            --coverm '$coverm'
            --gtdb '$gtdb'
            --tax_level '$tax_level'
            --format '$format'
            --max_col '$max_col'

        #if $metadata_cond.use_metadata == "yes"
            --metadata '$metadata_cond.metadata'
            --meta_bin_width '$metadata_cond.meta_bin_width'
            #if $metadata_cond.meta_cols
                --meta_cols
                #for $mc in $metadata_cond.meta_cols
                    '$mc'
                #end for
            #end if
        #end if

        $no_log

        --top_bar_height '$layout.top_bar_height'
        --hspace '$layout.hspace'
        --heatmap_width '$layout.heatmap_width'
        --spacer_legend '$layout.spacer_legend'
        --spacer_meta '$layout.spacer_meta'
        --spacer_heatmap '$layout.spacer_heatmap'
        --legend '$layout.legend'
        --meta_bar_add '$layout.meta_bar_add'
        --top_bar_spacer '$layout.top_bar_spacer'

            -o outputs &&
        cp outputs/heatmap_*.${format} outputs/final_plot.png
    ]]></command>
    <inputs>
        <param argument="--coverm" type="data" format="tabular" label="CoverM table"/>
        <param argument="--gtdb" type="data" format="tabular" label="GTDB annotation table"/>
        
        <conditional name="metadata_cond">
            <param name="use_metadata" type="select" label="Add metadata annotation?">
                <option value="no" selected="true">No</option>
                <option value="yes">Yes</option>
            </param>
            <when value="no"/>
            <when value="yes">
                <param name="metadata" type="data" format="tabular" label="Metadata table"/>
                <param name="meta_cols" type="data_column"
                    data_ref="metadata"
                    label="Metadata columns"
                    use_header_names="true"
                    multiple="true"
                    optional="true"
                    help="Select one or more columns (Ctrl+Click)"/>
                <param name="meta_bin_width" type="float" value="5.0" min="0.1" max="100.0" label="Bin width for numeric metadata"
                    help="Width of bins used to group numeric metadata values into discrete categories for coloring. 
                    For example, a bin with of 5 groups values 0-5, 5-10, 10-15 etc.
                    Smaller values create more categories with finer resolution; larger values group more broadly."/>
            </when>
        </conditional>
        
        <param argument="--tax_level" type="select" label="Taxonomic level">
            <option value="domain">domain</option>
            <option value="phylum" selected="true">phylum</option>
            <option value="class">class</option>
            <option value="order">order</option>
            <option value="family">family</option>
            <option value="genus">genus</option>
            <option value="species">species</option>
        </param>
        <expand macro="format_param"/>
        <param argument="--max_col" type="integer" value="10" min="1" max="100" label="Maximum number of taxonomy labels"/>
        <param argument="--no_log" type="boolean" checked="false" truevalue="--no_log" falsevalue="" label="Disable log10 scaling for the top bar plot"/>
        <section name="layout" title="Heatmap layout options" expanded="false">
            <param name="top_bar_height" type="float" value="0.7" min="0.1" max="10.0" label="Top bar height (inches)"/>
            <param name="hspace" type="float" value="0.25" min="0.0" max="5.0" label="Vertical spacing between top bar and heatmap (inches)"/>
            <param name="heatmap_width" type="float" value="11.0" min="1.0" max="100.0" label="Heatmap width (inches)"/>
            <param name="spacer_legend" type="float" value="0.3" min="0.0" max="10.0" label="Spacer between legend and metadata bars (inches)"/>
            <param name="spacer_meta" type="float" value="2.0" min="0.0" max="20.0" label="Spacer between metadata bars and heatmap (inches)"/>
            <param name="spacer_heatmap" type="float" value="0.10" min="0.0" max="10.0" label="Spacer between heatmap and histogram (inches)"/>
            <param name="legend" type="float" value="2.5" min="0.1" max="20.0" label="Legend width (inches)"/>
            <param name="meta_bar_add" type="float" value="1.5" min="0.0" max="20.0" label="Additional width for metadata bars (inches)"/>
            <param name="top_bar_spacer" type="float" value="0.0" min="0.0" max="10.0" label="Spacer above top bar (inches)"/>
        </section>
    </inputs>
    <outputs>
        <data name="plot" format="png" label="${tool.name} on ${on_string}" from_work_dir="outputs/final_plot.png">
            <expand macro="format_change"/>
        </data>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="coverm" value="coverm.tsv"/>
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="tax_level" value="phylum"/>
            <param name="format" value="png"/>
            <output name="plot" ftype="png">
                <assert_contents>
                    <has_size min="280000"/>
                    <has_image_width min="2000"/>
                    <has_image_height min="2000"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="coverm" value="coverm.tsv"/>
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="metadata_cond|use_metadata" value="yes"/>
            <param name="metadata_cond|metadata" value="metadata.tsv"/>
            <param name="metadata_cond|meta_cols" value="7,8,9"/>
            <param name="tax_level" value="species"/>
            <param name="format" value="png"/>
            <output name="plot" ftype="png">
                <assert_contents>
                    <has_size min="300500"/>
                    <has_image_width min="2000"/>
                    <has_image_height min="2000"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="coverm" value="coverm.tsv"/>
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="tax_level" value="phylum"/>
            <param name="format" value="svg"/>
            <output name="plot" ftype="svg">
                <assert_contents>
                    <has_size min="100000"/>
                    <has_text text="MAG distribution"/>
                    <has_text text="Pseudomonadota"/>
                    <has_text text="Bacillota"/>
                    <has_text text="Bacteroidota"/>
                    <has_text text="SRR24759596"/>
                    <has_text text="Abundance"/>
                    <has_text text="MAGs/sample"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**MAGs-visualization: sample-heatmap**

This tool generates a heatmap showing MAG detection patterns across samples based on MAG abundance estimates (CoverM) and GTDB taxonomy assignments.

Optional metadata columns can be added as annotation bars above the heatmap to facilitate comparison across samples.

Requirements:

- CoverM abundance table
- GTDB taxonomy table

Output:

- Heatmap visualizing MAG abundance across samples at the selected taxonomic level

**Layout options:**
All size and spacing parameters (figure width, height, spacers) are specified in **inches**.

Example output plots are available in the MAGs-visualization use cases with example configurations and parameter choices:
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases

For a direct example (bee microbiome dataset):
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases/bee-use-case/plots
    ]]></help>
    <expand macro="citation"/>
</tool>
