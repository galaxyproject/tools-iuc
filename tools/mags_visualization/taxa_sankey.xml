<tool id="mags_visualization_taxa_sankey" name="MAGs-visualization taxa-sankey" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Create GTDB taxonomy Sankey plots</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="version_command"/>
    <command detect_errors="exit_code"><![CDATA[
        mags-visualization taxa-sankey
            --gtdb '$gtdb'
            --rank '$rank'
            --format html
            -o outputs
    ]]></command>
    <inputs>
        <param argument="--gtdb" type="data" format="tabular" label="GTDB annotation table"/>
        <param argument="--rank" type="select" label="Taxonomic rank">
            <option value="domain">domain</option>
            <option value="phylum" selected="true">phylum</option>
            <option value="class">class</option>
            <option value="order">order</option>
            <option value="family">family</option>
            <option value="genus">genus</option>
            <option value="species">species</option>
        </param>
    </inputs>

    <outputs>
        <collection name="plots" type="list">
            <discover_datasets directory="outputs" pattern="(?P&lt;designation&gt;.+)\.(?P&lt;ext&gt;html)$" visible="true"/>
        </collection>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="rank" value="phylum"/>
            <output_collection name="plots" type="list">
                <element name="sankey_plot" ftype="html">
                    <assert_contents>
                        <has_size min="4200000"/>
                        <has_text text="Bacteria"/>
                        <has_text text="Pseudomonadota"/>
                        <has_text text="Bacillota"/>
                        <has_text text="Bacilli"/>
                        <has_text text="Lachnospirales"/>
                        <has_text text="Unknown Species"/>
                        <has_text text="Proteus mirabilis"/>
                        <has_text text="&lt;html"/>
                    </assert_contents>
                </element>
                <element name="sankey_plot_rank_filtered" ftype="html">
                    <assert_contents>
                        <has_size min="4200000"/>
                        <has_text text="Pseudomonadota"/>
                        <has_text text="Bacillota"/>
                        <has_text text="Bacillota_A"/>
                        <has_text text="Bacteroidota"/>
                        <has_text text="Actinomycetota"/>
                        <has_text text="SRR24759597_bin_73064.fasta"/>
                    </assert_contents>
                </element>
            </output_collection>
        </test>

        <test expect_num_outputs="1">
            <param name="gtdb" value="gtdb.tsv"/>
            <param name="rank" value="genus"/>
            <output_collection name="plots" type="list">
                <element name="sankey_plot" ftype="html">
                    <assert_contents>
                        <has_size min="4200000"/>
                        <has_text text="Frischella"/>
                        <has_text text="Gilliamella"/>
                        <has_text text="Entomomonas"/>
                        <has_text text="Snodgrassella"/>
                        <has_text text="Enterococcus"/>
                        <has_text text="Proteus"/>
                        <has_text text="&lt;html"/>
                    </assert_contents>
                </element>
                <element name="sankey_plot_rank_filtered" ftype="html">
                    <assert_contents>
                        <has_size min="4200000"/>
                    </assert_contents>
                </element>
            </output_collection>
        </test>
    </tests>
    <help><![CDATA[
**MAGs-visualization: taxa-sankey**

This tool generates Sankey diagrams to visualize the taxonomic classification of MAGs based on GTDB annotations.

Outputs include:

- a Sankey plot showing the full taxonomy hierarchy
- a Sankey plot filtered to the selected taxonomic rank

Sankey outputs are generated as HTML files using Plotly.

Depending on the Galaxy instance security settings, HTML content may be displayed as plain text. In this case, download the file and open it in a web browser to view the plot.
In this Galaxy wrapper, Sankey plots are generated as HTML files.
The underlying command-line tool also supports png, pdf and svg output when Plotly/Kaleido static image export dependencies are available.
Requirements:

- GTDB taxonomy table

Output:

- Interactive HTML Sankey diagrams

Example output plots are available in the MAGs-visualization use cases with example configurations and parameter choices:
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases

For a direct example (bee microbiome dataset):
https://github.com/usegalaxy-eu/MAGs-visualization/tree/main/use-cases/bee-use-case/plots
    ]]></help>
    <expand macro="citation"/>
</tool>
