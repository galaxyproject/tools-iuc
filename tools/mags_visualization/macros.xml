<macros>
    <token name="@TOOL_VERSION@">0.0.10</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.0</token>
    <token name="@FIG_SIZE_COMMAND@">
        #if str($fig_size.width) != "" and str($fig_size.height) != ""
            --fig_size '$fig_size.width' '$fig_size.height'
        #end if
    </token>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">mags-visualization</requirement>
        </requirements>
    </xml>
    <xml name="version_command">
        <version_command><![CDATA[mags-visualization --version]]></version_command>
    </xml>
    <xml name="citation">
        <citations>
            <citation type="bibtex">
@misc{mags_visualization,
  author = {Alexandra H. and contributors},
  title = {MAGs-visualization},
  year = {2026},
  howpublished = {\url{https://github.com/usegalaxy-eu/MAGs-visualization}},
}
            </citation>
        </citations>
    </xml>
    <xml name="format_param">
        <param argument="--format" type="select" label="Output format">
            <option value="png" selected="true">PNG</option>
            <option value="pdf">PDF</option>
            <option value="svg">SVG</option>
        </param>
    </xml>

    <xml name="format_param_with_html">
        <param argument="--format" type="select" label="Output format">
            <option value="html" selected="true">HTML (interactive)</option>
            <option value="png">PNG</option>
            <option value="pdf">PDF</option>
            <option value="svg">SVG</option>
        </param>
    </xml>

    <xml name="format_change">
        <change_format>
            <when input="format" value="pdf" format="pdf"/>
            <when input="format" value="svg" format="svg"/>
        </change_format>
    </xml>

    <xml name="format_change_with_html">
        <change_format>
            <when input="format" value="png" format="png"/>
            <when input="format" value="pdf" format="pdf"/>
            <when input="format" value="svg" format="svg"/>
        </change_format>
    </xml>

    <xml name="fig_size">
        <section name="fig_size" title="Figure size" expanded="false">
            <param name="width" type="float" optional="true" min="1" max="100" label="Figure width (inches)"/>
            <param name="height" type="float" optional="true" min="1" max="100" label="Figure height (inches)"/>
        </section>
    </xml>
</macros>
