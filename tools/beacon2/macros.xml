<macros>
    <token name="@TOOL_VERSION@">2.1.2</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">21.05</token>

    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">beacon2-ri-tools</requirement>
        </requirements>
    </xml>

    <xml name="xrefs">
        <xrefs>
            <xref type="bio.tools">ga4gh_beacon</xref>
        </xrefs>
    </xml>

    <xml name="creators">
        <creator>
            <person givenName="Khaled" familyName="Mohamed"/>
        </creator>
    </xml>

    <xml name="stdio">
        <stdio>
            <exit_code range="1:" level="fatal"/>
            <regex match="(?i)(error|exception|traceback)" source="stderr" level="fatal"/>
        </stdio>
    </xml>

    <xml name="version_command">
        <version_command><![CDATA[
python -c "
import importlib.metadata
print(importlib.metadata.version('beacon2-ri-tools'))
" 2>/dev/null || echo 'beacon2-ri-tools'
        ]]></version_command>
    </xml>

    <xml name="dataset_id">
        <param name="dataset_id" type="text" value="test_dataset" label="Dataset identifier" help="Value passed to --datasetId and used to build Beacon identifiers."/>
    </xml>

    <!-- Keep this — used by credential logic -->
    <xml name="database_connection_section">
        <section name="database" title="MongoDB connection" expanded="false">
            <param name="database_host" type="text" value="localhost" label="MongoDB host"/>
            <param name="database_port" type="integer" value="27017" min="1" label="MongoDB port"/>
            <param name="database_name" type="text" value="beacon" label="MongoDB database name"/>
        </section>
    </xml>

    <!-- Single source of truth for all configurable options -->
    <!-- Expanded to cover ALL standard Beacon v2 entity types -->
    <xml name="beacon2_configurable_params">
        <param name="entry_type" type="select" label="Entry type" help="Type of the beacon2 csv metadata entry">
            <option value="individuals">individuals</option>
            <option value="biosamples">biosamples</option>
            <option value="genomicVariations" selected="true">genomicVariations</option>
            <option value="analyses">analyses</option>
            <option value="runs">runs</option>
            <option value="cohorts">cohorts</option>
            <option value="datasets">datasets</option>
            <option value="patients">patients</option>
            <option value="collections">collections</option>
        </param>
        <param name="only_process_reads_with_allele_frequency" type="boolean" truevalue="True" falsevalue="False" checked="true"
               label="Only process reads with allele frequency"/>
        <param name="populations_by_allele_counts" type="boolean" truevalue="True" falsevalue="False" checked="true"
               label="Enable populations by allele counts"/>
        <param name="reference_genome" type="select" label="Reference genome">
            <option value="GRCh37" selected="true">GRCh37</option>
            <option value="GRCh38">GRCh38</option>
            <option value="NCBI36">NCBI36</option>
        </param>
        <param name="case_level_data" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Generate caseLevelData when supported"/>
        <param name="exact_heterozygosity" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Exact heterozygosity"/>
        <param name="num_rows" type="integer" min="0" value="15000000" label="Maximum number of rows or variants to process (0 = unlimited)"/>
        <param name="verbosity" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Verbose logging"/>
        <param name="alleleCounts" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Enable populations by allele counts"/>
        <param name="alleleFrequency" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Enable allele frequency"/>
        <param name="json" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Enable JSON output"/>
        <!-- Full custom override (highest priority) -->
        <param name="custom_conf_py" type="data" format="txt" optional="true" label="Custom conf.py (overrides ALL settings above)" help="Upload your own optimized conf/conf.py file for complete control"/>
    </xml>

    <!-- Modern advanced section that uses the single source of truth -->
    <xml name="advanced_section">
        <section name="advanced" title="Advanced configuration" expanded="false">
            <expand macro="beacon2_configurable_params"/>
            <expand macro="database_connection_section"/>
        </section>
    </xml>

    <!-- Unified config tokens (no more duplication) -->
    <token name="@BEACON2_CONF_BASE_ADVANCED@"><![CDATA[# Auto-generated by the Galaxy wrapper.

csv_folder = '.'
output_docs_folder = '.'
entry_type = '${advanced.entry_type}'
only_process_reads_with_allele_frequency = ${advanced.only_process_reads_with_allele_frequency}
populations_by_allele_counts = ${advanced.populations_by_allele_counts}
reference_genome = '${advanced.reference_genome}'
datasetId = '${dataset_id}'
case_level_data = ${advanced.case_level_data}
exact_heterozygosity = ${advanced.exact_heterozygosity}
num_rows = ${advanced.num_rows}
verbosity = ${advanced.verbosity}

# ── Credentials from Galaxy server config (UNTOUCHED) ──
database_host = '${advanced.database.database_host}'
database_port = ${advanced.database.database_port}
database_name = '${advanced.database.database_name}'
    ]]></token>

    <token name="@BEACON2_CONF_BASE_DBONLY@"><![CDATA[# Auto-generated by the Galaxy wrapper (credentials from your Galaxy server config).

csv_folder = './csv'
output_docs_folder = './out/'
entry_type = '$entry_type'
only_process_reads_with_allele_frequency = $only_process_reads_with_allele_frequency
populations_by_allele_counts = $populations_by_allele_counts
reference_genome = '$reference_genome'
case_level_data = $case_level_data
exact_heterozygosity = $exact_heterozygosity
num_rows = $num_rows
verbosity = $verbosity

# ── Credentials from Galaxy server config (UNTOUCHED) ──
database_host = '${database.database_host}'
database_port = ${database.database_port}
database_name = '${database.database_name}'
]]></token>

    <!-- Updated runtime setup with full custom conf.py support -->
    <token name="@BEACON2_RUNTIME_SETUP@"><![CDATA[
export LC_ALL=C.UTF-8 && export LANG=C.UTF-8 &&
mkdir -p conf
    ]]></token>

    <xml name="json_output">
        <data name="out_json" format="json" from_work_dir="out/@OUTPUT_NAME@"
              label="${tool.name} on ${on_string}: @OUTPUT_NAME@"/>
        <data name="log" format="txt" from_work_dir="output.log"
              label="${tool.name} on ${on_string}: execution log"/>
    </xml>

    <xml name="collection_output">
        <collection name="out_collection" type="list" label="${tool.name} on ${on_string}: Beacon JSON files">
            <discover_datasets pattern="(?P&lt;designation&gt;.+)\.json" directory="out" format="json"/>
        </collection>
        <data name="log" format="txt" from_work_dir="output.log"
              label="${tool.name} on ${on_string}: execution log"/>
    </xml>

    <xml name="log_output">
        <data name="log" format="txt" from_work_dir="output.log"
              label="${tool.name} on ${on_string}: execution log"/>
    </xml>

    <xml name="citations">
        <citations>
            <citation type="doi">10.1093/bioinformatics/btac568</citation>
            <citation type="bibtex"><![CDATA[
@misc{beacon2_ri_tools_v2,
  author = {{EGA Archive}},
  title = {Beacon2 RI Tools v2},
  year = {2026},
  url = {https://github.com/EGA-archive/beacon2-ri-tools-v2}
}
            ]]></citation>
        </citations>
    </xml>

    <xml name="beacon_credentials_configfile">
        <configfiles>
            <configfile name="credentials"><![CDATA[
#set $db_auth_source = $__user__.extra_preferences.get('beacon2_account|db_auth_source', "")
#set $db_user = $__user__.extra_preferences.get('beacon2_account|db_user', "")
#set $db_password = $__user__.extra_preferences.get('beacon2_account|db_password', "")
#if $db_user == "" or $db_password == "" or $db_auth_source == "":
    #set $db_auth_source = "admin"
    #set $db_user = "root"
    #set $db_password = "example"
#end if
{
    "db_auth_source": "$db_auth_source",
    "db_user": "$db_user",
    "db_password": "$db_password"
}
            ]]></configfile>
        </configfiles>
    </xml>
</macros>
