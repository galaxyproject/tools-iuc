<tool id="beacon2_genomic_variations_postprocessing" name="Beacon2 genomicVariations postprocessing" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>add caseLevelData or variantLevelData to existing Beacon genomic variations</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="stdio"/>
    <expand macro="version_command"/>
    <expand macro="beacon_credentials_configfile"/>
    <configfiles>
        <configfile name="conf_py"><![CDATA[
@BEACON2_CONF_BASE_ADVANCED@
record_type = 'genomicVariation'
collection_name = 'genomicVariations'
        ]]></configfile>
    </configfiles>
    <command detect_errors="exit_code"><![CDATA[
@BEACON2_RUNTIME_SETUP@ &&
python ./beacon2_runtime/genomicVariations_postprocessing.py \
    --input '$input_csv' \
    --datasetId '${dataset_id}' \
    > output.log 2>&1
    ]]></command>
    <inputs>
        <param name="input_csv" type="data" format="csv" label="genomicVariations CSV for postprocessing"/>
        <expand macro="dataset_id"/>
        <expand macro="advanced_section"/>
    </inputs>
    <outputs>
        <expand macro="log_output"/>
    </outputs>
    <help><![CDATA[
Post-process genomic variations already loaded in Beacon MongoDB. Credentials are
read from Galaxy secret user preferences.
    ]]></help>
    <expand macro="citations"/>
</tool>
