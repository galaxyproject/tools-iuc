<tool id="beacon2_update_record" name="Beacon2 update record" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>update one or more Beacon records in MongoDB from JSON</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="stdio"/>
    <expand macro="version_command"/>

    <command detect_errors="exit_code"><![CDATA[
@BEACON2_RUNTIME_SETUP@ &&
python ./beacon2_runtime/update_record.py \
    --file '$input_json' \
    --recordType '${record.record_type}' \
    --collection '${record.collection_name}' \
    > output.log 2>&1
    ]]></command>

    <!-- SINGLE <configfiles> SECTION (required by Galaxy XSD) -->
    <configfiles>
        <!-- Tool-specific conf.py -->
        <configfile name="conf_py"><![CDATA[
@BEACON2_CONF_BASE_ADVANCED@
# Tool-specific settings for update_record
datasetId = '${dataset_id}'
record_type = '${record.record_type}'
collection_name = '${record.collection_name}'
        ]]></configfile>

        <!-- Credentials from user preferences -->
        <configfile name="credentials"><![CDATA[
#set $db_auth_source = $__user__.extra_preferences.get('beacon2_account|db_auth_source', "")
#set $db_user = $__user__.extra_preferences.get('beacon2_account|db_user', "")
#set $db_password = $__user__.extra_preferences.get('beacon2_account|db_password', "")
#if $db_user == "" or $db_password == "" or $db_auth_source == "":
    #set $db_auth_source = "admin"
    #set $db_user = "root"
    #set $db_password = "example"
#end if
{
    "db_auth_source": "$db_auth_source",
    "db_user": "$db_user",
    "db_password": "$db_password"
}
        ]]></configfile>
    </configfiles>

    <inputs>
        <param name="input_json" type="data" format="json" label="Input Beacon JSON record or list of records"/>

        <expand macro="dataset_id"/>

        <!-- Record type → collection mapping (tool-specific) -->
        <conditional name="record">
            <param name="record_type" type="select" label="Record type to validate and update">
                <option value="genomicVariation" selected="true">genomicVariation</option>
                <option value="analysis">analysis</option>
                <option value="biosample">biosample</option>
                <option value="cohort">cohort</option>
                <option value="dataset">dataset</option>
                <option value="individual">individual</option>
                <option value="run">run</option>
            </param>
            <when value="genomicVariation"><param name="collection_name" type="hidden" value="genomicVariations"/></when>
            <when value="analysis"><param name="collection_name" type="hidden" value="analyses"/></when>
            <when value="biosample"><param name="collection_name" type="hidden" value="biosamples"/></when>
            <when value="cohort"><param name="collection_name" type="hidden" value="cohorts"/></when>
            <when value="dataset"><param name="collection_name" type="hidden" value="datasets"/></when>
            <when value="individual"><param name="collection_name" type="hidden" value="individuals"/></when>
            <when value="run"><param name="collection_name" type="hidden" value="runs"/></when>
        </conditional>

        <!-- Full advanced configuration (single source of truth + custom conf.py support) -->
        <!-- Most advanced options are ignored by this tool, but this keeps full consistency across the suite -->
        <expand macro="advanced_section"/>
    </inputs>

    <outputs>
        <expand macro="log_output"/>
    </outputs>

    <tests>
        <test>
            <param name="input_json" value="test-data/individuals.json" />
            <param name="dataset_id" value="test_dataset" />
            <!-- record type selection (required by the conditional) -->
            <param name="record|record_type" value="individual" />
            <!-- entry_type for the unified config system -->
            <param name="advanced|entry_type" value="individuals" />

            <!-- Minimal test: checks that the update script runs without crashing -->
            <!-- (actual DB update testing would require a running MongoDB with test data) -->
            <output name="log" compare="contains">
                <assert_contents>
                    <has_text text="update" />
                    <has_text text="record" />
                    <has_text text="completed" />
                    <has_text text="success" />
                </assert_contents>
            </output>
        </test>
    </tests>

    <help><![CDATA[
**Beacon2 update record**

Updates (or inserts) one or more Beacon records directly into MongoDB from a JSON file.

The input JSON can contain:
- A single Beacon record, or
- A list of records (`[ {…}, {…} ]`)

**Features**
- Automatically maps the selected **Record type** to the correct MongoDB collection
- Validates against the Beacon schema (via the underlying Python tool)
- Full support for the new unified configuration system

**New features you can now control (Advanced section):**
- Entry type, reference genome, maximum rows
- Case-level data, allele frequency & population settings
- Exact heterozygosity, verbosity
- **Custom `conf.py`** (upload your own file for complete control — highest priority)

MongoDB credentials are read automatically from your Galaxy user preferences (or fall back to Docker Compose defaults).
    ]]></help>
    <expand macro="citations"/>
</tool>