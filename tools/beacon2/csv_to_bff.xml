<tool id="beacon2_csv_to_bff" name="Beacon2 CSV to BFF" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>convert Beacon CSV sheets to Beacon Friendly Format JSON</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="stdio"/>
    <expand macro="version_command"/>
    <expand macro="beacon_credentials_configfile"/>
    <configfiles>
        <configfile name="conf_py"><![CDATA[
@BEACON2_CONF_BASE_ADVANCED@
record_type = 'genomicVariation'
collection_name = 'genomicVariations'
        ]]></configfile>
    </configfiles>
    <command detect_errors="exit_code"><![CDATA[
@BEACON2_RUNTIME_SETUP@ &&
python ./beacon2_runtime/csv_to_bff.py \
    --input '$input_csv' \
    --output ./out \
    --datasetId '${dataset_id}' \
    --entry_type '${entry_type}' \
    > output.log 2>&1
    ]]></command>
    <inputs>
        <param name="input_csv" type="data" format="csv" label="Input CSV file"/>
        <expand macro="dataset_id"/>
        <param name="entry_type" type="select" label="Entry type to generate">
            <option value="analyses">analyses</option>
            <option value="biosamples">biosamples</option>
            <option value="cohorts">cohorts</option>
            <option value="datasets">datasets</option>
            <option value="genomicVariations">genomicVariations</option>
            <option value="individuals">individuals</option>
            <option value="runs">runs</option>
            <option value="EUCAIM/collections">EUCAIM/collections</option>
            <option value="EUCAIM/imageStudies">EUCAIM/imageStudies</option>
            <option value="EUCAIM/patients">EUCAIM/patients</option>
            <option value="all">all</option>
        </param>
        <expand macro="advanced_section"/>
    </inputs>
    <outputs>
        <expand macro="collection_output"/>
    </outputs>
    <help><![CDATA[
Convert a Beacon CSV sheet into Beacon Friendly Format JSON.

MongoDB credentials are read from the Galaxy user preferences under the
``beacon2_account`` secret keys. Host, port, and database name stay as normal
wrapper parameters.
    ]]></help>
    <expand macro="citations"/>
</tool>
