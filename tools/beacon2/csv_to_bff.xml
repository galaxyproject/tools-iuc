<tool id="beacon2_csv_to_bff" name="Beacon2 CSV to BFF" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>convert Beacon CSV sheets to Beacon Friendly Format JSON</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="stdio"/>
    <expand macro="version_command"/>
    <expand macro="beacon_credentials_configfile"/>

    <configfiles>
        <configfile name="conf_py"><![CDATA[
@BEACON2_CONF_BASE_ADVANCED@

# Tool-specific settings for csv_to_bff
record_type = 'genomicVariation'
collection_name = 'genomicVariations'
        ]]></configfile>
    </configfiles>

    <command detect_errors="exit_code"><![CDATA[
@BEACON2_RUNTIME_SETUP@ &&
python ./beacon2_runtime/csv_to_bff.py \
    --input '$input_csv' \
    --output ./out \
    --datasetId '${dataset_id}' \
    --entry_type '${advanced.entry_type}' \
    > output.log 2>&1
    ]]></command>

    <inputs>
        <param name="input_csv" type="data" format="csv" label="Input CSV file"/>
        <expand macro="dataset_id"/>
        <!-- Single clean advanced section (no more duplicate entry_type) -->
        <expand macro="advanced_section"/>
    </inputs>

    <outputs>
        <expand macro="collection_output"/>
    </outputs>

    <tests>
        <test>
            <param name="input_csv" value="test-data/individuals.csv" />
            <!-- entry_type is now inside the advanced section -->
            <param name="advanced|entry_type" value="individuals" />
            <output_collection type="list" name="out_collection" count="1">
                <element name="individuals" file="test-data/individuals.json" ftype="json" />
            </output_collection>
            <output name="log" compare="contains">
                <assert_contents>
                    <has_text text="BFF conversion completed" />
                </assert_contents>
            </output>
        </test>
    </tests>

    <help><![CDATA[
**Beacon2 CSV to BFF**

Converts Beacon CSV files (individuals, biosamples, genomicVariations, analyses, cohorts, etc.) into Beacon Friendly Format (BFF) JSON.

**New features you can now control:**
- Entry type (including EUCAIM options)
- Reference genome
- Maximum rows to process
- Allele frequency & population settings
- Verbose logging

For complete control, use the **"Custom conf.py"** option at the bottom of Advanced configuration.
    ]]></help>
    <expand macro="citations"/>
</tool>