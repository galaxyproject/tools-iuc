<tool id="beacon2_individuals_to_cohorts_csv" name="Beacon2 individuals to cohorts CSV" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>derive cohorts JSON from an individuals CSV sheet</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="stdio"/>
    <expand macro="version_command"/>

    <command detect_errors="exit_code"><![CDATA[
@BEACON2_RUNTIME_SETUP@ &&
python ./beacon2_runtime/individuals_to_cohorts_csv.py \
    --input '$input_csv' \
    --output ./out \
    --datasetId '${dataset_id}' \
    --cohortId '${cohort_id}' \
    --cohortName '${cohort_name}' \
    --cohortType '${cohort_type}' \
    > output.log 2>&1
    ]]></command>

    <!-- SINGLE <configfiles> SECTION (required by Galaxy XSD) -->
    <configfiles>
        <!-- Tool-specific conf.py -->
        <configfile name="conf_py"><![CDATA[
@BEACON2_CONF_BASE_ADVANCED@

# Tool-specific settings for individuals_to_cohorts_csv
record_type = 'cohort'
collection_name = 'cohorts'
        ]]></configfile>

        <!-- Credentials from user preferences -->
        <configfile name="credentials"><![CDATA[
#set $db_auth_source = $__user__.extra_preferences.get('beacon2_account|db_auth_source', "")
#set $db_user = $__user__.extra_preferences.get('beacon2_account|db_user', "")
#set $db_password = $__user__.extra_preferences.get('beacon2_account|db_password', "")
#if $db_user == "" or $db_password == "" or $db_auth_source == "":
    #set $db_auth_source = "admin"
    #set $db_user = "root"
    #set $db_password = "example"
#end if
{
    "db_auth_source": "$db_auth_source",
    "db_user": "$db_user",
    "db_password": "$db_password"
}
        ]]></configfile>
    </configfiles>

    <inputs>
        <param name="input_csv" type="data" format="csv" label="Individuals CSV input"/>
        <expand macro="dataset_id"/>

        <param name="cohort_id"   type="text" value="cohortId"   label="Column name used as cohort identifier"/>
        <param name="cohort_name" type="text" value="cohortName" label="Column name used as cohort name"/>
        <param name="cohort_type" type="text" value="user-defined" label="Cohort type"/>

        <!-- Full advanced configuration (single source of truth + custom conf.py support) -->
        <expand macro="advanced_section"/>
    </inputs>

    <outputs>
        <data name="out_json" format="json" from_work_dir="out/cohorts.json"
              label="${tool.name} on ${on_string}: cohorts.json"/>
        <data name="log" format="txt" from_work_dir="output.log"
              label="${tool.name} on ${on_string}: execution log"/>
    </outputs>

    <tests>
        <test>
            <param name="input_csv" value="test-data/individuals.csv" />
            <param name="dataset_id" value="test_dataset" />
            <param name="cohort_id" value="cohortId" />
            <param name="cohort_name" value="cohortName" />
            <param name="cohort_type" value="user-defined" />
            <!-- entry_type is set for consistency with other tools (used by conf.py) -->
            <param name="advanced|entry_type" value="individuals" />

            <!-- The tool always produces ONE cohort that aggregates ALL individuals -->
            <!-- It computes distributions (age, sex, diseases, phenotypes, etc.) -->
            <output name="out_json" ftype="json">
                <assert_contents>
                    <has_text text="collectionEvents" />
                    <has_text text="eventSize" />
                    <!-- Optional: check for specific distribution keys that the script always generates -->
                    <has_text text="eventGenders" />
                    <has_text text="eventDiseases" />
                </assert_contents>
            </output>

            <output name="log" compare="contains">
                <assert_contents>
                    <has_text text="cohort" />
                    <has_text text="completed" />
                    <not_has_text text="No registries found" />
                </assert_contents>
            </output>
        </test>
    </tests>

    <help><![CDATA[
**Beacon2 individuals to cohorts CSV**

Derives a Beacon Friendly Format (`cohorts.json`) file by aggregating **all individuals** from an `individuals.csv` sheet into a **single cohort**.

The tool automatically calculates rich summary statistics inside `collectionEvents`:
- `eventSize` (total number of individuals)
- Distributions for age ranges, genders, ethnicities, diseases, phenotypes, geographic origin, etc.

**New features you can now control (Advanced section):**
- Entry type, reference genome, maximum rows
- Verbose logging
- **Custom `conf.py`** (upload your own file for complete control — highest priority)

MongoDB credentials are read automatically from your Galaxy user preferences.
    ]]></help>
    <expand macro="citations"/>
</tool>