<tool id="beacon2_individuals_to_cohorts_csv" name="Beacon2 individuals to cohorts CSV" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>derive cohorts JSON from an individuals CSV sheet</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="stdio"/>
    <expand macro="version_command"/>
    <expand macro="beacon_credentials_configfile"/>
    <configfiles>
        <configfile name="conf_py"><![CDATA[
@BEACON2_CONF_BASE_ADVANCED@
record_type = 'cohort'
collection_name = 'cohorts'
        ]]></configfile>
    </configfiles>
    <command detect_errors="exit_code"><![CDATA[
@BEACON2_RUNTIME_SETUP@ &&
python ./beacon2_runtime/individuals_to_cohorts_csv.py \
    --input '$input_csv' \
    --output ./out \
    --datasetId '${dataset_id}' \
    --cohortId '${cohort_id}' \
    --cohortName '${cohort_name}' \
    --cohortType '${cohort_type}' \
    > output.log 2>&1
    ]]></command>
    <inputs>
        <param name="input_csv" type="data" format="csv" label="Individuals CSV input"/>
        <expand macro="dataset_id"/>
        <param name="cohort_id" type="text" value="cohortId" label="Column name used as cohort identifier"/>
        <param name="cohort_name" type="text" value="cohortName" label="Column name used as cohort name"/>
        <param name="cohort_type" type="text" value="user-defined" label="Cohort type"/>
        <expand macro="advanced_section"/>
    </inputs>
    <outputs>
        <data name="out_json" format="json" from_work_dir="out/cohorts.json" label="${tool.name} on ${on_string}: cohorts.json"/>
        <data name="log" format="txt" from_work_dir="output.log" label="${tool.name} on ${on_string}: execution log"/>
    </outputs>
    <help><![CDATA[
Build cohorts JSON from an individuals CSV sheet. MongoDB credentials are taken
from Galaxy secret user preferences.
    ]]></help>
    <expand macro="citations"/>
</tool>
