<tool id="beacon2_genomic_variations_vcf" name="Beacon2 genomicVariations from VCF" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>convert annotated VCF to Beacon genomicVariations JSON</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="stdio"/>
    <expand macro="version_command"/>
    <expand macro="beacon_credentials_configfile"/>
    <configfiles>
        <configfile name="conf_py"><![CDATA[
@BEACON2_CONF_BASE_ADVANCED@
record_type = 'genomicVariation'
collection_name = 'genomicVariations'
        ]]></configfile>
    </configfiles>
    <command detect_errors="exit_code"><![CDATA[
@BEACON2_RUNTIME_SETUP@ &&
python ./beacon2_runtime/genomicVariations_vcf.py \
    --input '$input_vcf' \
    --output ./out/ \
    --datasetId '${dataset_id}' \
    --refGen '${advanced.reference_genome}' \
    --numRows ${advanced.num_rows} \
    --json \
    #if str($advanced.case_level_data) == 'True'
    --caseLevelData \
    #else
    --no-caseLevelData \
    #end if
    #if str($advanced.verbosity) == 'True'
    --verbosity \
    #else
    --no-verbosity \
    #end if
    #if str($advanced.populations_by_allele_counts) == 'True'
    --alleleCounts \
    #else
    --no-alleleCounts \
    #end if
    #if str($advanced.only_process_reads_with_allele_frequency) == 'True'
    --alleleFrequency \
    #else
    --no-alleleFrequency \
    #end if
    > output.log 2>&1
    ]]></command>
    <inputs>
        <param name="input_vcf" type="data" format="vcf,vcf_bgzip,vcf.gz" label="Annotated VCF input"/>
        <expand macro="dataset_id"/>
        <expand macro="advanced_section"/>
    </inputs>
    <outputs>
        <data name="out_json" format="json" from_work_dir="out/genomicVariations.json" label="${tool.name} on ${on_string}: genomicVariations.json"/>
        <data name="case_level_json" format="json" from_work_dir="out/caseLevelData.json" label="${tool.name} on ${on_string}: caseLevelData.json" optional="true">
            <filter>advanced['case_level_data']</filter>
        </data>
        <data name="targets_json" format="json" from_work_dir="out/targets.json" label="${tool.name} on ${on_string}: targets.json" optional="true"/>
        <data name="log" format="txt" from_work_dir="output.log" label="${tool.name} on ${on_string}: execution log"/>
    </outputs>
    <tests>
        <test>
            <param name="input_vcf" value="test-data/test.vcf.gz" />
            <param name="datasetId" value="test_dataset" />
            <!-- enable caseLevelData if you want to test the optional output -->
            <param name="advanced|caseLevelData" value="true" />
            <output name="output_json" file="test-data/genomicVariationsVcf.json" ftype="json" />
            <output name="caseLevelData" file="test-data/some_expected_caseLevelData.json" ftype="json" />  <!-- if you add a test file -->
            <output name="log" compare="contains">
            <assert_contents>
                <has_text text="VCF processing completed" />
            </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
Convert an annotated VCF into Beacon genomicVariations JSON. MongoDB credentials
are taken from Galaxy secret user preferences instead of normal text inputs.
    ]]></help>
    <expand macro="citations"/>
</tool>