<tool id="beacon2_genomic_variations_vcf" name="Beacon2 genomicVariations from VCF" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>convert annotated VCF to Beacon genomicVariations JSON</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="stdio"/>
    <expand macro="version_command"/>

    <command detect_errors="exit_code"><![CDATA[
@BEACON2_RUNTIME_SETUP@ &&
python ./beacon2_runtime/genomicVariations_vcf.py \
    --input '$input_vcf' \
    --output ./out/ \
    --datasetId '${dataset_id}' \
    --refGen '${advanced.reference_genome}' \
    --numRows ${advanced.num_rows} \
    --json \
    #if str($advanced.case_level_data) == 'True'
    --caseLevelData \
    #else
    --no-caseLevelData \
    #end if
    #if str($advanced.verbosity) == 'True'
    --verbosity \
    #else
    --no-verbosity \
    #end if
    #if str($advanced.populations_by_allele_counts) == 'True'
    --alleleCounts \
    #else
    --no-alleleCounts \
    #end if
    #if str($advanced.only_process_reads_with_allele_frequency) == 'True'
    --alleleFrequency \
    #else
    --no-alleleFrequency \
    #end if
    > output.log 2>&1
    ]]></command>

    <!-- SINGLE <configfiles> SECTION -->
    <configfiles>
        <!-- Tool-specific conf.py – HARD-CODED for this single-purpose tool -->
        <configfile name="conf_py"><![CDATA[
@BEACON2_CONF_BASE_ADVANCED@

# Tool-specific settings for genomicVariations_vcf
# This tool ONLY produces genomicVariations
entry_type = 'genomicVariations'
record_type = 'genomicVariation'
collection_name = 'genomicVariations'
        ]]></configfile>

        <!-- Credentials from user preferences -->
        <configfile name="credentials"><![CDATA[
#set $db_auth_source = $__user__.extra_preferences.get('beacon2_account|db_auth_source', "")
#set $db_user = $__user__.extra_preferences.get('beacon2_account|db_user', "")
#set $db_password = $__user__.extra_preferences.get('beacon2_account|db_password', "")
#if $db_user == "" or $db_password == "" or $db_auth_source == "":
    #set $db_auth_source = "admin"
    #set $db_user = "root"
    #set $db_password = "example"
#end if
{
    "db_auth_source": "$db_auth_source",
    "db_user": "$db_user",
    "db_password": "$db_password"
}
        ]]></configfile>
    </configfiles>

    <inputs>
        <param name="input_vcf" type="data" format="vcf,vcf_bgzip" label="Annotated VCF input"/>
        <expand macro="dataset_id"/>
        <expand macro="advanced_section"/>
    </inputs>

    <outputs>
        <data name="out_json" format="json" from_work_dir="out/genomicVariations.json" label="${tool.name} on ${on_string}: genomicVariations.json"/>
        <data name="case_level_json" format="json" from_work_dir="out/caseLevelData.json" label="${tool.name} on ${on_string}: caseLevelData.json">
            <filter>advanced['case_level_data']</filter>
        </data>
        <data name="targets_json" format="json" from_work_dir="out/targets.json" label="${tool.name} on ${on_string}: targets.json"/>
        <data name="log" format="txt" from_work_dir="output.log" label="${tool.name} on ${on_string}: execution log"/>
    </outputs>

    <tests>
        <test expect_num_outputs="4">
            <param name="input_vcf" value="test-data/test.vcf.gz" />
            <param name="dataset_id" value="test_dataset" />
            <!-- enable caseLevelData if you want to test the optional output -->
            <param name="advanced|case_level_data" value="true" />
            <output name="out_json" file="test-data/genomicVariationsVcf.json" ftype="json" />
            <output name="case_level_json" file="test-data/some_expected_caseLevelData.json" ftype="json" />
            <output name="log" compare="contains">
                <assert_contents>
                    <has_text text="VCF processing completed" />
                </assert_contents>
            </output>
        </test>
    </tests>

    <help><![CDATA[
Convert an annotated VCF into Beacon genomicVariations JSON. MongoDB credentials
are taken from Galaxy secret user preferences instead of normal text inputs.
    ]]></help>
    <expand macro="citations"/>
</tool>