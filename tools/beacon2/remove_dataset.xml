<tool id="beacon2_remove_dataset" name="Beacon2 remove dataset" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>remove all records for one dataset from MongoDB</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="stdio"/>
    <expand macro="version_command"/>
    <expand macro="beacon_credentials_configfile"/>
    <configfiles>
        <configfile name="conf_py"><![CDATA[
@BEACON2_CONF_BASE_DBONLY@
datasetId = '${dataset_id}'
record_type = 'genomicVariation'
collection_name = 'genomicVariations'
        ]]></configfile>
    </configfiles>
    <command detect_errors="exit_code"><![CDATA[
@BEACON2_RUNTIME_SETUP@ &&
python ./beacon2_runtime/remove_dataset.py \
    --datasetId '${dataset_id}' \
    > output.log 2>&1
    ]]></command>
    <inputs>
        <expand macro="dataset_id"/>
        <expand macro="database_connection_section"/>
    </inputs>
    <outputs>
        <expand macro="log_output"/>
    </outputs>
    <help><![CDATA[
Remove all Beacon records for one dataset from MongoDB. Credentials are read
from Galaxy secret user preferences.
    ]]></help>
    <expand macro="citations"/>
</tool>
