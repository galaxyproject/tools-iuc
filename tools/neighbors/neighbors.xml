<tool id="neighbors" name="Neighbors" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@" license="GPL-3.0-or-later">
    <description>identify target and neighbor genomes for marker discovery</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <version_command>neighbors -v</version_command>
    <command detect_errors="aggressive"><![CDATA[
        #if $db_source.db_source == "cached":
            ln -s '${db_source.db_table.fields.path}' db.sqlite &&
        #else:
            ln -s '${db_source.db_file}' db.sqlite &&
        #end if
        printf '%s\n' '$taxids' | tr ',' '\n' > targets.txt &&
        neighbors
            -l
            $genome_sequences_only
            db.sqlite
            targets.txt |
        sed -E 's/[[:space:]]+/\t/g' > output.tsv
    ]]></command>
    <inputs>
        <conditional name="db_source">
            <param name="db_source" type="select" label="Neighbors database source">
                <option value="cached" selected="true">Use installed database</option>
                <option value="history">Use a database from history</option>
            </param>
            <when value="cached">
                <param name="db_table" type="select" label="Neighbors database">
                    <options from_data_table="marker_discovery_neighbors_db">
                        <filter type="static_value" value="1" column="version"/>
                        <filter type="sort_by" column="1" />
                        <validator type="no_options" message="No Neighbors database is available" />
                    </options>
                </param>
            </when>
            <when value="history">
                <param name="db_file" type="data" format="sqlite" label="Neighbors database" help="SQLite taxonomy database built with makeNeiDb"/>
            </when>
        </conditional>
        <param name="taxids" type="text" value="2" label="Target taxon IDs" help="Comma-separated taxon IDs, for example 9606 or 9606,9605">
            <validator type="regex" message="Use comma-separated integers only">^[0-9]+(,[0-9]+)*$</validator>
        </param>
        <section name="output_options" title="Output options" expanded="false">
            <param name="genome_sequences_only" argument="-g" type="boolean" truevalue="-g" falsevalue="" checked="false" label="Show only taxa with genomes" />
        </section>
    </inputs>
    <outputs>
        <data name="output" format="tabular" from_work_dir="output.tsv" label="${tool.name} on ${on_string}: neighbors">
            <actions>
                <action type="metadata" name="column_names" default="Sample,Accession" />
            </actions>
        </data>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <conditional name="db_source">
                <param name="db_source" value="cached"/>
                <param name="db_table" value="sample"/>
            </conditional>
            <param name="taxids" value="2"/>
            <output name="output" file="expected.tsv">
                <metadata name="column_names" value="Sample,Accession"/>
            </output>
        </test>
        <test expect_num_outputs="1">
            <conditional name="db_source">
                <param name="db_source" value="history"/>
                <param name="db_file" value="test.db"/>
            </conditional>
            <param name="taxids" value="2"/>
            <section name="output_options">
                <param name="genome_sequences_only" value="true"/>
            </section>
            <output name="output">
                <metadata name="column_names" value="Sample,Accession"/>
                <assert_contents>
                    <has_line_matching expression="^t\tACC000002\.1$"/>
                    <has_line_matching expression="^n\tACC000003\.1$"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help format="markdown"><![CDATA[
Neighbors
=========

Identify target and neighbor genomes for marker discovery.

**Input**

- A Neighbors SQLite database built with ``makeNeiDb``.
- The database can be selected from an installed location table or uploaded from history.
- A comma-separated list of target taxon IDs.

**Output**

- A tab-delimited report on stdout.
- The output dataset stores the column names as Galaxy metadata and lists the target and neighbor taxa with genome accessions.

-----

This wrapper supports both installed database locations and history-uploaded SQLite databases.
    ]]></help>
    <expand macro="citations"/>
</tool>
