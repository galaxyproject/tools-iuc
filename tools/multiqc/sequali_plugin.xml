<macros>
    <token name="@SEQUALI_COMMAND@"><![CDATA[
        #set $pattern = '"sequali_version"'
        #set $prefix = ""
        #set $suffix = ".json"
        @LN_FILES@
    ]]></token>
    <xml name="sequali_form">
        <param name="input" type="data" format="json" multiple="true" label="JSON output of Sequali" help="It should be the JSON report from Sequali containing 'sequali_version'" optional="true"/>
    </xml>
    <xml name="sequali_test">
        <test expect_num_outputs="2">
            <repeat name="results">
                <conditional name="software_cond">
                    <param name="software" value="sequali"/>
                    <param name="input" value="sequali.json"/>
                </conditional>
            </repeat>
            <param name="title" value="Title of the report"/>
            <param name="comment" value="Commment for the report"/>
            <output name="html_report">
                <assert_contents>
                    <has_text text="Title of the report"/>
                    <has_text text="Commment for the report"/>
                    <has_text text="Average GC content %"/>
                </assert_contents>
            </output>
            <output name="stats">
                <assert_contents>
                    <has_text text="sequali-"/>
                    <has_n_lines n="2"/>
                    <has_text text="sequali_json&#9;35.974605693879575&#9;101.0&#9;101&#9;0.0005&#9;0.050499999999999996&#9;1.6000000000000014&#9;31.524"/>
                </assert_contents>
            </output>
        </test>
    </xml>
</macros>
