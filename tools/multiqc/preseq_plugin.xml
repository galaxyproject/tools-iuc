<macros>
    <token name="@PRESEQ_COMMAND@"><![CDATA[
        #set $pattern = ""
        #set $prefix = ""
        #set $suffix = ".ccurve.txt"
        @LN_FILES@
    ]]></token>
    
    <xml name="preseq_form">
        <param name="input" type="data" format="tabular,txt,tsv" multiple="true" label="Output of Preseq"/>
    </xml>
	
    <xml name="preseq_test">
        <test expect_num_outputs="3">
            <repeat name="results">
                <conditional name="software_cond">
                    <param name="software" value="preseq"/>
                    <param name="input" value="preseq with space.tsv"/>
                </conditional>
            </repeat>
            <param name="title" value="Test Report"/>
            <param name="export" value="true"/>
            <output name="html_report">
                <assert_contents>
                    <has_text text="Preseq"/>
                </assert_contents>
            </output>
        </test>
    </xml>
</macros>