<macros>
    <token name="@ADAPTERREMOVAL_COMMAND@"><![CDATA[
        #set $pattern = "AdapterRemoval ver"
        #set $prefix = ""
        #set $suffix = ".settings"
        @LN_FILES@
    ]]></token>
    
    <xml name="adapterremoval_form">
        <param name="input" type="data" format="txt,tabular" multiple="true" label="Output settings of AdapterRemoval" optional="true"/>
    </xml>
    
    <xml name="adapterremoval_test">
        <test expect_num_outputs="3">
            <repeat name="results">
                <conditional name="software_cond">
                    <param name="software" value="adapterremoval"/>
                    <param name="input" value="adapterremoval.txt"/>
                </conditional>
            </repeat>
            <param name="title" value="Test Report"/>
            <param name="export" value="true"/>
            <output name="html_report">
                <assert_contents>
                    <has_text text="AdapterRemoval"/>
                </assert_contents>
            </output>
        </test>
    </xml>
</macros>