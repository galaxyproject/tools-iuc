<macros>
    <token name="@NANOSTAT_COMMAND@"><![CDATA[
        #set $pattern = "Metrics\s+dataset"
        #set $prefix = ""
        #set $suffix = ""
        @LN_FILES@
    ]]></token>
    <xml name="nanostat_form">
        <param name="input" type="data" format="txt,tabular" multiple="true" label="Output of NanoStat or NanoPlot (NanoStats.txt)" help="It should contain 'Metrics' followed by 'dataset' on the first line" optional="true"/>
    </xml>
    <xml name="nanostat_test">
        <test expect_num_outputs="2">
            <repeat name="results">
                <conditional name="software_cond">
                    <param name="software" value="nanostat"/>
                    <param name="input" value="NanoStats.txt"/>
                </conditional>
            </repeat>
            <param name="title" value="Title of the report"/>
            <param name="comment" value="Commment for the report"/>
            <output name="html_report">
                <assert_contents>
                    <has_text text="Title of the report"/>
                    <has_text text="Commment for the report"/>
                    <has_text text="NanoStat"/>
                    <has_text text="General Statistics: Columns"/>
                </assert_contents>
            </output>
            <output name="stats">
                <assert_contents>
                    <has_text text="nanostat-"/>
                    <has_n_lines n="2"/>
                    <has_text text="NanoStats_txt&#9;169.0&#9;9390.0&#9;23212.6&#9;60395.0&#9;10.3&#9;9.8&#9;0.371&#9;8.611870999999999"/>
                </assert_contents>
            </output>
        </test>
    </xml>
</macros>
