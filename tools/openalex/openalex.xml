<tool id="openalex_explorer" name="OpenAlex explorer" version="0.2.0+galaxy0" profile="23.1">
    <description>Fetch citing papers, references, related works, authors, and concepts from OpenAlex</description>
    <requirements>
        <requirement type="package" version="3.10">python</requirement>
        <requirement type="package" version="2.31.0">requests</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
python3 '$__tool_directory__/openalex_fetch.py'
$input_type '$identifier'
--mode '$mode'
--max-citations '$max_citations'
#if $mode == "citing_papers"
    $download_pdfs
#end if
#if $email
--email '$email'
#end if
]]></command>
    <inputs>
        <param name="input_type" type="select" label="Input type" help="Select whether the identifier is an OpenAlex ID, DOI, or Title">
            <option value="--doi" selected="true">DOI</option>
            <option value="--id">OpenAlex ID</option>
            <option value="--title">Title</option>
        </param>
        <param name="identifier" type="text" label="Identifier" help="Enter the OpenAlex ID, DOI, or Title depending on your selection above"/>
        <param name="mode" type="select" label="What to fetch" help="Select which information to retrieve from OpenAlex">
            <option value="citing_papers" selected="true">Citing papers (papers that cite this work)</option>
            <option value="summary">Summary (citation count, OA status)</option>
            <option value="references">References (works cited by this work)</option>
            <option value="related">Related works (similar papers)</option>
            <option value="authors">Authors (with affiliations and ORCIDs)</option>
            <option value="concepts">Concepts/Topics (research topics and scores)</option>
        </param>
        <param name="download_pdfs" type="boolean" truevalue="--download" falsevalue="" label="Download available OA PDFs?" value="false" help="Only available when fetching citing papers"/>
        <param name="max_citations" type="select" label="Max papers to fetch" help="Limit the number of results">
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50" selected="true">50</option>
            <option value="100">100</option>
            <option value="all">All</option>
        </param>
        <param name="email" type="text" optional="true" label="Email for polite pool" help="Providing your email gives access to the OpenAlex polite pool for faster API access"/>
    </inputs>
    <outputs>
        <data name="summary_out" format="txt" label="Citation Summary">
            <filter>mode == "citing_papers" or mode == "summary"</filter>
            <from_work_dir>summary.txt</from_work_dir>
        </data>
        <data name="tsv_out" format="tabular" label="Citing Papers TSV">
            <filter>mode == "citing_papers" or mode == "summary"</filter>
            <from_work_dir>citing_papers.tsv</from_work_dir>
        </data>
        <data name="references_out" format="tabular" label="Referenced Works TSV">
            <filter>mode == "references"</filter>
            <from_work_dir>referenced_works.tsv</from_work_dir>
        </data>
        <data name="related_out" format="tabular" label="Related Works TSV">
            <filter>mode == "related"</filter>
            <from_work_dir>related_works.tsv</from_work_dir>
        </data>
        <data name="authors_out" format="tabular" label="Authors TSV">
            <filter>mode == "authors"</filter>
            <from_work_dir>authors.tsv</from_work_dir>
        </data>
        <data name="concepts_out" format="tabular" label="Concepts TSV">
            <filter>mode == "concepts"</filter>
            <from_work_dir>concepts.tsv</from_work_dir>
        </data>
        <collection name="pdf_outputs" label="Downloaded PDFs" type="list" format="pdf">
            <filter>mode == "citing_papers" and download_pdfs</filter>
            <discover_datasets pattern="__designation_and_ext__" directory="downloads"/>
        </collection>
    </outputs>
    <tests>
        <test>
            <param name="input_type" value="--id"/>
            <param name="identifier" value="W4398182689"/>
            <param name="mode" value="citing_papers"/>
            <param name="max_citations" value="10"/>
            <param name="download_pdfs" value="false"/>
            <output name="summary_out" file="expected_summary.txt"/>
            <output name="tsv_out" file="expected_citing_papers.tsv"/>
        </test>
        <test>
            <param name="input_type" value="--doi"/>
            <param name="identifier" value="10.1093/nar/gkae410"/>
            <param name="mode" value="citing_papers"/>
            <param name="max_citations" value="50"/>
            <param name="download_pdfs" value="false"/>
            <output name="summary_out" file="expected_summary_doi.txt"/>
            <output name="tsv_out" file="expected_citing_papers_doi.tsv"/>
        </test>
        <test>
            <param name="input_type" value="--title"/>
            <param name="identifier" value="The Galaxy platform for accessible, reproducible, and collaborative data analyses: 2024 update"/>
            <param name="mode" value="citing_papers"/>
            <param name="max_citations" value="50"/>
            <param name="download_pdfs" value="false"/>
            <output name="summary_out" file="expected_summary_title.txt"/>
            <output name="tsv_out" file="expected_citing_papers_title.tsv"/>
        </test>
        <test>
            <param name="input_type" value="--id"/>
            <param name="identifier" value="W2088676066"/>
            <param name="mode" value="citing_papers"/>
            <param name="max_citations" value="10"/>
            <param name="download_pdfs" value="true"/>
            <output name="summary_out" file="expected_summary_wddownload.txt"/>
            <output name="tsv_out" file="expected_citing_papers_wddownload.tsv"/>
            <output_collection name="pdf_outputs" type="list" count="1"/>
        </test>
    </tests>
    <help><![CDATA[
    This tool fetches information from OpenAlex for a paper specified by OpenAlex ID, DOI, or Title.

    **Modes:**

    - **Citing papers**: Fetch papers that cite this work, with OA status and optional PDF download
    - **Summary**: Get citation count, OA status, and basic metadata
    - **References**: Fetch the bibliography (works cited by this paper)
    - **Related works**: Find similar papers based on OpenAlex relevance
    - **Authors**: Get author details with affiliations and ORCIDs
    - **Concepts**: Get research topics/concepts with relevance scores

    **Outputs:**

    - summary.txt / citing_papers.tsv: For citing papers and summary modes
    - referenced_works.tsv: Title, DOI, Year, Is_OA for referenced works
    - related_works.tsv: Title, DOI, Year, Cited_By_Count, Is_OA for related works
    - authors.tsv: Name, ORCID, Affiliation, Country
    - concepts.tsv: Concept, Score, Wikidata_ID
    ]]></help>
    <citations>
        <citation type="doi">10.48550/arXiv.2205.01833</citation>
    </citations>
</tool>