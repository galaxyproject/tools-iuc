<tool id="openalex_explorer" name="OpenAlex explorer" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Fetch works, citations, authors, concepts, and publications from OpenAlex</description>
    <macros>
        <token name="@TOOL_VERSION@">0.3.0</token>
        <token name="@VERSION_SUFFIX@">0</token>
        <token name="@PROFILE@">25.0</token>
    </macros>
    <requirements>
        <requirement type="package" version="3.10">python</requirement>
        <requirement type="package" version="2.31.0">requests</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
python3 '$__tool_directory__/openalex_fetch.py'
--input-entity '$entity.input_entity'
#if str($input_source.source) == 'paste'
    --identifier-file '$pasted_identifiers'
#else
    --identifier-file '$input_source.identifier_file'
#end if
#for $selected_mode in $entity.mode
    --mode '$selected_mode'
#end for
--max-citations '$max_citations'
--open-access '$work_filters.open_access'
#if str($work_filters.publication_year_from)
    --publication-year-from '$work_filters.publication_year_from'
#end if
#if str($work_filters.publication_year_to)
    --publication-year-to '$work_filters.publication_year_to'
#end if
--work-type '$work_filters.work_type'
--sort '$work_filters.sort'
$work_filters.include_xpac
#if str($email) == 'true'
    --email '$__user_email__'
#end if
]]></command>
    <configfiles>
        <configfile name="pasted_identifiers">#if str($input_source.source) == 'paste'
$input_source.identifiers
#end if</configfile>
    </configfiles>
    <inputs>
        <conditional name="entity">
            <param name="input_entity" type="select" label="Input entity" help="Choose whether each input line describes works, authors, or institutions">
                <option value="work" selected="true">Works: OpenAlex work ID, DOI, DOI URL, OpenAlex work URL, or title</option>
                <option value="author">Authors: OpenAlex author ID, OpenAlex author URL, ORCID, ORCID URL, or author name</option>
                <option value="institution">Institutions: ROR ID, ROR URL, OpenAlex institution ID, OpenAlex institution URL, or institution name</option>
            </param>
            <when value="work">
                <param name="mode" type="select" multiple="true" label="What to fetch" help="Select one or more outputs for resolved work inputs">
                    <option value="citing_papers" selected="true">Citing papers</option>
                    <option value="summary">Summary</option>
                    <option value="references">References</option>
                    <option value="related">Related works</option>
                    <option value="authors">Authors</option>
                    <option value="concepts">Concepts/Topics</option>
                    <option value="download_pdfs">Download available OA PDFs</option>
                    <validator type="no_options" message="Select at least one mode"/>
                </param>
            </when>
            <when value="author">
                <param name="mode" type="select" multiple="true" label="What to fetch" help="Fetch publications for resolved author inputs, optionally downloading available Open Access PDFs">
                    <option value="author_works" selected="true">Author works</option>
                    <option value="download_pdfs">Download available OA PDFs from fetched author works</option>
                    <validator type="no_options" message="Select at least one mode"/>
                </param>
            </when>
            <when value="institution">
                <param name="mode" type="select" multiple="true" label="What to fetch" help="Fetch publications for resolved institution inputs, optionally downloading available Open Access PDFs">
                    <option value="institution_works" selected="true">Institution works</option>
                    <option value="download_pdfs">Download available OA PDFs from fetched institution works</option>
                    <validator type="no_options" message="Select at least one mode"/>
                </param>
            </when>
        </conditional>
        <conditional name="input_source">
            <param name="source" type="select" label="Input source">
                <option value="paste" selected="true">Paste identifiers</option>
                <option value="dataset">Use dataset</option>
            </param>
            <when value="paste">
                <param name="identifiers" type="text" area="true" label="Identifiers" help="Enter one identifier, title, author, or institution per line">
                    <sanitizer invalid_char="">
                        <valid initial="default">
                            <add value="&#10;"/>
                            <add value="ä"/>
                            <add value="ö"/>
                            <add value="ü"/>
                            <add value="Ä"/>
                            <add value="Ö"/>
                            <add value="Ü"/>
                            <add value="ß"/>
                            <add value="á"/>
                            <add value="à"/>
                            <add value="â"/>
                            <add value="ã"/>
                            <add value="å"/>
                            <add value="Á"/>
                            <add value="À"/>
                            <add value="Â"/>
                            <add value="Ã"/>
                            <add value="Å"/>
                            <add value="é"/>
                            <add value="è"/>
                            <add value="ê"/>
                            <add value="ë"/>
                            <add value="É"/>
                            <add value="È"/>
                            <add value="Ê"/>
                            <add value="Ë"/>
                            <add value="í"/>
                            <add value="ì"/>
                            <add value="î"/>
                            <add value="ï"/>
                            <add value="Í"/>
                            <add value="Ì"/>
                            <add value="Î"/>
                            <add value="Ï"/>
                            <add value="ó"/>
                            <add value="ò"/>
                            <add value="ô"/>
                            <add value="õ"/>
                            <add value="ø"/>
                            <add value="Ó"/>
                            <add value="Ò"/>
                            <add value="Ô"/>
                            <add value="Õ"/>
                            <add value="Ø"/>
                            <add value="ú"/>
                            <add value="ù"/>
                            <add value="û"/>
                            <add value="Ú"/>
                            <add value="Ù"/>
                            <add value="Û"/>
                            <add value="ç"/>
                            <add value="Ç"/>
                            <add value="ñ"/>
                            <add value="Ñ"/>
                            <add value="ý"/>
                            <add value="ÿ"/>
                            <add value="Ý"/>
                            <add value="Æ"/>
                            <add value="æ"/>
                            <add value="Œ"/>
                            <add value="œ"/>
                        </valid>
                    </sanitizer>
                </param>
            </when>
            <when value="dataset">
                <param name="identifier_file" type="data" format="txt,tabular" label="Identifier dataset" help="Text or tabular dataset; the first column from each non-comment row is used"/>
            </when>
        </conditional>
        <param name="max_citations" type="select" label="Max works to fetch" help="Limit the number of list results per input entity">
            <option value="1">1</option>
            <option value="3">3</option>
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50" selected="true">50</option>
            <option value="100">100</option>
            <option value="all">All</option>
        </param>
        <section name="work_filters" title="Work-list filters" expanded="false">
            <param name="open_access" type="select" label="Open Access filter" help="Filter work-list outputs such as citing, related, referenced, author, and institution works by OpenAlex Open Access status">
                <option value="any" selected="true">Any access status</option>
                <option value="true">Open Access only</option>
                <option value="false">Closed Access only</option>
            </param>
            <param name="publication_year_from" type="integer" optional="true" min="1" max="9999" label="Publication year from" help="Only include works published in or after this year"/>
            <param name="publication_year_to" type="integer" optional="true" min="1" max="9999" label="Publication year to" help="Only include works published in or before this year"/>
            <param name="work_type" type="select" label="Work type" help="Filter work-list outputs by OpenAlex work type">
                <option value="any" selected="true">Any type</option>
                <option value="article">Article</option>
                <option value="book">Book</option>
                <option value="book-chapter">Book chapter</option>
                <option value="dataset">Dataset</option>
                <option value="dissertation">Dissertation</option>
                <option value="editorial">Editorial</option>
                <option value="letter">Letter</option>
                <option value="paratext">Paratext</option>
                <option value="peer-review">Peer review</option>
                <option value="preprint">Preprint</option>
                <option value="reference-entry">Reference entry</option>
                <option value="report">Report</option>
                <option value="review">Review</option>
            </param>
            <param name="sort" type="select" label="Sort work lists by" help="Sort list outputs using OpenAlex list sorting; referenced works are sorted locally">
                <option value="none" selected="true">OpenAlex default order</option>
                <option value="cited_by_count:desc">Citation count, descending</option>
                <option value="publication_year:desc">Publication year, newest first</option>
                <option value="publication_year:asc">Publication year, oldest first</option>
            </param>
            <param name="include_xpac" type="boolean" truevalue="--include-xpac" falsevalue="" checked="false" label="Include OpenAlex XPAC expansion works?" help="Pass include_xpac=true to OpenAlex list and search queries. XPAC expands coverage but may include lower-confidence metadata"/>
        </section>
        <param name="email" type="boolean" truevalue="true" falsevalue="false" checked="false" label="Use your email for polite pool?" help="Use your email to provide access to the OpenAlex polite pool for faster API access"/>
    </inputs>
    <outputs>
        <data name="summary_out" format="tabular" label="${tool.name} on ${on_string}: Work summary" from_work_dir="summary.tsv">
            <filter>entity['input_entity'] == 'work' and 'summary' in entity['mode']</filter>
            <actions>
                <action name="column_names" type="metadata" default="Input,Resolved_OpenAlex_ID,Resolved_Title,DOI,Year,Type,Cited_By_Count,Is_OA" />
            </actions>
        </data>
        <data name="citing_papers_out" format="tabular" label="${tool.name} on ${on_string}: Citing papers" from_work_dir="citing_papers.tsv">
            <filter>entity['input_entity'] == 'work' and 'citing_papers' in entity['mode']</filter>
            <actions>
                <action name="column_names" type="metadata" default="Input,Resolved_Entity_ID,Resolved_Entity_Name,Work_OpenAlex_ID,Title,DOI,Year,Type,Cited_By_Count,Is_OA" />
            </actions>
        </data>
        <data name="references_out" format="tabular" label="${tool.name} on ${on_string}: Referenced works" from_work_dir="referenced_works.tsv">
            <filter>entity['input_entity'] == 'work' and 'references' in entity['mode']</filter>
            <actions>
                <action name="column_names" type="metadata" default="Input,Resolved_Entity_ID,Resolved_Entity_Name,Work_OpenAlex_ID,Title,DOI,Year,Type,Cited_By_Count,Is_OA" />
            </actions>
