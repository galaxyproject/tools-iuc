<tool id="openalex_explorer" name="OpenAlex explorer" version="0.2.0+galaxy0" profile="24.1">
    <description>Fetch citing papers, references, related works, authors, and concepts from OpenAlex</description>
    <requirements>
        <requirement type="package" version="3.10">python</requirement>
        <requirement type="package" version="2.31.0">requests</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
python3 '$__tool_directory__/openalex_fetch.py'
$input_type
'$identifier'
#for $selected_mode in $mode
    --mode '$selected_mode'
#end for
--max-citations '$max_citations'
#if "citing_papers" in $mode
    $download_pdfs
#end if
--open-access '$open_access'
#if $publication_year_from
    --publication-year-from '$publication_year_from'
#end if
#if $publication_year_to
    --publication-year-to '$publication_year_to'
#end if
--work-type '$work_type'
--sort '$sort'
$include_xpac
#if $email
    --email '$__user_email__'
#end if
]]></command>
    <inputs>
        <param name="input_type" type="select" label="Input type" help="Select whether the identifier is an OpenAlex ID, DOI, or Title">
            <option value="--doi" selected="true">DOI</option>
            <option value="--id">OpenAlex ID</option>
            <option value="--title">Title</option>
        </param>
        <param name="identifier" type="text" label="Identifier" help="Enter the OpenAlex ID, DOI, or Title depending on your selection above"/>
        <param name="mode" type="select" multiple="true" label="What to fetch" help="Select one or more information types to retrieve from OpenAlex">
            <option value="citing_papers" selected="true">Citing papers (papers that cite this work)</option>
            <option value="summary">Summary (citation count, OA status)</option>
            <option value="references">References (works cited by this work)</option>
            <option value="related">Related works (similar papers)</option>
            <option value="authors">Authors (with affiliations and ORCIDs)</option>
            <option value="concepts">Concepts/Topics (research topics and scores)</option>
        </param>
        <param name="download_pdfs" type="boolean" truevalue="--download" falsevalue="" label="Download available OA PDFs?" value="false" help="Only available when fetching citing papers"/>
        <param name="max_citations" type="select" label="Max papers to fetch" help="Limit the number of results">
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50" selected="true">50</option>
            <option value="100">100</option>
            <option value="all">All</option>
        </param>
        <param name="open_access" type="select" label="Open Access filter" help="Filter work-list outputs such as citing, related, and referenced works by OpenAlex Open Access status">
            <option value="any" selected="true">Any access status</option>
            <option value="true">Open Access only</option>
            <option value="false">Closed Access only</option>
        </param>
        <param name="publication_year_from" type="integer" optional="true" min="1" label="Publication year from" help="Only include works published in or after this year"/>
        <param name="publication_year_to" type="integer" optional="true" min="1" label="Publication year to" help="Only include works published in or before this year"/>
        <param name="work_type" type="select" label="Work type" help="Filter work-list outputs by OpenAlex work type">
            <option value="any" selected="true">Any type</option>
            <option value="article">Article</option>
            <option value="book">Book</option>
            <option value="book-chapter">Book chapter</option>
            <option value="dataset">Dataset</option>
            <option value="dissertation">Dissertation</option>
            <option value="editorial">Editorial</option>
            <option value="letter">Letter</option>
            <option value="paratext">Paratext</option>
            <option value="peer-review">Peer review</option>
            <option value="preprint">Preprint</option>
            <option value="reference-entry">Reference entry</option>
            <option value="report">Report</option>
            <option value="review">Review</option>
        </param>
        <param name="sort" type="select" label="Sort work lists by" help="Sort citing and related works using OpenAlex list sorting; referenced works are sorted locally">
            <option value="none" selected="true">OpenAlex default order</option>
            <option value="cited_by_count:desc">Citation count, descending</option>
            <option value="publication_year:desc">Publication year, newest first</option>
            <option value="publication_year:asc">Publication year, oldest first</option>
        </param>
        <param name="include_xpac" type="boolean" truevalue="--include-xpac" falsevalue="" checked="false" label="Include Crossref posted-content archive records?" help="Pass include_xpac=true to OpenAlex list queries"/>
        <param name="email" type="boolean" truevalue="true" falsevalue="" checked="false" label="Use your email for polite pool?" help="Use your email to provide access to the OpenAlex polite pool for faster API access"/>
    </inputs>
    <outputs>
        <data name="summary_out" format="txt" label="${tool.name} on ${on_string}: Citation Summary" from_work_dir="summary.txt">
            <filter>'citing_papers' in mode or 'summary' in mode</filter>
        </data>
        <data name="tsv_out" format="tabular" label="${tool.name} on ${on_string}: Citing Papers TSV" from_work_dir="citing_papers.tsv">
            <filter>'citing_papers' in mode or 'summary' in mode</filter>
        </data>
        <data name="references_out" format="tabular" label="${tool.name} on ${on_string}: Referenced Works TSV" from_work_dir="referenced_works.tsv">
            <filter>'references' in mode</filter>
        </data>
        <data name="related_out" format="tabular" label="${tool.name} on ${on_string}: Related Works TSV" from_work_dir="related_works.tsv">
            <filter>'related' in mode</filter>
        </data>
        <data name="authors_out" format="tabular" label="${tool.name} on ${on_string}: Authors TSV" from_work_dir="authors.tsv">
            <filter>'authors' in mode</filter>
        </data>
        <data name="concepts_out" format="tabular" label="${tool.name} on ${on_string}: Concepts TSV" from_work_dir="concepts.tsv">
            <filter>'concepts' in mode</filter>
        </data>
        <collection name="pdf_outputs" label="${tool.name} on ${on_string}: Downloaded PDFs" type="list" format="pdf">
            <filter>'citing_papers' in mode and download_pdfs</filter>
            <discover_datasets pattern="__designation_and_ext__" directory="downloads"/>
        </collection>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="input_type" value="--id"/>
            <param name="identifier" value="W4398182689"/>
            <param name="mode" value="citing_papers"/>
            <param name="max_citations" value="10"/>
            <param name="download_pdfs" value="false"/>
            <output name="summary_out" ftype="txt">
                <assert_contents>
                    <has_n_lines n="3"/>
                    <has_text text="Total citing papers:"/>
                    <has_text text="Open Access papers:"/>
                    <has_text text="Closed Access papers:"/>
                </assert_contents>
            </output>
            <output name="tsv_out" ftype="tabular">
                <assert_contents>
                    <has_n_lines n="11"/>
                    <has_n_columns n="3"/>
                    <has_text text="Title"/>
                    <has_text text="DOI"/>
                    <has_text text="Is_OA"/>
                    <has_text text="Database resources of the National Center for Biotechnology Information in 2025"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="2">
            <param name="input_type" value="--doi"/>
            <param name="identifier" value="10.1093/nar/gkae410"/>
            <param name="mode" value="citing_papers"/>
            <param name="max_citations" value="50"/>
            <param name="download_pdfs" value="false"/>
            <output name="summary_out" ftype="txt">
                <assert_contents>
                    <has_n_lines n="3"/>
                    <has_text text="Total citing papers:"/>
                    <has_text text="Open Access papers:"/>
                    <has_text text="Closed Access papers:"/>
                </assert_contents>
            </output>
            <output name="tsv_out" ftype="tabular">
                <assert_contents>
                    <has_n_lines n="51"/>
                    <has_n_columns n="3"/>
                    <has_text text="Title"/>
                    <has_text text="DOI"/>
                    <has_text text="Is_OA"/>
                    <has_text text="Database resources of the National Center for Biotechnology Information in 2025"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="2">
            <param name="input_type" value="--title"/>
            <param name="identifier" value="The Galaxy platform for accessible, reproducible, and collaborative data analyses: 2024 update"/>
            <param name="mode" value="citing_papers"/>
            <param name="max_citations" value="50"/>
            <param name="download_pdfs" value="false"/>
            <output name="summary_out" ftype="txt">
                <assert_contents>
                    <has_n_lines n="3"/>
                    <has_text text="Total citing papers:"/>
                    <has_text text="Open Access papers:"/>
                    <has_text text="Closed Access papers:"/>
                </assert_contents>
            </output>
            <output name="tsv_out" ftype="tabular">
                <assert_contents>
                    <has_n_lines n="51"/>
                    <has_n_columns n="3"/>
                    <has_text text="Title"/>
                    <has_text text="DOI"/>
                    <has_text text="Is_OA"/>
                    <has_text text="Database resources of the National Center for Biotechnology Information in 2025"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="2">
            <param name="input_type" value="--id"/>
            <param name="identifier" value="W2088676066"/>
            <param name="mode" value="citing_papers"/>
            <param name="max_citations" value="10"/>
            <param name="download_pdfs" value="false"/>
            <output name="summary_out" ftype="txt">
                <assert_contents>
                    <has_n_lines n="3"/>
                    <has_text text="Total citing papers:"/>
                    <has_text text="Open Access papers:"/>
                    <has_text text="Closed Access papers:"/>
                </assert_contents>
            </output>
            <output name="tsv_out" ftype="tabular">
                <assert_contents>
                    <has_n_lines n="11"/>
                    <has_n_columns n="3"/>
                    <has_text text="Title"/>
                    <has_text text="DOI"/>
                    <has_text text="Is_OA"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="2">
            <param name="input_type" value="--id"/>
            <param name="identifier" value="W4398182689"/>
            <param name="mode" value="authors,concepts"/>
            <param name="max_citations" value="10"/>
            <param name="download_pdfs" value="false"/>
            <output name="authors_out" ftype="tabular">
                <assert_contents>
                    <has_n_lines n="132"/>
                    <has_n_columns n="4"/>
                    <has_text text="Name"/>
                    <has_text text="The Galaxy Community"/>
                </assert_contents>
            </output>
            <output name="concepts_out" ftype="tabular">
                <assert_contents>
                    <has_n_lines n="11"/>
                    <has_n_columns n="3"/>
                    <has_text text="Concept"/>
                    <has_text text="Computer science"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
    This tool fetches information from OpenAlex for a paper specified by OpenAlex ID, DOI, or Title.

    **Modes:**

    - **Citing papers**: Fetch papers that cite this work, with OA status and optional PDF download
    - **Summary**: Get citation count, OA status, and basic metadata
    - **References**: Fetch the bibliography (works cited by this paper)
    - **Related works**: Find similar papers based on OpenAlex relevance
    - **Authors**: Get author details with affiliations and ORCIDs
    - **Concepts**: Get research topics/concepts with relevance scores

    **Options:**

    - Multiple modes can be selected in one run.
    - Work lists can be filtered by Open Access status, publication year range, and OpenAlex work type.
    - Citing and related work lists can be sorted by OpenAlex relevance, citation count, or publication year.
    - A polite-pool email address can be supplied for improved API access.

    **Outputs:**

    - summary.txt / citing_papers.tsv: For citing papers and summary modes
    - referenced_works.tsv: Title, DOI, Year, Is_OA for referenced works
    - related_works.tsv: Title, DOI, Year, Cited_By_Count, Is_OA for related works
    - authors.tsv: Name, ORCID, Affiliation, Country
    - concepts.tsv: Concept, Score, Wikidata_ID
    ]]></help>
    <citations>
        <citation type="doi">10.48550/arXiv.2205.01833</citation>
    </citations>
</tool>
