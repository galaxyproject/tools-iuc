<tool id="countess" name="CountESS" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>run a saved CountESS workflow configuration</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <required_files>
        <include path="countess_runner.py"/>
    </required_files>
    <command detect_errors="exit_code"><![CDATA[
python '$__tool_directory__/countess_runner.py'
    --config '$config_file'
    --input-mappings '$input_mappings_json'
    --output-mappings '$output_mappings_json'
    --extra-overrides '$extra_overrides_json'
    --output-dir countess_outputs
    --log-level '$log_level'
    > '$log' 2>&1
    ]]></command>
    <configfiles>
        <configfile name="input_mappings_json"><![CDATA[
#import json
[
#for $i, $mapping in enumerate($input_mappings)
    #if $i
,
    #end if
    #set $target_filename = getattr($mapping.target_filename, "value", $mapping.target_filename)
    {
        "node": #echo json.dumps(str($mapping.node_name))#,
        "parameter": #echo json.dumps(str($mapping.parameter_name))#,
        "path": #echo json.dumps(str($mapping.input_file))#,
        "identifier": #echo json.dumps(str($mapping.input_file.element_identifier))#,
        "extension": #echo json.dumps(str($mapping.input_file.ext))#,
        "staged_name": #echo json.dumps(str($target_filename))#
    }
#end for
]
        ]]></configfile>
        <configfile name="output_mappings_json"><![CDATA[
#import json
[
#for $i, $mapping in enumerate($output_mappings)
    #if $i
,
    #end if
    {
        "node": #echo json.dumps(str($mapping.node_name))#,
        "parameter": #echo json.dumps(str($mapping.parameter_name))#,
        "filename": #echo json.dumps(str($mapping.output_filename))#
    }
#end for
]
        ]]></configfile>
        <configfile name="extra_overrides_json"><![CDATA[
#import json
[
#for $i, $override in enumerate($advanced_overrides)
    #if $i
,
    #end if
    #set $value_literal = getattr($override.value_literal, "value", $override.value_literal)
    {
        "node": #echo json.dumps(str($override.node_name))#,
        "parameter": #echo json.dumps(str($override.parameter_name))#,
        "value": #echo json.dumps(str($value_literal))#
    }
#end for
]
        ]]></configfile>
    </configfiles>
    <inputs>
        <param name="config_file" type="data" format="txt" label="CountESS configuration file" help="INI configuration saved from the CountESS GUI."/>
        <repeat name="input_mappings" title="Input file mapping" min="1" default="1" help="Map Galaxy datasets to CountESS load-node filename parameters.">
            <param name="node_name" type="text" label="CountESS input node name" help="For example: CSV Load 1 or FASTQ Load. This must match the node name in the CountESS INI file.">
                <validator type="empty_field"/>
            </param>
            <param name="parameter_name" type="text" value="files.0.filename" label="CountESS filename parameter" help="E.g., files.0.filename.">
                <validator type="empty_field"/>
            </param>
            <param name="input_file" type="data" format="data,txt,csv,tsv,tabular,fasta,fastq,fastqsanger,fastqsanger.gz" label="Galaxy input dataset"/>
            <param name="target_filename" type="text" optional="true" label="Staged filename" help="Optional filename visible to CountESS. Leave empty to use the Galaxy dataset name."/>
        </repeat>
        <repeat name="output_mappings" title="Output file mapping" min="1" default="1" help="Map CountESS save-node filename parameters into a Galaxy output collection.">
            <param name="node_name" type="text" label="CountESS save node name" help="For example: CSV Save 5. This must match the node name in the CountESS INI file.">
                <validator type="empty_field"/>
            </param>
            <param name="parameter_name" type="text" value="filename" label="CountESS output filename parameter" help="E.g., filename.">
                <validator type="empty_field"/>
            </param>
            <param name="output_filename" type="text" value="output.csv" label="Output filename" help="Relative filename to write into the Galaxy output collection. Use extensions like .csv, .tsv, or .txt for datatype detection.">
                <validator type="empty_field"/>
            </param>
        </repeat>
        <repeat name="advanced_overrides" title="Advanced CountESS parameter override" min="0" default="0">
            <param name="node_name" type="text" label="CountESS node name"/>
            <param name="parameter_name" type="text" label="CountESS parameter name"/>
            <param name="value_literal" type="text" label="Python literal value" help="Enter the value as a Python literal. String values must be wrapped in single or double quotes, for example 'column_name' or 'result = count * 2'. Boolean and numeric values do not need quotes, for example True or 10. Type comparison operators directly, for example 'result > 20000', not the XML-escaped form."/>
        </repeat>
        <param name="log_level" type="select" label="Log level">
            <option value="INFO" selected="true">INFO</option>
            <option value="DEBUG">DEBUG</option>
            <option value="WARNING">WARNING</option>
            <option value="ERROR">ERROR</option>
        </param>
    </inputs>
    <outputs>
        <collection name="outputs" type="list" label="${tool.name} on ${on_string}: output files">
            <discover_datasets directory="countess_outputs" pattern="(?P&lt;designation&gt;.+)\.csv$" format="csv" recurse="true"/>
            <discover_datasets directory="countess_outputs" pattern="(?P&lt;designation&gt;.+)\.tsv$" format="tabular" recurse="true"/>
            <discover_datasets directory="countess_outputs" pattern="(?P&lt;designation&gt;.+)\.txt$" format="txt" recurse="true"/>
            <discover_datasets directory="countess_outputs" pattern="(?P&lt;designation&gt;.+)\.text$" format="txt" recurse="true"/>
            <discover_datasets directory="countess_outputs" pattern="(?P&lt;designation&gt;.+)\.(csv|tsv|txt|text)\.gz$" format="data" recurse="true"/>
            <discover_datasets directory="countess_outputs" pattern="(?P&lt;designation&gt;.+)\.(csv|tsv|txt|text)\.bz2$" format="data" recurse="true"/>
        </collection>
        <data name="log" format="txt" label="${tool.name} on ${on_string}: log"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="config_file" value="simple.ini" ftype="txt"/>
            <repeat name="input_mappings">
                <param name="node_name" value="CSV Load 1"/>
                <param name="parameter_name" value="files.0.filename"/>
                <param name="input_file" value="input1.csv" ftype="csv"/>
                <param name="target_filename" value="input1.csv"/>
            </repeat>
            <repeat name="input_mappings">
                <param name="node_name" value="CSV Load 2"/>
                <param name="parameter_name" value="files.0.filename"/>
                <param name="input_file" value="input2.txt" ftype="txt"/>
                <param name="target_filename" value="input2.txt"/>
            </repeat>
            <repeat name="output_mappings">
                <param name="node_name" value="CSV Save 5"/>
                <param name="parameter_name" value="filename"/>
                <param name="output_filename" value="output.csv"/>
            </repeat>
            <output_collection name="outputs" type="list" count="1">
                <element name="output" file="expected_output.csv" ftype="csv"/>
            </output_collection>
            <output name="log">
                <assert_contents>
                    <has_text text="CSV Load 1"/>
                    <has_text text="CSV Save 5"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="2">
            <param name="config_file" value="simple.ini" ftype="txt"/>
            <repeat name="input_mappings">
                <param name="node_name" value="CSV Load 1"/>
                <param name="parameter_name" value="files.0.filename"/>
                <param name="input_file" value="input1.csv" ftype="csv"/>
                <param name="target_filename" value="input1.csv"/>
            </repeat>
            <repeat name="input_mappings">
                <param name="node_name" value="CSV Load 2"/>
                <param name="parameter_name" value="files.0.filename"/>
                <param name="input_file" value="input2.txt" ftype="txt"/>
                <param name="target_filename" value="input2.txt"/>
            </repeat>
            <repeat name="output_mappings">
                <param name="node_name" value="CSV Save 5"/>
                <param name="parameter_name" value="filename"/>
                <param name="output_filename" value="output.csv"/>
            </repeat>
            <repeat name="advanced_overrides">
                <param name="node_name" value="Regex Tool"/>
                <param name="parameter_name" value="drop_unmatch"/>
                <param name="value_literal" value="False"/>
            </repeat>
            <repeat name="advanced_overrides">
                <param name="node_name" value="Join 3"/>
                <param name="parameter_name" value="inputs.0.required"/>
                <param name="value_literal" value="False"/>
            </repeat>
            <output_collection name="outputs" type="list" count="1">
                <element name="output" file="expected_all_nodes_output.csv" ftype="csv"/>
            </output_collection>
            <output name="log">
                <assert_contents>
                    <has_text text="CSV Load 1"/>
                    <has_text text="CSV Load 2"/>
                    <has_text text="Regex Tool"/>
                    <has_text text="Join 3"/>
                    <has_text text="Expression"/>
                    <has_text text="CSV Save 5"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="2">
            <param name="config_file" value="simple.ini" ftype="txt"/>
            <repeat name="input_mappings">
                <param name="node_name" value="CSV Load 1"/>
                <param name="parameter_name" value="files.0.filename"/>
                <param name="input_file" value="input1.csv" ftype="csv"/>
                <param name="target_filename" value="input1.csv"/>
            </repeat>
            <repeat name="input_mappings">
                <param name="node_name" value="CSV Load 2"/>
                <param name="parameter_name" value="files.0.filename"/>
                <param name="input_file" value="input2.txt" ftype="txt"/>
                <param name="target_filename" value="input2.txt"/>
            </repeat>
            <repeat name="output_mappings">
                <param name="node_name" value="CSV Save 5"/>
                <param name="parameter_name" value="filename"/>
                <param name="output_filename" value="override_output.csv"/>
            </repeat>
            <repeat name="advanced_overrides">
                <param name="node_name" value="Expression"/>
                <param name="parameter_name" value="code"/>
                <param name="value_literal" value="'result = number * foo * bar / baz\n\n__filter = result &gt; 20000\n\nfoo_bar_baz = number = foo = bar = baz = None\n\n'"/>
            </repeat>
            <output_collection name="outputs" type="list" count="1">
                <element name="override_output" file="expected_override_output.csv" ftype="csv"/>
            </output_collection>
            <output name="log">
                <assert_contents>
                    <has_text text="Expression"/>
                    <has_text text="CSV Save 5"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="2">
            <param name="config_file" value="dual_outputs.ini" ftype="txt"/>
            <repeat name="input_mappings">
                <param name="node_name" value="CSV Load 1"/>
                <param name="parameter_name" value="files.0.filename"/>
                <param name="input_file" value="dual_outputs_input.csv" ftype="csv"/>
                <param name="target_filename" value="dual_outputs_input.csv"/>
            </repeat>
            <repeat name="output_mappings">
                <param name="node_name" value="CSV Save CSV"/>
                <param name="parameter_name" value="filename"/>
                <param name="output_filename" value="dual_csv.csv"/>
            </repeat>
            <repeat name="output_mappings">
                <param name="node_name" value="CSV Save TSVBZ2"/>
                <param name="parameter_name" value="filename"/>
                <param name="output_filename" value="dual_tsv.tsv.bz2"/>
            </repeat>
            <output_collection name="outputs" type="list" count="2">
                <element name="dual_csv" file="expected_dual_output.csv" ftype="csv"/>
                <element name="dual_tsv" file="expected_dual_output.tsv.bz2" ftype="data"/>
            </output_collection>
            <output name="log">
                <assert_contents>
                    <has_text text="CSV Save CSV"/>
                    <has_text text="CSV Save TSVBZ2"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
CountESS is a workflow-like analysis tool for tabular and sequence-count data. This Galaxy wrapper runs an existing CountESS INI configuration saved from the CountESS GUI.

Typical usage:

1. Build a workflow in the CountESS GUI.
2. Save the workflow as an INI configuration file.
3. Upload the INI file and input datasets to Galaxy.
4. Map each Galaxy dataset to the matching CountESS input node filename parameter.
5. Map each CountESS save node filename parameter to an output filename.

Node name values in the Galaxy tool form must match node names in the CountESS INI file exactly.

The wrapper runs CountESS in headless mode using `countess_cmd`. Advanced users can add raw CountESS parameter overrides using the `NODENAME.PARAMETER=VALUE` mechanism exposed by CountESS, where VALUE is a Python literal.
    ]]></help>
    <expand macro="citations"/>
</tool>
