<tool id="multiclasspredict" name="multiclasspredict" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Multi Class prediction </description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    
    <command detect_errors="exit_code"><![CDATA[
        python $__tool_directory__/multiclasspredict.py
        --X '$X'
        --y '$y'
        --ks $ks
        --n_seeds $n_seeds
        --label '$label'
        --model '$model'
        --sampling_strategy '$sampling_strategy'
        $grid_search
        --output '$output'
        --diagnostic_plot '$diagnostic_plot'
        --plot_per_feature '$plot_per_feature'
    ]]></command>

  
    <inputs>

        <param name="X" type="data" format="tabular" label="X: Input features" help="Feature matrix (independent variables used for prediction)"/>
        <param name="y" type="data" format="tabular" label="Y: Target values" help="Target labels (dependent variable)"/>
       <param name="ks" type="text" label="Feature counts (k)" help="Comma-separated feature counts (e.g. 10,100,200)"/>
        <param name="n_seeds" type="integer" value="2" label="Number of seeds" help="Number of random seeds for repeated runs"/>
        <param name="label" type="text" label="Dataset label" help="Label for tracking results (e.g. 'combined')"/>
        <param name="model" type="select" label="Model type">
            <option value="rf">Random Forest</option>
            <option value="xgb">XGBoost</option>
            <option value="etc">Extra Trees</option>
            <option value="lgbm">LightGBM</option>
            <option value="tabpfn">TabPFN</option>
        </param>

        <param name="sampling_strategy" type="select" label="Sampling strategy">
            <option value="No Sampling">No Sampling</option>
            <option value="Random OverSampling">Random OverSampling</option>
            <option value="SMOTE">SMOTE</option>
            <option value="Random UnderSampling">Random UnderSampling</option>
            <option value="NearMiss (v1)">NearMiss (v1)</option>
            <option value="NearMiss (v2)">NearMiss (v2)</option>
            <option value="NearMiss (v3)">NearMiss (v3)</option>
        </param>

        <param name="grid_search" type="boolean" truevalue="--grid_search" falsevalue="" checked="false"  label="Enable Grid Search" help="Enable hyperparameter tuning (slower)"/>

    </inputs>

    <outputs>
        <data name="output" format="csv" label="Multiclass AUC results"/>
        <data name="diagnostic_plot" format="png" label="Diagnostic Plot"/>
         <data name="plot_per_feature" format="png" label="Plots per feature"/>
    </outputs>
    <tests>
        <test expect_num_outputs="3">
            <param name="X" value="input.tsv"/>
            <param name="y" value="target.tsv"/>
            <param name="n_seeds" value="2"/>
            <param name="ks" value="10,100"/>
            <param name="label" value="combined dataset"/>
            <param name="model" value="rf"/>
            <param name="sampling_strategy" value="No Sampling"/>
            <param name="grid_search" value="false"/>

            <output name="output">
                <assert_contents>
                    <has_size value="4947" delta="200"/>
                </assert_contents>
            </output>
            
            <output name="diagnostic_plot">
                <assert_contents>
                    <has_size value="153471" delta="5000"/>
                </assert_contents>
            </output>
            <output name="plot_per_feature">
                <assert_contents>
                    <has_size value="63636" delta="5000"/>
                </assert_contents>
            </output>
            
        </test>
    </tests>  
    
    
    
    <help><![CDATA[
    This tool performs multiclass prediction on medical datasets.
    
    ]]></help>
</tool>
