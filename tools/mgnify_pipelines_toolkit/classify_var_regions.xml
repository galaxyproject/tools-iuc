<tool id="mgnify_pipelines_toolkit_classify_var_regions" name="MGnify: Classify rRNA variable regions" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@" license="@LICENSE@">
    <description>Identify amplified rRNA variable regions from CMsearch tblout results</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="creators"/>
    <expand macro="requirements"/>
    <command detect_errors="aggressive"><![CDATA[
        classify_var_regions -d ./ -o sample '$input' $stats_cond.stats_select &&
        mkdir per_read &&
        find ./ -maxdepth 1 -type f -name "sample.*S.*.txt" -exec mv {} per_read ';'
    ]]></command>
    <inputs>
        <param name="input" type="data" label="CMsearch tblout results" format="tabular" help="Tabular output from Infernal CMsearch containing rRNA model matches"/>
        <conditional name="stats_cond">
            <param name="stats_select" type="select" label="Generate detailed statistics files">
                <option value="" selected="true">No</option>
                <option value="--statistics">Yes</option>
            </param>
            <when value="">
                <param name="outputs_select" type="select" multiple="true" label="Select desired outputs">
                    <expand macro="standard_outputs"/>
                </param>
            </when>
            <when value="--statistics">
                <param name="outputs_select" type="select" multiple="true" label="Select desired outputs">
                    <expand macro="standard_outputs"/>
                    <option value="condensed_stats">Condensed statistics</option>
                    <option value="missing_files_log">Missing files log</option>
                    <option value="seq_count_per_region">Sequence counts per region</option>
                    <option value="detailed_stats">Detailed statistics</option>
                </param>
            </when>
        </conditional>
    </inputs>    
    <outputs>
        <data name="output_json" label="${tool.name} on ${on_string}: Region classification JSON" format="json" from_work_dir="sample.json">
            <filter>"json" in stats_cond['outputs_select']</filter>
        </data>
        <data name="output_tabular" label="${tool.name} on ${on_string}: Amplified regions table" format="tabular" from_work_dir="sample.tsv">
            <filter>"amp_regions" in stats_cond['outputs_select']</filter>
        </data>
        <data name="output_regions" label="${tool.name} on ${on_string}: Detected regions list" format="txt" from_work_dir="sample_regions.txt">
            <filter>"regions_list" in stats_cond['outputs_select']</filter>
        </data>
        <data name="output_coverages" label="${tool.name} on ${on_string}: Region coverage summary" format="txt" from_work_dir="sample_all_coverages.txt">
            <filter>"coverage_summary" in stats_cond['outputs_select']</filter>
        </data>
        <collection name="per_read_regions" type="list" label="${tool.name} on ${on_string}: Per-read region assignments" format="txt">
            <filter>"per_read_region_assign" in stats_cond['outputs_select']</filter>
            <discover_datasets format="txt" directory="per_read" pattern="__name_and_ext__"/>
        </collection>
        <data name="output_condensed_stats" label="${tool.name} on ${on_string}: Condensed statistics" format="tabular" from_work_dir="sample.condensed_stats">
            <filter>"condensed_stats" in stats_cond['outputs_select']</filter>
        </data>
        <data name="output_missing_files" label="${tool.name} on ${on_string}: Missing files log" format="txt" from_work_dir="sample.missing_files.txt">
            <filter>"missing_files_log" in stats_cond['outputs_select']</filter>
        </data>
        <data name="output_seq_count" label="${tool.name} on ${on_string}: Sequence counts per region" format="txt" from_work_dir="sample.seq_count.txt">
            <filter>"seq_count_per_region" in stats_cond['outputs_select']</filter>
        </data>
        <data name="output_stats" label="${tool.name} on ${on_string}: Detailed statistics" format="tabular" from_work_dir="sample.stats">
            <filter>"detailed_stats" in stats_cond['outputs_select']</filter>
        </data>
    </outputs>
    <tests>
        <test expect_num_outputs="9">
            <param name="input" value="test_success_single.tblout.deoverlapped"/>
            <conditional name="stats_cond">
                <param name="stats_select" value="--statistics"/>
                <param name="outputs_select" value="json,amp_regions,regions_list,coverage_summary,per_read_region_assign,condensed_stats,missing_files_log,seq_count_per_region,detailed_stats"/>
            </conditional>
            <output name="output_json" ftype="json">
                <assert_contents>
                    <has_text text="dataset"/>
                    <has_text text="Bacteria"/>
                    <has_text text="V3-V4"/>
                    <has_text text="1.0"/>
                    <has_n_lines n="1"/>
                </assert_contents>
            </output>
            <output name="output_tabular" ftype="tabular">
                <assert_contents>
                    <has_text text="16S"/>
                    <has_text text="V3-V4"/>
                    <has_text text="ECO_0000363"/>
                    <has_n_columns n="5"/>
                    <has_n_lines n="2"/>
                </assert_contents>
            </output>
            <output name="output_regions" ftype="txt">
                <assert_contents>
                    <has_text text="16S.V3-V4"/>
                    <has_n_lines n="1"/>
                </assert_contents>
            </output>
            <output name="output_coverages" ftype="txt">
                <assert_contents>
                    <has_text text="Bacteria:V3: 1.0"/>
                    <has_text text="Bacteria:V4: 1.0"/>
                    <has_n_lines n="2"/>
                </assert_contents>
            </output>
            <output_collection name="per_read_regions" type="list" count="1">
                <element name="sample.16S.V3-V4" ftype="txt">
                    <assert_contents>
                        <has_text text="ERR4822665"/>
                        <has_n_lines n="6500"/>
                    </assert_contents>
                </element>
            </output_collection>
            <output name="output_condensed_stats" ftype="tabular">
                <assert_contents>
                    <has_n_columns n="5"/>
                    <has_n_lines n="2"/>
                </assert_contents>
            </output>
            <output name="output_seq_count" ftype="txt">
                <assert_contents>
                    <has_text text="Bacteria"/>
                    <has_text text="V3-V4"/>
                    <has_text text="6500"/>
                    <has_n_lines n="1"/>
                </assert_contents>
            </output>
            <output name="output_stats" ftype="tabular">
                <assert_contents>
                    <has_text text="Regions bact"/>
                    <has_text text="V3-V4"/>
                    <has_n_columns n="16"/>
                    <has_n_lines n="2"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help>
<![CDATA[

**Classify rRNA Variable Regions**
----------------------------------

This tool identifies which **ribosomal RNA variable regions** were amplified in a sequencing run.

It analyzes **Infernal CMsearch tblout results** and determines the variable regions represented in the dataset by comparing sequence coordinates against known rRNA reference models.

-----

Supported marker genes
----------------------

The tool automatically detects the rRNA marker gene and domain from the covariance model:

+----------+-------------+-------------+
| Model    | Domain      | Marker gene |
+==========+=============+=============+
| RF00177  | Bacteria    | 16S         |
+----------+-------------+-------------+
| RF01959  | Archaea     | 16S         |
+----------+-------------+-------------+
| RF01960  | Eukaryotes  | 18S         |
+----------+-------------+-------------+
]]>
    </help>
    <expand macro="citations" />
</tool>
