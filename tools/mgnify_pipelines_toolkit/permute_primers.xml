<tool id="mgnify_pipelines_toolkit_permute_primers" name="MGnify: Permute primers" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@" license="@LICENSE@">
    <description>Generate all primer sequence permutations from IUPAC ambiguous bases</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="creators"/>
    <expand macro="requirements"/>
    <command detect_errors="aggressive"><![CDATA[
        permute_primers -i '$input' -p prefix
    ]]></command>
    <inputs>
        <param name="input" type="data" label="Input primers" format="fasta" help="FASTA file containing primer sequences with possible IUPAC ambiguous bases"/>
    </inputs>    
    <outputs>
        <data name="output" label="${tool.name} on ${on_string}: Primer permutations" format="fasta" from_work_dir="prefix_permuted_primers.fasta"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input" value="f_and_r_primers.fasta"/>
            <output name="output">
                <assert_contents>
                    <has_line line=">341F"/>
                    <has_line line="CCTACGGGNGGCWGCAG"/>
                    <has_line line=">341F_variant_1_F"/>
                    <has_line line="CCTACGGGAGGCAGCAG"/>
                    <has_line line=">341F_variant_2_F"/>
                    <has_line line="CCTACGGGAGGCTGCAG"/>
                    <has_line line=">341F_variant_3_F"/>
                    <has_line line="CCTACGGGCGGCAGCAG"/>
                    <has_line line=">341F_variant_4_F"/>
                    <has_line line="CCTACGGGCGGCTGCAG"/>
                    <has_line line=">341F_variant_5_F"/>
                    <has_line line="CCTACGGGTGGCAGCAG"/>
                    <has_line line=">341F_variant_6_F"/>
                    <has_line line="CCTACGGGTGGCTGCAG"/>
                    <has_line line=">341F_variant_7_F"/>
                    <has_line line="CCTACGGGGGGCAGCAG"/>
                    <has_n_lines n="38"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help>
<![CDATA[ 
**Expand Degenerate Primers**

This tool expands primer sequences containing **IUPAC ambiguous nucleotide codes** into all possible concrete sequence permutations.
]]>
    </help>
    <expand macro="citations" />
</tool>
