<tool id="mgnify_pipelines_toolkit_primer_val_classification" name="MGnify: Primer Validation and Classification" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@" license="@LICENSE@">
    <description>Validate primers against CMsearch hits and assign strand orientation</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="creators"/>
    <expand macro="requirements"/>
    <command detect_errors="aggressive"><![CDATA[
        #set input_basename = str($cmsearch_input.name).rsplit('.',1)[0]
        primer_val_classification -i '$cmsearch_input' -f '$primers' -s '$input_basename' $se &&
        mv '$input_basename'_primer_validation.tsv '$summary'
    ]]></command>
    <inputs>
        <param name="cmsearch_input" type="data" label="CMsearch-deoverlap tblout results" format="tabular" help="Output from Infernal cmsearch with overlaps removed"/>
        <param name="primers" type="data" label="Primer sequences" format="fasta" help="FASTA file containing primer sequences"/>
        <param argument="--se" type="boolean" label="Single-end sequencing" truevalue="--se" falsevalue=""/>
    </inputs>    
    <outputs>
        <data name="summary" label="${tool.name} on ${on_string}: Primer validation summary" format="tsv"/>
        <data name="fwd_primers" label="${tool.name} on ${on_string}: Forward primers" format="fasta" from_work_dir="fwd_primers.fasta"/>
        <data name="rev_primers" label="${tool.name} on ${on_string}: Reverse primers" format="fasta" from_work_dir="rev_primers.fasta"/>
    </outputs>
    <tests>
        <test expect_num_outputs="3">
            <param name="cmsearch_input" value="test.cmsearch_matches.tbl.deoverlapped" ftype="tabular"/>
            <param name="primers" value="test_permuted_primers.fasta" ftype="fasta"/>
            <output name="summary" file="sample_primer_validation.tsv" ftype="tsv"/>
            <output name="fwd_primers" file="fwd_primers.fasta" ftype="fasta"/>
            <output name="rev_primers" file="rev_primers.fasta" ftype="fasta"/>
        </test>
    </tests>
    <help>
<![CDATA[ 
**Validate and Classify rRNA Primers**
--------------------------------------

This tool validates primer sequences against rRNA covariance model matches and classifies them as **forward** or **reverse** primers.

The tool:

* Reads primer alignment coordinates produced by **cmsearch**
* Determines whether primers bind outside rRNA hypervariable regions
* Assigns the targeted **variable region** (e.g. V3, V4)
* Classifies primers by **strand orientation**
* Outputs validated primer sequences
]]>
    </help>
    <expand macro="citations" />
</tool>
