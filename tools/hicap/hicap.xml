<tool id="hicap" name="HiCap" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@" license="GPL-3.0-or-later">
    <description>identify cap locus serotype and structure in Haemophilus influenzae assemblies</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <version_command>hicap --version</version_command>
    <command detect_errors="aggressive"><![CDATA[
        mkdir -p output &&
        #if $input.ext.endswith(".gz")
            gunzip -c '$input' > input.fasta &&
        #else
            ln -s '$input' input.fasta &&
        #end if
        hicap
            --query_fp ./input.fasta
            --output_dir ./output
            --threads "\${GALAXY_SLOTS:-1}"
            --gene_coverage $gene_coverage
            --gene_identity $gene_identity
            --broken_gene_length $broken_gene_length
            --broken_gene_identity $broken_gene_identity
            $full_sequence
    ]]></command>
    <inputs>
        <param name="input" type="data" format="fasta,fasta.gz" label="Input assembly" help="FASTA assembly to analyse"/>
        <param argument="--full_sequence" type="boolean" truevalue="--full_sequence" falsevalue="" checked="false" label="Write the full input sequence to the GenBank output" />
        <section name="search" title="Search parameters" expanded="false">
            <param argument="--gene_coverage" type="float" value="0.8" min="0" max="1" label="Minimum gene coverage" />
            <param argument="--gene_identity" type="float" value="0.7" min="0" max="1" label="Minimum gene identity" />
            <param argument="--broken_gene_length" type="integer" value="60" min="1" label="Minimum broken gene length" />
            <param argument="--broken_gene_identity" type="float" value="0.8" min="0" max="1" label="Minimum broken gene identity" />
        </section>
    </inputs>
    <outputs>
        <data name="summary" format="tabular" from_work_dir="./output/input.tsv" label="${tool.name} on ${on_string}: summary"/>
        <data name="genbank" format="genbank" from_work_dir="./output/input.gbk" label="${tool.name} on ${on_string}: genbank"/>
        <data name="graphic" format="svg" from_work_dir="./output/input.svg" label="${tool.name} on ${on_string}: graphic"/>
    </outputs>
    <tests>
        <test expect_num_outputs="3">
            <param name="input" value="Hi75.fasta.gz" ftype="fastqsanger.gz"/>
            <output name="summary" file="output01.tabular" ftype="tabular">
                <assert_contents>
                    <has_n_lines n="2"/>
                    <has_n_columns n="9"/>
                    <has_line_matching expression="^#isolate\tpredicted_serotype\tattributes\tgenes_identified\tlocus_location\tregion_I_genes\tregion_II_genes\tregion_III_genes\tIS1016_hits$"/>
                </assert_contents>
            </output>
            <output name="genbank" file="output01.gbk" ftype="genbank">
                <assert_contents>
                    <has_text text="LOCUS"/>
                    <has_text text="FEATURES"/>
                    <has_n_lines n="380" min="300"/>
                </assert_contents>
            </output>
            <output name="graphic" file="output.svg" ftype="svg">
                <assert_contents>
                    <is_valid_xml/>
                    <has_text text="http://www.w3.org/2000/svg"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help format="markdown"><![CDATA[
hicap
=====

Identify the `cap` locus serotype and structure in *Haemophilus influenzae* assemblies.

**Input**

- One FASTA assembly, plain or gzipped.

**Output**

- `summary`: tabular summary of serotype prediction and locus features.
- `genbank`: annotated GenBank record for the locus region.
- `graphic`: SVG locus graphic.

    ]]></help>
    <expand macro="citations"/>
</tool>
