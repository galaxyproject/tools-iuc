<tool id="getitd" name="getITD" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="21.05">
    <description>detect FLT3-ITDs from amplicon NGS data</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <required_files>
        <include path="anno/amplicon.txt"/>
        <include path="anno/amplicon_kayser.tsv"/>
    </required_files>
    <command detect_errors="exit_code"><![CDATA[
getitd
    -nkern \${GALAXY_SLOTS:-1}
    #if $reference_source.reference_source_selector == 'history'
        -reference '$reference_source.reference'
        -anno '$reference_source.anno'
    #else
        -reference '$__tool_directory__/anno/amplicon.txt'
        -anno '$__tool_directory__/anno/amplicon_kayser.tsv'
    #end if
    -technology '$technology'
    -infer_sense_from_alignment $infer_sense_from_alignment
    -require_indel_free_primers $require_indel_free_primers
    #if $forward_primer
        -forward_primer '$forward_primer'
    #end if
    #if $reverse_primer
        -reverse_primer '$reverse_primer'
    #end if
    #if $forward_adapter
        -forward_adapter '$forward_adapter'
    #end if
    #if $reverse_adapter
        -reverse_adapter '$reverse_adapter'
    #end if
    -min_bqs $filtering.min_bqs
    -min_read_length $filtering.min_read_length
    -min_read_copies $filtering.min_read_copies
    -min_insert_seq_length $filtering.min_insert_seq_length
    -filter_ins_unique_reads $filtering.filter_ins_unique_reads
    -filter_ins_total_reads $filtering.filter_ins_total_reads
    -filter_ins_vaf $filtering.filter_ins_vaf
    -minscore_inserts $alignment.minscore_inserts
    -minscore_alignments $alignment.minscore_alignments
    -gap_open $alignment.gap_open
    -gap_extend $alignment.gap_extend
    -match $alignment.match
    -mismatch $alignment.mismatch
    -max_trailing_bp $alignment.max_trailing_bp
    $plot_coverage
    --
    sample
    '$library.fastq1'
    #if $library.library_type == 'paired'
        '$library.fastq2'
    #end if
    ]]></command>
    <inputs>
        <conditional name="library">
            <param name="library_type" type="select" label="Single-end or paired-end">
                <option value="paired" selected="true">Paired-end</option>
                <option value="single">Single-end</option>
            </param>
            <when value="paired">
                <param name="fastq1" type="data" format="fastq,fastqsanger,fastq.gz,fastqsanger.gz" label="Forward reads (R1)"/>
                <param name="fastq2" type="data" format="fastq,fastqsanger,fastq.gz,fastqsanger.gz" label="Reverse reads (R2)"/>
            </when>
            <when value="single">
                <param name="fastq1" type="data" format="fastq,fastqsanger,fastq.gz,fastqsanger.gz" label="Reads (R1)"/>
            </when>
        </conditional>
        <conditional name="reference_source">
            <param name="reference_source_selector" type="select" label="Amplicon reference and annotation" help="Use the built-in FLT3 reference (Kayser amplicon) or supply your own.">
                <option value="builtin" selected="true">Built-in FLT3 amplicon (default)</option>
                <option value="history">Use reference/annotation from history</option>
            </param>
            <when value="builtin"/>
            <when value="history">
                <param argument="-reference" type="data" format="txt,fasta" label="WT amplicon reference sequence" help="Single-line wild-type amplicon sequence."/>
                <param argument="-anno" type="data" format="tabular,tsv" label="Amplicon annotation" help="Per-base annotation."/>
            </when>
        </conditional>
        <param argument="-technology" type="select" label="Sequencing technology">
            <option value="Illumina" selected="true">Illumina</option>
            <option value="454">454</option>
        </param>
        <param argument="-infer_sense_from_alignment" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Infer read sense from alignment"/>
        <param argument="-require_indel_free_primers" type="boolean" truevalue="True" falsevalue="False" checked="true" label="Require indel-free primers" help="Discard reads with indels in, or missing, the primer sequence. Turn off if primers/adapters were already trimmed."/>
        <param argument="-forward_primer" type="text" optional="true" label="Forward primer sequence" help="Leave empty to use the getITD default.">
            <sanitizer invalid_char="">
                <valid initial="string.ascii_letters"/>
            </sanitizer>
            <validator type="regex" message="Only nucleotide letters (A, C, G, T, N) are allowed">^[ACGTNacgtn]*$</validator>
        </param>
        <param argument="-reverse_primer" type="text" optional="true" label="Reverse primer sequence" help="Leave empty to use the getITD default.">
            <sanitizer invalid_char="">
                <valid initial="string.ascii_letters"/>
            </sanitizer>
            <validator type="regex" message="Only nucleotide letters (A, C, G, T, N) are allowed">^[ACGTNacgtn]*$</validator>
        </param>
        <param argument="-forward_adapter" type="text" optional="true" label="Forward adapter sequence" help="Leave empty to use the getITD default.">
            <sanitizer invalid_char="">
                <valid initial="string.ascii_letters"/>
            </sanitizer>
            <validator type="regex" message="Only nucleotide letters (A, C, G, T, N) are allowed">^[ACGTNacgtn]*$</validator>
        </param>
        <param argument="-reverse_adapter" type="text" optional="true" label="Reverse adapter sequence" help="Leave empty to use the getITD default.">
            <sanitizer invalid_char="">
                <valid initial="string.ascii_letters"/>
            </sanitizer>
            <validator type="regex" message="Only nucleotide letters (A, C, G, T, N) are allowed">^[ACGTNacgtn]*$</validator>
        </param>
        <section name="filtering" title="Read and insertion filtering" expanded="false">
            <param argument="-min_bqs" type="integer" value="30" min="0" label="Minimum average base quality score"/>
            <param argument="-min_read_length" type="integer" value="100" min="1" label="Minimum read length after N-trimming"/>
            <param argument="-min_read_copies" type="integer" value="2" min="1" label="Minimum read copy count"/>
            <param argument="-min_insert_seq_length" type="integer" value="6" min="1" label="Minimum insertion length (bp)"/>
            <param argument="-filter_ins_unique_reads" type="integer" value="2" min="1" label="Minimum unique reads supporting an insertion"/>
            <param argument="-filter_ins_total_reads" type="integer" value="1" min="1" label="Minimum total reads supporting an insertion"/>
            <param argument="-filter_ins_vaf" type="float" value="0.006" min="0" max="100" label="Minimum variant allele frequency (%)"/>
        </section>
        <section name="alignment" title="Alignment scoring" expanded="false">
            <param argument="-minscore_inserts" type="float" value="0.5" min="0" max="1" label="Min alignment score fraction for ITD detection"/>
            <param argument="-minscore_alignments" type="float" value="0.4" min="0" max="1" label="Min alignment score fraction for reads"/>
            <param argument="-gap_open" type="integer" value="-36" label="Gap opening cost"/>
            <param argument="-gap_extend" type="float" value="-0.5" label="Gap extension cost"/>
            <param argument="-match" type="integer" value="5" label="Match score"/>
            <param argument="-mismatch" type="integer" value="-15" label="Mismatch score"/>
            <param argument="-max_trailing_bp" type="integer" value="0" min="0" label="Max trailing bp for trailing-ITD detection" help="0 disables trailing-ITD detection."/>
        </section>
        <param argument="-plot_coverage" type="boolean" truevalue="-plot_coverage True" falsevalue="" checked="false" label="Plot read coverage" help="Generate a coverage plot across the reference."/>
    </inputs>
    <outputs>
        <data name="config" format="txt" label="${tool.name} on ${on_string}: config" from_work_dir="sample_getitd/config.txt"/>
        <data name="stats" format="txt" label="${tool.name} on ${on_string}: stats" from_work_dir="sample_getitd/stats.txt"/>
        <data name="coverage" format="tabular" label="${tool.name} on ${on_string}: coverage" from_work_dir="sample_getitd/coverage.txt"/>
        <data name="coverage_plot" format="png" label="${tool.name} on ${on_string}: coverage plot" from_work_dir="sample_getitd/coverage.png">
            <filter>plot_coverage</filter>
        </data>
        <collection name="itds" type="list" label="${tool.name} on ${on_string}: ITD tables">
            <discover_datasets pattern="(?P&lt;designation&gt;itds.+)\.tsv" directory="sample_getitd" format="tabular"/>
        </collection>
        <collection name="insertions" type="list" label="${tool.name} on ${on_string}: insertion tables">
            <discover_datasets pattern="(?P&lt;designation&gt;insertions.+)\.tsv" directory="sample_getitd" format="tabular"/>
        </collection>
    </outputs>
    <tests>
        <test expect_num_outputs="5">
            <conditional name="library">
                <param name="library_type" value="paired"/>
                <param name="fastq1" value="test_R1.fastq.gz" ftype="fastqsanger.gz"/>
                <param name="fastq2" value="test_R2.fastq.gz" ftype="fastqsanger.gz"/>
            </conditional>
            <output name="config">
                <assert_contents>
                    <has_text text="1.5.16"/>
                </assert_contents>
            </output>
            <output_collection name="itds" type="list">
                <element name="itds_collapsed-is-same_is-similar_is-close_is-same_trailing_hc">
                    <assert_contents>
                        <has_text text="vaf"/>
                    </assert_contents>
                </element>
            </output_collection>
        </test>
        <test expect_num_outputs="5">
            <conditional name="library">
                <param name="library_type" value="paired"/>
                <param name="fastq1" value="test_R1.fastq.gz" ftype="fastqsanger.gz"/>
                <param name="fastq2" value="test_R2.fastq.gz" ftype="fastqsanger.gz"/>
            </conditional>
            <param name="forward_primer" value="GCAATTTAGGTATGAAAGCCAGCTAC"/>
            <param name="reverse_primer" value="CTTTCAGCATTTTGACGGCAACC"/>
            <output name="config">
                <assert_contents>
                    <has_text text="GCAATTTAGGTATGAAAGCCAGCTAC"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help format="markdown"><![CDATA[
## What it does

getITD detects and characterises FLT3 internal tandem duplications (ITDs) from
amplicon sequencing data for minimal residual disease monitoring in AML.

To process several samples at once, use Galaxy's collection / batch handling on
the read inputs: getITD then runs once per sample.

## Inputs

- **Reads**: single-end or paired-end FASTQ (plain or gzipped).
- **Reference / annotation**: the built-in FLT3 amplicon (default) or your own.
- **Primers and adapters**: optional sequences. Leave empty to use getITD's
  built-in defaults.

## Outputs

`config`, `stats`, `coverage`, and the ITD / insertion tables.

More detail: [getITD](https://github.com/tjblaette/getitd)
    ]]></help>
    <creator>
        <person givenName="Joachim" familyName="Wolff"/>
        <person givenName="Tamara" familyName="Blätte"/>
    </creator>
    <expand macro="citations"/>
</tool>
