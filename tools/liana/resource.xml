<tool id="liana_resource" name="Liana Resource" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>prior knowledge and ligand-receptor resources</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="bio_tools"/>
    <expand macro="creators"/>
    <expand macro="requirements"/>
    <expand macro="version_command"/>
    <command detect_errors="exit_code"><![CDATA[
cat '$script_file' > '$hidden_output' &&
python '$script_file' >> '$hidden_output' 2>&1
    ]]></command>
    <configfiles>
        <configfile name="script_file"><![CDATA[
@CMD_IMPORTS@

def _parse_csv(value):
    return [x.strip() for x in str(value).split(',') if x.strip()]


def _prepare_ortholog_map(frame, source_description):
    """Normalize an ortholog table to source/target columns for LIANA."""
    if {'source', 'target'}.issubset(frame.columns):
        mapping = frame[['source', 'target']].copy()
    elif 'human_symbol' in frame.columns:
        target_columns = [
            column for column in frame.columns
            if column.endswith('_symbol') and column != 'human_symbol'
        ]
        if len(target_columns) != 1:
            raise ValueError(
                f"The {source_description} must contain exactly one target-species '*_symbol' "
                f"column alongside 'human_symbol'; found {target_columns or 'none'}."
            )
        mapping = frame[['human_symbol', target_columns[0]]].copy()
        mapping.columns = ['source', 'target']
    elif frame.shape[1] == 2:
        mapping = frame.iloc[:, :2].copy()
        mapping.columns = ['source', 'target']
    else:
        raise ValueError(
            f"The {source_description} must contain 'source' and 'target' columns, "
            "one human_symbol and one target-species *_symbol column, or exactly two columns."
        )

    mapping = mapping.dropna().drop_duplicates()
    mapping['source'] = mapping['source'].astype(str).str.strip()
    mapping['target'] = mapping['target'].astype(str).str.strip()
    mapping = mapping[(mapping['source'] != '') & (mapping['target'] != '')]
    if mapping.empty:
        raise ValueError(f"The {source_description} contains no non-empty ortholog mappings.")
    return mapping[['source', 'target']]

#if str($method.method) == 'select_resource'
#if str($method.resource_api_cached.resource_source_selector) == 'cached'
# Cached: read from Data Manager path (path is directory, file is path/value.tsv)
import os
resource_path = '$method.resource_api_cached.resource_cached.fields.path'
resource_value = '$method.resource_api_cached.resource_cached.fields.value'
tsv_path = os.path.join(resource_path, resource_value + '.tsv')
resource = pd.read_csv(tsv_path, sep='\t')
#else
resource = li.resource.select_resource(resource_name='$method.resource_api_cached.resource_name')
#end if
resource.to_csv('resource_output.tsv', sep='\t', index=False)

#else if str($method.method) == 'show_resources'
resources = li.resource.show_resources()
with open('resources_list.txt', 'w') as f:
    for r in resources:
        f.write(r + '\n')



#elif str($method.method) == 'get_metalinks'
metalinks_filters = {
    'type': [
    #for $t in $method.types
        '$t',
    #end for
    ],
    'cell_location': _parse_csv('$method.cell_location'),
    'tissue_location': _parse_csv('$method.tissue_location'),
    'biospecimen_location': _parse_csv('$method.biospecimen_location'),
    'disease': _parse_csv('$method.disease'),
    'pathway': _parse_csv('$method.pathway'),
    'hmdb': _parse_csv('$method.hmdb_ids'),
    'uniprot': _parse_csv('$method.uniprot_ids'),
    'source': _parse_csv('$method.source'),
}

#if str($method.metalinks_source.source_selector) == 'cached'
metalinks_path = '$method.metalinks_source.metalinks_cached.fields.path'
metalinks_value = '$method.metalinks_source.metalinks_cached.fields.value'
tsv_path = os.path.join(metalinks_path, metalinks_value + '.tsv')
metalinks = pd.read_csv(tsv_path, sep='\t')
for column, accepted_values in metalinks_filters.items():
    if accepted_values:
        if column not in metalinks.columns:
            raise ValueError(f"Cached Metalinks table has no '{column}' column required by the selected filter")
        metalinks = metalinks[metalinks[column].astype(str).isin(accepted_values)]
#else
metalinks = li.resource.get_metalinks(
    types=metalinks_filters['type'] or None,
    cell_location=metalinks_filters['cell_location'] or None,
    tissue_location=metalinks_filters['tissue_location'] or None,
    biospecimen_location=metalinks_filters['biospecimen_location'] or None,
    disease=metalinks_filters['disease'] or None,
    pathway=metalinks_filters['pathway'] or None,
    hmdb_ids=metalinks_filters['hmdb'] or None,
    uniprot_ids=metalinks_filters['uniprot'] or None,
    source=metalinks_filters['source'] or None,
)
#end if
metalinks.to_csv('metalinks.tsv', sep='\t', index=False)

#else if str($method.method) == 'get_hcop_orthologs'
#if str($method.hcop_source.source_selector) == 'cached'
hcop_path = '$method.hcop_source.hcop_cached.fields.path'
hcop_value = '$method.hcop_source.hcop_cached.fields.value'
tsv_path = os.path.join(hcop_path, hcop_value + '.tsv')
orthologs = pd.read_csv(tsv_path, sep='\t')
#else
orthologs = li.resource.get_hcop_orthologs(
    target_organism='$method.hcop_source.target_organism',
    #if str($method.hcop_source.url).strip() != '':
    url='$method.hcop_source.url',
    #end if
    min_evidence=$method.hcop_source.min_evidence,
    #if str($method.hcop_source.columns).strip() != '':
    columns=_parse_csv('$method.hcop_source.columns'),
    #end if
)
#end if
orthologs.to_csv('orthologs.tsv', sep='\t', index=False)

#else if str($method.method) == 'translate_resource'
#if str($method.resource_input.resource_source) == 'builtin':
#if str($method.resource_input.resource_api_cached.resource_source_selector) == 'cached'
import os
resource_path = '$method.resource_input.resource_api_cached.resource_cached.fields.path'
resource_value = '$method.resource_input.resource_api_cached.resource_cached.fields.value'
tsv_path = os.path.join(resource_path, resource_value + '.tsv')
resource = pd.read_csv(tsv_path, sep='\t')
#else
resource = li.resource.select_resource(resource_name='$method.resource_input.resource_api_cached.resource_name')
#end if
#else:
resource = pd.read_csv('$method.resource_input.resource_file', sep='\t')
#end if
#if str($method.mapping_api_cached.mapping_source_selector) == 'cached'
hcop_path = '$method.mapping_api_cached.hcop_cached.fields.path'
hcop_value = '$method.mapping_api_cached.hcop_cached.fields.value'
hcop_tsv_path = os.path.join(hcop_path, hcop_value + '.tsv')
map_df = _prepare_ortholog_map(
    pd.read_csv(hcop_tsv_path, sep='\t'),
    'cached HCOP resource',
)
#elif str($method.mapping_api_cached.mapping_source_selector) == 'builtin'
map_df = li.resource.get_hcop_orthologs(
    target_organism='$method.mapping_api_cached.target_organism',
    #if str($method.mapping_api_cached.url).strip() != '':
    url='$method.mapping_api_cached.url',
    #end if
    min_evidence=$method.mapping_api_cached.min_evidence,
)
map_df = _prepare_ortholog_map(map_df, 'HCOP mapping downloaded by LIANA')
#else
map_df = _prepare_ortholog_map(
    pd.read_csv('$method.mapping_api_cached.map_file', sep='\t'),
    'history ortholog mapping file',
)
#end if
translated = li.resource.translate_resource(
    resource=resource,
    map_df=map_df,
    columns=_parse_csv('$method.columns') or None)
translated.to_csv('translated_resource.tsv', sep='\t', index=False)

#end if
        ]]></configfile>
    </configfiles>
    <inputs>
        <conditional name="method">
            <param name="method" type="select" label="Method">
                <option value="select_resource" selected="true">select_resource - Get ligand-receptor resource</option>
                <option value="show_resources">show_resources - List available resources</option>
                <option value="get_metalinks">get_metalinks - Get metabolite-protein interactions</option>
                <option value="get_hcop_orthologs">get_hcop_orthologs - Get HCOP ortholog mappings</option>
                <option value="translate_resource">translate_resource - Translate resource to another species</option>
            </param>
            <when value="select_resource">
                <conditional name="resource_api_cached">
                    <param name="resource_source_selector" type="select" label="Resource source" help="Use cached resources from this Galaxy server (installed via Data Manager) for fast offline access, or download from LIANA API.">
                        <option value="builtin">Download from LIANA API</option>
                        <option value="cached" selected="true">Cached on server (from Data Manager)</option>
                    </param>
                    <when value="cached">
                        <expand macro="param_cached_lr_resource"/>
                    </when>
                    <when value="builtin">
                        <expand macro="param_resource_name"/>
                    </when>
                </conditional>
            </when>
            <when value="show_resources">
                <!-- No parameters needed -->
            </when>
            <when value="get_metalinks">
                <conditional name="metalinks_source">
                    <param name="source_selector" type="select" label="Metalinks source">
                        <option value="cached" selected="true">Cached on Galaxy server (from Data Manager)</option>
                        <option value="builtin">Fetch with LIANA</option>
                    </param>
                    <when value="cached">
                        <param name="metalinks_cached" type="select" label="Cached Metalinks resource">
                            <options from_data_table="liana_resources">
                                <filter type="regexp" column="value" value="^metalinks_"/>
                                <filter type="sort_by" column="name"/>
                                <validator type="no_options" message="No cached Metalinks resources available. Install them via Admin → Data Managers."/>
                            </options>
                        </param>
                    </when>
                    <when value="builtin"/>
                </conditional>
                <param name="types" type="select" multiple="true" optional="true" label="Edge types" help="lr = ligand-receptor; pd = production-degradation">
                    <option value="lr">Ligand-receptor (lr)</option>
                    <option value="pd">Production-degradation (pd)</option>
                </param>
                <param name="cell_location" type="text" optional="true" label="Cell location" help="Comma-separated values">
                    <expand macro="sanitize_query"/>
                    <expand macro="validator_optional_csv" FIELD="cell-location list"/>
                </param>
                <param name="tissue_location" type="text" optional="true" label="Tissue location" help="Comma-separated values">
                    <expand macro="sanitize_query"/>
                    <expand macro="validator_optional_csv" FIELD="tissue-location list"/>
                </param>
                <param name="biospecimen_location" type="text" optional="true" label="Biospecimen location" help="Comma-separated values">
                    <expand macro="sanitize_query"/>
                    <expand macro="validator_optional_csv" FIELD="biospecimen-location list"/>
                </param>
                <param name="disease" type="text" optional="true" label="Disease" help="Comma-separated values">
                    <expand macro="sanitize_query"/>
                    <expand macro="validator_optional_csv" FIELD="disease list"/>
                </param>
                <param name="pathway" type="text" optional="true" label="Pathway" help="Comma-separated values">
                    <expand macro="sanitize_query"/>
                    <expand macro="validator_optional_csv" FIELD="pathway list"/>
                </param>
                <param name="hmdb_ids" type="text" optional="true" label="HMDB IDs" help="Comma-separated values">
                    <expand macro="sanitize_query"/>
                    <expand macro="validator_optional_csv" FIELD="HMDB-ID list"/>
                </param>
                <param name="uniprot_ids" type="text" optional="true" label="UniProt IDs" help="Comma-separated values">
                    <expand macro="sanitize_query"/>
                    <expand macro="validator_optional_csv" FIELD="UniProt-ID list"/>
                </param>
                <param name="source" type="text" optional="true" label="Source database" help="Comma-separated values">
                    <expand macro="sanitize_query"/>
                    <expand macro="validator_optional_csv" FIELD="source-database list"/>
                </param>
            </when>
            <when value="get_hcop_orthologs">
                <conditional name="hcop_source">
                    <param name="source_selector" type="select" label="HCOP source">
                        <option value="cached" selected="true">Cached on Galaxy server (from Data Manager)</option>
                        <option value="builtin">Download with LIANA</option>
                    </param>
                    <when value="cached">
                        <expand macro="param_cached_hcop_resource"/>
                    </when>
                    <when value="builtin">
                        <expand macro="params_hcop_download"/>
                        <param argument="columns" type="text" value="" optional="true" label="Columns to retain" help="Optional comma-separated output columns; empty keeps all columns.">
                            <expand macro="sanitize_query"/>
                            <expand macro="validator_optional_csv" FIELD="output-column list"/>
                        </param>
                    </when>
                </conditional>
            </when>
            <when value="translate_resource">
                <conditional name="resource_input">
                    <param name="resource_source" type="select" label="Resource source">
                        <option value="builtin" selected="true">Built-in resource</option>
                        <option value="file">Custom resource file</option>
                    </param>
                    <when value="builtin">
                        <conditional name="resource_api_cached">
                            <param name="resource_source_selector" type="select" label="Resource source" help="Use cached resources from this Galaxy server (installed via Data Manager) for fast offline access, or use the built-in LIANA resource definitions.">
                                <option value="builtin">Built into LIANA</option>
                                <option value="cached" selected="true">Cached on Galaxy server (from Data Manager)</option>
                            </param>
                            <when value="cached">
                                <expand macro="param_cached_lr_resource"/>
                            </when>
                            <when value="builtin">
                                <expand macro="param_resource_name"/>
                            </when>
                        </conditional>
                    </when>
                    <when value="file">
                        <param name="resource_file" type="data" format="tabular" label="Resource file" help="Tabular file with ligand and receptor columns"/>
                    </when>
                </conditional>
                <conditional name="mapping_api_cached">
                    <param name="mapping_source_selector" type="select" label="Ortholog mapping source" help="Use an administrator-cached HCOP table, download HCOP through LIANA, or provide a mapping from the current history.">
                        <option value="cached" selected="true">Cached on Galaxy server (from Data Manager)</option>
                        <option value="builtin">Download with LIANA</option>
                        <option value="history">Mapping table from history</option>
                    </param>
                    <when value="cached">
                        <expand macro="param_cached_hcop_resource"/>
                    </when>
                    <when value="builtin">
                        <expand macro="params_hcop_download"/>
                    </when>
                    <when value="history">
                        <param name="map_file" type="data" format="tabular" label="Ortholog mapping file" help="The first two columns are treated as source and target. LIANA HCOP output with human_symbol and one target-species *_symbol column is also accepted."/>
                    </when>
                </conditional>
                <param argument="columns" type="text" value="ligand,receptor" label="Columns to translate" help="Comma-separated list of column names to translate (e.g., ligand,receptor).">
                    <expand macro="sanitize_query"/>
                    <expand macro="validator_required_csv" FIELD="column list"/>
                </param>
            </when>
        </conditional>
        <expand macro="inputs_common_advanced"/>
    </inputs>
    <outputs>
        <data name="resource_out" format="tabular" from_work_dir="resource_output.tsv" label="${tool.name} (${method.method}) on ${on_string}: Resource">
            <filter>method['method'] == 'select_resource'</filter>
        </data>
        <data name="resources_list_out" format="txt" from_work_dir="resources_list.txt" label="${tool.name} (${method.method}): Available resources">
            <filter>method['method'] == 'show_resources'</filter>
        </data>
        <data name="metalinks_out" format="tabular" from_work_dir="metalinks.tsv" label="${tool.name} (${method.method}): Metalinks">
            <filter>method['method'] == 'get_metalinks'</filter>
        </data>
        <data name="orthologs_out" format="tabular" from_work_dir="orthologs.tsv" label="${tool.name} (${method.method}): HCOP ortholog mappings">
            <filter>method['method'] == 'get_hcop_orthologs'</filter>
        </data>
        <data name="translated_out" format="tabular" from_work_dir="translated_resource.tsv" label="${tool.name} (${method.method}): Translated resource">
            <filter>method['method'] == 'translate_resource'</filter>
        </data>
        <data name="hidden_output" format="txt" label="Log file">
            <filter>advanced_common['show_log']</filter>
        </data>
    </outputs>
    <tests>
        <!-- Test 1: select_resource with cached DB (no download) -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="select_resource"/>
                <conditional name="resource_api_cached">
                    <param name="resource_source_selector" value="cached"/>
                    <param name="resource_cached" value="consensus"/>
                </conditional>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="resource_out" ftype="tabular">
                <assert_contents>
                    <has_text text="ligand"/>
                    <has_text text="receptor"/>
                    <has_n_columns n="2"/>
                    <has_text_matching expression="LGALS9\s+PTPRC"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="pd.read_csv"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 2: select_resource from LIANA API (downloads) -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="select_resource"/>
                <conditional name="resource_api_cached">
                    <param name="resource_source_selector" value="builtin"/>
                    <param name="resource_name" value="consensus"/>
                </conditional>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="resource_out" location="https://zenodo.org/records/18388645/files/resource_consensus.tsv" ftype="tabular">
                <assert_contents>
                    <has_text text="ligand"/>
                    <has_text text="receptor"/>
                    <has_n_columns n="2"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="li.resource.select_resource"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 3: show_resources -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="show_resources"/>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="resources_list_out" location="https://zenodo.org/records/18388645/files/resources_list.txt" ftype="txt">
                <assert_contents>
                    <has_text text="consensus"/>
                    <has_text text="cellphonedb"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="li.resource.show_resources"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 4: get_hcop_orthologs from cached resource -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="get_hcop_orthologs"/>
                <conditional name="hcop_source">
                    <param name="source_selector" value="cached"/>
                    <param name="hcop_cached" value="hcop_human_mouse"/>
                </conditional>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="orthologs_out" ftype="tabular">
                <assert_contents>
                    <has_text text="human_symbol"/>
                    <has_text text="mouse_symbol"/>
                    <has_n_columns min="2"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="pd.read_csv"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 5: translate_resource with cached resource -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="translate_resource"/>
                <conditional name="resource_input">
                    <param name="resource_source" value="builtin"/>
                    <conditional name="resource_api_cached">
                        <param name="resource_source_selector" value="cached"/>
                        <param name="resource_cached" value="consensus"/>
                    </conditional>
                </conditional>
                <conditional name="mapping_api_cached">
                    <param name="mapping_source_selector" value="history"/>
                    <param name="map_file" value="ortholog_map.tsv" ftype="tabular"/>
                </conditional>
                <param name="columns" value="ligand,receptor"/>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="translated_out" ftype="tabular">
                <assert_contents>
                    <has_text text="ligand"/>
                    <has_text text="receptor"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="resource = pd.read_csv"/>
                </assert_contents>
            </output>
        </test>
