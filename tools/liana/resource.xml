<tool id="liana_resource" name="Liana Resource" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>prior knowledge and ligand-receptor resources</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="bio_tools"/>
    <expand macro="creators"/>
    <expand macro="requirements"/>
    <expand macro="version_command"/>
    <command detect_errors="exit_code"><![CDATA[
cat '$script_file' > '$hidden_output' &&
python '$script_file' >> '$hidden_output' 2>&1
    ]]></command>
    <configfiles>
        <configfile name="script_file"><![CDATA[
@CMD_IMPORTS@

#if str($method.method) == 'select_resource'
#if str($method.resource_api_cached.resource_source_selector) == 'cached'
# Cached: read from Data Manager path (path is directory, file is path/value.tsv)
import os
resource_path = '$method.resource_api_cached.resource_cached.fields.path'
resource_value = '$method.resource_api_cached.resource_cached.fields.value'
tsv_path = os.path.join(resource_path, resource_value + '.tsv')
resource = pd.read_csv(tsv_path, sep='\t')
#else
resource = li.resource.select_resource(resource_name='$method.resource_api_cached.resource_name')
#end if
resource.to_csv('resource_output.tsv', sep='\t', index=False)

#else if str($method.method) == 'show_resources'
resources = li.resource.show_resources()
with open('resources_list.txt', 'w') as f:
    for r in resources:
        f.write(r + '\n')



#elif str($method.method) == 'get_metalinks'
def _parse_csv(value):
    return [x.strip() for x in str(value).split(',') if x.strip()]

#if str($method.metalinks_source.source_selector) == 'cached'
import os
metalinks_path = '$method.metalinks_source.metalinks_cached.fields.path'
metalinks_value = '$method.metalinks_source.metalinks_cached.fields.value'
tsv_path = os.path.join(metalinks_path, metalinks_value + '.tsv')
metalinks = pd.read_csv(tsv_path, sep='\t')
#else
metalinks = li.resource.get_metalinks(
#if str($method.metalinks_source.types) != ''
    types=[
    #for $t in $method.metalinks_source.types
        '$t',
    #end for
    ],
#end if
#if str($method.metalinks_source.cell_location).strip() != ''
    cell_location=_parse_csv('$method.metalinks_source.cell_location'),
#end if
#if str($method.metalinks_source.tissue_location).strip() != ''
    tissue_location=_parse_csv('$method.metalinks_source.tissue_location'),
#end if
#if str($method.metalinks_source.biospecimen_location).strip() != ''
    biospecimen_location=_parse_csv('$method.metalinks_source.biospecimen_location'),
#end if
#if str($method.metalinks_source.disease).strip() != ''
    disease=_parse_csv('$method.metalinks_source.disease'),
#end if
#if str($method.metalinks_source.pathway).strip() != ''
    pathway=_parse_csv('$method.metalinks_source.pathway'),
#end if
#if str($method.metalinks_source.hmdb_ids).strip() != ''
    hmdb_ids=_parse_csv('$method.metalinks_source.hmdb_ids'),
#end if
#if str($method.metalinks_source.uniprot_ids).strip() != ''
    uniprot_ids=_parse_csv('$method.metalinks_source.uniprot_ids'),
#end if
#if str($method.metalinks_source.source).strip() != ''
    source=_parse_csv('$method.metalinks_source.source'),
#end if
)
#end if
metalinks.to_csv('metalinks.tsv', sep='\t', index=False)


#else if str($method.method) == 'get_hcop_orthologs'
#if str($method.ortholog_source.source_selector) == 'cached'
import os
ortholog_path = '$method.ortholog_source.ortholog_cached.fields.path'
ortholog_value = '$method.ortholog_source.ortholog_cached.fields.value'
tsv_path = os.path.join(ortholog_path, ortholog_value + '.tsv')
print("Reading cached orthologs from:", tsv_path)
orthologs = pd.read_csv(tsv_path, sep='\t')
#else
#if str($method.ortholog_source.url_selector.url_mode) == 'manual'
hcop_url = '$method.ortholog_source.url_selector.custom_url'
#else
hcop_url = '$method.ortholog_source.url_selector.url'
#end if
print("HCOP URL:", hcop_url)
print("Minimum evidence:", $method.ortholog_source.min_evidence)

try:
    orthologs = li.resource.get_hcop_orthologs(
        url=hcop_url,
        min_evidence=$method.ortholog_source.min_evidence
    )
    print("Orthologs shape:", orthologs.shape)
    print("Ortholog columns:", list(orthologs.columns))
except Exception as e:
    import traceback
    traceback.print_exc()
    raise
#end if
orthologs.to_csv('orthologs.tsv', sep='\t', index=False)

#else if str($method.method) == 'translate_resource'
#if str($method.resource_input.resource_source) == 'builtin':
#if str($method.resource_input.resource_api_cached.resource_source_selector) == 'cached'
import os
resource_path = '$method.resource_input.resource_api_cached.resource_cached.fields.path'
resource_value = '$method.resource_input.resource_api_cached.resource_cached.fields.value'
tsv_path = os.path.join(resource_path, resource_value + '.tsv')
resource = pd.read_csv(tsv_path, sep='\t')
#else
resource = li.resource.select_resource(resource_name='$method.resource_input.resource_api_cached.resource_name')
#end if
#else:
resource = pd.read_csv('$method.resource_input.resource_file', sep='\t')
#end if
map_df = pd.read_csv('$method.map_df', sep='\t')
translated = li.resource.translate_resource(
    resource=resource,
    map_df=map_df,
    columns='$method.columns'.split(',') if '$method.columns' else None)
translated.to_csv('translated_resource.tsv', sep='\t', index=False)

#end if
        ]]></configfile>
    </configfiles>
    <inputs>
        <conditional name="method">
            <param name="method" type="select" label="Method">
                <option value="select_resource" selected="true">select_resource - Get ligand-receptor resource</option>
                <option value="show_resources">show_resources - List available resources</option>
                <option value="get_metalinks">get_metalinks - Get metabolite-protein interactions</option>
                <option value="get_hcop_orthologs">get_hcop_orthologs - Get ortholog mappings from HCOP</option>
                <option value="translate_resource">translate_resource - Translate resource to another species</option>
            </param>
            <when value="select_resource">
                <conditional name="resource_api_cached">
                            <param name="resource_source_selector" type="select" label="Resource source" help="Use cached resources from this Galaxy server (installed via Data Manager) for fast offline access, or use the built-in LIANA resource definitions.">
                                <option value="builtin">Built into LIANA</option>
                                <option value="cached" selected="true">Cached on Galaxy server (from Data Manager)</option>
                            </param>
                            <when value="cached">
                                <param name="resource_cached" type="select" label="Ligand-receptor database (cached)" help="Select from resources installed by the LIANA Resources Data Manager.">
                                    <options from_data_table="liana_resources">
                                        <filter type="sort_by" column="name"/>
                                        <validator type="no_options" message="No cached LIANA ligand-receptor resources available. Install them via Admin → Data Managers → Download LIANA Resources."/>
                                    </options>
                                </param>
                            </when>
                            <when value="builtin">
                                <expand macro="param_resource_name"/>
                            </when>
                </conditional>
            </when>
            <when value="show_resources">
                <!-- No parameters needed -->
            </when>
            <when value="get_metalinks">
                <conditional name="metalinks_source">
                    <param name="source_selector" type="select" label="Metalinks source">
                        <option value="cached" selected="true">Cached on Galaxy server (from Data Manager)</option>
                        <option value="builtin">Fetch with LIANA</option>
                    </param>
                    <when value="cached">
                        <param name="metalinks_cached" type="select" label="Cached Metalinks resource">
                            <options from_data_table="liana_resources">
                                <filter type="sort_by" column="name"/>
                                <validator type="no_options" message="No cached Metalinks resources available. Install them via Admin → Data Managers."/>
                            </options>
                        </param>
                    </when>
                    <when value="builtin">
                        <param name="types" type="select" multiple="true" optional="true" label="Edge types" help="lr = ligand-receptor; pd = production-degradation">
                            <option value="lr">Ligand-receptor (lr)</option>
                            <option value="pd">Production-degradation (pd)</option>
                        </param>
                        <param name="cell_location" type="text" optional="true" label="Cell location" help="Comma-separated values" />
                        <param name="tissue_location" type="text" optional="true" label="Tissue location" help="Comma-separated values" />
                        <param name="biospecimen_location" type="text" optional="true" label="Biospecimen location" help="Comma-separated values" />
                        <param name="disease" type="text" optional="true" label="Disease" help="Comma-separated values" />
                        <param name="pathway" type="text" optional="true" label="Pathway" help="Comma-separated values" />
                        <param name="hmdb_ids" type="text" optional="true" label="HMDB IDs" help="Comma-separated HMDB identifiers" />
                        <param name="uniprot_ids" type="text" optional="true" label="UniProt IDs" help="Comma-separated UniProt identifiers" />
                        <param name="source" type="text" optional="true" label="Source" help="Comma-separated values" />
                    </when>
                </conditional>
            </when>
            <when value="get_hcop_orthologs">
                <conditional name="ortholog_source">
                    <param name="source_selector" type="select" label="Ortholog mapping source" help="Use a cached ortholog mapping installed by the Data Manager, or download one from HCOP.">
                        <option value="cached" selected="true">Cached on Galaxy server (from Data Manager)</option>
                        <option value="builtin">Download from HCOP</option>
                    </param>
                    <when value="cached">
                        <param name="ortholog_cached" type="select" label="Cached ortholog mapping" help="Select from ortholog mappings installed by the LIANA Resources Data Manager.">
                            <options from_data_table="liana_resources">
                                <filter type="sort_by" column="name"/>
                                <validator type="no_options" message="No cached LIANA ligand-receptor resources available. Install them via Admin → Data Managers → Download LIANA Resources."/>
                            </options>
                        </param>
                    </when>
                    <when value="builtin">
                        <conditional name="url_selector">
                            <param name="url_mode" type="select" label="HCOP URL source">
                                <option value="preset" selected="true">Use preset HCOP URL</option>
                                <option value="manual">Enter custom HCOP URL</option>
                            </param>
                            <when value="preset">
                                <param name="url" type="select" label="Species mapping">
                                    <option value="https://ftp.ebi.ac.uk/pub/databases/genenames/hcop/human_mouse_hcop_fifteen_column.txt.gz" selected="true">Human to Mouse</option>
                                    <option value="https://ftp.ebi.ac.uk/pub/databases/genenames/hcop/human_rat_hcop_fifteen_column.txt.gz">Human to Rat</option>
                                    <option value="https://ftp.ebi.ac.uk/pub/databases/genenames/hcop/human_chicken_hcop_fifteen_column.txt.gz">Human to Chicken</option>
                                    <option value="https://ftp.ebi.ac.uk/pub/databases/genenames/hcop/human_zebrafish_hcop_fifteen_column.txt.gz">Human to Zebrafish</option>
                                </param>
                            </when>
                            <when value="manual">
                                <param name="custom_url" type="text" optional="true" label="Custom HCOP URL">
                                    <expand macro="sanitize_query"/>
                                </param>
                            </when>
                        </conditional>
                        <param argument="min_evidence" type="integer" value="3" min="1" label="Minimum evidence" help="Minimum number of orthology resources supporting the interaction."/>
                    </when>
                </conditional>
            </when>
            <when value="translate_resource">
                <conditional name="resource_input">
                    <param name="resource_source" type="select" label="Resource source">
                        <option value="builtin" selected="true">Built-in resource</option>
                        <option value="file">Custom resource file</option>
                    </param>
                    <when value="builtin">
                        <conditional name="resource_api_cached">
                            <param name="resource_source_selector" type="select" label="Resource source" help="Use cached resources from this Galaxy server (installed via Data Manager) for fast offline access, or use the built-in LIANA resource definitions.">
                                <option value="builtin">Built into LIANA</option>
                                <option value="cached" selected="true">Cached on Galaxy server (from Data Manager)</option>
                            </param>
                            <when value="cached">
                                <param name="resource_cached" type="select" label="Ligand-receptor database (cached)" help="Select from resources installed by the LIANA Resources Data Manager.">
                                    <options from_data_table="liana_resources">
                                        <filter type="sort_by" column="name"/>
                                        <validator type="no_options" message="No cached LIANA ligand-receptor resources available. Install them via Admin → Data Managers → Download LIANA Resources."/>
                                    </options>
                                </param>
                            </when>
                            <when value="builtin">
                                <expand macro="param_resource_name"/>
                            </when>
                        </conditional>
                    </when>
                    <when value="file">
                        <param name="resource_file" type="data" format="tabular" label="Resource file" help="Tabular file with ligand and receptor columns"/>
                    </when>
                </conditional>
                <param name="map_df" type="data" format="tabular" label="Ortholog mapping file" help="Tabular file with ortholog mappings. Recommended columns are 'source' and 'target'. This can be generated with get_hcop_orthologs and further edited in Galaxy if needed."/>
                <param argument="columns" type="text" value="ligand,receptor" label="Columns to translate" help="Comma-separated list of column names to translate (e.g., ligand,receptor).">
                    <expand macro="sanitize_query"/>
                </param>
            </when>
        </conditional>
        <expand macro="inputs_common_advanced"/>
    </inputs>
    <outputs>
        <data name="resource_out" format="tabular" from_work_dir="resource_output.tsv" label="${tool.name} (${method.method}) on ${on_string}: Resource">
            <filter>method['method'] == 'select_resource'</filter>
        </data>
        <data name="resources_list_out" format="txt" from_work_dir="resources_list.txt" label="${tool.name} (${method.method}): Available resources">
            <filter>method['method'] == 'show_resources'</filter>
        </data>
        <data name="metalinks_out" format="tabular" from_work_dir="metalinks.tsv" label="${tool.name} (${method.method}): Metalinks">
            <filter>method['method'] == 'get_metalinks'</filter>
        </data>
        <data name="orthologs_out" format="tabular" from_work_dir="orthologs.tsv" label="${tool.name} (${method.method}): Ortholog mappings">
            <filter>method['method'] == 'get_hcop_orthologs'</filter>
        </data>
        <data name="translated_out" format="tabular" from_work_dir="translated_resource.tsv" label="${tool.name} (${method.method}): Translated resource">
            <filter>method['method'] == 'translate_resource'</filter>
        </data>
        <data name="hidden_output" format="txt" label="Log file">
            <filter>advanced_common['show_log']</filter>
        </data>
    </outputs>
    <tests>
        <!-- Test 1: select_resource with cached DB (no download) -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="select_resource"/>
                <conditional name="resource_api_cached">
                    <param name="resource_source_selector" value="cached"/>
                    <param name="resource_cached" value="consensus"/>
                </conditional>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="resource_out" ftype="tabular">
                <assert_contents>
                    <has_text text="ligand"/>
                    <has_text text="receptor"/>
                    <has_n_columns n="2"/>
                    <has_text_matching expression="LGALS9\s+PTPRC" />
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="pd.read_csv"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 2: select_resource from LIANA API (downloads) -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="select_resource"/>
                <conditional name="resource_api_cached">
                    <param name="resource_source_selector" value="builtin"/>
                    <param name="resource_name" value="consensus"/>
                </conditional>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="resource_out" location="https://zenodo.org/records/18388645/files/resource_consensus.tsv" ftype="tabular">
                <assert_contents>
                    <has_text text="ligand"/>
                    <has_text text="receptor"/>
                    <has_n_columns n="2"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="li.resource.select_resource"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 3: show_resources -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="show_resources"/>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="resources_list_out" location="https://zenodo.org/records/18388645/files/resources_list.txt" ftype="txt">
                <assert_contents>
                    <has_text text="consensus"/>
                    <has_text text="cellphonedb"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="li.resource.show_resources"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 4: get_hcop_orthologs from HCOP -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="get_hcop_orthologs"/>
                <conditional name="ortholog_source">
                    <param name="source_selector" value="builtin"/>
                    <conditional name="url_selector">
                        <param name="url_mode" value="preset"/>
                        <param name="url" value="https://ftp.ebi.ac.uk/pub/databases/genenames/hcop/human_mouse_hcop_fifteen_column.txt.gz"/>
                    </conditional>
                    <param name="min_evidence" value="3"/>
                </conditional>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="orthologs_out" ftype="tabular">
                <assert_contents>
                    <has_text text="human_symbol"/>
                    <has_text text="mouse_symbol"/>
                    <has_n_columns min="2"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="li.resource.get_hcop_orthologs"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 5: get_hcop_orthologs with cached mapping -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="get_hcop_orthologs"/>
                <conditional name="ortholog_source">
                    <param name="source_selector" value="cached"/>
                    <param name="ortholog_cached" value="hcop_human_mouse"/>
                </conditional>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="orthologs_out" ftype="tabular">
                <assert_contents>
                    <has_text text="human_symbol"/>
                    <has_n_columns min="2"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="pd.read_csv"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 6: translate_resource with cached resource -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="translate_resource"/>
                <conditional name="resource_input">
                    <param name="resource_source" value="builtin"/>
                    <conditional name="resource_api_cached">
                        <param name="resource_source_selector" value="cached"/>
                        <param name="resource_cached" value="consensus"/>
                    </conditional>
                </conditional>
                <param name="map_df" value="ortholog_map.tsv" ftype="tabular"/>
                <param name="columns" value="ligand,receptor"/>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="translated_out" ftype="tabular">
                <assert_contents>
                    <has_text text="ligand"/>
                    <has_text text="receptor"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="resource = pd.read_csv"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 7: translate_resource with built-in resource -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="translate_resource"/>
                <conditional name="resource_input">
                    <param name="resource_source" value="builtin"/>
                    <conditional name="resource_api_cached">
                        <param name="resource_source_selector" value="builtin"/>
                        <param name="resource_name" value="consensus"/>
                    </conditional>
                </conditional>
                <param name="map_df" location="https://zenodo.org/records/18388645/files/ortholog_map.tsv" ftype="tabular"/>
                <param name="columns" value="ligand,receptor"/>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="translated_out" ftype="tabular">
                <assert_contents>
                    <has_text text="ligand"/>
                    <has_text text="receptor"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="li.resource.translate_resource"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 8: get_metalinks via LIANA -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="get_metalinks"/>
                <conditional name="metalinks_source">
                    <param name="source_selector" value="builtin"/>
                    <param name="types" value="lr"/>
                </conditional>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="metalinks_out" ftype="tabular">
                <assert_contents>
                    <has_text text="type"/>
                    <has_text text="metabolite"/>
                    <has_text text="gene_symbol"/>
                    <has_n_columns min="4"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="li.resource.get_metalinks"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 9: get_metalinks from cached resource -->
        <test expect_num_outputs="2">
            <conditional name="method">
                <param name="method" value="get_metalinks"/>
                <conditional name="metalinks_source">
                    <param name="source_selector" value="cached"/>
                    <param name="metalinks_cached" value="metalinks"/>
                </conditional>
            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="metalinks_out" ftype="tabular">
                <assert_contents>
                    <has_text text="type"/>
                    <has_text text="metabolite"/>
                    <has_text text="gene_symbol"/>
                    <has_n_columns min="4"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text_matching expression="pd.read_csv"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

This tool provides access to prior knowledge resources from LIANA+ for ligand-receptor interaction analysis.

**Methods**

- **select_resource**: Load a pre-defined ligand-receptor resource. Available resources include consensus, cellphonedb, cellchat, connectome, and more.

- **show_resources**: List all available built-in ligand-receptor resources.

- **get_metalinks**: Retrieve metabolite-protein interaction data from the Metalinks database. Useful for metabolite-mediated cell-cell communication analysis.

- **get_hcop_orthologs**: Retrieve ortholog mappings from HCOP, either from cached resources installed by the Data Manager or by downloading from HCOP. Supports human-mouse, human-rat, human-chicken, and human-zebrafish mappings.

- **translate_resource**: Translate a ligand-receptor resource from one species to another using ortholog mappings. The ortholog mapping can come from your history or from cached resources installed by the Data Manager.

**Available Resources**

The following ligand-receptor resources are available:
- consensus (default): Consensus resource combining multiple databases
- cellphonedb: CellPhoneDB resource
- cellchat: CellChat resource
- connectome: Connectome resource
- natmi: NATMI resource
- And more...

**Outputs**

- Tabular files with ligand-receptor pairs or resource information
- Text file listing available resources (for show_resources)
    ]]></help>
    <expand macro="citations"/>
</tool>
