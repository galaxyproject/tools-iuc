            </conditional>
            <section name="advanced_common">
                <param name="show_log" value="true"/>
            </section>
            <output name="translated_out" ftype="tabular">
                <assert_contents>
                    <has_text text="ligand"/>
                    <has_text text="receptor"/>
                </assert_contents>
            </output>
            <output name="hidden_output">
                <assert_contents>
                    <has_text text="li.resource.get_hcop_orthologs"/>
                    <has_text text="target_organism='mouse'"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 9: get_metalinks via LIANA -->
