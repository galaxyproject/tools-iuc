<tool id="proseg" name="Proseg" version="3.1.1+galaxy0" profile="21.05">
    <description>Probabilistic cell segmentation</description>
    <requirements>
        <requirement type="package" version="3.1.1">rust-proseg</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        ln -s '$transcripts' transcripts.csv &&
        mkdir out_dir &&

        proseg
        --output-path 'out_dir'
        --gene-column '$gene_col'
        --x-column '$x_col'
        --y-column '$y_col'
        --z-column '$z_col'
        --cell-id-column 'cell_id'
        --cell-id-unassigned '0'
        transcripts.csv &&

        mkdir -p '$segmentation_results.files_path' &&
        cp -r out_dir/proseg-output.zarr/* '$segmentation_results.files_path' &&
        echo "Segmentation complete. Results are in the Zarr directory." > '$segmentation_results'
    ]]></command>
    <inputs>
        <param name="transcripts" type="data" format="csv" label="Transcript coordinates"/>
        <param name="gene_col" type="text" value="gene" label="Gene column name" help="e.g., gene"/>
        <param name="x_col" type="text" value="x" label="X coordinate column" help="e.g., x"/>
        <param name="y_col" type="text" value="y" label="Y coordinate column" help="e.g., y"/>
        <param name="z_col" type="text" value="z" label="Z coordinate column" help="e.g., z"/>
    </inputs>
    <outputs>
        <data name="segmentation_results" format="txt" label="${tool.name} on ${on_string}: Summary" />
    </outputs>
    <tests>
        <test>
            <param name="transcripts" value="test_transcripts.csv" ftype="csv"/>
            <param name="gene_col" value="gene"/>
            <param name="x_col" value="x"/>
            <param name="y_col" value="y"/>
            <param name="z_col" value="z"/>
            <output name="segmentation_results">
                <assert_contents>
                    <has_text text="Segmentation complete" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
        Proseg 3.1.1. Results are stored as a Zarr hierarchy in the extra files path.
    ]]></help>
    <citations>
        <citation type="doi">10.1101/2023.11.21.568015</citation>
    </citations>
</tool>
