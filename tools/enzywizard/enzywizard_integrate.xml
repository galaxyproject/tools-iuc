<tool id="enzywizard_integrate" name="EnzyWizard Integrate" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Integrate multiple EnzyWizard JSON reports into a graph representation</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-integrate</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        mkdir -p input_dir &&
        #for $report in $input_reports:
            #set $report_name = str($report.element_identifier)
            #if not $report_name.endswith('.json'):
                #set $report_name = $report_name + '.json'
            #end if
            ln -s '$report' 'input_dir/${report_name}' &&
        #end for
        enzywizard-integrate
        -i input_dir
        @CMD_OUTPUT_DIR@
        @CMD_STRICT@
        @CMD_LOG@
    ]]></command>
    <inputs>
        <param name="input_reports" type="data_collection" collection_type="list" format="json" label="EnzyWizard reports" help="A list collection of EnzyWizard JSON reports. Exactly one clean report is required; add at most one report of each other supported type."/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="strict"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <data name="out_edges" format="json" label="${tool.name} JSON edges report"  from_work_dir="integrate_edges_*.json" />
        <data name="out_nodes" format="json" label="${tool.name} JSON nodes report"  from_work_dir="integrate_nodes_*.json" />
        <data name="out_report" format="json" label="${tool.name} JSON report"  from_work_dir="integrate_report_*.json" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="4">
            <param name="input_reports">
                <collection type="list">
                    <element name="aaprops_report_cleaned_3GP6.json" value="aaprops_report_cleaned_3GP6.json"/>
                    <element name="clean_report_3GP6.json" value="clean_report_3GP6.json"/>
                    <element name="conservation_report_cleaned_3GP6.json" value="conservation_report_cleaned_3GP6.json"/>
                    <element name="disorder_report_cleaned_3GP6.json" value="disorder_report_cleaned_3GP6.json"/>
                    <element name="dock_report_cleaned_3GP6_glucose_fructose.json" value="dock_report_cleaned_3GP6_glucose_fructose.json"/>
                    <element name="embedding_report_cleaned_3GP6.json" value="embedding_report_cleaned_3GP6.json"/>
                    <element name="energy_report_cleaned_3GP6.json" value="energy_report_cleaned_3GP6.json"/>
                    <element name="flexibility_report_cleaned_3GP6.json" value="flexibility_report_cleaned_3GP6.json"/>
                    <element name="hydrocluster_report_cleaned_3GP6.json" value="hydrocluster_report_cleaned_3GP6.json"/>
                    <element name="interaction_report_cleaned_3GP6_docked_glucose_docked_fructose.json" value="interaction_report_cleaned_3GP6_docked_glucose_docked_fructose.json"/>
                    <element name="pocket_report_cleaned_3GP6.json" value="pocket_report_cleaned_3GP6.json"/>
                    <element name="substrate_report_glucose_fructose.json" value="substrate_report_glucose_fructose.json"/>
                </collection>
            </param>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <!-- Edges report: array of interactions -->
            <output name="out_edges">
                <assert_contents>
                    <has_text text="molecular_interaction" />
                    <has_text text="source_node" />
                    <has_text text="target_node" />
                    <has_text text="molecular_interaction_type" />
                    <has_text text="node_index" />
                    <!-- Check for at least one interaction type (e.g., VDW) -->
                    <has_text text="VDW" />
                </assert_contents>
            </output>
            <!-- Nodes report: array of residues with properties -->
            <output name="out_nodes">
                <assert_contents>
                    <has_text text="node_index" />
                    <has_text text="node_type" />
                    <has_text text="residue_index" />
                    <has_text text="residue_name" />
                    <has_text text="residue_alpha_carbon_coordinate" />
                    <!-- Check that first residue is present (e.g., M) -->
                    <has_text text="&quot;M&quot;" />
                </assert_contents>
            </output>
            <!-- Summary report: integrated graph with statistics -->
            <output name="out_report">
                <assert_contents>
                    <has_text text="enzywizard_integrate" />
                    <has_text text="overall_statistics" />
                    <has_text text="integrated_graph" />
                    <has_text text="total_potential_energy" />
                    <has_text text="hydrophobic_cluster_count" />
                    <has_text text="disordered_region_count" />
                </assert_contents>
            </output>
            <!-- Log file -->
            <output name="log">
                <assert_contents>
                    <has_text text="Integrate processing started" />
                    <has_text text="Integrate processing finished" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Integrate combines JSON reports from EnzyWizard modules into a graph representation. Residues and substrates become graph nodes, while molecular interactions become graph edges. The clean report anchors residue numbering and protein identity.

**Inputs**

* **EnzyWizard reports**: a Galaxy list collection of JSON reports. It must contain exactly one ``clean_report_*.json`` and at most one report of every other recognized type. Other report types are optional unless strict mode is enabled.
* **Strict mode**: require the complete supported report set before integration.

**Recognized report types**

``clean_report_*``, ``aaprops_report_*``, ``hydrocluster_report_*``, ``energy_report_*``, ``flexibility_report_*``, ``disorder_report_*``, ``conservation_report_*``, ``embedding_report_*``, ``pocket_report_*``, ``substrate_report_*``, ``dock_report_*``, and ``interaction_report_*``.

**Outputs**

* Integrated node JSON report.
* Integrated edge JSON report.
* Integrated graph summary JSON report.
* Optional log file.

**Usage note**

Use permissive mode during exploratory analyses when only part of the EnzyWizard workflow is available. Use strict mode for complete feature matrices and machine-learning-ready graph datasets.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-integrate"/>
    <expand macro="creator"/>
</tool>
