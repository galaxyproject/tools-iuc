<tool id="enzywizard_flexibility" name="EnzyWizard Flexibility" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Estimate protein flexibility from a cleaned protein structure</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-flexibility</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        ln -s '$input_name' '$input_name.name' &&
        enzywizard-flexibility
        -i '$input_name.name'
        --method '$advanced.flexibility.flexibility_method'
        --cutoff '$advanced.flexibility.flexibility_cutoff'
        --n_modes '$advanced.flexibility.flexibility_n_modes'
        -o ./
        > log.txt
    ]]></command>
    <inputs>
        <expand macro="protein_input"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <section name="flexibility" title="Flexibility analysis" expanded="false">
                <expand macro="flexibility_method"/>
                <expand macro="flexibility_cutoff"/>
                <expand macro="flexibility_n_modes"/>
            </section>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="flexibility_report_cleaned_*.json" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="input_name" value="cleaned_3GP6.cif"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <output name="out_json">
                <assert_contents>
                    <has_text text="enzywizard_flexibility" />
                    <has_text text="protein_flexibility" />
                    <has_text text="residue_index" />
                    <has_text text="residue_name" />
                    <has_text text="residue_root_mean_square_fluctuation" />
                    <!-- Check that the first residue is M (Methionine) -->
                    <has_text text="&quot;M&quot;" />
                </assert_contents>
            </output>
            <output name="log">
                <assert_contents>
                    <has_text text="Flexibility processing started" />
                    <has_text text="cleaned_3GP6" />
                    <has_text text="Flexibility processing finished" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Flexibility estimates residue flexibility from a cleaned protein structure using elastic network models. It reports per-residue root mean square fluctuation values calculated from low-frequency normal modes.

**Inputs**

* **Cleaned protein structure**: cleaned CIF or PDB structure.
* **Flexibility method**: ANM for anisotropic collective motions or GNM for isotropic residue mobility.
* **Flexibility distance cutoff**: CA atom distance cutoff for residue-residue connections.
* **Number of normal modes**: low-frequency modes used for RMSF calculation.

**Outputs**

* JSON report named like ``flexibility_report_*.json`` containing per-residue RMSF values.
* Optional log file.

**Downstream use**

Include the report in EnzyWizard Integrate or Batch to add residue mobility features to the integrated graph.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-flexibility"/>
    <expand macro="creator"/>
</tool>
