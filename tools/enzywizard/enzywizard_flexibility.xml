<tool id="enzywizard_flexibility" name="EnzyWizard Flexibility" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Estimate protein flexibility from a cleaned protein structure</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-flexibility</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        ln -s '$input_path' input.cif &&
        enzywizard-flexibility
        -i input.cif
        --method '$flexibility_method'
        --cutoff '$flexibility_cutoff'
        --n_modes '$flexibility_n_modes'
        -o ./
    ]]></command>
    <inputs>
        <expand macro="protein_input"/>
        <expand macro="flexibility_method"/>
        <expand macro="flexibility_cutoff"/>
        <expand macro="flexibility_n_modes"/>
    </inputs>
    <outputs>
        <expand macro="output_collection" name="output_files" label="${tool.name} outputs"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input_path" value="cleaned_3GP6.cif"/>
            <output_collection name="output_files" type="list" min="1"/>
        </test>
    </tests>
    <help><![CDATA[
Estimate protein flexibility from a cleaned protein structure. The wrapper symlinks Galaxy file inputs into the job working directory and captures the tool-created output directory/files as a Galaxy discovered collection.
    ]]></help>
    <expand macro="creator"/>
</tool>
