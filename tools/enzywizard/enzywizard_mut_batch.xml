<tool id="enzywizard_mut_batch" name="EnzyWizard Mut Batch" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Run paired EnzyWizard workflows for wild-type and mutant proteins</description>
    <macros><import>macros.xml</import></macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-mut-batch</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        ln -s '$wt_cleaned_input_path' wt_input.cif &&
        ln -s '$mut_cleaned_input_path' mut_input.cif &&
        ln -s '$wt_input_msa' wt_input_msa.sto &&
        ln -s '$mut_input_msa' mut_input_msa.sto &&
        enzywizard-mut-batch
        -w wt_input.cif
        -m mut_input.cif
        -wm wt_input_msa.sto
        -mm mut_input_msa.sto
        -a '$cleaned_amino_acid_substitution'
        #if $substrate_names:
        -s '$substrate_names'
        #end if
        -wo wt_output
        -mo mut_output
        $save_extra_outputs
        --hydrocluster_cutoff '$hydrocluster_cutoff'
        $no_minimize_energy
        --energy_minimization_iteration '$minimization_iteration'
        --flexibility_method '$flexibility_method'
        --flexibility_cutoff '$flexibility_cutoff'
        --flexibility_n_modes '$flexibility_n_modes'
        --disorder_window_size '$disorder_window_size'
        --disorder_min_region_length '$disorder_min_region_length'
        --embedding_model_name '$embedding_model_name'
    ]]></command>
    <inputs>
        <param name="wt_cleaned_input_path" type="data" format="mmcif,pdb" label="Wild-type cleaned protein structure"/>
        <param name="mut_cleaned_input_path" type="data" format="mmcif,pdb" label="Mutant cleaned protein structure"/>
        <param name="wt_input_msa" type="data" format="stockholm,fasta" label="Wild-type MSA"/>
        <param name="mut_input_msa" type="data" format="stockholm,fasta" label="Mutant MSA"/>
        <param name="cleaned_amino_acid_substitution" type="text" label="Cleaned amino acid substitution"/>
        <expand macro="substrate_names"/>
        <param name="save_extra_outputs" type="boolean" truevalue="--save_extra_outputs" falsevalue="" label="Save extra outputs"/>
        <expand macro="hydrocluster_cutoff"/>
        <expand macro="no_minimize_energy"/>
        <expand macro="minimization_iteration"/>
        <expand macro="flexibility_method"/>
        <expand macro="flexibility_cutoff"/>
        <expand macro="flexibility_n_modes"/>
        <expand macro="disorder_window_size"/>
        <expand macro="disorder_min_region_length"/>
        <expand macro="embedding_model_name"/>
    </inputs>
    <outputs>
        <expand macro="output_collection_json" name="wt_output_files" label="${tool.name} wild-type outputs" directory="wt_output"/>
        <expand macro="output_collection_json" name="mut_output_files" label="${tool.name} mutant outputs" directory="mut_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="wt_cleaned_input_path" value="cleaned_1ZG4_WT.cif"/>
            <param name="mut_cleaned_input_path" value="cleaned_1ZG6_S70G.cif"/>
            <param name="wt_input_msa" value="jhmm_1ZG4_WT.sto"/>
            <param name="mut_input_msa" value="jhmm_1ZG6_S70G.sto"/>
            <param name="cleaned_amino_acid_substitution" value="S70G"/>
            <output_collection name="wt_output_files" type="list" min="1"/>
            <output_collection name="mut_output_files" type="list" min="1"/>
        </test>
    </tests>
    <help><![CDATA[Wild-type and mutant output directories are collected as separate Galaxy output collections.]]></help>
    <expand macro="creator"/>
</tool>
