<tool id="enzywizard_mut_batch" name="EnzyWizard Mut Batch" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Run paired EnzyWizard workflows for wild-type and mutant proteins</description>
    <macros><import>macros.xml</import></macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-mut-batch</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        mkdir -p inputs &&
        #if $wt_cleaned_input_path.is_of_type("pdb"):
            ln -s '$wt_cleaned_input_path' 'inputs/wild_type.pdb' &&
        #else:
            ln -s '$wt_cleaned_input_path' 'inputs/wild_type.cif' &&
        #end if
        #if $mut_cleaned_input_path.is_of_type("pdb"):
            ln -s '$mut_cleaned_input_path' 'inputs/mutant.pdb' &&
        #else:
            ln -s '$mut_cleaned_input_path' 'inputs/mutant.cif' &&
        #end if
        #if $wt_input_msa.is_of_type("stockholm"):
            ln -s '$wt_input_msa' 'inputs/wild_type.sto' &&
        #else:
            ln -s '$wt_input_msa' 'inputs/wild_type.fasta' &&
        #end if
        #if $mut_input_msa.is_of_type("stockholm"):
            ln -s '$mut_input_msa' 'inputs/mutant.sto' &&
        #else:
            ln -s '$mut_input_msa' 'inputs/mutant.fasta' &&
        #end if
        enzywizard-mut-batch
        #if $wt_cleaned_input_path.is_of_type("pdb"):
            -w 'inputs/wild_type.pdb'
        #else:
            -w 'inputs/wild_type.cif'
        #end if
        #if $mut_cleaned_input_path.is_of_type("pdb"):
            -m 'inputs/mutant.pdb'
        #else:
            -m 'inputs/mutant.cif'
        #end if
        #if $wt_input_msa.is_of_type("stockholm"):
            -wm 'inputs/wild_type.sto'
        #else:
            -wm 'inputs/wild_type.fasta'
        #end if
        #if $mut_input_msa.is_of_type("stockholm"):
            -mm 'inputs/mutant.sto'
        #else:
            -mm 'inputs/mutant.fasta'
        #end if
        -a '$cleaned_amino_acid_substitution'
        @CMD_OPTIONAL_ADVANCED_SUBSTRATE_NAMES@
        @CMD_WT_MUT_OUTPUT_DIRS@
        @CMD_BATCH_ADVANCED_ARGS@
        @CMD_INTERACTION_DISTANCE_ARGS@
        @CMD_BATCH_VDW_ARG@
        @CMD_INTERACTION_STACKING_ARGS@
        @CMD_LOG@
    ]]></command>
    <inputs>
        <param argument="--wt_cleaned_input_path" type="data" format="cif,pdb" label="Wild-type cleaned protein structure" help="Cleaned wild-type CIF or PDB structure"/>
        <param argument="--mut_cleaned_input_path" type="data" format="cif,pdb" label="Mutant cleaned protein structure" help="Cleaned mutant CIF or PDB structure"/>
        <param argument="--wt_input_msa" type="data" format="stockholm,fasta" label="Wild-type MSA" help="Wild-type protein MSA"/>
        <param argument="--mut_input_msa" type="data" format="stockholm,fasta" label="Mutant MSA" help="Mutant protein MSA"/>
        <param argument="--cleaned_amino_acid_substitution" type="text" label="Cleaned amino acid substitution" help="Cleaned amino acid substitution, e.g. A123V"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="optional_substrate_names"/>
            <expand macro="hydrocluster_cutoff"/>
            <section name="energy" title="Energy minimization" expanded="false">
                <expand macro="no_minimize_energy"/>
                <expand macro="minimization_iteration"/>
            </section>
            <section name="flexibility" title="Flexibility analysis" expanded="false">
                <expand macro="flexibility_method"/>
                <expand macro="flexibility_cutoff"/>
                <expand macro="flexibility_n_modes"/>
            </section>
            <section name="disorder" title="Disorder prediction" expanded="false">
                <expand macro="disorder_window_size"/>
                <expand macro="disorder_min_region_length"/>
            </section>
            <expand macro="embedding_model_name"/>
            <section name="pocket" title="Automatic pocket detection" expanded="false">
                <expand macro="batch_pocket_params"/>
            </section>
            <section name="substrate" title="Substrate lookup and conformers" expanded="false">
                <expand macro="batch_substrate_params"/>
            </section>
            <section name="docking" title="Docking search and box settings" expanded="false">
                <expand macro="batch_dock_params"/>
            </section>
            <section name="interaction" title="Interaction cutoff settings" expanded="false">
                <expand macro="batch_interaction_params"/>
            </section>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <expand macro="output_collection_json" name="wt_output_files" label="${tool.name} wild-type outputs" directory="wt_output" pattern="(?P&lt;designation&gt;(?:mut_integrate_report_.+\.json|wt_integrate_(?:nodes|edges)_.+\.json))"/>
        <expand macro="output_collection_json" name="mut_output_files" label="${tool.name} mutant outputs" directory="mut_output" pattern="(?P&lt;designation&gt;(?:mut_integrate_report_.+\.json|mut_integrate_(?:nodes|edges)_.+\.json))"/>
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="wt_cleaned_input_path" value="cleaned_1ZG4_WT.cif"/>
            <param name="mut_cleaned_input_path" value="cleaned_1ZG6_S70G.cif"/>
            <param name="wt_input_msa" value="jhmm_1ZG4_WT.sto"/>
            <param name="mut_input_msa" value="jhmm_1ZG6_S70G.sto"/>
            <param name="cleaned_amino_acid_substitution" value="S45G"/>
            <section name="advanced">
                <section name="energy">
                    <param name="no_minimize_energy" value="true"/>
                    <param name="minimization_iteration" value="1"/>
                </section>
                <section name="flexibility">
                    <param name="flexibility_n_modes" value="1"/>
                </section>
                <section name="docking">
                    <param name="dock_max_attempt_num" value="1"/>
                    <param name="dock_exhaustiveness" value="1"/>
                </section>
            </section>

            <!-- Wild-type collection - elements reordered to match tool output -->
            <output_collection name="wt_output_files" type="list" count="3">
                <!-- Tool produces this report first -->
                <element name="mut_integrate_report_wild_type_to_mutant.json">
                    <assert_contents>
                        <has_text text="enzywizard_mut_integrate" />
                        <has_text text="overall_statistics" />
                        <has_text text="integrated_graph" />
                    </assert_contents>
                </element>
                <!-- Then edges -->
                <element name="wt_integrate_edges_wild_type.json">
                    <assert_contents>
                        <has_text text="molecular_interaction" />
                        <has_text text="source_node" />
                        <has_text text="target_node" />
                        <has_text text="HBOND" />
                    </assert_contents>
                </element>
                <!-- Then nodes -->
                <element name="wt_integrate_nodes_wild_type.json">
                    <assert_contents>
                        <has_text text="node_index" />
                        <has_text text="residue_name" />
                        <has_text text="residue_alpha_carbon_coordinate" />
                    </assert_contents>
                </element>
            </output_collection>

            <!-- Mutant collection - order already matches tool output -->
            <output_collection name="mut_output_files" type="list" count="3">
                <element name="mut_integrate_edges_mutant.json">
                    <assert_contents>
                        <has_text text="molecular_interaction" />
                        <has_text text="source_node" />
                        <has_text text="target_node" />
                    </assert_contents>
                </element>
                <element name="mut_integrate_nodes_mutant.json">
                    <assert_contents>
                        <has_text text="node_index" />
                        <has_text text="residue_name" />
                    </assert_contents>
                </element>
                <element name="mut_integrate_report_wild_type_to_mutant.json">
                    <assert_contents>
                        <has_text text="enzywizard_mut_integrate" />
                        <has_text text="overall_statistics" />
                    </assert_contents>
                </element>
            </output_collection>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Mut Batch runs paired EnzyWizard workflows for a wild-type protein and a mutant protein, then produces mutation-aware integrated graph outputs. It supports protein-only comparison and, when substrates are provided, paired substrate preparation, docking, and protein-substrate interaction analysis.

**Inputs**

* **Wild-type cleaned protein structure** and **mutant cleaned protein structure**: cleaned CIF or PDB structures.
* **Wild-type MSA** and **mutant MSA**: alignments matching the corresponding cleaned FASTA sequences.
* **Cleaned amino acid substitution**: mutation label in cleaned residue numbering, normally from EnzyWizard Mut Clean.
* **Optional substrate names or SMILES**: enables paired enzyme-substrate analysis.
* **Advanced options**: module-specific controls shared with EnzyWizard Batch.

**Outputs**

* Wild-type output collection with integrated reports.
* Mutant output collection with integrated reports.
* Optional log file.
* Optional intermediate files when **Save extra outputs** is enabled.

**Usage note**

Use this wrapper when the goal is direct wild-type versus mutant comparison. Use EnzyWizard Batch for a single protein workflow.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-mut-batch"/>
    <expand macro="creator"/>
</tool>
