<tool id="enzywizard_substrate" name="EnzyWizard Substrate" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Generate substrate structures from names or SMILES</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-substrate</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        exec 3>&1 4>&2;
        exec > enzywizard.log 2>&1;

        enzywizard-substrate
        -s '$substrate_names'
        --max_synonyms '$advanced.substrate.max_synonyms'
        --fp_radius '$advanced.substrate.fp_radius'
        --n_bits '$advanced.substrate.n_bits'
        --num_confs '$advanced.substrate.num_confs'
        --prune_rms '$advanced.substrate.prune_rms'
        -o ./
    ]]></command>
    <inputs>
        <expand macro="substrate_names"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <section name="substrate" title="Substrate lookup and conformers" expanded="false">
                <param argument="--max_synonyms" type="integer" value="20" min="1" label="Maximum substrate synonym retries" help="Maximum substrate name lookup attempts"/>
                <param argument="--fp_radius" type="integer" value="2" min="1" label="Morgan fingerprint radius" help="Morgan fingerprint radius"/>
                <param argument="--n_bits" type="integer" value="512" min="1" label="Fingerprint bit size" help="Morgan fingerprint bit length"/>
                <param argument="--num_confs" type="integer" value="5" min="1" label="Maximum substrate conformers" help="Maximum 3D conformers per substrate"/>
                <param argument="--prune_rms" type="float" value="0.5" min="0" label="Conformer prune RMS" help="RMS threshold for conformer pruning"/>
            </section>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <collection name="sdf_collection" type="list" label="Docked substrates (SDF)">
            <discover_datasets pattern="(?P&lt;designation&gt;.*?)\.sdf" directory="." recurse="false" match_relative_path="false" format="sdf" visible="true"/>
        </collection>
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="substrate_report_*.json" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="3">
            <param name="substrate_names" value="glucose;fructose"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <!-- SDF collection: 5 glucose + 5 fructose = 10 -->
            <output_collection name="sdf_collection" type="list" count="10">
                <!-- Match the order produced by the tool: fructose then glucose -->
                <element name="fructose_1">
                    <assert_contents>
                        <has_text text="RDKit" />
                    </assert_contents>
                </element>
                <element name="glucose_1">
                    <assert_contents>
                        <has_text text="RDKit" />
                    </assert_contents>
                </element>
            </output_collection>
            <!-- JSON report assertions -->
            <output name="out_json">
                <assert_contents>
                    <has_text text="enzywizard_substrate" />
                    <has_text text="substrates" />
                    <has_text text="glucose" />
                </assert_contents>
            </output>
            <!-- Log assertions -->
            <output name="log">
                <assert_contents>
                    <has_text text="Substrate processing" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Substrate processes small-molecule substrates from names or SMILES strings. It resolves substrate names where possible, records SMILES, generates RDKit descriptors and Morgan fingerprints, adds hydrogens, generates 3D conformers, minimizes conformer energy, and writes SDF structures for downstream docking.

**Inputs**

* **Substrate names or SMILES**: one or more entries separated by semicolons, for example ``glucose;fructose`` or ``glucose;CCO``.
* **Maximum substrate synonym retries**: controls how many synonym-based lookups are attempted for names.
* **Morgan fingerprint radius** and **fingerprint bit size**: control fingerprint encoding.
* **Maximum substrate conformers** and **conformer prune RMS**: control 3D conformer generation.

**Outputs**

* JSON substrate report named like ``substrate_report_*.json``.
* Collection of generated SDF substrate structures.
* Optional log file.

**Downstream use**

Use the SDF collection, zipped as a substrate directory when needed, with EnzyWizard Dock or Interaction.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-substrate"/>
    <expand macro="creator"/>
</tool>
