<tool id="enzywizard_mut_clean" name="EnzyWizard Mut Clean" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Clean paired wild-type and mutant protein structures</description>
    <macros><import>macros.xml</import></macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-mut-clean</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        exec 3>&1 4>&2
        exec > enzywizard.log 2>&1;

        #set $wt_name = $wt_input_path.element_identifier
        #set $mut_name = $mut_input_path.element_identifier
        ln -s '$wt_input_path' '$wt_name' &&
        ln -s '$mut_input_path' '$mut_name' &&
        enzywizard-mut-clean
        -w '$wt_name'
        -m '$mut_name'
        -s '$mutation'
        -o ./
        $advanced.no_add_h
        --pH '$advanced.ph'
    
    ]]></command>
    <inputs>
        <param name="wt_input_path" type="data" format="data,pdb" label="Wild-type protein structure"/>
        <param name="mut_input_path" type="data" format="data,pdb" label="Mutant protein structure"/>
        <param name="mutation" type="text" label="Amino acid substitution(s)" help="For example A123V or A123V;G456D."/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="no_add_h"/>
            <expand macro="ph"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <expand macro="output_collection" name="output_files" label="${tool.name} outputs" pattern="(?P&lt;designation&gt;(?:mut_clean_report_.+\.json|cleaned_.+\.(?:cif|pdb|fasta)))"/>
    
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="wt_input_path" value="1ZG4_WT.cif"/>
            <param name="mut_input_path" value="1ZG6_S70G.cif"/>
            <param name="mutation" value="S70G"/>
            <output_collection name="output_files" type="list" count="7"/>
        </test>
    </tests>
    <help><![CDATA[Directory-like outputs are collected as a Galaxy discovered collection.]]></help>
    <expand macro="citations" repo_name="enzywizard-mut-clean"/>
    <expand macro="creator"/>
</tool>
