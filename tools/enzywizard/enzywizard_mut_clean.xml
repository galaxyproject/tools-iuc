<tool id="enzywizard_mut_clean" name="EnzyWizard Mut Clean" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Clean paired wild-type and mutant protein structures</description>
    <macros><import>macros.xml</import></macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-mut-clean</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        mkdir -p inputs &&
        #if $wt_input_path.is_of_type("pdb"):
            ln -s '$wt_input_path' 'inputs/wild_type.pdb' &&
        #else:
            ln -s '$wt_input_path' 'inputs/wild_type.cif' &&
        #end if
        #if $mut_input_path.is_of_type("pdb"):
            ln -s '$mut_input_path' 'inputs/mutant.pdb' &&
        #else:
            ln -s '$mut_input_path' 'inputs/mutant.cif' &&
        #end if
        enzywizard-mut-clean
        #if $wt_input_path.is_of_type("pdb"):
            -w 'inputs/wild_type.pdb'
        #else:
            -w 'inputs/wild_type.cif'
        #end if
        #if $mut_input_path.is_of_type("pdb"):
            -m 'inputs/mutant.pdb'
        #else:
            -m 'inputs/mutant.cif'
        #end if
        -s '$mutation'
        @CMD_OUTPUT_DIR@
        @CMD_CLEAN_ARGS@
        @CMD_LOG@
    ]]></command>
    <inputs>
        <param argument="--wt_input_path" type="data" format="cif,pdb" label="Wild-type protein structure" help="Wild-type CIF or PDB structure"/>
        <param argument="--mut_input_path" type="data" format="cif,pdb" label="Mutant protein structure" help="Mutant CIF or PDB structure"/>
        <param argument="--mutation" type="text" label="Amino acid substitution(s)" help="One-letter amino-acid substitutions, e.g. S70G or S70G;A123V">
            <validator type="regex" message="Use one-letter amino-acid substitutions such as S70G; separate multiple substitutions with semicolons">[ACDEFGHIKLMNPQRSTVWY][1-9][0-9]*[ACDEFGHIKLMNPQRSTVWY](;[ACDEFGHIKLMNPQRSTVWY][1-9][0-9]*[ACDEFGHIKLMNPQRSTVWY])*$</validator>
        </param>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="no_add_h"/>
            <expand macro="ph"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="mut_clean_report_*.json" />
        <collection name="cif_collection" type="list" label="Cleaned structures (CIF)">
            <discover_datasets pattern="(?P&lt;designation&gt;.*?)\.cif" directory="." recurse="false" match_relative_path="false" format="cif" visible="true"/>
        </collection>
        <collection name="fasta_collection" type="list" label="Cleaned sequences (FASTA)">
            <discover_datasets pattern="(?P&lt;designation&gt;.*?)\.fasta" directory="." recurse="false" match_relative_path="false" format="fasta" visible="true"/>
        </collection>
        <collection name="pdb_collection" type="list" label="Cleaned structures (PDB)">
            <discover_datasets pattern="(?P&lt;designation&gt;.*?)\.pdb" directory="." recurse="false" match_relative_path="false" format="pdb" visible="true"/>
        </collection>
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="5">  <!-- out_json + 3 collections + log -->
            <param name="wt_input_path" value="1ZG4_WT.cif"/>
            <param name="mut_input_path" value="1ZG6_S70G.cif"/>
            <param name="mutation" value="S70G"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>

            <!-- JSON report (single data output) -->
            <output name="out_json">
                <assert_contents>
                    <has_text text="enzywizard_mut_clean" />
                    <has_text text="amino_acid_substitution" />
                    <has_text text="wild_type_residue_mapping_old_to_new" />
                    <has_text text="mutant_residue_mapping_old_to_new" />
                    <has_text text="clean_statistics" />
                </assert_contents>
            </output>

            <!-- CIF collection (2 files: WT and mutant) -->
            <output_collection name="cif_collection" type="list" count="2">
                <element name="cleaned_wild_type">
                    <assert_contents>
                        <has_text text="ATOM" />
                        <has_text text="HIS" />
                    </assert_contents>
                </element>
                <element name="cleaned_mutant">
                    <assert_contents>
                        <has_text text="ATOM" />
                        <has_text text="HIS" />
                    </assert_contents>
                </element>
            </output_collection>

            <!-- PDB collection (2 files: WT and mutant) -->
            <output_collection name="pdb_collection" type="list" count="2">
                <element name="cleaned_wild_type">
                    <assert_contents>
                        <has_text text="ATOM" />
                        <has_text text="HIS" />
                    </assert_contents>
                </element>
                <element name="cleaned_mutant">
                    <assert_contents>
                        <has_text text="ATOM" />
                        <has_text text="HIS" />
                    </assert_contents>
                </element>
            </output_collection>

            <!-- FASTA collection (2 files: WT and mutant) -->
            <output_collection name="fasta_collection" type="list" count="2">
                <element name="cleaned_wild_type">
                    <assert_contents>
                        <has_text text=">1ZG4_WT" />
                        <has_text text="HPETLVKVKDA" />
                    </assert_contents>
                </element>
                <element name="cleaned_mutant">
                    <assert_contents>
                        <has_text text=">1ZG6_S70G" />
                        <has_text text="HPETLVKVKDA" />
                    </assert_contents>
                </element>
            </output_collection>

            <!-- Log file -->
            <output name="log">
                <assert_contents>
                    <!-- Matches the actual log output -->
                    <has_text text="Mutclean processing started" />
                    <has_text text="Mutclean processing finished" />
                    <not_has_text text="[ERROR]" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Mut Clean cleans a wild-type structure and a corresponding mutant structure, maps original residue numbering to cleaned residue numbering, and remaps amino-acid substitution labels to the cleaned structures.

**Inputs**

* **Wild-type protein structure** and **mutant protein structure**: CIF or PDB structures before EnzyWizard cleaning.
* **Amino acid substitution(s)**: mutation label such as ``S70G`` or multiple substitutions separated by semicolons.
* **Hydrogen options**: same cleaning controls as EnzyWizard Clean.

**Outputs**

* Cleaned wild-type CIF, PDB, and FASTA outputs.
* Cleaned mutant CIF, PDB, and FASTA outputs.
* Mutation clean JSON report containing residue mapping and cleaned substitution information.
* Optional log file.

**Downstream use**

Use the cleaned structures and cleaned amino-acid substitution with EnzyWizard Mut Batch, and use the mutation clean report with EnzyWizard Mut Integrate.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-mut-clean"/>
    <expand macro="creator"/>
</tool>
