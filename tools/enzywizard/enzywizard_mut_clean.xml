<tool id="enzywizard_mut_clean" name="EnzyWizard Mut Clean" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Clean paired wild-type and mutant protein structures</description>
    <macros><import>macros.xml</import></macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-mut-clean</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        ln -s '$wt_input_path' wt_input.cif &&
        ln -s '$mut_input_path' mut_input.cif &&
        enzywizard-mut-clean
        -w wt_input.cif
        -m mut_input.cif
        -s '$mutation'
        -o ./
        $no_add_h
        --pH '$ph'
    ]]></command>
    <inputs>
        <param name="wt_input_path" type="data" format="mmcif,pdb" label="Wild-type protein structure"/>
        <param name="mut_input_path" type="data" format="mmcif,pdb" label="Mutant protein structure"/>
        <param name="mutation" type="text" label="Amino acid substitution(s)" help="For example A123V or A123V;G456D."/>
        <expand macro="no_add_h"/>
        <expand macro="ph"/>
    </inputs>
    <outputs>
        <expand macro="output_collection" name="output_files" label="${tool.name} outputs"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="wt_input_path" value="1ZG4_WT.cif"/>
            <param name="mut_input_path" value="1ZG6_S70G.cif"/>
            <param name="mutation" value="S70G"/>
            <output_collection name="output_files" type="list" min="1"/>
        </test>
    </tests>
    <help><![CDATA[Directory-like outputs are collected as a Galaxy discovered collection.]]></help>
    <expand macro="creator"/>
</tool>
