<tool id="enzywizard_disorder" name="EnzyWizard Disorder" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Predict intrinsically disordered regions from a cleaned protein structure</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-disorder</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        exec 3>&1 4>&2;
        exec > enzywizard.log 2>&1;

        #set $input_name = $input_path.element_identifier
        ln -s '$input_path' '$input_name' &&
        enzywizard-disorder
        -i '$input_name'
        --window_size '$advanced.disorder_window_size'
        --min_region_length '$advanced.disorder_min_region_length'
        -o ./
    ]]></command>
    <inputs>
        <expand macro="protein_input"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="disorder_window_size"/>
            <expand macro="disorder_min_region_length"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="disorder_report_cleaned_*.json" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="input_path" value="cleaned_3GP6.cif"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <output name="out_json" format="json">
            <assert_contents>
                <!-- Check the report type -->
                <has_text text="enzywizard_disorder" />
                <!-- Check top-level keys -->
                <has_text text="disordered_region_statistics" />
                <has_text text="disordered_regions" />
                <!-- Check statistics fields -->
                <has_text text="disordered_region_count" />
                <has_text text="max_disordered_region_length" />
                <has_text text="total_disordered_region_length" />
                <!-- Check that a region contains residues with expected structure -->
                <has_text text="&quot;residue_index&quot;" />
                <has_text text="&quot;residue_name&quot;" />
                <!-- Verify that a known residue (e.g., G) appears in a region -->
                <has_text text="&quot;G&quot;" />
            </assert_contents>
        </output>
        <output name="log">
            <assert_contents>
                <has_text text="Disorder processing started" />
                <has_text text="cleaned_3GP6" />
                <has_text text="Disorder processing finished" />
            </assert_contents>
        </output>
        </test>
    </tests>
    <help><![CDATA[
Predict intrinsically disordered regions from a cleaned protein structure. The wrapper symlinks Galaxy file inputs into the job working directory and captures the tool-created output directory/files as a Galaxy discovered collection.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-disorder"/>
    <expand macro="creator"/>
</tool>
