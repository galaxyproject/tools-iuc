<tool id="enzywizard_hydrocluster" name="EnzyWizard Hydrocluster" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Detect hydrophobic clusters from a cleaned protein structure</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-hydrocluster</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        ln -s '$input_name' '$input_name.name' &&
        enzywizard-hydrocluster
        -i '$input_name.name'
        --cutoff '$advanced.hydrocluster_cutoff'
        -o ./
        > log.txt
    ]]></command>
    <inputs>
        <expand macro="protein_input"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="hydrocluster_cutoff"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="hydrocluster_report_*.json" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="input_name" value="cleaned_3GP6.cif"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <output name="out_json">
                <assert_contents>
                    <has_text text="enzywizard_hydrocluster" />
                    <has_text text="hydrophobic_cluster_statistics" />
                    <has_text text="hydrophobic_cluster_count" />
                    <has_text text="max_hydrophobic_cluster_area" />
                    <has_text text="total_hydrophobic_cluster_area" />
                    <has_text text="hydrophobic_clusters" />
                    <has_text text="hydrophobic_cluster_area" />
                    <has_text text="residues" />
                    <has_text text="residue_index" />
                    <has_text text="residue_name" />
                    <!-- Check for a hydrophobic residue that appears in clusters, e.g., I -->
                    <has_text text="&quot;I&quot;" />
                </assert_contents>
            </output>
            <output name="log">
                <assert_contents>
                    <has_text text="Hydrocluster processing started" />
                    <has_text text="cleaned_3GP6" />
                    <has_text text="Hydrocluster processing finished" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Hydrocluster identifies hydrophobic clusters in a cleaned protein structure. It focuses on hydrophobic residue contacts, especially among ILE, VAL, and LEU residues, estimates side-chain contact areas, and groups connected residues into hydrophobic clusters.

**Inputs**

* **Cleaned protein structure**: cleaned CIF or PDB structure.
* **Hydrophobic cluster cutoff**: minimum estimated contact area required to connect hydrophobic residues.

**Outputs**

* JSON report named like ``hydrocluster_report_*.json`` with cluster membership and summary statistics.
* Optional log file.

**Downstream use**

Include this report in EnzyWizard Integrate or Batch to add hydrophobic-cluster information to residue nodes and graph-level statistics.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-hydrocluster"/>
    <expand macro="creator"/>
</tool>
