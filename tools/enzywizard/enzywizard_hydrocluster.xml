<tool id="enzywizard_hydrocluster" name="EnzyWizard Hydrocluster" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Detect hydrophobic clusters from a cleaned protein structure</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-hydrocluster</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        exec 3>&1 4>&2;
        exec > enzywizard.log 2>&1;
        #set $input_name = $input_path.element_identifier
        ln -s '$input_path' '$input_name' &&
        enzywizard-hydrocluster
        -i '$input_name'
        --cutoff '$advanced.hydrocluster_cutoff'
        -o ./
    ]]></command>
    <inputs>
        <expand macro="protein_input"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="hydrocluster_cutoff"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <expand macro="output_collection" name="output_files" label="${tool.name} outputs" pattern="(?P&lt;designation&gt;hydrocluster_report_.+\.json)"/>
    
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input_path" value="cleaned_3GP6.cif"/>
            <output_collection name="output_files" type="list" count="1"/>
        </test>
    </tests>
    <help><![CDATA[
Detect hydrophobic clusters from a cleaned protein structure. The wrapper symlinks Galaxy file inputs into the job working directory and captures the tool-created output directory/files as a Galaxy discovered collection.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-hydrocluster"/>
    <expand macro="creator"/>
</tool>
