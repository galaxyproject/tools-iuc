<tool id="enzywizard_pocket" name="EnzyWizard Pocket" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Detect and characterize binding pockets from a cleaned protein structure</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-pocket</requirement>
            <requirement type="package" version="3.1.0">pymol-open-source</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        exec 3>&1 4>&2;
        exec > enzywizard.log 2>&1;
        
        #set $input_name = $input_path.element_identifier
        ln -s '$input_path' '$input_name' &&
        enzywizard-pocket
        -i '$input_name'
        --min_rad '$advanced.pocket.min_rad'
        --max_rad '$advanced.pocket.max_rad'
        --min_volume '$advanced.pocket.min_volume'
        -o ./
    ]]></command>
    <inputs>
        <expand macro="protein_input"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <section name="pocket" title="Automatic pocket detection" expanded="false">
                <expand macro="pocket_params"/>
            </section>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="pocket_report_*.json" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="input_path" value="cleaned_1HVR.cif"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <output name="out_json">
                <assert_contents>
                    <has_text text="enzywizard_pocket" />
                    <has_text text="binding_pocket_statistics" />
                    <has_text text="binding_pockets" />
                </assert_contents>
            </output>
            <output name="log">
                <assert_contents>
                    <!-- Use a string that is actually present in the log -->
                    <has_text text="Pocket processing" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Pocket detects and characterizes binding pockets in a cleaned protein structure using geometry-based pocket detection. Each pocket is reported with properties such as volume, bounding-box information, and associated residues.

**Inputs**

* **Cleaned protein structure**: cleaned CIF or PDB structure.
* **Minimum/maximum probe radius**: PyVOL probe-radius range used for cavity detection.
* **Minimum pocket volume**: smallest pocket volume retained in the report.

**Outputs**

* JSON report named like ``pocket_report_*.json`` containing binding-pocket statistics and pocket details.
* Optional log file.

**Downstream use**

Pocket information can guide docking-box selection and can be integrated into graph features with EnzyWizard Integrate or Batch.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-pocket"/>
    <expand macro="creator"/>
</tool>
