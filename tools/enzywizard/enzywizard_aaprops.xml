<tool id="enzywizard_aaprops" name="EnzyWizard Aaprops" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Calculate amino acid residue properties from a cleaned protein structure</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-aaprops</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        enzywizard-aaprops
        @CMD_INPUT_NAME@
        @CMD_OUTPUT_DIR@
        @CMD_LOG@
    ]]></command>
    <inputs>
        <expand macro="protein_input"/>
        <expand macro="log_input"/>
    </inputs>
    <outputs>
        <expand macro="log_output"/>
        <data name="out_aaprop_file" format="json" label="${tool.name} JSON report"  from_work_dir="aaprops_report_*.json" />
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="input_name" value="cleaned_3GP6.cif"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <output name="out_aaprop_file">
                <assert_contents>
                    <has_text text="enzywizard_aaprops" />
                    <has_text text="M" />
                    <has_text text="residue_index" />
                    <has_text text="residue_properties_statistics" />
                    <has_text text="alpha_helix_count" />
                    <has_text text="17" />
                </assert_contents>
            </output>
            <output name="log">
            <assert_contents>
                <has_text text="Aaprops processing started" />
                <has_text text="Aaprops processing finished" />
            </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="input_name" value="cleaned_3GP6.pdb"/>
            <output name="out_aaprop_file">
                <assert_contents>
                    <has_text text="enzywizard_aaprops" />
                    <has_text text="residue_index" />
                    <has_text text="residue_properties_statistics" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Aaprops calculates residue-level structural and physicochemical properties from a cleaned protein structure. The report includes residue identity, chemical class, secondary-structure assignment, solvent accessibility, backbone torsion information, and predefined amino-acid property features.

**Inputs**

* **Cleaned protein structure**: cleaned CIF or PDB structure, normally from EnzyWizard Clean.

**Outputs**

* JSON report named like ``aaprops_report_*.json``.
* Optional log file.

**Downstream use**

The JSON report can be included in EnzyWizard Integrate or EnzyWizard Batch to add residue feature annotations to the integrated graph representation.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-aaprops"/>
    <expand macro="creator"/>
</tool>
