<tool id="enzywizard_clean" name="EnzyWizard Clean" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Clean a protein structure and generate multi-format files</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-clean</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        @CMD_SYMLINK_INPUT_NAME@
        enzywizard-clean
        @CMD_INPUT_NAME@
        @CMD_CLEAN_ARGS@
        @CMD_OUTPUT_DIR@
        > log.txt 2>&1
    ]]></command>
    <inputs>
        <param argument="--input_name" type="data" format="cif,pdb" label="Protein structure" help="Input CIF or PDB protein structure to clean"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="no_add_h"/>
            <expand macro="ph"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <data name="out_cif" format="cif" label="${tool.name} Clean CIF Protein structure"  from_work_dir="cleaned_*.cif" />
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="clean_report_*.json" />
        <data name="out_pdb" format="pdb" label="${tool.name} Clean PDB Protein structure"  from_work_dir="cleaned_*.pdb" />
        <data name="out_fasta" format="fasta" label="${tool.name} Clean  FASTA file"  from_work_dir="cleaned_*.fasta" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="5">
            <param name="input_name" value="3GP6.cif"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <output name="out_json">
                <assert_contents>
                    <has_text text="enzywizard_clean" />
                    <has_text text="residue_mapping_old_to_new" />
                    <has_text text="old_residue" />
                    <has_text text="new_residue" />
                    <has_text text="clean_statistics" />
                    <has_text text="removed_heterogen_count" />
                    <has_text text="added_hydrogen_atom_count" />
                    <has_text text="retained_residue_count" />
                    <has_text text="155" />
                </assert_contents>
            </output>
            <output name="log">
                <assert_contents>
                    <has_text text="Clean processing started" />
                    <has_text text="3GP6" />
                    <has_text text="Clean processing finished" />
                    <has_text text="Cleaned CIF saved" />
                </assert_contents>
            </output>
            <output name="out_cif">
                <assert_contents>
                    <has_text text="ATOM" />
                    <has_text text="CA" />
                </assert_contents>
            </output>
            <output name="out_pdb">
                <assert_contents>
                    <has_text text="ATOM" />
                    <has_text text="CA" />
                </assert_contents>
            </output>
            <output name="out_fasta">
                <assert_contents>
                    <has_text text=">3GP6" />
                    <has_text text="MNADEWMTTFRENI" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Clean prepares a protein structure for the rest of the EnzyWizard suite. It reads a CIF or PDB structure, removes heterogens such as ligands and water, repairs missing heavy atoms, optionally adds hydrogens, keeps a standardized single protein chain, and renumbers residues continuously.

**Inputs**

* **Protein structure**: CIF or PDB protein structure.
* **Disable hydrogen addition**: skip OpenMM hydrogen addition when hydrogens are already present or protonation should not be changed.
* **pH**: pH used for hydrogen addition when hydrogens are added.

**Outputs**

* Cleaned CIF structure.
* Cleaned PDB structure.
* Cleaned FASTA sequence.
* JSON clean report containing residue mapping and cleaning statistics.
* Optional log file.

**Downstream use**

Use the cleaned CIF/PDB output as input for EnzyWizard Aaprops, Hydrocluster, Energy, Flexibility, Disorder, Pocket, Dock, Interaction, and Batch. Use the cleaned FASTA output for EnzyWizard Conservation and Embedding.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-clean"/>
    <expand macro="creator"/>
</tool>
