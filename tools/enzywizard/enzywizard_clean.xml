<tool id="enzywizard_clean" name="EnzyWizard Clean" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Clean a protein structure and generate multi-format files</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-clean</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        exec 3>&1 4>&2
        exec > enzywizard.log 2>&1;

        #set $input_name = $input_path.element_identifier
        ln -s '$input_path' '$input_name' &&
        enzywizard-clean
        -i '$input_name'
        $advanced.no_add_h
        --pH '$advanced.ph'
        -o ./
    
    ]]></command>
    <inputs>
        <param name="input_path" type="data" format="data,pdb" label="Protein structure" help="Input protein structure file in CIF or PDB format."/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="no_add_h"/>
            <expand macro="ph"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <expand macro="output_collection" name="output_files" label="${tool.name} outputs" pattern="(?P&lt;designation&gt;(?:clean_report_.+\.json|cleaned_.+\.(?:cif|pdb|fasta)))"/>
    
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input_path" value="3GP6.cif"/>
            <output_collection name="output_files" type="list" count="4"/>
        </test>
    </tests>
    <help><![CDATA[
Clean a protein structure and generate multi-format files. The wrapper symlinks Galaxy file inputs into the job working directory and captures the tool-created output directory/files as a Galaxy discovered collection.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-clean"/>
    <expand macro="creator"/>
</tool>
