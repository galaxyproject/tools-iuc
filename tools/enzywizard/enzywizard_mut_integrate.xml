<tool id="enzywizard_mut_integrate" name="EnzyWizard Mut Integrate" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Integrate wild-type and mutant EnzyWizard JSON report directories</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-mut-integrate</requirement>
        <requirement type="package" version="6.0">unzip</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        exec 3>&1 4>&2;
        exec > enzywizard.log 2>&1;
        #set $mut_clean_name = $mut_clean_report_path.element_identifier
        mkdir -p wt_input mut_input &&
        unzip -q '$wt_input_zip' -d wt_input &&
        unzip -q '$mut_input_zip' -d mut_input &&
        ln -s '$mut_clean_report_path' '$mut_clean_name' &&
        enzywizard-mut_integrate
            -i '$mut_clean_name'
            -w wt_input
            -m mut_input
            -wo wt_output
            -mo mut_output
            $advanced.strict
            && find . -type f >&4
    ]]></command>
    <inputs>
        <param name="mut_clean_report_path" type="data" format="json" label="Mutation clean report"/>
        <expand macro="zip_input_dir" name="wt_input_zip" label="Wild-type report directory (zip)" help="Zip archive containing wild-type JSON reports."/>
        <expand macro="zip_input_dir" name="mut_input_zip" label="Mutant report directory (zip)" help="Zip archive containing mutant JSON reports."/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="strict"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <expand macro="output_collection_json" name="wt_output_files" label="${tool.name} wild-type outputs" directory="wt_output" pattern="(?P&lt;designation&gt;.+\.json)"/>
        <expand macro="output_collection_json" name="mut_output_files" label="${tool.name} mutant outputs" directory="mut_output" pattern="(?P&lt;designation&gt;.+\.json)"/>
    
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="mut_clean_report_path" value="mut_clean_report_1ZG4_WT_to_1ZG6_S70G.json"/>
            <param name="wt_input_zip" value="wt_input_1.zip"/>
            <param name="mut_input_zip" value="mut_input_1.zip"/>
            <!-- Wild‑type collection – order matches tool output -->
            <output_collection name="wt_output_files" type="list" count="3">
                <element name="mut_integrate_report_1ZG4_WT_to_1ZG6_S70G.json">
                    <assert_contents>
                        <has_text text="enzywizard_mut_integrate" />
                        <has_text text="overall_statistics" />
                        <has_text text="integrated_graph" />
                    </assert_contents>
                </element>
                <element name="wt_integrate_edges_1ZG4_WT.json">
                    <assert_contents>
                        <has_text text="molecular_interaction" />
                        <has_text text="source_node" />
                        <has_text text="target_node" />
                    </assert_contents>
                </element>
                <element name="wt_integrate_nodes_1ZG4_WT.json">
                    <assert_contents>
                        <has_text text="node_index" />
                        <has_text text="residue_name" />
                        <has_text text="residue_alpha_carbon_coordinate" />
                    </assert_contents>
                </element>
            </output_collection>
            <!-- Mutant collection – order matches tool output -->
            <output_collection name="mut_output_files" type="list" count="3">
                <element name="mut_integrate_edges_1ZG6_S70G.json">
                    <assert_contents>
                        <has_text text="molecular_interaction" />
                        <has_text text="source_node" />
                        <has_text text="target_node" />
                    </assert_contents>
                </element>
                <element name="mut_integrate_nodes_1ZG6_S70G.json">
                    <assert_contents>
                        <has_text text="node_index" />
                        <has_text text="residue_name" />
                    </assert_contents>
                </element>
                <element name="mut_integrate_report_1ZG4_WT_to_1ZG6_S70G.json">
                    <assert_contents>
                        <has_text text="enzywizard_mut_integrate" />
                        <has_text text="overall_statistics" />
                    </assert_contents>
                </element>
            </output_collection>
        </test>
    </tests>
    <help><![CDATA[
Integrate wild-type and mutant EnzyWizard JSON report directories. Directory inputs are represented as zip datasets and unpacked explicitly inside this wrapper command in the Galaxy job working directory. The mutation-clean report is passed as a separate input and is not copied into the wild-type report directory, because the upstream tool validates the number of report JSON files in each directory. Outputs are exposed as discovered dataset collections.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-mut-integrate"/>
    <expand macro="creator"/>
</tool>
