<tool id="enzywizard_mut_integrate" name="EnzyWizard Mut Integrate" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Integrate wild-type and mutant EnzyWizard JSON report directories</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-mut-integrate</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        mkdir -p wt_input mut_input wt_output mut_output &&
        ln -s '$mut_clean_report_path' 'mut_clean_report_wild_type_to_mutant.json' &&
        #for $report_index, $report in enumerate($wt_input_reports):
            ln -s '$report' 'wt_input/report_${report_index}.json' &&
        #end for
        #for $report_index, $report in enumerate($mut_input_reports):
            ln -s '$report' 'mut_input/report_${report_index}.json' &&
        #end for
        enzywizard-mut_integrate
            -i 'mut_clean_report_wild_type_to_mutant.json'
            -w wt_input
            -m mut_input
            @CMD_WT_MUT_OUTPUT_DIRS@
            @CMD_STRICT@
            @CMD_LOG@
    ]]></command>
    <inputs>
        <param argument="--mut_clean_report_path" type="data" format="json" label="Mutation clean report" help="Mut Clean JSON report for paired integration"/>
        <param name="wt_input_reports" type="data_collection" collection_type="list" format="json" label="Wild-type EnzyWizard reports" help="A list collection of wild-type EnzyWizard JSON reports. Include at most one report of each supported type."/>
        <param name="mut_input_reports" type="data_collection" collection_type="list" format="json" label="Mutant EnzyWizard reports" help="A list collection of mutant EnzyWizard JSON reports. Include at most one report of each supported type and use report types corresponding to the wild-type collection where possible."/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="strict"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <expand macro="output_collection_json" name="wt_output_files" label="${tool.name} wild-type outputs" directory="wt_output" pattern="(?P&lt;designation&gt;.+\.json)"/>
        <expand macro="output_collection_json" name="mut_output_files" label="${tool.name} mutant outputs" directory="mut_output" pattern="(?P&lt;designation&gt;.+\.json)"/>
    
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="mut_clean_report_path" value="mut_clean_report_1ZG4_WT_to_1ZG6_S70G.json"/>
            <param name="wt_input_reports">
                <collection type="list">
                    <element name="aaprops_report_cleaned_1ZG4_WT.json" value="wt_reports/aaprops_report_cleaned_1ZG4_WT.json"/>
                    <element name="conservation_report_cleaned_1ZG4_WT.json" value="wt_reports/conservation_report_cleaned_1ZG4_WT.json"/>
                    <element name="disorder_report_cleaned_1ZG4_WT.json" value="wt_reports/disorder_report_cleaned_1ZG4_WT.json"/>
                    <element name="dock_report_cleaned_1ZG4_WT_glucose_fructose.json" value="wt_reports/dock_report_cleaned_1ZG4_WT_glucose_fructose.json"/>
                    <element name="embedding_report_cleaned_1ZG4_WT.json" value="wt_reports/embedding_report_cleaned_1ZG4_WT.json"/>
                    <element name="energy_report_cleaned_1ZG4_WT.json" value="wt_reports/energy_report_cleaned_1ZG4_WT.json"/>
                    <element name="flexibility_report_cleaned_1ZG4_WT.json" value="wt_reports/flexibility_report_cleaned_1ZG4_WT.json"/>
                    <element name="hydrocluster_report_cleaned_1ZG4_WT.json" value="wt_reports/hydrocluster_report_cleaned_1ZG4_WT.json"/>
                    <element name="interaction_report_cleaned_1ZG4_WT_docked_glucose_docked_fructose.json" value="wt_reports/interaction_report_cleaned_1ZG4_WT_docked_glucose_docked_fructose.json"/>
                    <element name="pocket_report_cleaned_1ZG4_WT.json" value="wt_reports/pocket_report_cleaned_1ZG4_WT.json"/>
                    <element name="substrate_report_glucose_fructose.json" value="wt_reports/substrate_report_glucose_fructose.json"/>
                </collection>
            </param>
            <param name="mut_input_reports">
                <collection type="list">
                    <element name="aaprops_report_cleaned_1ZG6_S70G.json" value="mut_reports/aaprops_report_cleaned_1ZG6_S70G.json"/>
                    <element name="conservation_report_cleaned_1ZG6_S70G.json" value="mut_reports/conservation_report_cleaned_1ZG6_S70G.json"/>
                    <element name="disorder_report_cleaned_1ZG6_S70G.json" value="mut_reports/disorder_report_cleaned_1ZG6_S70G.json"/>
                    <element name="dock_report_cleaned_1ZG6_S70G_glucose_fructose.json" value="mut_reports/dock_report_cleaned_1ZG6_S70G_glucose_fructose.json"/>
                    <element name="embedding_report_cleaned_1ZG6_S70G.json" value="mut_reports/embedding_report_cleaned_1ZG6_S70G.json"/>
                    <element name="energy_report_cleaned_1ZG6_S70G.json" value="mut_reports/energy_report_cleaned_1ZG6_S70G.json"/>
                    <element name="flexibility_report_cleaned_1ZG6_S70G.json" value="mut_reports/flexibility_report_cleaned_1ZG6_S70G.json"/>
                    <element name="hydrocluster_report_cleaned_1ZG6_S70G.json" value="mut_reports/hydrocluster_report_cleaned_1ZG6_S70G.json"/>
                    <element name="interaction_report_cleaned_1ZG6_S70G_docked_glucose_docked_fructose.json" value="mut_reports/interaction_report_cleaned_1ZG6_S70G_docked_glucose_docked_fructose.json"/>
                    <element name="pocket_report_cleaned_1ZG6_S70G.json" value="mut_reports/pocket_report_cleaned_1ZG6_S70G.json"/>
                    <element name="substrate_report_glucose_fructose.json" value="mut_reports/substrate_report_glucose_fructose.json"/>
                </collection>
            </param>
            <param name="advanced|strict" value="true"/>
            <!-- Wild-type collection - order matches tool output -->
            <output_collection name="wt_output_files" type="list" count="3">
                <element name="mut_integrate_report_wild_type_to_mutant.json">
                    <assert_contents>
                        <has_text text="enzywizard_mut_integrate" />
                        <has_text text="overall_statistics" />
                        <has_text text="integrated_graph" />
                    </assert_contents>
                </element>
                <element name="wt_integrate_edges_wild_type.json">
                    <assert_contents>
                        <has_text text="molecular_interaction" />
                        <has_text text="source_node" />
                        <has_text text="target_node" />
                    </assert_contents>
                </element>
                <element name="wt_integrate_nodes_wild_type.json">
                    <assert_contents>
                        <has_text text="node_index" />
                        <has_text text="residue_name" />
                        <has_text text="residue_alpha_carbon_coordinate" />
                    </assert_contents>
                </element>
            </output_collection>
            <!-- Mutant collection - order matches tool output -->
            <output_collection name="mut_output_files" type="list" count="3">
                <element name="mut_integrate_edges_mutant.json">
                    <assert_contents>
                        <has_text text="molecular_interaction" />
                        <has_text text="source_node" />
                        <has_text text="target_node" />
                    </assert_contents>
                </element>
                <element name="mut_integrate_nodes_mutant.json">
                    <assert_contents>
                        <has_text text="node_index" />
                        <has_text text="residue_name" />
                    </assert_contents>
                </element>
                <element name="mut_integrate_report_wild_type_to_mutant.json">
                    <assert_contents>
                        <has_text text="enzywizard_mut_integrate" />
                        <has_text text="overall_statistics" />
                    </assert_contents>
                </element>
            </output_collection>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Mut Integrate combines wild-type and mutant EnzyWizard JSON report directories into a paired mutation-aware graph representation. The mutation clean report anchors the cleaned amino-acid substitution and residue mapping between wild-type and mutant structures.

**Inputs**

* **Mutation clean report**: JSON report from EnzyWizard Mut Clean.
* **Wild-type EnzyWizard reports**: a Galaxy list collection of wild-type JSON reports, with at most one report of each supported type.
* **Mutant EnzyWizard reports**: a corresponding Galaxy list collection of mutant JSON reports, also with at most one report of each type.
* **Strict mode**: require a complete supported report set and node fields before integration.

**Outputs**

* Wild-type integrated node and edge JSON reports.
* Mutant integrated node and edge JSON reports.
* Shared mutation-integrated summary JSON report.
* Optional log file.

**Usage note**

Wild-type and mutant report collections should contain corresponding report types where possible. Duplicate report types in either collection are not allowed.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-mut-integrate"/>
    <expand macro="creator"/>
</tool>
