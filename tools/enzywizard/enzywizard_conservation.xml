<tool id="enzywizard_conservation" name="EnzyWizard Conservation" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Calculate residue sequence conservation from a cleaned protein sequence and MSA</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-conservation</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        exec 3>&1 4>&2;
        exec > enzywizard.log 2>&1;

        #set $fasta_name = $input_fasta.element_identifier
        #set $msa_name = $input_msa.element_identifier
        ln -s '$input_fasta' '$fasta_name' &&
        ln -s '$input_msa' '$msa_name' &&
        enzywizard-conservation
        -i '$fasta_name'
        -m '$msa_name'
        -o ./
    
    ]]></command>
    <inputs>
        <expand macro="fasta_input"/>
        <expand macro="msa_input"/>
        <expand macro="log_input"/>
    </inputs>
    <outputs>
        <data name="out_sto" format="stockholm" label="${tool.name} StockholM alignment"  from_work_dir="cleaned_jhmm_*.sto" />
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="conservation_report_cleaned_*.json" />
        <data name="out_hmm" format="hmm3" label="${tool.name} Clean  Protein fingerprint"  from_work_dir="hmm_profile_jhmm_*.hmm" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="4">
            <param name="input_fasta" value="cleaned_1HVR.fasta"/>
            <param name="input_msa" value="jhmm_1HVR.sto"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <output name="out_json">
            <assert_contents>
                <has_text text="enzywizard_conservation" />
                <has_text text="sequence_conservation_scores" />
                <has_text text="residue_index" />
                <has_text text="residue_name" />
                <has_text text="hmm_profile_raw_score" />
                <has_text text="normalized_emission_probability" />
                <has_text text="normalized_shannon_information_content" />
                <!-- Check the first few residues are present -->
                <has_text text="&quot;P&quot;" />   <!-- residue_name: P -->
                <has_text text="&quot;Q&quot;" />   <!-- residue_name: Q -->
                <has_text text="&quot;V&quot;" />   <!-- residue_name: V -->
            </assert_contents>
        </output>
        <output name="out_hmm">
            <assert_contents>
                <has_text text="HMMER3" />
                <has_text text="NAME" />
                <has_text text="LENG" />
                <!-- The actual HMM file has two spaces between ALPH and amino -->
                <has_text text="ALPH  amino" />
                <has_text text="NSEQ" />
                <has_text text="COMPO" />
            </assert_contents>
        </output>
        <output name="out_sto">
            <assert_contents>
                <has_text text="# STOCKHOLM" />
                <has_text text="1HVR" />
                <has_text text="PQVTLWQR" />
                <has_text text="sp|O89940|POL_HV1SE" />
            </assert_contents>
        </output>
        <output name="log">
            <assert_contents>
                <has_text text="Conservation processing started" />
                <has_text text="cleaned_1HVR" />
                <has_text text="Conservation processing finished" />
            </assert_contents>
        </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Conservation calculates residue sequence-conservation scores from a cleaned protein FASTA sequence and a matching multiple sequence alignment. It standardizes the alignment, builds an HMM profile, and reports conservation-related values for each residue.

**Inputs**

* **Cleaned protein sequence**: FASTA sequence from EnzyWizard Clean.
* **Multiple sequence alignment**: MSA matching the cleaned protein sequence. Supported content includes Stockholm, aligned FASTA, or A3M-style alignments stored as compatible text data.

**Outputs**

* JSON report named like ``conservation_report_*.json``.
* Optional log file.

**Important usage note**

The query sequence in the MSA should correspond to the cleaned FASTA sequence. Mismatched residue order or numbering can make downstream integration invalid.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-conservation"/>
    <expand macro="creator"/>
</tool>
