<macros>
    <token name="@TOOL_VERSION@">1.0.2</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">26.0</token>
    <token name="@CMD_INPUT_NAME@"><![CDATA[-i '$input_name']]></token>
    <token name="@CMD_INPUT_FASTA@"><![CDATA[-i '$input_fasta']]></token>
    <token name="@CMD_INPUT_MSA@"><![CDATA[-m '$input_msa']]></token>
    <token name="@CMD_OUTPUT_DIR@"><![CDATA[-o ./]]></token>
    <token name="@CMD_LOG@"><![CDATA[> log.txt]]></token>
    <token name="@CMD_CLEAN_ARGS@"><![CDATA[$advanced.no_add_h
        --pH '$advanced.ph']]></token>
    <token name="@CMD_STRICT@"><![CDATA[$advanced.strict]]></token>
    <token name="@CMD_OPTIONAL_ADVANCED_SUBSTRATE_NAMES@"><![CDATA[#if $advanced.substrate_names:
        -s '$advanced.substrate_names'
        #end if]]></token>
    <token name="@CMD_SUBSTRATE_NAMES@"><![CDATA[-s '$substrate_names']]></token>
    <token name="@CMD_POCKET_ARGS@"><![CDATA[--min_rad '$advanced.pocket.min_rad'
        --max_rad '$advanced.pocket.max_rad'
        --min_volume '$advanced.pocket.min_volume']]></token>
    <token name="@CMD_BATCH_ADVANCED_ARGS@"><![CDATA[--hydrocluster_cutoff '$advanced.hydrocluster_cutoff'
        $advanced.energy.no_minimize_energy
        --energy_minimization_iteration '$advanced.energy.minimization_iteration'
        --flexibility_method '$advanced.flexibility.flexibility_method'
        --flexibility_cutoff '$advanced.flexibility.flexibility_cutoff'
        --flexibility_n_modes '$advanced.flexibility.flexibility_n_modes'
        --disorder_window_size '$advanced.disorder.disorder_window_size'
        --disorder_min_region_length '$advanced.disorder.disorder_min_region_length'
        --embedding_model_name '$advanced.embedding_model_name'
        --pocket_min_rad '$advanced.pocket.pocket_min_rad'
        --pocket_max_rad '$advanced.pocket.pocket_max_rad'
        --pocket_min_volume '$advanced.pocket.pocket_min_volume'
        --substrate_max_synonyms '$advanced.substrate.substrate_max_synonyms'
        --substrate_fp_radius '$advanced.substrate.substrate_fp_radius'
        --substrate_n_bits '$advanced.substrate.substrate_n_bits'
        --substrate_num_confs '$advanced.substrate.substrate_num_confs'
        --substrate_prune_rms '$advanced.substrate.substrate_prune_rms'
        --dock_max_attempt_num '$advanced.docking.dock_max_attempt_num'
        $advanced.docking.dock_no_early_stop
        --dock_exhaustiveness '$advanced.docking.dock_exhaustiveness'
        --dock_cpu "\${GALAXY_SLOTS:-1}"
        #if $advanced.docking.dock_catalytic_residue:
        --dock_catalytic_residue '$advanced.docking.dock_catalytic_residue'
        #end if
        #if $advanced.docking.dock_catalytic_site_coord:
        --dock_catalytic_site_coord '$advanced.docking.dock_catalytic_site_coord'
        #end if
        #if $advanced.docking.dock_box_size:
        --dock_box_size '$advanced.docking.dock_box_size'
        #end if
        --hbond_bonded_h_min_distance '$advanced.interaction.hbond_bonded_h_min_distance'
        --hbond_bonded_h_max_distance '$advanced.interaction.hbond_bonded_h_max_distance']]></token>
    <token name="@CMD_INTERACTION_DISTANCE_ARGS@"><![CDATA[--hbond_da_max_distance '$advanced.interaction.hbond_da_max_distance'
        --hbond_ha_max_distance '$advanced.interaction.hbond_ha_max_distance'
        --hbond_angle '$advanced.interaction.hbond_angle'
        --ionic_distance_cutoff '$advanced.interaction.ionic_distance_cutoff']]></token>
    <token name="@CMD_BATCH_VDW_ARG@"><![CDATA[--vdw_mu '$advanced.interaction.vdw_mu']]></token>
    <token name="@CMD_INTERACTION_STACKING_ARGS@"><![CDATA[--ppstack_center_distance_cutoff '$advanced.interaction.ppstack_center_distance_cutoff'
        --pication_distance_cutoff '$advanced.interaction.pication_distance_cutoff'
        --pication_angle_cutoff '$advanced.interaction.pication_angle_cutoff'
        --ssbond_max_distance '$advanced.interaction.ssbond_max_distance']]></token>
    <token name="@CMD_WT_MUT_OUTPUT_DIRS@"><![CDATA[-wo wt_output
            -mo mut_output]]></token>
    <xml name="creator">
        <creator>
            <person givenName="Khaled" familyName="Jum'ah" url="https://github.com/khaled196" />
            <person givenName="Mingkai" familyName="Wang" url="https://github.com/Mingkai14" />
            <person givenName="Krzysztof" familyName="Poterlowicz" url="https://github.com/kpoterlowicz" />
            <organization name="poterlowicz-lab" url="https://github.com/poterlowicz-lab" />
        </creator>
    </xml>
    <xml name="protein_input">
        <param argument="--input_name" type="data" format="cif,pdb" label="Cleaned protein structure" help="Cleaned protein structure from EnzyWizard Clean"/>
    </xml>
    <xml name="fasta_input">
        <param argument="--input_fasta" type="data" format="fasta" label="Cleaned protein sequence" help="Cleaned protein FASTA from EnzyWizard Clean"/>
    </xml>
    <xml name="msa_input">
        <param argument="--input_msa" type="data" format="stockholm,fasta" label="Multiple sequence alignment" help="MSA for the cleaned protein sequence"/>
    </xml>
    <xml name="substrate_names">
        <param argument="--substrate_names" type="text" label="Substrate names or SMILES" help="Substrate names or SMILES separated by semicolons">
            <sanitizer>
                <valid initial="string.ascii_letters,string.digits">
                    <add value=" "/>
                    <add value=";"/>
                    <add value=":"/>
                    <add value="_"/>
                    <add value="-"/>
                    <add value="+"/>
                    <add value="="/>
                    <add value="#"/>
                    <add value="."/>
                    <add value=","/>
                    <add value="&#92;"/>
                    <add value="("/>
                    <add value=")"/>
                    <add value="["/>
                    <add value="]"/>
                    <add value="@"/>
                </valid>
            </sanitizer>
        </param>
    </xml>
    <xml name="optional_substrate_names">
        <param argument="--substrate_names" type="text" optional="true" label="Substrate names or SMILES" help="Optional substrate names or SMILES">
            <sanitizer>
                <valid initial="string.ascii_letters,string.digits">
                    <add value=" "/>
                    <add value=";"/>
                    <add value=":"/>
                    <add value="_"/>
                    <add value="-"/>
                    <add value="+"/>
                    <add value="="/>
                    <add value="#"/>
                    <add value="."/>
                    <add value=","/>
                    <add value="&#92;"/>
                    <add value="("/>
                    <add value=")"/>
                    <add value="["/>
                    <add value="]"/>
                    <add value="@"/>
                </valid>
            </sanitizer>
        </param>
    </xml>
    <xml name="strict">
        <param argument="--strict" type="boolean" truevalue="--strict" falsevalue="" checked="false" label="Strict mode" help="Require all supported EnzyWizard reports"/>
    </xml>
    <xml name="no_add_h">
        <param name="no_add_h" argument="--no_add_H" type="boolean" truevalue="--no_add_H" falsevalue="" checked="false" label="Disable hydrogen addition" help="Skip hydrogen addition during cleaning"/>
    </xml>
    <xml name="ph">
        <param name="ph" argument="--pH" type="float" value="7.0" min="0" max="14" label="pH" help="pH used when adding hydrogens"/>
    </xml>
    <xml name="no_minimize_energy">
        <param argument="--no_minimize_energy" type="boolean" truevalue="--no_minimize_energy" falsevalue="" checked="false" label="Disable energy minimization" help="Skip energy minimization"/>
    </xml>
    <xml name="minimization_iteration">
        <param name="minimization_iteration" type="integer" value="1000" min="1" label="Energy minimization iterations" help="Maximum OpenMM minimization iterations"/>
    </xml>
    <xml name="hydrocluster_cutoff">
        <param name="hydrocluster_cutoff" type="float" value="10.0" min="0" label="Hydrophobic cluster cutoff" help="Minimum contact area for hydrophobic clustering"/>
    </xml>
    <xml name="flexibility_method">
        <param name="flexibility_method" type="select" label="Flexibility method" help="Elastic network model for RMSF calculation">
            <option value="ANM">ANM</option>
            <option value="GNM">GNM</option>
        </param>
    </xml>
    <xml name="flexibility_cutoff">
        <param name="flexibility_cutoff" type="float" value="15.0" min="0" label="Flexibility distance cutoff" help="CA distance cutoff for elastic network edges"/>
    </xml>
    <xml name="flexibility_n_modes">
        <param name="flexibility_n_modes" type="integer" value="20" min="1" label="Number of normal modes" help="Number of low-frequency modes for RMSF"/>
    </xml>
    <xml name="disorder_window_size">
        <param name="disorder_window_size" type="integer" value="11" min="1" label="Disorder window size" help="Window size for smoothing disorder scores"/>
    </xml>
    <xml name="disorder_min_region_length">
        <param name="disorder_min_region_length" type="integer" value="5" min="1" label="Minimum disordered region length" help="Minimum length for a disordered region"/>
    </xml>
    <xml name="embedding_model_name">
        <param name="embedding_model_name" type="select" label="ESM-2 model" help="ESM-2 model for per-residue embeddings">
            <option value="esm2_t6_8M_UR50D">esm2_t6_8M_UR50D</option>
            <option value="esm2_t12_35M_UR50D">esm2_t12_35M_UR50D</option>
            <option value="esm2_t30_150M_UR50D">esm2_t30_150M_UR50D</option>
        </param>
    </xml>
    <xml name="pocket_params">
        <param argument="--min_rad" type="float" value="1.8" min="0" label="Minimum probe radius" help="Minimum PyVOL probe radius"/>
        <param argument="--max_rad" type="float" value="6.2" min="0" label="Maximum probe radius" help="Maximum PyVOL probe radius"/>
        <param argument="--min_volume" type="integer" value="50" min="21" label="Minimum pocket volume" help="Minimum pocket volume to report"/>
    </xml>

    <xml name="batch_pocket_params">
        <param argument="--pocket_min_rad" type="float" value="1.8" min="0" label="Pocket minimum probe radius" help="Minimum pocket probe radius"/>
        <param argument="--pocket_max_rad" type="float" value="6.2" min="0" label="Pocket maximum probe radius" help="Maximum pocket probe radius"/>
        <param argument="--pocket_min_volume" type="integer" value="50" min="21" label="Pocket minimum volume" help="Minimum pocket volume to keep"/>
    </xml>
    <xml name="batch_substrate_params">
        <param argument="--substrate_max_synonyms" type="integer" value="20" min="1" label="Maximum substrate synonym retries" help="Maximum substrate name lookup attempts"/>
        <param argument="--substrate_fp_radius" type="integer" value="2" min="1" label="Substrate Morgan fingerprint radius" help="Morgan fingerprint radius"/>
        <param argument="--substrate_n_bits" type="integer" value="512" min="1" label="Substrate fingerprint bit size" help="Substrate fingerprint bit length"/>
        <param argument="--substrate_num_confs" type="integer" value="5" min="1" label="Maximum substrate conformers" help="Maximum 3D conformers per substrate"/>
        <param argument="--substrate_prune_rms" type="float" value="0.5" min="0" label="Substrate conformer prune RMS" help="RMS threshold for conformer pruning"/>
    </xml>
    <xml name="batch_dock_params">
        <param argument="--dock_max_attempt_num" type="integer" value="20" min="1" label="Maximum docking attempts" help="Maximum docking attempts"/>
        <param argument="--dock_no_early_stop" type="boolean" truevalue="--dock_no_early_stop" falsevalue="" checked="false" label="Disable docking early stop" help="Continue after the first successful docking result"/>
        <param argument="--dock_exhaustiveness" type="integer" value="16" min="1" label="Docking exhaustiveness" help="AutoDock Vina search exhaustiveness"/>
        <param argument="--dock_catalytic_residue" type="integer" optional="true" label="Manual center residue" help="Use this residue CA as box center"/>
        <param argument="--dock_catalytic_site_coord" type="text" optional="true" label="Manual center coordinate" help="Use this x,y,z coordinate as box center"/>
        <param argument="--dock_box_size" type="text" optional="true" label="Manual box dimensions" help="Box dimensions as x,y,z"/>
    </xml>
    <xml name="batch_interaction_params">
        <param argument="--hbond_bonded_h_min_distance" type="float" value="0.8" min="0" label="Hydrogen bond bonded H minimum distance" help="Minimum donor-H bonded distance"/>
        <param argument="--hbond_bonded_h_max_distance" type="float" value="1.3" min="0" label="Hydrogen bond bonded H maximum distance" help="Maximum donor-H bonded distance"/>
        <param argument="--hbond_da_max_distance" type="float" value="3.9" min="0" label="Hydrogen bond donor-acceptor maximum distance" help="Maximum donor-acceptor distance"/>
        <param argument="--hbond_ha_max_distance" type="float" value="2.5" min="0" label="Hydrogen bond hydrogen-acceptor maximum distance" help="Maximum hydrogen-acceptor distance"/>
        <param argument="--hbond_angle" type="float" value="90.0" min="0" label="Hydrogen bond minimum angle" help="Minimum donor-hydrogen-acceptor angle"/>
        <param argument="--ionic_distance_cutoff" type="float" value="4.0" min="0" label="Ionic bond distance cutoff" help="Maximum ionic interaction distance"/>
        <param argument="--vdw_mu" type="float" value="0.01" min="0" label="Van der Waals mu" help="Van der Waals contact model mu"/>
        <param argument="--ppstack_center_distance_cutoff" type="float" value="6.5" min="0" label="Pi-pi stacking center distance cutoff" help="Maximum pi-pi ring-center distance"/>
        <param argument="--pication_distance_cutoff" type="float" value="5.0" min="0" label="Pi-cation distance cutoff" help="Maximum pi-cation distance"/>
        <param argument="--pication_angle_cutoff" type="float" value="45.0" min="0" label="Pi-cation angle cutoff" help="Maximum pi-cation angle"/>
        <param argument="--ssbond_max_distance" type="float" value="2.5" min="0" label="Disulfide bond maximum distance" help="Maximum sulfur-sulfur distance"/>
    </xml>
    <xml name="output_collection_json" tokens="name,label,directory,pattern">
        <collection name="@NAME@" type="list" label="@LABEL@">
            <discover_datasets pattern="@PATTERN@" directory="@DIRECTORY@" recurse="true" match_relative_path="true" format="json" visible="true"/>
        </collection>
    </xml>

    <xml name="show_log_param">
        <param name="show_log" type="boolean" truevalue="true" falsevalue="false" checked="false" label="Output log file" help="Add the tool log to the Galaxy history"/>
    </xml>
    <xml name="log_input">
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="show_log_param"/>
        </section>
    </xml>
    <xml name="log_output">
        <data name="log" format="txt" from_work_dir="log.txt" label="${tool.name} on ${on_string}: log file">
            <filter>advanced['show_log']</filter>
        </data>
    </xml>
    <xml name="citations" tokens="repo_name">
        <citations>
            <citation type="bibtex">@software{@REPO_NAME@,
  title = {@REPO_NAME@},
  author = {Wang, Mingkai},
  url = {https://github.com/bioinfbrad/@REPO_NAME@}
}</citation>
        </citations>
    </xml>
</macros>
