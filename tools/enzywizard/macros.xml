<macros>
    <token name="@TOOL_VERSION@">1.0.2</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">23.0</token>
    <xml name="creator">
        <creator>
            <person givenName="Khaled" familyName="Jum'ah" url="https://github.com/khaled196" />
            <person givenName="Mingkai" familyName="Wang" url="https://github.com/Mingkai14" />
            <person givenName="Krzysztof" familyName="Poterlowicz" url="https://github.com/kpoterlowicz" />
            <organization name="poterlowicz-lab" url="https://github.com/poterlowicz-lab" />
        </creator>
    </xml>
    <xml name="protein_input">
        <param name="input_path" type="data" format="mmcif,pdb" label="Cleaned protein structure" help="Input cleaned protein structure file in CIF or PDB format."/>
    </xml>
    <xml name="fasta_input">
        <param name="input_fasta" type="data" format="fasta" label="Cleaned protein sequence" help="Input cleaned protein sequence file in FASTA format."/>
    </xml>
    <xml name="msa_input">
        <param name="input_msa" type="data" format="stockholm,fasta" label="Multiple sequence alignment" help="Input MSA file in Stockholm, aligned FASTA, or A3M format."/>
    </xml>
    <xml name="zip_input_dir" tokens="name label help optional">
        <param name="@NAME@" type="data" format="zip" optional="@OPTIONAL@" label="@LABEL@" help="@HELP@"/>
    </xml>
    <xml name="substrate_names">
        <param name="substrate_names" type="text" optional="true" label="Substrate names or SMILES" help="Substrate names or SMILES strings separated by ';'."/>
    </xml>
    <xml name="strict">
        <param name="strict" type="boolean" truevalue="--strict" falsevalue="" checked="false" label="Strict mode" help="Enable strict mode requiring all supported report types."/>
    </xml>
    <xml name="no_add_h">
        <param name="no_add_h" type="boolean" truevalue="--no_add_H" falsevalue="" checked="false" label="Disable hydrogen addition" help="Disable hydrogen addition using OpenMM."/>
    </xml>
    <xml name="ph">
        <param name="ph" type="float" value="7.0" min="0" max="14" label="pH" help="pH value used for hydrogen addition."/>
    </xml>
    <xml name="no_minimize_energy">
        <param name="no_minimize_energy" type="boolean" truevalue="--no_minimize_energy" falsevalue="" checked="false" label="Disable energy minimization"/>
    </xml>
    <xml name="minimization_iteration">
        <param name="minimization_iteration" type="integer" value="1000" min="1" label="Energy minimization iterations"/>
    </xml>
    <xml name="hydrocluster_cutoff">
        <param name="hydrocluster_cutoff" type="float" value="10.0" min="0" label="Hydrophobic cluster cutoff"/>
    </xml>
    <xml name="flexibility_method">
        <param name="flexibility_method" type="select" label="Flexibility method">
            <option value="ANM">ANM</option>
            <option value="GNM">GNM</option>
        </param>
    </xml>
    <xml name="flexibility_cutoff">
        <param name="flexibility_cutoff" type="float" value="15.0" min="0" label="Flexibility distance cutoff"/>
    </xml>
    <xml name="flexibility_n_modes">
        <param name="flexibility_n_modes" type="integer" value="20" min="1" label="Number of normal modes"/>
    </xml>
    <xml name="disorder_window_size">
        <param name="disorder_window_size" type="integer" value="11" min="1" label="Disorder window size"/>
    </xml>
    <xml name="disorder_min_region_length">
        <param name="disorder_min_region_length" type="integer" value="5" min="1" label="Minimum disordered region length"/>
    </xml>
    <xml name="embedding_model_name">
        <param name="embedding_model_name" type="select" label="ESM-2 model">
            <option value="esm2_t6_8M_UR50D">esm2_t6_8M_UR50D</option>
            <option value="esm2_t12_35M_UR50D">esm2_t12_35M_UR50D</option>
            <option value="esm2_t30_150M_UR50D">esm2_t30_150M_UR50D</option>
        </param>
    </xml>
    <xml name="pocket_params">
        <param name="min_rad" type="float" value="1.8" min="0" label="Minimum probe radius"/>
        <param name="max_rad" type="float" value="6.2" min="0" label="Maximum probe radius"/>
        <param name="min_volume" type="float" value="50" min="0" label="Minimum pocket volume"/>
    </xml>
    <xml name="output_collection" tokens="name label">
        <collection name="@NAME@" type="list" label="@LABEL@">
            <discover_datasets pattern="(?P&lt;designation&gt;.+)" directory="." recurse="true" match_relative_path="true" format="data" visible="true"/>
        </collection>
    </xml>
    <xml name="output_collection_json" tokens="name label directory">
        <collection name="@NAME@" type="list" label="@LABEL@">
            <discover_datasets pattern="(?P&lt;designation&gt;.+\.json)" directory="@DIRECTORY@" recurse="true" match_relative_path="true" format="json" visible="true"/>
        </collection>
    </xml>
</macros>
