<macros>
    <token name="@TOOL_VERSION@">1.0.2</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">26.0</token>
    <xml name="creator">
        <creator>
            <person givenName="Khaled" familyName="Khaled" email="khaled@example.org"/>
        </creator>
    </xml>
    <xml name="protein_input">
        <param name="input_path" type="data" format="data,pdb" label="Cleaned protein structure" help="Input cleaned protein structure file in CIF or PDB format."/>
    </xml>
    <xml name="fasta_input">
        <param name="input_fasta" type="data" format="fasta" label="Cleaned protein sequence" help="Input cleaned protein sequence file in FASTA format."/>
    </xml>
    <xml name="msa_input">
        <param name="input_msa" type="data" format="stockholm,fasta" label="Multiple sequence alignment" help="Input MSA file in Stockholm, aligned FASTA, or A3M format."/>
    </xml>
    <xml name="zip_input_dir" tokens="name,label,help">
        <param name="@NAME@" type="data" format="zip" label="@LABEL@" help="@HELP@"/>
    </xml>
    <xml name="optional_zip_input_dir" tokens="name,label,help">
        <param name="@NAME@" type="data" format="zip" optional="true" label="@LABEL@" help="@HELP@"/>
    </xml>
    <xml name="substrate_names">
        <param name="substrate_names" type="text" label="Substrate names or SMILES" help="Substrate names or SMILES strings separated by ';'.">
            <sanitizer>
                <valid initial="string.ascii_letters,string.digits">
                    <add value=" "/>
                    <add value=";"/>
                    <add value=":"/>
                    <add value="_"/>
                    <add value="-"/>
                    <add value="+"/>
                    <add value="="/>
                    <add value="#"/>
                    <add value="."/>
                    <add value=","/>
                    <add value="/"/>
                    <add value="&#92;"/>
                    <add value="("/>
                    <add value=")"/>
                    <add value="["/>
                    <add value="]"/>
                    <add value="@"/>
                </valid>
            </sanitizer>
        </param>
    </xml>
    <xml name="optional_substrate_names">
        <param name="substrate_names" type="text" optional="true" label="Substrate names or SMILES" help="Optional substrate names or SMILES strings separated by ';'.">
            <sanitizer>
                <valid initial="string.ascii_letters,string.digits">
                    <add value=" "/>
                    <add value=";"/>
                    <add value=":"/>
                    <add value="_"/>
                    <add value="-"/>
                    <add value="+"/>
                    <add value="="/>
                    <add value="#"/>
                    <add value="."/>
                    <add value=","/>
                    <add value="/"/>
                    <add value="&#92;"/>
                    <add value="("/>
                    <add value=")"/>
                    <add value="["/>
                    <add value="]"/>
                    <add value="@"/>
                </valid>
            </sanitizer>
        </param>
    </xml>
    <xml name="strict">
        <param name="strict" type="boolean" truevalue="--strict" falsevalue="" checked="false" label="Strict mode" help="Enable strict mode requiring all supported report types."/>
    </xml>
    <xml name="no_add_h">
        <param name="no_add_h" type="boolean" truevalue="--no_add_H" falsevalue="" checked="false" label="Disable hydrogen addition" help="Disable hydrogen addition using OpenMM."/>
    </xml>
    <xml name="ph">
        <param name="ph" type="float" value="7.0" min="0" max="14" label="pH" help="pH value used for hydrogen addition."/>
    </xml>
    <xml name="no_minimize_energy">
        <param name="no_minimize_energy" type="boolean" truevalue="--no_minimize_energy" falsevalue="" checked="false" label="Disable energy minimization"/>
    </xml>
    <xml name="minimization_iteration">
        <param name="minimization_iteration" type="integer" value="1000" min="1" label="Energy minimization iterations"/>
    </xml>
    <xml name="hydrocluster_cutoff">
        <param name="hydrocluster_cutoff" type="float" value="10.0" min="0" label="Hydrophobic cluster cutoff"/>
    </xml>
    <xml name="flexibility_method">
        <param name="flexibility_method" type="select" label="Flexibility method">
            <option value="ANM">ANM</option>
            <option value="GNM">GNM</option>
        </param>
    </xml>
    <xml name="flexibility_cutoff">
        <param name="flexibility_cutoff" type="float" value="15.0" min="0" label="Flexibility distance cutoff"/>
    </xml>
    <xml name="flexibility_n_modes">
        <param name="flexibility_n_modes" type="integer" value="20" min="1" label="Number of normal modes"/>
    </xml>
    <xml name="disorder_window_size">
        <param name="disorder_window_size" type="integer" value="11" min="1" label="Disorder window size"/>
    </xml>
    <xml name="disorder_min_region_length">
        <param name="disorder_min_region_length" type="integer" value="5" min="1" label="Minimum disordered region length"/>
    </xml>
    <xml name="embedding_model_name">
        <param name="embedding_model_name" type="select" label="ESM-2 model">
            <option value="esm2_t6_8M_UR50D">esm2_t6_8M_UR50D</option>
            <option value="esm2_t12_35M_UR50D">esm2_t12_35M_UR50D</option>
            <option value="esm2_t30_150M_UR50D">esm2_t30_150M_UR50D</option>
        </param>
    </xml>
    <xml name="pocket_params">
        <param name="min_rad" type="float" value="1.8" min="0" label="Minimum probe radius"/>
        <param name="max_rad" type="float" value="6.2" min="0" label="Maximum probe radius"/>
        <param name="min_volume" type="integer" value="50" min="21" label="Minimum pocket volume"/>
    </xml>

    <xml name="batch_pocket_params">
        <param name="pocket_min_rad" type="float" value="1.8" min="0" label="Pocket minimum probe radius"/>
        <param name="pocket_max_rad" type="float" value="6.2" min="0" label="Pocket maximum probe radius"/>
        <param name="pocket_min_volume" type="integer" value="50" min="21" label="Pocket minimum volume"/>
    </xml>
    <xml name="batch_substrate_params">
        <param name="substrate_max_synonyms" type="integer" value="20" min="1" label="Maximum substrate synonym retries"/>
        <param name="substrate_fp_radius" type="integer" value="2" min="1" label="Substrate Morgan fingerprint radius"/>
        <param name="substrate_n_bits" type="integer" value="512" min="1" label="Substrate fingerprint bit size"/>
        <param name="substrate_num_confs" type="integer" value="5" min="1" label="Maximum substrate conformers"/>
        <param name="substrate_prune_rms" type="float" value="0.5" min="0" label="Substrate conformer prune RMS"/>
    </xml>
    <xml name="batch_dock_params">
        <param name="dock_max_attempt_num" type="integer" value="20" min="1" label="Maximum docking attempts"/>
        <param name="dock_no_early_stop" type="boolean" truevalue="--dock_no_early_stop" falsevalue="" checked="false" label="Disable docking early stop"/>
        <param name="dock_exhaustiveness" type="integer" value="16" min="1" label="Docking exhaustiveness"/>
        <param name="dock_catalytic_residue" type="integer" optional="true" label="Docking catalytic residue index" help="Cleaned protein residue index used as the docking box center. Requires docking box size."/>
        <param name="dock_catalytic_site_coord" type="text" optional="true" label="Docking catalytic site coordinate" help="Coordinate as x,y,z. Requires docking box size."/>
        <param name="dock_box_size" type="text" optional="true" label="Docking box size" help="Box size as x,y,z. Required when a catalytic residue or catalytic site coordinate is provided."/>
    </xml>
    <xml name="batch_interaction_params">
        <param name="hbond_bonded_h_min_distance" type="float" value="0.8" min="0" label="Hydrogen bond bonded H minimum distance"/>
        <param name="hbond_bonded_h_max_distance" type="float" value="1.3" min="0" label="Hydrogen bond bonded H maximum distance"/>
        <param name="hbond_da_max_distance" type="float" value="3.9" min="0" label="Hydrogen bond donor-acceptor maximum distance"/>
        <param name="hbond_ha_max_distance" type="float" value="2.5" min="0" label="Hydrogen bond hydrogen-acceptor maximum distance"/>
        <param name="hbond_angle" type="float" value="90.0" min="0" label="Hydrogen bond minimum angle"/>
        <param name="ionic_distance_cutoff" type="float" value="4.0" min="0" label="Ionic bond distance cutoff"/>
        <param name="vdw_mu" type="float" value="0.01" min="0" label="Van der Waals mu"/>
        <param name="ppstack_center_distance_cutoff" type="float" value="6.5" min="0" label="Pi-pi stacking center distance cutoff"/>
        <param name="pication_distance_cutoff" type="float" value="5.0" min="0" label="Pi-cation distance cutoff"/>
        <param name="pication_angle_cutoff" type="float" value="45.0" min="0" label="Pi-cation angle cutoff"/>
        <param name="ssbond_max_distance" type="float" value="2.5" min="0" label="Disulfide bond maximum distance"/>
    </xml>

    <xml name="output_collection" tokens="name,label,pattern">
        <collection name="@NAME@" type="list" label="@LABEL@">
            <discover_datasets pattern="@PATTERN@" directory="." recurse="true" match_relative_path="true" format="data" visible="true"/>
        </collection>
    </xml>
    <xml name="output_collection_json" tokens="name,label,directory,pattern">
        <collection name="@NAME@" type="list" label="@LABEL@">
            <discover_datasets pattern="@PATTERN@" directory="@DIRECTORY@" recurse="true" match_relative_path="true" format="json" visible="true"/>
        </collection>
    </xml>

    <xml name="show_log_param">
        <param name="show_log" type="boolean" truevalue="true" falsevalue="false" checked="false" label="Output log file" help="Add the captured standard output and standard error log to the history."/>
    </xml>
    <xml name="log_input">
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="show_log_param"/>
        </section>
    </xml>
    <xml name="log_output">
        <data name="log" format="txt" from_work_dir="log.txt" label="${tool.name} on ${on_string}: log file">
            <filter>advanced['show_log']</filter>
        </data>
    </xml>
    <xml name="citations" tokens="repo_name">
        <citations>
            <citation type="bibtex">@software{@REPO_NAME@,
  title = {@REPO_NAME@},
  author = {Wang, Mingkai},
  url = {https://github.com/bioinfbrad/@REPO_NAME@}
}</citation>
        </citations>
    </xml>
</macros>
