<tool id="enzywizard_batch" name="EnzyWizard Batch" version="@TOOL_VERSION@" profile="@PROFILE@">
    <description>Run a complete EnzyWizard analysis workflow from a cleaned protein structure and MSA</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements">
        <requirement type="package" version="0.1.0">enzywizard-batch</requirement>
    </expand>
    <command detect_errors="exit_code"><![CDATA[
        enzywizard-batch
        -i '$input_path'
        -m '$input_msa'
        #if $substrate_names:
            -s '$substrate_names'
        #end if
        -o ./
        --hydrocluster_cutoff '$hydrocluster_cutoff'
        $no_minimize_energy
        --energy_minimization_iteration '$minimization_iteration'
        --flexibility_method '$flexibility_method'
        --flexibility_cutoff '$flexibility_cutoff'
        --flexibility_n_modes '$flexibility_n_modes'
        --disorder_window_size '$disorder_window_size'
        --disorder_min_region_length '$disorder_min_region_length'
        --embedding_model_name '$embedding_model_name'
    ]]></command>
    <inputs>
        <expand macro="protein_input"/>
        <expand macro="msa_input"/>
        <expand macro="substrate_names"/>
        <expand macro="hydrocluster_cutoff"/>
        <expand macro="no_minimize_energy"/>
        <expand macro="minimization_iteration"/>
        <expand macro="flexibility_method"/>
        <expand macro="flexibility_cutoff"/>
        <expand macro="flexibility_n_modes"/>
        <expand macro="disorder_window_size"/>
        <expand macro="disorder_min_region_length"/>
        <expand macro="embedding_model_name"/>
    </inputs>
    <outputs>
        <expand macro="json_output"/>
    </outputs>
    <tests>
        <test>
            <param name="input_path" value="cleaned_3GP6.cif"/>
            <param name="input_msa" value="jhmm_3GP6.sto"/>
            <param name="substrate_names" value="glucose;fructose"/>
            <output name="json_report" file="integrate_report_3GP6.json" compare="sim_size" delta="0.1"/>
        </test>
    </tests>
    <help><![CDATA[
**EnzyWizard-Batch**

Runs a complete EnzyWizard analysis workflow from a cleaned protein structure and a matched MSA file. Performs multiple modules including amino acid property analysis, hydrophobic cluster detection, energy evaluation, flexibility analysis, disorder prediction, conservation analysis, embedding generation, pocket detection, optional substrate docking, interaction network calculation, and final graph integration.

**Inputs**
- Cleaned protein structure in CIF or PDB format.
- MSA file in Stockholm, aligned FASTA, or A3M format.
- Optional substrate names or SMILES strings.

**Outputs**
- Integrated JSON report.

For more information, see the `enzywizard-batch` documentation: https://github.com/bioinfbrad/enzywizard-batch
    ]]></help>
    <creator>
        <person givenName="Your" familyName="Name" email="your.email@example.com"/>
    </creator>
</tool>
