<tool id="enzywizard_embedding" name="EnzyWizard Embedding" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Generate protein sequence embeddings using ESM-2</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-embedding</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        exec 3>&1 4>&2;
        exec > enzywizard.log 2>&1;
        #set $input_name = $input_fasta.element_identifier
        ln -s '$input_fasta' '$input_name' &&
        enzywizard-embedding
        -i '$input_name'
        --model_name '$advanced.embedding_model_name'
        -o ./
    ]]></command>
    <inputs>
        <expand macro="fasta_input"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="embedding_model_name"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="embedding_report_cleaned_*.json" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="input_fasta" value="cleaned_1HVR.fasta"/>
            <section name="advanced">
                <param name="show_log" value="true"/>
            </section>
            <output name="out_json" format="json">
                <assert_contents>
                    <has_text text="enzywizard_embedding" />
                    <has_text text="sequence_embeddings" />
                    <has_text text="residue_index" />
                    <has_text text="residue_name" />
                    <has_text text="residue_embedding" />
                    <!-- Check that the first residue is P (as in the example) -->
                    <has_text text="&quot;P&quot;" />
                </assert_contents>
            </output>
            <output name="log">
                <assert_contents>
                    <has_text text="Embedding processing started" />
                    <has_text text="cleaned_1HVR" />
                    <has_text text="Embedding processing finished" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
Generate protein sequence embeddings using ESM-2. The wrapper symlinks Galaxy file inputs into the job working directory and captures the tool-created output directory/files as a Galaxy discovered collection.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-embedding"/>
    <expand macro="creator"/>
</tool>
