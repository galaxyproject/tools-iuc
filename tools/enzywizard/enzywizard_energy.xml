<tool id="enzywizard_energy" name="EnzyWizard Energy" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Calculate molecular energy terms from a cleaned protein structure</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">enzywizard-energy</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        @CMD_LINK_INPUT_NAME@
        enzywizard-energy
        @CMD_INPUT_NAME@
        $advanced.no_minimize_energy
        --minimization_iteration '$advanced.minimization_iteration'
        @CMD_OUTPUT_DIR@
        @CMD_LOG@
    ]]></command>
    <inputs>
        <expand macro="protein_input"/>
        <section name="advanced" title="Advanced options" expanded="false">
            <expand macro="no_minimize_energy"/>
            <expand macro="minimization_iteration"/>
            <expand macro="show_log_param"/>
        </section>
    </inputs>
    <outputs>
        <data name="out_json" format="json" label="${tool.name} JSON report"  from_work_dir="energy_report_*.json" />
        <expand macro="log_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="input_name" value="cleaned_3GP6.cif"/>
            <section name="advanced">
                <param name="minimization_iteration" value="10"/>
                <param name="show_log" value="true"/>
            </section>
            <output name="out_json">
                <assert_contents>
                    <has_text text="enzywizard_energy" />
                    <has_text text="energy_terms" />
                    <has_text text="total_potential_energy" />
                    <has_text text="harmonic_bond_potential_energy" />
                    <has_text text="harmonic_angle_potential_energy" />
                    <has_text text="custom_bond_potential_energy" />
                    <has_text text="custom_torsion_potential_energy" />
                    <has_text text="custom_nonbonded_potential_energy" />
                    <has_text text="nonbonded_potential_energy" />
                    <has_text text="periodic_torsion_potential_energy" />
                    <has_text text="cmap_torsion_potential_energy" />
                </assert_contents>
            </output>
            <output name="log">
                <assert_contents>
                    <has_text text="Energy processing started" />
                    <has_text text="Energy processing finished" />
                    <not_has_text text="[ERROR]" />
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

EnzyWizard Energy evaluates molecular energy terms from a cleaned protein structure using OpenMM. It can optionally minimize the structure before reporting energy terms, allowing comparison between minimized and near-input conformational states.

**Inputs**

* **Cleaned protein structure**: cleaned CIF or PDB structure.
* **Disable energy minimization**: report energy terms without a minimization step.
* **Energy minimization iterations**: maximum number of minimization iterations when minimization is enabled.

**Outputs**

* JSON report named like ``energy_report_*.json`` with total potential energy and component energy terms.
* Optional log file.

**Downstream use**

Include the energy report in EnzyWizard Integrate or Batch to add molecular energy information to the integrated graph summary.
    ]]></help>
    <expand macro="citations" repo_name="enzywizard-energy"/>
    <expand macro="creator"/>
</tool>
