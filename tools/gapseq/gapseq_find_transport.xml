<tool id="gapseq_find_transport" name="gapseq find-transport" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="25.01">
    <description></description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        ## Gapseq uses the filename even when we soft link it with a different name, so we copy the input file instead.
        cp '$fasta_input' input.fa &&

        gapseq find-transport
            -b $b
            -i $i
            -c $c
            $q
            $a
            #if $m != "":
                -m '$m'
            #end if
            -A $A
            -f ./output
            -K "\${GALAXY_SLOTS:-1}"
            input.fa
    
    ]]></command>
    <inputs>
        <expand macro="fasta_input_macro"/>
        <expand macro="bitscore_cutoff" default_score="50"/>
        <expand macro="identity_cutoff" default_score="0"/>
        <expand macro="coverage_cutoff" default_score="75"/>
        <param argument="-q" type="boolean" truevalue="-q" falsevalue="" checked="false" label="Include sequences of hits in results table" />
        <param argument="-a" type="boolean" truevalue="-a" falsevalue="" checked="false" label="Do not use alternative transport reaction types if no database reaction exists for the specific TC type of the reference sequence" />
        <param argument="-m" type="text" value="" label="Only check for this keyword/metabolite" help="Leave empty to check all"/>
        <expand macro="alignment_tool"/>
    </inputs>
    <outputs>
        <expand macro="transporters"/>
    </outputs>
    <tests>
    <test expect_num_outputs="1">
        <param name="fasta_input" value="ecore.faa.gz"/>
        <param name="b" value="50"/>
        <param name="i" value="0"/>
        <param name="c" value="75"/>
        <param name="q" value="false"/>
        <param name="a" value="false"/>
        <param name="m" value=""/>
        <param name="A" value="blast"/>
        <output name="transporters">
            <assert_contents>
                <has_size value="283884" delta="32"/>
            </assert_contents>
        </output>
    </test>
    </tests>
    <help><![CDATA[
@HELP@
    ]]></help>
    <expand macro="citations"/>
</tool>


