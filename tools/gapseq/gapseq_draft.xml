<tool id="gapseq_draft" name="gapseq draft" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="25.01" license="MIT">
    <description></description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        gapseq draft
        -r '$r'
        -t '$t'
        -p '$p'
        -u $u
        -l $l
        #if str( $biomass_reaction.biomass ) in ["pos", "neg", "archaea", "auto"]:
            --biomass '$biomass_reaction.biomass'
        #elif str( $biomass_reaction.biomass ) == "custom":
            --biomass '$biomass_reaction.custom_model'
        #end if
        -n input
        -f ./output/
    
    ]]></command>
    <inputs>
        <expand macro="reaction_table_input" parameter="-r"/>
        <expand macro="pathway_pred"/>
        <param argument="-t" type="data" format="tabular" label="Gapseq Transporter table" help="from 'gapseq find-transport'"/>
        <conditional name="biomass_reaction">
            <param name="biomass" type="select" label="Biomass reaction for network model">
                <option value="pos">Gram-positive</option>
                <option value="neg">Gram-negative</option>
                <option value="archaea">Archaea</option>
                <option value="auto" selected="true">Auto</option>
                <option value="custom">Custom</option>
            </param>
            <when value="pos"/>
            <when value="neg"/>
            <when value="archaea"/>
            <when value="auto"/>
            <when value="custom">
                <param name="custom_model" type="data" format="json" label="Custom biomass reaction model" help="See tool help or gapseq documentation for instructions" />
            </when>
        </conditional>
        <param argument="-u" type="float" min="0" value="200" label="Reactions with an associated blast-hit with a bitscore above this value will be added to the draft model as core reactions" />
        <param argument="-l" type="float" min="0" value="50" label="Reactions with an associated blast-hit with a bitscore below this value will be considered just as reactions that have no blast hit" />
    </inputs>
    <outputs>
        <expand macro="draft_rds"/>
        <expand macro="draft_xml"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <!--TODO: auto-generated test case. Please fill in the required values-->
            <param name="r" value="input-all-Reactions.tbl"/>
            <param name="p" value="input-all-Pathways.tbl"/>
            <param name="t" value="input-Transporter.tbl"/>
            <param name="u" value="200"/>
            <param name="l" value="50"/>
            <conditional name="biomass_reaction">
                <param name="biomass" value="neg"/>
            </conditional>
            <output name="draft_rds">
                <assert_contents>
                    <has_size value="130487" delta="32"/>
                </assert_contents>
            </output>
            <output name="draft_xml">
                <assert_contents>
                    <has_size value="928986" delta="32"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
@HELP@
    ]]></help>
    <expand macro="citations"/>
</tool>


