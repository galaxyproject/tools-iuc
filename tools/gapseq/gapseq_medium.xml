<tool id="gapseq_medium" name="gapseq medium" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="25.01" license="MIT">
    <description></description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        gapseq medium    
            --model '$model'
            --pathway.pred '$p'
            #if $c != "":
                --manual.flux '$c'
            #end if
            --output.file input-medium.csv
            --output.dir ./output/
    ]]></command>
    <inputs>
        <expand macro="model"/>
        <expand macro="pathway_pred"/>
        <param argument="-c" type="text" value="" label="Specify fixed maxFlux values in medium for specific compounds." help="Format: [Compound 1]:[Compound 1 maxFlux];[Compound 2]:[Compound 2 maxFlux]"/>
    </inputs>
    <outputs>
        <expand macro="medium"/>
    </outputs>
    <tests>
    <test expect_num_outputs="1">
        <!--TODO: auto-generated test case. Please fill in the required values-->
        <param name="model" value="input.RDS"/>
        <param name="p" value="pathways.tbl"/>
        <param name="c" value=""/>
        <output name="medium">
            <assert_contents>
                <has_size value="897" delta="32"/>
                <has_line line="cpd00001,H2O,100"/>
            </assert_contents>
        </output>
    </test>
    </tests>
    <help><![CDATA[
@HELP@
    ]]></help>
    <expand macro="citations"/>
</tool>


