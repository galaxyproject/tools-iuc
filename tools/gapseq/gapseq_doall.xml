<tool id="gapseq_doall" name="gapseq doall" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="25.01" license="MIT">
    <description></description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        ## Gapseq uses the filename even when we soft link it with a different name, so we copy the input file instead.
        cp '$fasta_input' input.fa &&
        #if str( $reference_source.ref_selector ) == "cached":
            mkdir ./database &&
            ## Gapseq expects the database folder to be writable, hence we soft link it here.
            ln -s $reference_source.D.fields.path/* ./database/ &&
            #set database_path = "./database"
        #elif str( $reference_source.ref_selector ) == "history":
            mkdir ./database &&
            unzip '$reference_source.gapseq_sequence_zip' -d ./database &&
            #set database_path = "./database"
        #end if

        gapseq doall    
            -b $b
            -i $i
            -c $c
            -l $l
            -t $t
            -A $A
            #if str( $conditional_media_component.media_component_source ) == "auto":
                -m '$conditional_media_component.media_component_source'
            #elif str( $conditional_media_component.media_component_source ) == "table":
                -m '$conditional_media_component.m'
            #end if
            -f ./output
            -D $database_path
            -K "\${GALAXY_SLOTS:-1}"
            $O
            input.fa

            && mv ./output/*-Pathways.tbl $pathways
            && mv ./output/*-Reactions.tbl $reactions
    ]]></command>
    <inputs>
        <expand macro="fasta_input_macro"/>
        <expand macro="reference_source_macro"/>
        <expand macro="bitscore_cutoff"/>
        <expand macro="identity_cutoff"/>
        <expand macro="coverage_cutoff"/>
        <expand macro="bitscore_reaction_cutoff" parameter="-l"/>
        <expand macro="taxonomic_range"/>
        <expand macro="conditional_media_component"/>
        <expand macro="alignment_tool"/>
        <expand macro="offline_mode"/>
    </inputs>
    <outputs>
        <expand macro="pathways"/>
        <expand macro="reactions"/>
        <expand macro="transporters"/>
        <expand macro="draft_rds"/>
        <expand macro="draft_xml"/>
        <expand macro="model_rds"/>
        <expand macro="model_xml"/>
        <expand macro="medium"/>
    </outputs>
    <tests>
        <test expect_num_outputs="8">
            <param name="fasta_input" value="ecore.faa.gz"/>
            <param name="b" value="200"/>
            <param name="i" value="0"/>
            <param name="c" value="75"/>
            <param name="l" value="50"/>
            <param name="t" value="auto"/>
            <param name="A" value="blast"/>
            <conditional name="reference_source">
                <param name="ref_selector" value="cached"/>
                <param name="D" value="gapseq_bac_nadh"/>
            </conditional>
            <param name="O" value="true"/>
            <conditional name="conditional_media_component">
                <param name="media_component_source" value="auto"/>
            </conditional>

            <output name="pathways">
                <assert_contents>
                    <has_size size="150079" delta="32"/>
                </assert_contents>
            </output>
            <output name="reactions">
                <assert_contents>
                    <has_size size="1825639" delta="32"/>
                </assert_contents>
            </output>
            <output name="transporters">
                <assert_contents>
                    <has_size size="283884" delta="32"/>
                </assert_contents>
            </output>
            <output name="draft_rds">
                <assert_contents>
                    <has_size size="130487" delta="32"/>
                </assert_contents>
            </output>
            <output name="draft_xml">
                <assert_contents>
                    <has_size size="928986" delta="32"/>
                </assert_contents>
            </output>
            <output name="model_rds">
                <assert_contents>
                    <has_size size="234076" delta="32"/>
                </assert_contents>
            </output>
            <output name="model_xml">
                <assert_contents>
                    <has_size size="2019193" delta="32"/>
                </assert_contents>
            </output>
            <output name="medium">
                <assert_contents>
                    <has_size size="897" delta="32"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
@HELP@
    ]]></help>
    <expand macro="citations"/>
</tool>


