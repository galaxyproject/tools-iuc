<tool id="gapseq_find" name="gapseq find" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="25.01" license="MIT">
    <description></description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        ## Gapseq uses the filename even when we soft link it with a different name, so we copy the input file instead.
        cp '$fasta_input' input.fa &&
        #if str( $reference_source.ref_selector ) == "cached":
            mkdir ./database &&
            ## Gapseq expects the database folder to be writable, hence we soft link it here.
            ln -s $reference_source.D.fields.path/* ./database/ &&
            #set database_path = "./database"
        #elif str( $reference_source.ref_selector ) == "history":
            mkdir ./database &&
            unzip '$reference_source.gapseq_sequence_zip' -d ./database &&
            #set database_path = "./database"
        #end if

        gapseq find
            #if $search.p != "":
                -p "$search.p"
            #end if
            #if $search.e != "":
                -e "$search.e"
            #end if
            #if $search.r != "":
                -r "$search.r"
            #end if
            -t $t
            -b $b
            -i $i
            -c $c
            $s
            -a $a
            -k $k
            $n
            -l $l
            $o
            $x
            -z $z
            -m $m
            $w
            $O
            -A $A
            -f ./output
            -D $database_path
            -K "\${GALAXY_SLOTS:-1}"
            input.fa

            && mv ./output/*-Pathways.tbl $pathways
            && mv ./output/*-Reactions.tbl $reactions
    ]]></command>
    <inputs>
        <expand macro="fasta_input_macro"/>
        <expand macro="reference_source_macro"/>
        <section name="search" title="Search options" expanded="true" help="Submit at least one search term in the fields below">
            <param argument="-p" type="text" value="all" label="Search by keywords such as pathways or subsystems (comma-separated)" help="For example: amino,nucl,cofactor,carbo,polyamine"/>
            <param argument="-e" type="text" value="" label="Search by ec numbers (comma-separated)" help="Must be a valid Enzyme Commission (EC) number, like '1.1.1.1' ">
                <sanitizer invalid_char="">
                    <valid initial="string.digits">
                        <add value="." />
                    </valid>
                </sanitizer>
            </param>
            <param argument="-r" type="text" value="" label="Search by enzyme name (semicolon-separated)" help="For example, 'nicotinamide N-methyltransferase;alcohol dehydrogenase'"/>
        </section>
        <expand macro="taxonomic_range"/>
        <expand macro="bitscore_cutoff"/>
        <expand macro="identity_cutoff"/>
        <expand macro="coverage_cutoff"/>
        <param argument="-s" type="boolean" truevalue="-s" falsevalue="" checked="false" label="Strict candidate reaction handling" help="When checked, do *not* use pathway completeness, key enzymes, and operon structure to infere if incomplete pathway could still be present." />
        <param argument="-a" type="float" min="0" max="100" value="80" label="Pathway completeness threshold in percentage" />
        <param argument="-k" type="float" min="0" max="100" value="66" label="Pathway completeness threshold for pathways with additional hints (i.e. key enzyme detection) in percentage" />
        <param argument="-n" type="boolean" truevalue="-n" falsevalue="" checked="false" label="Consider superpathways of MetaCyc database" />
        <param argument="-l" type="select" multiple="true" label="Select the pathway database" >
            <option value="custom" selected="true" >Gapseq custom built-in</option>
            <option value="metacyc" selected="true" >MetaCyc</option>
            <option value="kegg">KEGG</option>
            <option value="seed">SEED</option>
            <option value="all">All</option>
        </param>
        <param argument="-o" type="boolean" truevalue="-o" falsevalue="" checked="false" label="Only list pathways found for keyword" />
        <param argument="-x" type="boolean" truevalue="-x" falsevalue="" checked="false" label="Do not use sequence alignment, only list pathways, reactions, and check for available sequences" />
        <param argument="-z" type="select" label="Quality of sequences for homology search" >
            <option value="1">1: Only reviewed (swissprot)</option>
            <option value="2" selected="true">2: Unreviewed only if reviewed not available</option>
            <option value="3">3: Reviewed + unreviewed</option>
            <option value="4">4: Only unreviewed</option>
        </param>
        <param argument="-m" type="select" label="Limit pathways to taxonomic range">
            <option value="auto" selected="true">Auto</option>
            <option value="Bacteria">Bacteria</option>
            <option value="Archaea">Archaea</option>
        </param>
        <param argument="-w" type="boolean" truevalue="-w" falsevalue="" checked="false" label="Use additional sequences from gene names" />
        <expand macro="offline_mode"/>
        <expand macro="alignment_tool"/>
    </inputs>
    <outputs>
        <expand macro="pathways"/>
        <expand macro="reactions"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="fasta_input" value="ecore.faa.gz"/>
            <conditional name="reference_source">
                <param name="ref_selector" value="cached"/>
                <param name="D" value="gapseq_bac_nadh"/>
            </conditional>
            <section name="search">
                <param name="p" value="all"/>
                <param name="e" value=""/>
                <param name="r" value=""/>
            </section>
            <param name="t" value="auto"/>
            <param name="b" value="200"/>
            <param name="i" value="0"/>
            <param name="c" value="75"/>
            <param name="s" value="false"/>
            <param name="a" value="80"/>
            <param name="k" value="66"/>
            <param name="n" value="false"/>
            <param name="l" value="custom"/>
            <param name="o" value="false"/>
            <param name="x" value="false"/>
            <param name="z" value="1"/>
            <param name="m" value="auto"/>
            <param name="w" value="false"/>
            <param name="O" value="true"/>
            <param name="A" value="blast"/>
            <output name="pathways">
                <assert_contents>
                    <has_size size="5530" delta="32"/>
                </assert_contents>
            </output>
            <output name="reactions">
                <assert_contents>
                    <has_size size="79503" delta="32"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
@HELP@
    ]]></help>
    <expand macro="citations"/>
</tool>


