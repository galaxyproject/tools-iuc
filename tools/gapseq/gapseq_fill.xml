<tool id="gapseq_fill" name="gapseq fill" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="25.01" license="MIT">
    <description></description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        cp '$model' input.RDS &&
        gapseq fill
            --model input.RDS
            --media '$media'
            -t '$t'
            --bcore $bcore
            $q
            --output.dir ./output/
            #if $limit != "":
                --limit '$limit'
            #end if
            $x
            $r
            #if $environment != "":
                --environment '$environment'
            #end if
            $w
            -k $k
    ]]></command>
    <inputs>
        <expand macro="model"/>
        <expand macro="medium_input" parameter="--media"/>
        <param argument="-t" type="text" value="cpd11416" label="ID (without compartment suffix) of metabolite that shall be produced" help="Default: cpd11416 (Biomass)"/>
        <expand macro="bitscore_reaction_cutoff" parameter="--bcore"/>
        <param argument="-q" type="boolean" truevalue="-q" falsevalue="" checked="false" label="Quick gapfilling" help="Perform only step 1 and 2" />
        <param argument="--limit" type="text" value="" label="Test metabolite to which search is limited"/>
        <param argument="-x" type="boolean" truevalue="-x" falsevalue="" checked="false" label="Always use all reactions instead of core reactions, which have sequence evidence" />
        <param argument="-r" type="boolean" truevalue="-r" falsevalue="" checked="false" label="Save final model as unconstraint network" help="I.e. all exchange reactions are open" />
        <param argument="--environment" type="text" value="" label="Adjusting reaction directions according to specific environmental conditions. CAUTION: experimental option" help="See documentation for details"/>
        <param argument="-w" type="boolean" truevalue="-w" falsevalue="" checked="false" label="Write a list with found carbon sources and fermentation products"/>
        <param argument="-k" type="float" min="0" value="0.01" label="Minimum growth rate that should be achieved by gap-filling"/>
    </inputs>
    <outputs>
        <expand macro="model_rds"/>
        <expand macro="model_xml"/>
        <expand macro="carbon_source_tbl"/>
        <expand macro="fermentation_product_tbl"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <!--TODO: auto-generated test case. Please fill in the required values-->
            <param name="model" value="input.RDS"/>
            <param name="media" value="input-medium.csv"/>
            <param name="t" value="cpd11416"/>
            <param name="bcore" value="50"/>
            <param name="q" value="false"/>
            <param name="limit" value=""/>
            <param name="x" value="false"/>
            <param name="r" value="false"/>
            <param name="environment" value=""/>
            <param name="w" value="false"/>
            <param name="k" value="0.01"/>
            <output name="model_rds">
                <assert_contents>
                    <has_size value="242732" delta="32"/>
                </assert_contents>
            </output>
            <output name="model_xml">
                <assert_contents>
                    <has_size value="2027053" delta="32"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="4">
            <param name="model" value="input.RDS"/>
            <param name="media" value="input-medium.csv"/>
            <param name="t" value="cpd11416"/>
            <param name="bcore" value="50"/>
            <param name="q" value="false"/>
            <param name="limit" value=""/>
            <param name="x" value="false"/>
            <param name="r" value="false"/>
            <param name="environment" value=""/>
            <param name="w" value="true"/>
            <param name="k" value="0.01"/>
            <output name="model_rds">
                <assert_contents>
                    <has_size value="242732" delta="32"/>
                </assert_contents>
            </output>
            <output name="model_xml">
                <assert_contents>
                    <has_size value="2027053" delta="32"/>
                </assert_contents>
            </output>
            <output name="carbon_sources">
                <assert_contents>
                    <has_size value="2975" delta="32"/>
                </assert_contents>
            </output>
            <output name="fermentation_products">
                <assert_contents>
                    <has_size value="2959" delta="32"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
@HELP@
    ]]></help>
    <expand macro="citations"/>
</tool>


