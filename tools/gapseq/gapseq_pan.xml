<tool id="gapseq_pan" name="gapseq pan" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="25.01" license="MIT">
    <description></description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        mkdir -p input_models input_pathways &&
        #for $counter, $model in enumerate($models_path):
            cp '$model' ./input_models/input${counter}-draft.RDS &&
        #end for
        #for $counter, $pathways in enumerate($pathway_pred_multi):
            cp '$pathways' ./input_pathways/input${counter}-all-Pathways.tbl &&
        #end for
        gapseq pan
            --models_path ./input_models
            --pathways.table.path ./input_pathways
            -t '$t'
            $b
            -f ./output/
    ]]></command>
    <inputs>
        <expand macro="model_multi"/>
        <expand macro="pathway_pred_multi"/>
        <param argument="-t" type="float" min="0" max="1" value="0.06" label="Minimum reaction frequency (mrf) to include the reactions in the pan-Draft" />
        <param argument="-b" type="boolean" truevalue="-b" falsevalue="" checked="false" label="Perform only models comparison to get a binary table summarizing reaction presence/absence" />
    </inputs>
    <outputs>
        <data name="model_rds" format="rds" label="Model (RDS): ${tool.name} on ${on_string}" from_work_dir="output/panModel-draft.RDS">
            <filter>b is False</filter>
        </data>
        <data name="model_xml" format="sbml" label="Model (SBML): ${tool.name} on ${on_string}" from_work_dir="output/panModel-draft.xml">
            <filter>b is False</filter>
        </data>
        <data name="rxn_prs_abs_matrix" format="tabular" label="Reactions presence/absence matrix: ${tool.name} on ${on_string}" from_work_dir="output/rxnXmod.tsv"/>
        <data name="pan_reactome" format="tabular" label="Pan-reactome stats: ${tool.name} on ${on_string}" from_work_dir="output/pan-reactome_stat.tsv">
            <filter>b is False</filter>
        </data>
        <data name="pan_rxn_genes" format="rds" label="Pan reactions/genes matrix RDS: ${tool.name} on ${on_string}" from_work_dir="output/panModel-rxnXgenes.RDS">
            <filter>b is False</filter>
        </data>
        <data name="pan_pathways" format="tabular" label="Pan pathways: ${tool.name} on ${on_string}" from_work_dir="output/panModel-tmp-Pathways.tbl">
            <filter>b is False</filter>
        </data>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="models_path" value="draft.RDS,draft_2.RDS"/>
            <param name="pathway_pred_multi" value="pathways.tbl,pathways_2.tbl"/>
            <param name="t" value="0.06"/>
            <param name="b" value="true"/>
            <output name="rxn_prs_abs_matrix">
                <assert_contents>
                    <has_size value="3801" delta="32"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="6">
            <param name="models_path" value="draft.RDS,draft_2.RDS"/>
            <param name="pathway_pred_multi" value="pathways.tbl,pathways_2.tbl"/>
            <param name="t" value="0.06"/>
            <param name="b" value="false"/>
            <output name="model_rds">
                <assert_contents>
                    <has_size value="175679" delta="32"/>
                </assert_contents>
            </output>
            <output name="model_xml">
                <assert_contents>
                    <has_size value="858596" delta="32"/>
                </assert_contents>
            </output>
            <output name="rxn_prs_abs_matrix">
                <assert_contents>
                    <has_size value="3801" delta="32"/>
                </assert_contents>
            </output>
            <output name="pan_reactome">
                <assert_contents>
                    <has_size value="135" delta="32"/>
                </assert_contents>
            </output>
            <output name="pan_rxn_genes">
                <assert_contents>
                    <has_size value="73341" delta="32"/>
                </assert_contents>
            </output>
            <output name="pan_pathways">
                <assert_contents>
                    <has_size value="14545" delta="32"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
@HELP@
    ]]></help>
    <expand macro="citations"/>
</tool>