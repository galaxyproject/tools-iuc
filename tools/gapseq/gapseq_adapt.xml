<tool id="gapseq_adapt" name="gapseq adapt" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="25.01" license="MIT">
    <description></description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        cp '$model' input.RDS &&
        gapseq adapt
            --model input.RDS
            #if $id != "":
                --id '$id'
            #end if
                --rxn.blast.file '$b'
            #if $add != "":
                --add '$add'
            #end if
            #if $remove != "":
                --remove '$remove'
            #end if
            #if $growth != "":
                --growth '$growth'
            #end if
            #if $k != 0.0:
                --min.growth $k
            #end if
            --output.dir ./output/
    ]]></command>
    <inputs>
        <expand macro="model"/>
        <param argument="--id" type="text" value="" label="Model identifier when the provided model RDS file is a list of many models"/>
        <expand macro="reaction_table_input" parameter="-b"/>
        <param argument="--add" type="text" value="" label="Comma-separated list of reactions or pathways that should be added to the model"/>
        <param argument="--remove" type="text" value="" label="Comma-separated list of reactions or pathways that should be removed from the model"/>
        <param argument="--growth" type="text" value="" label="Compounds for which growth or non-growth should be ensured" help="Example: 'cpd00027:TRUE,cpd00017:FALSE'"/>
        <param argument="-k" type="float" value="0" label="Set minimum growth rate that should be achieved by gap-filling" />    
    </inputs>
    <outputs>
        <expand macro="adapt_rds"/>
        <expand macro="adapt_xml"/>
    </outputs>
    <tests>
        <test expect_num_outputs="2">
            <param name="model" value="input.RDS"/>
            <param name="id" value=""/>
            <param name="b" value="reactions.tbl"/>
            <param name="add" value=""/>
            <param name="remove" value=""/>
            <param name="growth" value="cpd00017:TRUE"/>
            <param name="k" value="0"/>
            <output name="draft_rds">
                <assert_contents>
                    <has_size value="245800" delta="32"/>
                </assert_contents>
            </output>
            <output name="draft_xml">
                <assert_contents>
                    <has_size value="2062950" delta="32"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="2">
            <param name="model" value="input.RDS"/>
            <param name="id" value=""/>
            <param name="b" value="reactions.tbl"/>
            <param name="add" value=""/>
            <param name="remove" value="GLUTAMATE-DEG1-PWY"/>
            <param name="growth" value=""/>
            <param name="k" value="0"/>
            <output name="draft_rds">
                <assert_contents>
                    <has_size value="242556" delta="32"/>
                </assert_contents>
            </output>
            <output name="draft_xml">
                <assert_contents>
                    <has_size value="2024088" delta="32"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
@HELP@
    ]]></help>
    <expand macro="citations"/>
</tool>