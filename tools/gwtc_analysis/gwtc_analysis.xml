<tool id="gwtc_analysis" name="GWTC" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
  <description>Analysis of Gravitational-Wave Transient Catalogs</description>
  <macros>
    <import>macros.xml</import>
  </macros>
  <expand macro="requirements"/>
   <command detect_errors="exit_code"><![CDATA[
    mkdir -p plots &&
    #if str($mode.analysis_mode) == "catalog_statistics":
        gwtc_analysis catalog_statistics
            --catalogs
        #for $c in $mode.catalogs:
            '$c'
        #end for
            --out-events '$out_events'
            --out-report '$out_report'
            $mode.include_detectors
            $mode.include_area
        #if $mode.include_area:
            --area-cred '$mode.area_cred'
        #end if
            --plots-dir 'plots/'
            --data-repo '$mode.data_repo'

    #elif str($mode.analysis_mode) == "event_selection":
        gwtc_analysis event_selection
            --catalogs
        #for $c in $mode.catalogs:
            '$c'
        #end for
            --out-selection '$out_selection'
        #if $mode.m1_min:
            --m1-min '$mode.m1_min'
        #end if
        #if $mode.m1_max:
            --m1-max '$mode.m1_max'
        #end if
        #if $mode.m2_min:
            --m2-min '$mode.m2_min'
        #end if
        #if $mode.m2_max:
            --m2-max '$mode.m2_max'
        #end if
        #if $mode.dl_min:
            --dl-min '$mode.dl_min'
        #end if
        #if $mode.dl_max:
            --dl-max '$mode.dl_max'
        #end if

    #elif str($mode.analysis_mode) == "search_skymaps":
        gwtc_analysis search_skymaps
            --catalogs
        #for $c in $mode.catalogs:
            '$c'
        #end for
            --ra-deg '$mode.ra_deg'
            --dec-deg '$mode.dec_deg'
            --prob '$mode.prob'
            --skymap-label '$mode.skymap_label'
            --out-events '$out_events'
            --out-report '$out_report'
            --plots-dir 'plots/'
            --data-repo '$mode.data_repo'

    #elif str($mode.analysis_mode) == "parameters_estimation":
        gwtc_analysis parameters_estimation
            --src-name '$mode.src_name'
            --out-report '$out_report'
            --plots-dir 'plots/'
            --data-repo '$mode.data_repo'
        #if $mode.pe_vars:
            --pe-vars
            #for $v in $mode.pe_vars:
                '$v'
            #end for
        #end if
        #if $mode.pe_pairs:
            --pe-pairs
            #for $p in $mode.pe_pairs:
                '$p'
            #end for
        #end if
            --start '$mode.start'
            --stop '$mode.stop'
            --fs-low '$mode.fs_low'
            --fs-high '$mode.fs_high'
            --pe-label '$mode.pe_label'
            --waveform-engine '$mode.waveform_engine'
    #end if
]]></command>

  <inputs>
    <conditional name="mode">
      <param name="analysis_mode" type="select" label="Analysis mode">
        <option value="catalog_statistics" selected="true">Catalog Statistics</option>
        <option value="event_selection">Event Selection</option>
        <option value="search_skymaps">Search Skymaps at RA/Dec</option>
        <option value="parameters_estimation">Parameter Estimation (PE)</option>
      </param>

      <when value="catalog_statistics">
        <param name="catalogs" type="select" label="Catalogs" multiple="true" display="checkboxes">
          <option value="ALL">ALL</option>
          <option value="GWTC-1">GWTC-1</option>
          <option value="GWTC-2.1" selected="true">GWTC-2.1</option>
          <option value="GWTC-3">GWTC-3</option>
          <option value="GWTC-4">GWTC-4</option>
        </param>
        <param argument="--include-detectors" type="boolean" label="Include detector network" truevalue="--include-detectors" falsevalue="" checked="false"/>
        <param argument="--include-area" type="boolean" label="Compute localization area (Axx)" truevalue="--include-area" falsevalue="" checked="false"/>
        <param name="area_cred" type="float" label="Credible level for area" value="0.9"/>
        <param name="data_repo" type="select" label="Data repository" help="Where to read data from">
          <option value="galaxy" selected="true">Galaxy</option>
          <option value="s3">S3</option>
          <option value="zenodo">Zenodo</option>
        </param>
      </when>

      <when value="event_selection">
        <param name="catalogs" type="select" label="Catalogs" multiple="true" display="checkboxes">
          <option value="ALL">ALL</option>
          <option value="GWTC-1">GWTC-1</option>
          <option value="GWTC-2.1" selected="true">GWTC-2.1</option>
          <option value="GWTC-3">GWTC-3</option>
          <option value="GWTC-4">GWTC-4</option>
        </param>
        <param name="m1_min" type="float" optional="true" value="" label="m1 (source) min [Msun]"/>
        <param name="m1_max" type="float" optional="true" value="" label="m1 (source) max [Msun]"/>
        <param name="m2_min" type="float" optional="true" value="" label="m2 (source) min [Msun]"/>
        <param name="m2_max" type="float" optional="true" value="" label="m2 (source) max [Msun]"/>
        <param name="dl_min" type="float" optional="true" value="" label="Luminosity distance min [Mpc]"/>
        <param name="dl_max" type="float" optional="true" value="" label="Luminosity distance max [Mpc]"/>
      </when>

      <when value="search_skymaps">
        <param name="catalogs" type="select" label="Catalogs" multiple="true" display="checkboxes">
          <option value="ALL">ALL</option>
          <option value="GWTC-1">GWTC-1</option>
          <option value="GWTC-2.1" selected="true">GWTC-2.1</option>
          <option value="GWTC-3">GWTC-3</option>
          <option value="GWTC-4">GWTC-4</option>
        </param>
        <param name="ra_deg" type="float" value="30.0" label="Right ascension (deg)"/>
        <param name="dec_deg" type="float" value="40.0" label="Declination (deg)"/>
        <param name="prob" type="float" value="0.9" min="0.01" max="1.0" label="Credible-level threshold"/>
        <param name="skymap_label" type="text" value="Mixed" label="Label filter" help="Select skymap label products."/>
        <param name="data_repo" type="select" label="Data repository">
          <option value="galaxy" selected="true">Galaxy</option>
          <option value="s3">S3</option>
          <option value="zenodo">Zenodo</option>
        </param>
      </when>

      <when value="parameters_estimation">
        <param name="src_name" type="text" label="Source event name" value="GW190828_063405"/>
        <param name="data_repo" type="select" label="Data repository">
          <option value="galaxy" selected="true">Galaxy</option>
          <option value="s3">S3</option>
          <option value="zenodo">Zenodo</option>
        </param>
        <param name="pe_vars" type="text" optional="true" multiple="true" label="PE variables to plot (1D)" help="Space-separated parameters."/>
        <param name="pe_pairs" type="text" optional="true" multiple="true" label="PE variable pairs to plot (2D)" help="Space-separated parameter pairs like x:y (e.g. chi_eff:chi_p)."/>
        <param name="start" type="float" label="Seconds before GPS time" value="0.2"/>
        <param name="stop" type="float" label="Seconds after GPS time" value="0.1"/>
        <param name="fs_low" type="float" label="Bandpass low frequency (Hz)" value="20.0"/>
        <param name="fs_high" type="float" label="Bandpass high frequency (Hz)" value="300.0"/>
        <param name="pe_label" type="text" label="Sample method / label selector" value="Mixed"/>
        <param name="waveform_engine" type="text" label="Strain approximant" value="IMRPhenomXPHM"/>
      </when>
    </conditional>
  </inputs>

  <outputs>
    <data name="out_events" format="tabular" label="${tool.name} on ${on_string}: Events">
      <filter>mode['analysis_mode'] in ('catalog_statistics', 'search_skymaps')</filter>
    </data>
    <data name="out_selection" format="tabular" label="${tool.name} on ${on_string}: Selection">
      <filter>mode['analysis_mode'] == 'event_selection'</filter>
    </data>
    <data name="out_report" format="html" label="${tool.name} on ${on_string}: Report">
      <filter>mode['analysis_mode'] != 'event_selection'</filter>
    </data>
    <collection name="plots" type="list" label="${tool.name} on ${on_string}: Plots">
      <discover_datasets pattern="__name_and_ext__" directory="plots"/>
      <filter>mode['analysis_mode'] != 'event_selection'</filter>
    </collection>
  </outputs>

  <tests>
    <!-- Test 01: Testing Catalog statistics mode | Outputs: Event table, Report, and 3 plots. -->
    <test expect_num_outputs="3">
      <conditional name="mode">
        <param name="analysis_mode" value="catalog_statistics"/>
        <param name="catalogs" value="GWTC-2.1"/>
        <param name="data_repo" value="s3"/>
      </conditional>
      <output name="out_events">
        <assert_contents>
          <has_text text="event_id"/>
          <has_n_lines min="2"/>
        </assert_contents>
      </output>
      <output name="out_report">
        <assert_contents>
          <has_text text="GWTC"/>
        </assert_contents>
      </output>
      <output_collection name="plots" type="list" count="3"/>
    </test>

    <!-- Test 02: Testing Event selection mode | Outputs: Event table -->
    <test expect_num_outputs="1">
      <conditional name="mode">
        <param name="analysis_mode" value="event_selection"/>
        <param name="catalogs" value="GWTC-2.1"/>
        <param name="m1_min" value="10"/>
        <param name="m1_max" value="500"/>
      </conditional>
      <output name="out_selection" ftype="tabular">
        <assert_contents>
          <has_text text="event_id"/>
          <has_n_lines min="2"/>
        </assert_contents>
      </output>
    </test>
  
    <!-- Test 03: Testing Search skymaps mode | Outputs: Event table, Report, and 3 plots. -->
    <test expect_num_outputs="3">
      <conditional name="mode">
        <param name="analysis_mode" value="search_skymaps"/>
        <param name="catalogs" value="GWTC-2.1"/>
        <param name="ra_deg" value="180.0"/>
        <param name="dec_deg" value="0.0"/>
        <param name="prob" value="0.9"/>
        <param name="skymap_label" value="Mixed"/>
        <param name="data_repo" value="s3"/>
      </conditional>
      <output name="out_events" ftype="tabular">
        <assert_contents>
          <has_text text="event_id"/>
          <has_n_lines min="2"/>
        </assert_contents>
      </output>
      <output name="out_report" ftype="html">
        <assert_contents>
          <has_text text="skymap"/>
        </assert_contents>
      </output>
      <output_collection name="plots" type="list" count="3"/>
    </test>

    <!-- Test 04: Testing Parameter estimation mode | Outputs: Report, and 14 plots. -->
    <test expect_num_outputs="2">
      <conditional name="mode">
        <param name="analysis_mode" value="parameters_estimation"/>
        <param name="src_name" value="GW190828_063405"/>
        <param name="data_repo" value="s3"/>
        <param name="pe_label" value="Mixed"/>
        <param name="waveform_engine" value="IMRPhenomXPHM"/>
      </conditional>
      <output name="out_report" ftype="html">
        <assert_contents>
          <has_text text="Parameter estimation"/>
          <has_text text="Run parameters"/>
        </assert_contents>
      </output>
      <output_collection name="plots" type="list" count="14"/>
    </test>
  </tests>

<help><![CDATA[
GWTC analysis
=============

This tool wraps **gwtc_analysis** to analyze Gravitational-Wave Transient Catalogs (GWTC).

Available modules
-----------------

* **catalog_statistics**: Summarize selected catalog(s) and generate event tables and report pages.
* **event_selection**: Filter events using physical cuts (component masses, luminosity distance).
* **search_skymaps**: Query whether a sky position lies within credible regions of catalog events.
* **parameters_estimation**: Generate PE plots and report outputs for a selected source.

Data source
-----------

The `Data repository` parameter selects where data are read from (`Galaxy`, `S3`, or `Zenodo`), depending on the selected module.

Outputs
-------

The tool produces event or selection tables depending on the selected module, plus an HTML report when applicable.

For report-producing modes, generated plot files are bundled alongside the HTML dataset so linked figures remain available in Galaxy.
]]></help>
  <expand macro="citations"/>
</tool>