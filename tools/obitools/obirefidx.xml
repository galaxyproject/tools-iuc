<tool id="obi_refidx" name="obirefidx" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>
        Index sequence file according to a taxdump file
    </description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="stdio"/>
    <command><![CDATA[
        obirefidx
        --no-progressbar
        @TAXO_DIR@
        @INPUT_FORMAT@
        @OUT_FORMAT@
        '$input'
        >'$output'
    ]]></command>
    <inputs>
        <param name="input" type="data" format="@INPUT_FORMATS@" label="Input sequences file"/>
        <expand macro="taxo_macro">
            <token name="macro_rank"/>
            <token name="optional_taxo_option"/>
        </expand>
        <expand macro="input_format_options_macro"/>
        <expand macro="out_format_macro"/>
    </inputs>
    <outputs>
        <data format_source="input" name="output">
            <expand macro="change_format_macro"/>
        </data>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input" value="output_obitag.fasta" ftype="fasta"/>
            <conditional name="taxonomy">
                <param name="taxonomy_source" value="cached"/>
                <param name="taxonomy_table" value="2019-01-01"/>
            </conditional>
            <output name="output" file="output_obirefidx.fasta" ftype="fasta" compare="sim_size" />  
        </test>
    </tests>
    <help><![CDATA[

    .. class:: infomark

    **What it does**

    This tool enables the indexing of sequence files annotated with taxonomic information against a taxonomic database. To do so, obirefidx will take all the ancestor sequences from the query sequence and compute an alignment score for each. The least different sequence according to the taxonomic annotation will be included in the annotation of the sequence.

    @OBITOOLS_LINK_OBI4@

    ]]>
    </help>
    <expand macro="citation" />

</tool>
