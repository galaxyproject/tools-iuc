<tool id="obi_tag" name="obitag" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Taxonomic sequence annotation</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="stdio"/>
    <command><![CDATA[
        obitag
        -R '$reference_db'
        ${save_db_bool}
        @TAXO_DIR@
        @INPUT_FORMAT@
        @OUT_FORMAT@
        '$input' >
        '$output'
       
    ]]></command>
    <inputs>
        <param name="input" type="data" format="@INPUT_FORMATS@" label="Input sequences file"/>
        <param name="reference_db" type="data" format="@INPUT_FORMATS@" label="Parameter file" help="reference database"/>
        <param name="save_db_bool" type="boolean" truevalue="--save-db db_output.fasta" falsevalue="" checked="false" label="Do you want to generate a file with the reference DB with its indices"/>
        <expand macro="taxo_macro">
            <token name="macro_rank"/>
            <token name="optional_taxo_option"/>
        </expand>
        <expand macro="input_format_options_macro"/>
        <expand macro="out_format_macro"/>
    </inputs>
    <outputs>
        <data name="save_db"  format_source="input" from_work_dir="db_output.fasta" label="${tool.name} on ${on_string}: Reference DB with its indices">
            <expand macro="change_format_macro"/>
            <filter>save_db_bool is True</filter>
        </data>
        <data name="output"  format_source="input" label="${tool.name} on ${on_string}: Trimmed and tagged">
            <expand macro="change_format_macro"/>
        </data>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input" value="output_obiclean_simple.fasta" ftype="fasta"/>
            <param name="reference_db" value="db_v05_r117.fasta.gz"/>
            <conditional name="taxonomy">
                <param name="taxonomy_source" value="history"/>
                <param name="taxdump" value="taxdump_mammalia_old.csv.gz" ftype="csv"/>
            </conditional>
            <output name="output" value="output_obitag_history.fasta" ftype="fasta" compare="sim_size"/>
        </test>
        <test expect_num_outputs="2">
            <param name="input" value="output_obiclean_advanced.fasta.gz" ftype="fasta.gz"/>
            <param name="reference_db" value="db_v05_r117.fasta.gz"/>
            <conditional name="taxonomy">
                <param name="taxonomy_source" value="history"/>
                <param name="taxdump" value="taxdump_mammalia_old.csv.gz"/>
            </conditional>
            <param name="save_db_bool" value="true"/>
            <output name="output" value="output_obitag_advanced_history.fasta.gz" ftype="fasta.gz" compare="sim_size"/>
            <output name="save_db" value="output_obitag_refdb_history.fasta.gz" ftype="fasta.gz" compare="sim_size"/>
        </test>
        <test expect_num_outputs="1">
            <param name="input" value="output_obiclean_simple.fasta" ftype="fasta"/>
            <param name="reference_db" value="db_v05_r117.fasta.gz"/>
            <conditional name="taxonomy">
                <param name="taxonomy_source" value="cached"/>
                <param name="taxonomy_table" value="2019-01-01"/>
            </conditional>
            <output name="output" value="output_obitag.fasta" ftype="fasta" compare="sim_size"/>
        </test>
        <test expect_num_outputs="2">
            <param name="input" value="output_obiclean_advanced.fasta.gz" ftype="fasta.gz"/>
            <param name="reference_db" value="db_v05_r117.fasta.gz"/>
            <conditional name="taxonomy">
                <param name="taxonomy_source" value="cached"/>
                <param name="taxonomy_table" value="2019-01-01"/>
            </conditional>
            <param name="save_db_bool" value="true"/>
            <output name="output" value="output_obitag_advanced.fasta.gz" ftype="fasta.gz" compare="sim_size"/>
            <output name="save_db" value="output_obitag_refdb.fasta.gz" ftype="fasta.gz" compare="sim_size"/>
        </test>
    </tests>
    <help><![CDATA[
        
    .. class:: infomark

    **What it does**

    A Least Common Ancestor-based algorithm for taxonomic sequence annotation.

    @OBITOOLS_LINK_OBI4@

    ]]>
    </help>
    <expand macro="citation" />

</tool>
