<macros>
    <token name="@TOOL_VERSION@">1.8.1</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.0</token>
    <xml name="requirements">
        <requirements>
            <container type="docker">quay.io/galaxy/squidpy:v1.8.1-1</container>
        </requirements>
    </xml>
    <xml name="creators">
        <creator>
            <person givenName="Amirhossein" familyName="Naghsh Nilchi" email="nilchia@informatik.uni-freiburg.de"/>
            <person givenName="Pavan" familyName="Videm" email="videmp@informatik.uni-freiburg.de"/>
            <person givenName="Björn" familyName="Grüning" email="gruening@informatik.uni-freiburg.de"/>
            <organization name="European Galaxy Team" url="https://usegalaxy-eu.github.io/people"/>
        </creator>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.1038/s41592-021-01358-2</citation>
        </citations>
    </xml>
    <!-- Input macros -->
    <xml name="param_input_data">
        <param name="input_data" type="data" format="spatialdata.zip,h5ad" label="spatial object (in SpatialData or AnnData format)"/>
    </xml>
    <!-- Sanitizer macros -->
    <xml name="sanitize_query" token_validinitial="string.letters,string.digits">
        <sanitizer>
            <valid initial="@VALIDINITIAL@">
                <add value="_"/>
                <add value="-"/>
                <add value="."/>
            </valid>
        </sanitizer>
    </xml>
    <xml name="sanitize_digits">
        <sanitizer invalid_char="">
            <valid initial="string.digits">
                <add value="."/>
                <add value=","/>
                <add value="-"/>
                <yield/>
            </valid>
        </sanitizer>
    </xml>
    <!-- Common parameter macros -->
    <xml name="param_spatial_key" token_value="spatial" token_help="">
        <param argument="--spatial_key" type="text" value="@VALUE@" label="Key in adata.obsm where spatial coordinates are stored" help="@HELP@">
            <expand macro="sanitize_query"/>
        </param>
    </xml>
    <xml name="param_cluster_key" token_optional="false">
        <param argument="--cluster_key" type="text" optional="@OPTIONAL@" label="Key in adata.obs where clustering is stored">
            <expand macro="sanitize_query"/>
        </param>
    </xml>
    <xml name="param_connectivity_key" token_value="spatial_connectivities" token_optional="false">
        <param argument="--connectivity_key" type="text" value="@VALUE@" optional="@OPTIONAL@" label="Connectivity key" help="Key in adata.obsp where spatial connectivities are stored">
            <expand macro="sanitize_query"/>
        </param>
    </xml>
    <xml name="param_library_key">
        <param argument="--library_key" type="text" optional="true" label="Column in adata.obs which stores mapping between library_id and obs">
            <expand macro="sanitize_query"/>
        </param>
    </xml>
    <!-- Plotting parameter macros -->
    <xml name="param_pl_figsize">
        <param name="width" type="float" min="0" optional="true" label="Figure width (inches)"/>
        <param name="height" type="float" min="0" optional="true" label="Figure height (inches)"/>
    </xml>
    <token name="@CMD_PL_FIGSIZE@"><![CDATA[
    #if $operation_condi.width and $operation_condi.height:
    figsize=($operation_condi.width, $operation_condi.height),
    #end if
    ]]></token>
    <xml name="param_pl_dpi">
        <param argument="--dpi" type="integer" min="0" optional="true" label="Dots per inch"/>
    </xml>
    <token name="@CMD_PL_DPI@"><![CDATA[
    #if $operation_condi.dpi:
    dpi=$operation_condi.dpi,
    #end if
    ]]></token>
    <xml name="param_pl_annotate">
        <param argument="--annotate" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Annotate heatmap cells?"/>
    </xml>
