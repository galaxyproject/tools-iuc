    <xml name="param_pl_cmap">
        <param argument="--cmap" type="select" label="Continuous colormap">
            <expand macro="color_options"/>
        </param>
    </xml>
    <xml name="param_pl_method">
        <param argument="--method" type="select" optional="true" label="Dendrogram linkage method" help="Linkage method for scipy.cluster.hierarchy.linkage()">
            <option value="single">single</option>
            <option value="complete">complete</option>
            <option value="average">average</option>
            <option value="weighted">weighted</option>
            <option value="centroid">centroid</option>
            <option value="median">median</option>
            <option value="ward">ward</option>
        </param>
    </xml>
    <token name="@CMD_PL_METHOD@"><![CDATA[
    #if $operation_condi.method:
    method='$operation_condi.method',
    #else:
    method=None,
    #end if
    ]]></token>
    <xml name="param_pl_palette">
        <param argument="--palette" type="select" optional="true" label="Palette" help="Categorical colormap for clusters. If empty, uses colors from adata.uns['{cluster_key}_colors']">
            <expand macro="color_options"/>
        </param>
    </xml>
    <token name="@CMD_PL_PALETTE@"><![CDATA[
    #if $operation_condi.palette:
    palette='$operation_condi.palette',
    #end if
    ]]></token>
    <token name="@CMD_PL_ADATA@"><![CDATA[
#if $input_data.ext == 'spatialdata.zip':
adata_for_plot = spatial_obj.tables['$table_key']
#else:
adata_for_plot = spatial_obj
#end if
print("Using adata for plotting.")
print(adata_for_plot)
]]></token>
    <token name="@CMD_PL_SAVE@"><![CDATA[
plt.savefig('./output/plot.$operation_condi.pl_format', bbox_inches='tight')
plt.close('all')
print("Plot saved.")
    ]]></token>
    <xml name="param_plot_format">
        <param name="pl_format" type="select" label="Output plot format">
            <option value="png" selected="true">PNG</option>
            <option value="pdf">PDF</option>
            <option value="svg">SVG</option>
            <option value="jpg">JPG</option>
        </param>
    </xml>
    <!-- Analysis parameter macros -->
    <xml name="param_seed">
        <param argument="--seed" type="integer" optional="true" label="Random seed for reproducibility"/>
    </xml>
    <xml name="param_genes">
        <param argument="--genes" type="text" optional="true" label="Comma-separated gene names. If empty, uses highly_variable genes or all genes">
            <expand macro="sanitize_query"/>
        </param>
    </xml>
    <xml name="param_use_raw" token_checked="false" token_help="">
        <param argument="--use_raw" type="boolean" truevalue="True" falsevalue="False" checked="@CHECKED@" label="Use raw data?" help="@HELP@"/>
    </xml>
    <xml name="param_layer">
        <param argument="--layer" type="text" optional="true" label="Layer to use. If empty, use adata.X">
            <expand macro="sanitize_query"/>
        </param>
    </xml>
    <xml name="param_corr_method" token_optional="true">
        <param argument="--corr_method" type="select" optional="@OPTIONAL@" label="Multiple testing correction method">
