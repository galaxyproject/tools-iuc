            <option value="bonferroni">Bonferroni</option>
            <option value="sidak">Sidak</option>
            <option value="holm-sidak">Holm-Sidak</option>
            <option value="holm">Holm</option>
            <option value="simes-hochberg">Simes-Hochberg</option>
            <option value="hommel">Hommel</option>
            <option value="fdr_by">FDR Benjamini-Yekutieli</option>
            <option value="fdr_tsbh">FDR two-stage Benjamini-Hochberg</option>
            <option value="fdr_tsbky">FDR two-stage Benjamini-Krieger-Yekutieli</option>
        </param>
    </xml>
