<macros>
    <token name="@TOOL_VERSION@">1.8.1</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.0</token>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">squidpy</requirement>
            <yield />
        </requirements>
    </xml>
    <xml name="creators">
        <creator>
            <person givenName="Amirhossein" familyName="Naghsh Nilchi" email="nilchia@informatik.uni-freiburg.de"/>
            <person givenName="Pavan" familyName="Videm" email="videmp@informatik.uni-freiburg.de"/>
            <person givenName="Björn" familyName="Grüning" email="gruening@informatik.uni-freiburg.de"/>
            <organization name="European Galaxy Team" url="https://usegalaxy-eu.github.io/people"/>
        </creator>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.1038/s41592-021-01358-2</citation>
        </citations>
    </xml>

    <!-- Input macros -->
    <xml name="input_spatialdata">
        <param name="input_spatialdata" type="data" format="spatialdata.zip,h5ad" label="SpatialData object"/>
    </xml>

    <!-- Sanitizer macros -->
    <xml name="sanitize_query" token_validinitial="string.printable">
        <sanitizer>
            <valid initial="@VALIDINITIAL@">
                <remove value="&apos;"/>
            </valid>
       </sanitizer>
    </xml>

    <xml name="sanitize_digits">
        <sanitizer invalid_char="">
            <valid initial="string.digits">
                <add value="."/>
                <add value=","/>
                <add value="-"/>
            </valid>
       </sanitizer>
    </xml>

    <!-- Common parameter macros -->
    <xml name="param_spatial_key" token_value="spatial" token_help="Key in adata.obsm where spatial coordinates are stored">
        <param name="spatial_key" type="text" value="@VALUE@" label="Spatial key" help="@HELP@">
            <expand macro="sanitize_query"/>
        </param>
    </xml>

    <xml name="param_cluster_key" token_optional="false">
        <param name="cluster_key" type="text" optional="@OPTIONAL@" label="Cluster key" help="Key in adata.obs where clustering is stored">
            <expand macro="sanitize_query"/>
        </param>
    </xml>

    <xml name="param_connectivity_key" token_value="spatial_connectivities" token_optional="false">
        <param name="connectivity_key" type="text" value="@VALUE@" optional="@OPTIONAL@" label="Connectivity key" help="Key in adata.obsp where spatial connectivities are stored">
            <expand macro="sanitize_query"/>
        </param>
    </xml>

    <xml name="param_library_key">
        <param name="library_key" type="text" optional="true" label="Library key" help="Column in adata.obs which stores mapping between library_id and obs">
            <expand macro="sanitize_query"/>
        </param>
    </xml>

    <xml name="param_backend">
        <param name="backend" type="select" label="Parallelization backend">
            <option value="loky" selected="true">loky</option>
            <option value="threading">threading</option>
            <option value="multiprocessing">multiprocessing</option>
        </param>
    </xml>
</macros>
