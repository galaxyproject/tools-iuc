<tool id="squidpy_plot" name="Squidpy Plot" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>plot spatial graph analysis results</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <command detect_errors="exit_code"><![CDATA[
        mkdir -p input output &&
        #if $input_data.ext == 'spatialdata.zip':
            unzip -q '$input_data' -d input &&

            ## Rename directory to spatialdata.zarr if it has a different name
            dir_name=\$(ls -d input/*/ | head -1 | xargs basename) &&
            if [ -n "\$dir_name" ] && [ "\$dir_name" != "spatialdata.zarr" ]; then
                mv "input/\$dir_name" input/spatialdata.zarr;
            fi &&
        #else if $input_data.ext == 'h5ad':
            ln -s '$input_data' input/spatialdata.h5ad &&
        #end if
        ## run the graph operation
        cat 'squidpy_plot.py' &&
        python3 'squidpy_plot.py'
    ]]></command>
    <configfiles>
        <configfile name="squidpy_config" filename="squidpy_plot.py"><![CDATA[
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import spatialdata as sd
import anndata as ad
import squidpy as sq
import numpy as np

#if $input_data.ext == 'spatialdata.zip':
## Load the spatial object
spatial_obj = sd.read_zarr("input/spatialdata.zarr")

print("Input spatial object:")

#else if $input_data.ext == 'h5ad':
## Load the AnnData object
spatial_obj = ad.read_h5ad("input/spatialdata.h5ad", backed='r')

print("Input Anndata object:")
#end if

print(spatial_obj)

#if $operation_condi.operation == 'plot_nhood_enrichment':
## Generate neighborhood enrichment plot
print("\nGenerating neighborhood enrichment plot...")
@CMD_PL_ADATA@
sq.pl.nhood_enrichment(
    adata_for_plot,
    cluster_key='$operation_condi.cluster_key',
    mode='$operation_condi.mode',
    annotate=$operation_condi.annotate,
    @CMD_PL_METHOD@
    cmap='$operation_condi.cmap',
    @CMD_PL_PALETTE@
    @CMD_PL_FIGSIZE@
    @CMD_PL_DPI@
)
@CMD_PL_SAVE@

#else if $operation_condi.operation == 'plot_co_occurrence':
## Generate co-occurrence plot
print("\nGenerating co-occurrence plot...")
    #if $operation_condi.clusters:
        #set clusters_list = [str(x.strip()) for x in str($operation_condi.clusters).split(',')]
clusters = $clusters_list
    #else:
clusters = None
    #end if
@CMD_PL_ADATA@
sq.pl.co_occurrence(
    adata_for_plot,
    cluster_key='$operation_condi.cluster_key',
    clusters=clusters,
    @CMD_PL_PALETTE@
    @CMD_PL_FIGSIZE@
    @CMD_PL_DPI@
)
@CMD_PL_SAVE@

#else if $operation_condi.operation == 'plot_centrality_scores':
## Generate centrality scores plot
print("\nGenerating centrality scores plot...")
    #if $operation_condi.score:
        #set score_list = [str(x.strip()) for x in str($operation_condi.score).split(',')]
score = $score_list
    #else:
score = None
    #end if
@CMD_PL_ADATA@
sq.pl.centrality_scores(
    adata_for_plot,
    cluster_key='$operation_condi.cluster_key',
    score=score,
    @CMD_PL_PALETTE@
    @CMD_PL_FIGSIZE@
    @CMD_PL_DPI@
)
@CMD_PL_SAVE@

#else if $operation_condi.operation == 'plot_interaction_matrix':
## Generate interaction matrix plot
print("\nGenerating interaction matrix plot...")
@CMD_PL_ADATA@
sq.pl.interaction_matrix(
    adata_for_plot,
    cluster_key='$operation_condi.cluster_key',
    annotate=$operation_condi.annotate,
    @CMD_PL_METHOD@
    cmap='$operation_condi.cmap',
    @CMD_PL_PALETTE@
    @CMD_PL_FIGSIZE@
    @CMD_PL_DPI@
)
@CMD_PL_SAVE@

#else if $operation_condi.operation == 'plot_ripley':
## Generate Ripley's statistic plot
print("\nGenerating Ripley's statistic plot...")
@CMD_PL_ADATA@
sq.pl.ripley(
    adata_for_plot,
    cluster_key='$operation_condi.cluster_key',
    mode='$operation_condi.mode',
    plot_sims=$operation_condi.plot_sims,
    @CMD_PL_PALETTE@
    @CMD_PL_FIGSIZE@
    @CMD_PL_DPI@
)
@CMD_PL_SAVE@

#else if $operation_condi.operation == 'plot_ligrec':
## Generate ligand-receptor plot
print("\nGenerating ligand-receptor plot...")
@CMD_PL_ADATA@
    #if $operation_condi.source_groups:
        #set source_groups_list = [str(x.strip()) for x in str($operation_condi.source_groups).split(',')]
source_groups = $source_groups_list
    #else:
source_groups = None
    #end if
    #if $operation_condi.target_groups:
        #set target_groups_list = [str(x.strip()) for x in str($operation_condi.target_groups).split(',')]
target_groups = $target_groups_list
    #else:
target_groups = None
    #end if
    #if str($operation_condi.means_range_min) != '':
pl_means_min = $operation_condi.means_range_min
    #else:
pl_means_min = float('-inf')
    #end if
    #if str($operation_condi.means_range_max) != '':
pl_means_max = $operation_condi.means_range_max
    #else:
pl_means_max = float('inf')
    #end if
    #if $operation_condi.key_added:
ligrec_key = '$operation_condi.key_added'
    #else:
ligrec_key = '$operation_condi.cluster_key' + '_ligrec'
    #end if
sq.pl.ligrec(
    adata_for_plot,
    cluster_key='$operation_condi.cluster_key',
    source_groups=source_groups,
    target_groups=target_groups,
    means_range=(pl_means_min, pl_means_max),
    pvalue_threshold=$operation_condi.pvalue_threshold,
    remove_empty_interactions=$operation_condi.remove_empty_interactions,
    remove_nonsig_interactions=$operation_condi.remove_nonsig_interactions,
    #if str($operation_condi.dendrogram) != 'None':
    dendrogram='$operation_condi.dendrogram',
    #end if
    alpha=$operation_condi.alpha,
    swap_axes=$operation_condi.swap_axes,
    @CMD_PL_FIGSIZE@
    @CMD_PL_DPI@
)
@CMD_PL_SAVE@

#end if

print("\nOperation completed successfully!")
        ]]></configfile>
    </configfiles>
    <inputs>
        <expand macro="param_input_data"/>
        <param argument="--table_key" type="text" value="table" label="Key in SpatialData.tables where the table is stored">
            <expand macro="sanitize_query"/>
        </param>
        <conditional name="operation_condi">
            <param name="operation" type="select" label="Operation">
                <option value="plot_nhood_enrichment">Plot neighborhood enrichment (pl.nhood_enrichment)</option>
                <option value="plot_co_occurrence">Plot co-occurrence (pl.co_occurrence)</option>
                <option value="plot_centrality_scores">Plot centrality scores (pl.centrality_scores)</option>
                <option value="plot_interaction_matrix">Plot interaction matrix (pl.interaction_matrix)</option>
                <option value="plot_ripley">Plot Ripley statistics (pl.ripley)</option>
                <option value="plot_ligrec">Plot ligand-receptor interactions (pl.ligrec)</option>
            </param>
            <when value="plot_nhood_enrichment">
                <expand macro="param_cluster_key"/>
                <param argument="--mode" type="select" label="Which result to plot">
                    <option value="zscore" selected="true">Z-score</option>
                    <option value="count">Count</option>
                </param>
                <expand macro="param_pl_annotate"/>
                <expand macro="param_pl_method"/>
                <expand macro="param_pl_cmap"/>
                <expand macro="param_pl_palette"/>
                <expand macro="param_pl_figsize"/>
                <expand macro="param_pl_dpi"/>
                <expand macro="param_plot_format"/>
            </when>
            <when value="plot_co_occurrence">
                <expand macro="param_cluster_key"/>
                <param argument="--clusters" type="text" optional="true" label="Comma-separated cluster names for conditional probability plot" help="If empty, all clusters are shown">
                    <expand macro="sanitize_query"/>
                </param>
                <expand macro="param_pl_palette"/>
                <expand macro="param_pl_figsize"/>
                <expand macro="param_pl_dpi"/>
                <expand macro="param_plot_format"/>
            </when>
            <when value="plot_centrality_scores">
                <expand macro="param_cluster_key"/>
                <param argument="--score" type="select" multiple="true" optional="true" label="Centrality measures" help="If none selected, all measures are plotted">
                    <option value="closeness_centrality">Closeness centrality</option>
                    <option value="average_clustering">Average clustering</option>
                    <option value="degree_centrality">Degree centrality</option>
                </param>
                <expand macro="param_pl_palette"/>
                <expand macro="param_pl_figsize"/>
                <expand macro="param_pl_dpi"/>
                <expand macro="param_plot_format"/>
            </when>
            <when value="plot_interaction_matrix">
                <expand macro="param_cluster_key"/>
                <expand macro="param_pl_annotate"/>
                <expand macro="param_pl_method"/>
                <expand macro="param_pl_cmap"/>
                <expand macro="param_pl_palette"/>
                <expand macro="param_pl_figsize"/>
                <expand macro="param_pl_dpi"/>
                <expand macro="param_plot_format"/>
            </when>
            <when value="plot_ripley">
                <expand macro="param_cluster_key"/>
                <param argument="--mode" type="select" label="Ripley statistic mode">
                    <option value="F" selected="true">F statistic</option>
                    <option value="G">G statistic</option>
                    <option value="L">L statistic</option>
                </param>
                <param argument="--plot_sims" type="boolean" truevalue="True" falsevalue="False" checked="true" label="Overlay simulations in plot?"/>
                <expand macro="param_pl_palette"/>
                <expand macro="param_pl_figsize"/>
                <expand macro="param_pl_dpi"/>
                <expand macro="param_plot_format"/>
            </when>
            <when value="plot_ligrec">
                <expand macro="param_cluster_key"/>
                <param argument="--source_groups" type="text" optional="true" label="Source groups" help="Comma-separated source interaction cluster names. If empty, all clusters are used">
                    <expand macro="sanitize_query"/>
                </param>
                <param argument="--target_groups" type="text" optional="true" label="Target groups" help="Comma-separated target interaction cluster names. If empty, all clusters are used">
                    <expand macro="sanitize_query"/>
                </param>
                <param name="means_range_min" type="float" optional="true" label="Means range minimum" help="Only show interactions with mean expression &gt;= this value. If empty, no minimum filter"/>
                <param name="means_range_max" type="float" optional="true" label="Means range maximum" help="Only show interactions with mean expression &lt;= this value. If empty, no maximum filter"/>
                <param argument="--pvalue_threshold" type="float" value="1.0" min="0" max="1" label="P-value threshold" help="Only show interactions with p-value &lt;= this threshold"/>
                <param argument="--remove_empty_interactions" type="boolean" truevalue="True" falsevalue="False" checked="true" label="Remove rows/columns that only contain NaN values"/>
                <param argument="--remove_nonsig_interactions" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Remove rows/columns that only contain interactions larger than alpha"/>
                <param argument="--dendrogram" type="select" label="How to cluster based on p-values">
                    <option value="None" selected="true">None (no clustering)</option>
                    <option value="interacting_molecules">Interacting molecules</option>
                    <option value="interacting_clusters">Interacting clusters</option>
                    <option value="both">Both</option>
                </param>
                <param argument="--alpha" type="float" value="0.001" min="0" max="1" label="Significance threshold (alpha)" help="Elements with p-values &lt;= alpha will be marked by tori instead of dot"/>
                <param argument="--swap_axes" type="boolean" truevalue="True" falsevalue="False" checked="false" label="Swap axes?" help="Show cluster combinations as rows and interacting pairs as columns"/>
                <expand macro="param_pl_figsize"/>
                <expand macro="param_pl_dpi"/>
                <expand macro="param_plot_format"/>
                <param argument="--key_added" type="text" optional="true" label="Key in adata.uns where results are stored" help="Default: '{cluster_key}_ligrec'. Only needed if you used a custom key_added when computing ligrec">
                    <expand macro="sanitize_query"/>
                </param>
            </when>
        </conditional>
    </inputs>
    <outputs>
        <data name="plot_output_png" format="png" from_work_dir="output/plot.png" label="${tool.name} on ${on_string}: ${operation_condi.operation} - Plot PNG">
            <filter>operation_condi['pl_format'] == 'png'</filter>
        </data>
        <data name="plot_output_pdf" format="pdf" from_work_dir="output/plot.pdf" label="${tool.name} on ${on_string}: ${operation_condi.operation} - Plot PDF">
            <filter>operation_condi['pl_format'] == 'pdf'</filter>
        </data>
        <data name="plot_output_svg" format="svg" from_work_dir="output/plot.svg" label="${tool.name} on ${on_string}: ${operation_condi.operation} - Plot SVG">
            <filter>operation_condi['pl_format'] == 'svg'</filter>
        </data>
        <data name="plot_output_jpg" format="jpg" from_work_dir="output/plot.jpg" label="${tool.name} on ${on_string}: ${operation_condi.operation} - Plot JPG">
            <filter>operation_condi['pl_format'] == 'jpg'</filter>
        </data>
    </outputs>
