<tool id="vg_giraffe" name="vg giraffe" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>is a fast haplotype-aware read mapper</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">vg</requirement>
        <requirement type="package" version="1.23.1">samtools</requirement>
    </requirements>
    <expand macro="version_command"/>
    <command detect_errors="aggressive"><![CDATA[
        set -o pipefail;

        ## Copy to avoid issues in HPC clusters when multiple processes access the same dist file.
        ## https://github.com/vgteam/vg/wiki/Giraffe-best-practices#distance-index-zipcodes-file-and-minimizer-index
        #if $indexes.dist_name:
            cp '$indexes.dist_name' graph.dist &&
        #end if

        ## echo headers for tsv output for improved user experience
        #if $format_cond.output_format == 'TSV':
            echo -e 'Read Name\tReference Name\tOffset\tMapping Quality\tScore' >> '$output' &&
        #end if

        ## Run main command
        vg giraffe
            
            ## Print additional progress information to stderr for troubleshooting or reporting issues
            --progress 

            ## Reference Graph
            #if $reference.index_type == 'gbz':
                --gbz-name '$reference.gbz_name'
            #elif $reference.index_type == 'xg':
                --xg-name '$reference.xg_name'
                --gbwt-name '$reference.gbwt_name'
            #elif $reference.index_type == 'gg':
                --graph-name '$reference.graph_name'
                --gbwt-name '$reference.gbwt_name'
            #end if

            ## Indexes
            #if $indexes.minimizer_name:
                --minimizer-name '$indexes.minimizer_name'
            #end if
            #if $indexes.dist_name:
                --dist-name graph.dist
            #end if
            #if $indexes.zipcode_name:
                --zipcode-name '$indexes.zipcode_name'
            #end if

              ## Set index basename to the current working directory to prevent writing to read-only directories when creating indexes on the fly
            --index-basename 'giraffe_index'

            ## Preset
            --parameter-preset '$preset'

            ## Input Reads
            #if $reads.reads_type == 'single':
                -f '$reads.input_fastq'
                $reads.interleaved
                $reads.comments_as_tags
            #elif $reads.reads_type == 'paired':
                -f '$reads.input_fastq1' 
                -f '$reads.input_fastq2'
                $reads.comments_as_tags
            #elif $reads.reads_type == 'gam':
                -G '$reads.input_gam'
                $reads.interleaved
            #end if
        
            ## Output Options
            --output-format '$format_cond.output_format'
            #if $format_cond.output_format in ['SAM', 'BAM', 'CRAM']:
                #if $format_cond.xg_name and $reference.index_type != 'xg':
                    --xg-name '$format_cond.xg_name'
                #end if
                #if $format_cond.ref_name:
                    --ref-name '$format_cond.ref_name'
                #end if
                #if $format_cond.ref_paths:
                    --ref-paths '$format_cond.ref_paths'
                #end if
                $format_cond.add_graph_aln
            #elif $format_cond.output_format in ['GAM', 'GAF', 'JSON']:
                $format_cond.named_coordinates
                #if $format_cond.output_format != 'GAF':
                    $format_cond.set_refpos 
                #end if
            #elif $format_cond.output_format == 'TSV':
                $format_cond.set_refpos
            #end if

            #if $format_cond.output_format in ['GAM', 'JSON', 'SAM', 'BAM', 'CRAM']:
                #if $format_cond.sample:
                    --sample '$format_cond.sample'
                #end if
                #if $format_cond.read_group:
                    --read-group '$format_cond.read_group'
                #end if
            #end if

            ## Advanced Options
            $advanced.rec_mode
            #if $advanced.rescue_algorithm != 'dozeu':
                --rescue-algorithm '$advanced.rescue_algorithm'
            #end if
            #if $advanced.fragment_length_cond.fragment_length_settings == 'manual':
                --fragment-mean $advanced.fragment_length_cond.fragment_mean
                --fragment-stdev $advanced.fragment_length_cond.fragment_stdev
            #end if

            ### Program Options
            #if $advanced.program_options_args:
                #for $arg in str($advanced.program_options_args).split(','):
                    #set $arg = $arg.strip()
                    #if $arg:
                        #if '=' in $arg:
                            #set $key = $arg.split('=', 1)[0].strip()
                            #set $val = $arg.split('=', 1)[1].strip()
                            #if $key and $val:
                                $key '$val'
                            #end if
                        #else:
                            $arg
                        #end if
                    #end if
                #end for
            #end if

            #if $format_cond.output_format in ['BAM', 'CRAM']:
                ## Sort the BAM/CRAM file by coordinates so the job in Galaxy does not fail 
                | samtools sort -O '$format_cond.output_format' 
            #end if
            
            >> '$output'
    ]]></command>
    <inputs>
        <conditional name="reference">
            <param name="index_type" type="select" label="Graph to Map Against">
                <option value="gbz" selected="true">GBZ Graph (default) (--gbz-name)</option>
                <option value="xg">XG Graph (--xg-name)</option>
                <option value="gg">GBWTGraph (--graph-name)</option>
            </param>
            <when value="gbz">
                <param argument="--gbz-name" type="data" format="gbz" label="GBZ Graph" help="Map to this GBZ graph"/>
            </when>
            <when value="xg">
                <param argument="--xg-name" type="data" format="xg" label="XG Graph" help="Map to this XG Graph"/>
                <expand macro="param_gbwt_name"/>
            </when>
            <when value="gg">
                <param argument="--graph-name" type="data" format="vg.gg" label="GBWTGraph" help="Map to this GBWTGraph"/>
                <expand macro="param_gbwt_name"/>
            </when>
        </conditional>
        <section name="indexes" title="Graph Index Files" expanded="false" help="Providing according index files that are compatible with the input graph will speed up analysis. If omitted, vg giraffe will automatically try to generate them on the fly before mapping">
            <param argument="--minimizer-name" type="data" format="vg.min" optional="true" label="Minimizer Index" help="Provide to speed up finding matches (seeds) between reads and the graph"/>
            <param argument="--dist-name" type="data" format="vg.dist" optional="true" label="Distance Index" help="Provide to quickly cluster seeds"/>
            <param argument="--zipcode-name" type="data" format="vg.zipcodes" optional="true" label="Zipcodes Index" help="Provide for distance hints to speed up chaining, especially for long reads"/>
            <param name="export_indexes" type="boolean" truevalue="--export_indexes" falsevalue="" checked="false" label="Export Generated Index Files" help="If vg giraffe generates any missing index files, enable this to store them in your history for future reuse"/>
        </section>
        <param name="preset" type="select" label="Parameter Preset" help="Set computational parameters (--parameter-preset)">
            <option value="default" selected="true">Default</option>
            <option value="fast">Fast</option>
            <option value="hifi">PacBio HiFi</option>
            <option value="r10">ONT R10</option>
            <option value="chaining-sr">Short reads with chaining</option>
            <option value="srold">Old short reads preset</option>
        </param>
        <conditional name="reads">
            <param name="reads_type" type="select" label="Input Reads">
                <option value="single" selected="true">Read and align a FASTQ/FASTA file (one file) (-f)</option>
                <option value="paired">Read and align paired-end FASTQ/FASTA files (two files) (-f)</option>
                <option value="gam">Read and realign a GAM file (-G)</option>
            </param>
            <when value="single">
                <param name="input_fastq" type="data" format="fastqsanger,fastqsanger.gz,fasta,fasta.gz" label="Reads"/>
                <expand macro="param_interleaved"/>
                <expand macro="param_comments_as_tags"/>
            </when>
            <when value="paired">
                <param name="input_fastq1" type="data" format="fastqsanger,fastqsanger.gz,fasta,fasta.gz" label="Forward Reads"/>
                <param name="input_fastq2" type="data" format="fastqsanger,fastqsanger.gz,fasta,fasta.gz" label="Reverse Reads"/>
                <expand macro="param_comments_as_tags"/>
            </when>
            <when value="gam">
                <param name="input_gam" type="data" format="gam" label="GAM Alignments"/>
                <expand macro="param_interleaved"/>
            </when>
        </conditional>
        <conditional name="format_cond">
            <param name="output_format" type="select" label="Output Format">
                <option value="GAM" selected="true">GAM</option>
                <option value="GAF">GAF</option>
                <option value="SAM">SAM</option>
                <option value="BAM">BAM</option>
                <option value="CRAM">CRAM</option>
                <option value="JSON">JSON</option>
                <option value="TSV">TSV</option>
            </param>
            <when value="GAM">
                <expand macro="param_named_coordinates"/>
                <expand macro="param_set_refpos"/>
                <expand macro="param_sample"/>
                <expand macro="param_read_group"/>
            </when>
            <when value="GAF">
                <expand macro="param_named_coordinates"/>
            </when>
            <when value="JSON">
                <expand macro="param_named_coordinates"/>
                <expand macro="param_set_refpos"/>
                <expand macro="param_sample"/>
                <expand macro="param_read_group"/>
            </when>
            <when value="TSV">
                <expand macro="param_set_refpos"/>
            </when>
            <when value="SAM">
                <expand macro="param_xg_name_for_htslib"/>
                <expand macro="param_ref_name"/>
                <expand macro="param_ref_paths"/>
                <expand macro="param_add_graph_aln"/>
                <expand macro="param_sample"/>
                <expand macro="param_read_group"/>
            </when>
             <when value="BAM">
                <expand macro="param_xg_name_for_htslib"/>
                <expand macro="param_ref_name"/>
                <expand macro="param_ref_paths"/>
                <expand macro="param_add_graph_aln"/>
                <expand macro="param_sample"/>
                <expand macro="param_read_group"/>
             </when>
             <when value="CRAM">
                <expand macro="param_xg_name_for_htslib"/>
                <expand macro="param_ref_name"/>
                <expand macro="param_ref_paths"/>
                <expand macro="param_add_graph_aln"/>
                <expand macro="param_sample"/>
                <expand macro="param_read_group"/>
            </when>
        </conditional>
        <!-- Advanced Options -->
        <section name="advanced" title="Advanced Options" expanded="false">
            <param argument="--rec-mode" type="boolean" truevalue="--rec-mode" falsevalue="" checked="false" label="Recombination-Aware Mode" help="Mode for long reads. It helps keep alignments on a single, consistent haplotype path and avoids jumping between similar sequences"/>
            <param argument="--rescue-algorithm" type="select" label="Rescue Algorithm" help="For paired-end reads. If one read maps but its partner doesn't, this algorithm will try to find a location for the unmapped read near its mapped partner">
                <option value="dozeu" selected="true">dozeu (default)</option>
                <option value="none">none</option>
                <option value="gssw">gssw</option>
            </param>
            <conditional name="fragment_length_cond">
                <param name="fragment_length_settings" type="select" label="Fragment Length Distribution (Paired-End)" help="Control the distance between input read pairs. Automatically detect the fragment length distribution or manually force a specific one. This option has no effect for single-end reads">
                    <option value="auto" selected="true">Automatic (default)</option>
                    <option value="manual">Set Mean and Standard Deviation</option>
                </param>
                <when value="auto"/>
                <when value="manual">
                    <param argument="--fragment-mean" type="float" value="0" min="0" label="Fragment Mean" help="Force fragment length distribution to have this mean"/>
                    <param argument="--fragment-stdev" type="float" value="0" min="0" label="Fragment Standard Deviation" help="Force fragment length distribution to have this standard deviation"/>
                </when>
            </conditional>
            <param name="program_options_args" type="text" optional="true" label="program_options args" help="Add additional arguments to vg giraffe. Comma-separated option_name=option_value. If the option_name is a boolean, then the option_value is not needed. Example: --mismatch=4,--match=1,--log-reads. See the Help section below for a link to the full list of options.">
                <validator type="regex" message="Options must be formatted as key or key=value and separated by commas.">^[^,=]+(=[^,]+)?(,[^,=]+(=[^,]+)?)*$</validator>
            </param>
        </section>
    </inputs>
    <outputs>
        <data name="output" format="gam" label="${tool.name} on ${on_string}">
            <change_format>
                <when input="format_cond.output_format" value="GAF" format="gaf"/>
                <when input="format_cond.output_format" value="SAM" format="sam"/>
                <when input="format_cond.output_format" value="BAM" format="bam"/>
                <when input="format_cond.output_format" value="CRAM" format="cram"/>
                <when input="format_cond.output_format" value="JSON" format="json"/>
                <when input="format_cond.output_format" value="TSV" format="tabular"/>
            </change_format>
        </data>
        <data name="output_dist" format="vg.dist" from_work_dir="giraffe_index.dist" label="${tool.name} on ${on_string}: Distance index">
            <filter>indexes['export_indexes']</filter>
            <filter>not indexes['dist_name']</filter>
        </data>
        <data name="output_min_short" format="vg.min" from_work_dir="giraffe_index.shortread.withzip.min" label="${tool.name} on ${on_string}: Minimizer index (for short read)">
            <filter>indexes['export_indexes']</filter>
            <filter>not indexes['minimizer_name']</filter>
            <filter>preset != 'hifi' and preset != 'r10'</filter>
        </data>
        <data name="output_min_long" format="vg.min" from_work_dir="giraffe_index.longread.withzip.min" label="${tool.name} on ${on_string}: Minimizer index (for long read)">
            <filter>indexes['export_indexes']</filter>
            <filter>not indexes['minimizer_name']</filter>
            <filter>preset == 'hifi' or preset == 'r10'</filter>
        </data>
        <data name="output_zip_short" format="vg.zipcodes" from_work_dir="giraffe_index.shortread.zipcodes" label="${tool.name} on ${on_string}: Zipcodes index (for short read)">
            <filter>indexes['export_indexes']</filter>
            <filter>not indexes['zipcode_name']</filter>
            <filter>preset != 'hifi' and preset != 'r10'</filter>
        </data>
        <data name="output_zip_long" format="vg.zipcodes" from_work_dir="giraffe_index.longread.zipcodes" label="${tool.name} on ${on_string}: Zipcodes index (for long read)">
            <filter>indexes['export_indexes']</filter>
            <filter>not indexes['zipcode_name']</filter>
            <filter>preset == 'hifi' or preset == 'r10'</filter>
        </data>
    </outputs>
    <tests>
        <!-- Test 1: Mapping to a GBZ graph and a single read. Output in GAM -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gbz"/>
                <param name="gbz_name" value="giraffe/graph.gbz"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="single"/>
                <param name="input_fastq" value="giraffe/reads_1.fastq.gz"/>
            </conditional>
            <output name="output" ftype="gam">
                <assert_contents>
                    <has_size min="270000"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 2: Mapping to a GBWT graph and a single read. Output in GAM -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gg"/>
                <param name="graph_name" value="giraffe/graph.gg"/>
                <param name="gbwt_name" value="giraffe/graph.gbwt"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="single"/>
                <param name="input_fastq" value="giraffe/reads_1.fastq.gz"/>
            </conditional>
            <output name="output" ftype="gam">
                <assert_contents>
                    <has_size min="270000"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 3: Mapping to a XG graph and a single read. Output in GAM -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="xg"/>
                <param name="xg_name" value="giraffe/graph.xg"/>
                <param name="gbwt_name" value="giraffe/graph.gbwt"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="single"/>
                <param name="input_fastq" value="giraffe/reads_1.fastq.gz"/>
            </conditional>
            <output name="output" ftype="gam">
                <assert_contents>
                    <has_size min="270000"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 4: Mapping to a GBZ graph and a paired read. Output in GAF -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gbz"/>
                <param name="gbz_name" value="giraffe/graph.gbz"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="paired"/>
                <param name="input_fastq1" value="giraffe/reads_1.fastq.gz"/>
                <param name="input_fastq2" value="giraffe/reads_2.fastq.gz"/>
            </conditional>
            <conditional name="format_cond">
                <param name="output_format" value="GAF"/>
            </conditional>
            <output name="output" ftype="gaf">
                <assert_contents>
                    <has_size min="1100000"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 5: Mapping to a GBZ graph and a paired read. Output in JSON -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gbz"/>
                <param name="gbz_name" value="giraffe/graph.gbz"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="paired"/>
                <param name="input_fastq1" value="giraffe/reads_1.fastq.gz"/>
                <param name="input_fastq2" value="giraffe/reads_2.fastq.gz"/>
            </conditional>
            <conditional name="format_cond">
                <param name="output_format" value="JSON"/>
            </conditional>
            <output name="output" ftype="json">
                <assert_contents>
                    <has_text text="{&quot;annotation&quot;:" n="4000"/>
                    <has_text text="refpos" negate="true"/>
                    <has_text text="sample_name" negate="true"/>
                    <has_text text="read_group" negate="true"/>
                    <has_text text="8af8856b4bda81f1_"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 6: Mapping to a GBZ graph and a paired read (interleaved fasta file). Ouput in JSON -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gbz"/>
                <param name="gbz_name" value="giraffe/graph.gbz"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="single"/>
                <param name="input_fastq" value="giraffe/reads_interleaved.fastq.gz"/>
                <param name="interleaved" value="true"/>
            </conditional>
            <conditional name="format_cond">
                <param name="output_format" value="JSON"/>
            </conditional>
            <output name="output" ftype="json">
                <assert_contents>
                    <has_text text="{&quot;annotation&quot;:" n="4000"/>
                    <has_text text="refpos" negate="true"/>
                    <has_text text="sample_name" negate="true"/>
                    <has_text text="read_group" negate="true"/>
                    <has_text text="8af8856b4bda81f1_"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 7: Mapping to a GBZ graph and a paired read. Output in JSON with ref-pos, sample and read-group set -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gbz"/>
                <param name="gbz_name" value="giraffe/graph.gbz"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="paired"/>
                <param name="input_fastq1" value="giraffe/reads_1.fastq.gz"/>
                <param name="input_fastq2" value="giraffe/reads_2.fastq.gz"/>
            </conditional>
            <conditional name="format_cond">
                <param name="output_format" value="JSON"/>
                <param name="set_refpos" value="true"/>
                <param name="sample" value="mysample"/>
                <param name="read_group" value="groupy"/>
            </conditional>
            <output name="output" ftype="json">
                <assert_contents>
                    <has_text text="{&quot;annotation&quot;:" n="4000"/>
                    <has_text text="&quot;refpos&quot;:"/>
                    <has_text text="&quot;sample_name&quot;: &quot;mysample&quot;"/>
                    <has_text text="&quot;read_group&quot;: &quot;groupy&quot;"/>
                    <has_text text="8af8856b4bda81f1_"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 8: Mapping to a GBZ graph and a paired read. Ouput in TSV -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gbz"/>
                <param name="gbz_name" value="giraffe/graph.gbz"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="paired"/>
                <param name="input_fastq1" value="giraffe/reads_1.fastq.gz"/>
                <param name="input_fastq2" value="giraffe/reads_2.fastq.gz"/>
            </conditional>
             <conditional name="format_cond">
                <param name="output_format" value="TSV"/>
            </conditional>
            <output name="output" ftype="tabular">
                <assert_contents>
                    <has_line line="8af8856b4bda81f1_&#009;&#009;0&#009;60&#009;160" n="2"/>
                    <has_text text="chr1" negate="true"/>
                    <has_n_lines n="4001"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 9: Mapping to a GBZ graph and a paired read. Ouput in TSV with ref-pos set -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gbz"/>
                <param name="gbz_name" value="giraffe/graph.gbz"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="paired"/>
                <param name="input_fastq1" value="giraffe/reads_1.fastq.gz"/>
                <param name="input_fastq2" value="giraffe/reads_2.fastq.gz"/>
            </conditional>
            <conditional name="format_cond">
                <param name="output_format" value="TSV"/>
                <param name="set_refpos" value="true"/>
            </conditional>
            <output name="output" ftype="tabular">
                <assert_contents>
                    <has_line line="8af8856b4bda81f1_&#009;chr1&#009;1782&#009;60&#009;160" n="1"/>
                    <has_line line="8af8856b4bda81f1_&#009;chr1&#009;1515&#009;60&#009;160" n="1"/>
                    <has_n_lines n="4001"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 10: Mapping to a GBZ graph and a paired read. Ouput in SAM without XG graph -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gbz"/>
                <param name="gbz_name" value="giraffe/graph.gbz"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="paired"/>
                <param name="input_fastq1" value="giraffe/reads_1.fastq.gz"/>
                <param name="input_fastq2" value="giraffe/reads_2.fastq.gz"/>
            </conditional>
            <conditional name="format_cond">
                <param name="output_format" value="SAM"/>
            </conditional>
            <output name="output" ftype="sam">
                <assert_contents>
                    <has_line line="@HD&#009;VN:1.5&#009;SO:unknown" n="1"/>
                    <has_text text="@SQ&#009;SN:chr1" n="1"/>
                    <has_text text="@SQ&#009;SN:chr2" n="1"/>
                    <has_line line="@PG&#009;ID:0&#009;PN:vg" n="1"/>
                    <has_text text="8af8856b4bda81f1_&#009;83&#009;chr1&#009;1663&#009;60&#009;150M&#009;=&#009;1516&#009;-297"/>
                    <has_text text="1020e3d0e69ad810_&#009;83&#009;chr2&#009;3674&#009;60&#009;150M&#009;=&#009;3540&#009;-284"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 11: Mapping to a GBZ graph and a paired read. Ouput in SAM with XG graph. This is just for testing as our gbz graph is fast enough and would not require a XG graph -->
        <test expect_num_outputs="1">
            <conditional name="reference">
                <param name="index_type" value="gbz"/>
                <param name="gbz_name" value="giraffe/graph.gbz"/>
            </conditional>
            <conditional name="reads">
                <param name="reads_type" value="paired"/>
