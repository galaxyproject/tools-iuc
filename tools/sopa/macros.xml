<macros>
    <token name="@TOOL_VERSION@">2.2.8</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.0</token>

    <token name="@CMD_UNZIP_ZARR@"><![CDATA[
        ## Unzip input SpatialData object
        unzip -q '$input_sdata' &&
    ]]></token>

    <token name="@CMD_ZIP_ZARR@"><![CDATA[
        ## Zip output SpatialData object
        cd output_dir &&
        zip -r -q ../sdata_output.zip *.zarr/ &&
        cd ..
    ]]></token>

    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">sopa</requirement>
            <requirement type="package" version="0.7.2">spatialdata</requirement>
            <requirement type="package" version="0.6.0">spatialdata-io</requirement>
            <requirement type="package" version="0.2.14">spatialdata-plot</requirement>
            <requirement type="package" version="0.13.0">ome-zarr</requirement>
            <requirement type="package" version="0.12.10">anndata</requirement>
            <requirement type="package" version="2.3.3">pandas</requirement>
            <requirement type="package" version="3.0">zip</requirement>
            <requirement type="package" version="6.0">unzip</requirement>
            <yield />
        </requirements>
    </xml>
    <xml name="bio_tools">
        <xrefs>
            <xref type="bio.tools">sopa</xref>
        </xrefs>
    </xml>
    <xml name="creators">
        <creator>
            <person givenName="Amirhossein" familyName="Naghsh Nilchi" email="nilchia@informatik.uni-freiburg.de"/>
            <person givenName="Pavan" familyName="Videm" email="videmp@informatik.uni-freiburg.de"/>
            <person givenName="Björn" familyName="Grüning" email="gruening@informatik.uni-freiburg.de"/>
            <organization name="European Galaxy Team" url="https://usegalaxy-eu.github.io/people"/>
        </creator>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.1038/s41467-024-48981-z</citation>
        </citations>
    </xml>

    <!-- param macros -->
    <xml name="sanitize_query" token_validinitial="string.printable">
        <sanitizer>
            <valid initial="@VALIDINITIAL@">
                <remove value="&apos;"/>
            </valid>
       </sanitizer>
    </xml>
    <xml name="sanitize_vectors" token_validinitial="string.digits">
        <sanitizer>
            <valid initial="@VALIDINITIAL@">
                <add value=","/>
            </valid>
        </sanitizer>
    </xml>

    <xml name="input_sdata">
        <param name="input_sdata" type="data" format="zip" label="Input SpatialData object"
               help="Zipped .zarr directory containing a SpatialData object (output from SpatialData IO or previous SOPA tool)"/>
    </xml>

    <xml name="output_sdata">
        <data name="output_sdata" format="zip" from_work_dir="sdata_output.zip"
              label="${tool.name} on ${on_string}: SpatialData"/>
    </xml>

</macros>