<macros>
    <token name="@TOOL_VERSION@">2.2.8</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.0</token>
    <token name="@CMD_UNZIP_ZARR@"><![CDATA[
        ## Unzip input SpatialData object
        unzip -q '$input_sdata' -d input &&

        ## Rename directory to spatialdata.zarr if it has a different name
        dir_name=\$(ls -d input/*/ | head -1 | xargs basename) &&
        if [ -n "\$dir_name" ] && [ "\$dir_name" != "spatialdata.zarr" ]; then
            mv "input/\$dir_name" input/spatialdata.zarr;
        fi &&
        echo "Input SpatialData content:" &&
        python -c "import spatialdata as sd; spdata = sd.read_zarr('input/spatialdata.zarr'); print(spdata)" &&
    ]]></token>
    <token name="@CMD_ZIP_ZARR@"><![CDATA[
        ## Zip output SpatialData object
        cd output_dir &&
        ## print spatialdata.zarr content for debugging
        echo "Saving SpatialData content:" &&
        python -c "import spatialdata as sd; spdata = sd.read_zarr('spatialdata.zarr'); print(spdata)" &&
        zip -r -q ../sdata_output.spatialdata.zip spatialdata.zarr/ &&
        cd ..
    ]]></token>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">sopa</requirement>
            <requirement type="package" version="0.7.2">spatialdata</requirement>
            <requirement type="package" version="0.6.0">spatialdata-io</requirement>
            <requirement type="package" version="0.2.14">spatialdata-plot</requirement>
            <requirement type="package" version="0.13.0">ome-zarr</requirement>
            <requirement type="package" version="0.12.10">anndata</requirement>
            <requirement type="package" version="2.3.3">pandas</requirement>
            <requirement type="package" version="3.0">zip</requirement>
            <requirement type="package" version="6.0">unzip</requirement>
            <!-- set cellpose to < 4 so no GPU required for cellpose
            <requirement type="package" version="<4">cellpose</requirement> -->
            <yield/>
        </requirements>
    </xml>
    <xml name="bio_tools">
        <xrefs>
            <xref type="bio.tools">sopa</xref>
        </xrefs>
    </xml>
    <xml name="creators">
        <creator>
            <person givenName="Amirhossein" familyName="Naghsh Nilchi" email="nilchia@informatik.uni-freiburg.de"/>
            <person givenName="Pavan" familyName="Videm" email="videmp@informatik.uni-freiburg.de"/>
            <person givenName="Björn" familyName="Grüning" email="gruening@informatik.uni-freiburg.de"/>
            <organization name="European Galaxy Team" url="https://usegalaxy-eu.github.io/people"/>
        </creator>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.1038/s41467-024-48981-z</citation>
        </citations>
    </xml>
    <!-- param macros -->
    <xml name="sanitize_query" token_validinitial="string.letters,string.digits">
        <sanitizer>
            <valid initial="@VALIDINITIAL@">
                <add value="_"/>
                <add value="-"/>
                <add value="."/>
                <add value=","/>
            </valid>
        </sanitizer>
    </xml>
    <xml name="sanitize_vectors" token_validinitial="string.digits">
        <sanitizer>
            <valid initial="@VALIDINITIAL@">
                <add value=","/>
            </valid>
        </sanitizer>
    </xml>
    <xml name="min_area_param">
        <param argument="--min-area" type="integer" value="0" min="0" label="Minimum area (in pixels^2) for a cell to be considered as valid"/>
    </xml>
    <xml name="image_preprocessing_params">
        <param argument="--clip-limit" type="float" value="0.2" min="0" max="1" label="CLAHE clip limit for skimage.exposure.equalize_adapthist" help="Applied before running the segmentation."/>
        <param argument="--clahe-kernel-size" type="integer" optional="true" min="0" label="CLAHE kernel size for skimage.exposure.equalize_adapthist" help="Applied before running the segmentation."/>
        <param argument="--gaussian-sigma" type="float" value="1.0" min="0" label="Gaussian smoothing sigma for scipy gaussian_filter" help="Applied before running the segmentation."/>
    </xml>
    <token name="@CMD_IMG_PREPROCESSING@"><![CDATA[
            --clip-limit $method.clip_limit
            #if $method.clahe_kernel_size
                --clahe-kernel-size $method.clahe_kernel_size
            #end if
            --gaussian-sigma $method.gaussian_sigma
    ]]></token>
    <xml name="input_sdata">
        <param name="input_sdata" type="data" format="spatialdata.zip" label="Input SpatialData object"/>
    </xml>
    <xml name="output_sdata">
        <data name="output_sdata" format="spatialdata.zip" from_work_dir="sdata_output.spatialdata.zip" label="${tool.name} on ${on_string}: SpatialData"/>
    </xml>
</macros>
