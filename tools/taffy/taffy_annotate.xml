<tool id="taffy_annotate" name="Taffy annotate" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>adds annotations from a Wiggle file to a TAF file</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/> 
    <expand macro="stdio"/>
    <command detect_errors="aggressive">
        <![CDATA[
        ## Set variables
        @SET_UNCOMPRESS_NAMES@
        
        ## Uncompress input files if necessary and create symlinks for uncompressed files
        @UNCOMPRESS_TAF_AND_MAF@

        ## Run main command
        taffy annotate
            --logLevel 'INFO'
            --inputFile '$uncompressed_input'
            --wiggle '$input_wig'
            --tagName '$tagName'
            #if $refPrefix:
                --refPrefix '$refPrefix'
            #end if
            --repeatCoordinatesEveryNColumns $repeatCoordinatesEveryNColumns

        ## Compress TAF output if requested by user 
        @COMPRESS_TAF@
    ]]></command>
    <inputs>
        <expand macro="input_taf"/> 
        <param name="input_wig" type="data" format="wig" label="Wiggle file"/>
        <param argument="--tagName" type="text" optional="false" label="Tag name" help="This tag name becomes the key for every annotation added from the Wiggle file"/>
        <param argument="--refPrefix" type="text" optional="true" label="Reference prefix" help="Specify a string that is prepended to every chromosome name read from the Wiggle file before looking it up in the TAF file"/>
        <expand macro="params_repeatCoordinatesEveryNColumns"/>
        <expand macro="params_conditional_compression_taf"/>
    </inputs>
    <outputs>
        <data name="out_file" format="taf">
            <change_format>
                <when input="compression_taf" value="gz" format="taf.gz"/>
            </change_format>
        </data>
    </outputs>
    <tests>
        <!-- Test 1: TAF input with wiggle file, tagName and refPrefix -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testTaf.taf"/>
            <param name="input_wig" value="taffy_annotate_input.wig"/>
            <param name="tagName" value="scoreTag"/>
            <param name="refPrefix" value="Anc0."/>
            <output name="out_file" ftype="taf">
                <assert_contents>
                    <has_text text="#taf" n="1"/>
                    <has_text text=" @ scoreTag:" n="4"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 2: Compressed TAF input (.gz) with wiggle file, tagName and refPrefix -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testTaf.taf.gz"/>
            <param name="input_wig" value="taffy_annotate_input.wig"/>
            <param name="tagName" value="scoreTag"/>
            <param name="refPrefix" value="Anc0."/>
            <output name="out_file" ftype="taf">
                <assert_contents>
                    <has_text text="#taf" n="1"/>
                    <has_text text=" @ scoreTag:" n="4"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 3: TAF input with wiggle file, tagName, Output should equal input due to missing refPrefix -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testTaf.taf"/>
            <param name="input_wig" value="taffy_annotate_input.wig"/>
            <param name="tagName" value="scoreTag"/>
            <output name="out_file" ftype="taf" md5="44549a3d5b05d230e2917baaff6c3fbb"/>
        </test>
        <!-- Test 4: TAF input with wiggle file, tagName and refPrefix, compressed TAF output (.gz) -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testTaf.taf"/>
            <param name="input_wig" value="taffy_annotate_input.wig"/>
            <param name="tagName" value="scoreTag"/>
            <param name="refPrefix" value="Anc0."/>
            <param name="compression_taf" value="gz"/>
            <output name="out_file" ftype="taf.gz">
                <assert_contents>
                    <has_size size="646" delta="10"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
Taffy annotate adds annotations to a TAF file with values from a Wiggle file by using a user-defined tag name.
This tool only applies annotations based on the coordinates of the reference sequence (first row). 
    ]]></help>
    <expand macro="citation"/>
    <expand macro="creator"/>
</tool>