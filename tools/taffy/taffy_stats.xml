<tool id="taffy_stats" name="Taffy stats" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>prints statistics from a TAF or MAF file</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/> 
    <expand macro="stdio"/>
    <command detect_errors="aggressive">
        <![CDATA[
        ## Set variables
        @SET_UNCOMPRESS_NAMES@
        
        ## Uncompress input files if necessary and create symlinks for uncompressed files
        @UNCOMPRESS_TAF_AND_MAF@

        ## If --sequenceLengths is selected, an index file needs to be available with the 
        ## same name as the input file + an .tai extension. For this, we generate the index 
        ## file automatically based on the input file name.
        ## Input file name is defined in @SET_UNCOMPRESS_NAMES@
        #if $statsType == '--sequenceLengths':
            taffy index
            --logLevel 'INFO'
            --inputFile '$uncompressed_input' && 
        #end if 

        ## Run main command
        taffy stats
            --logLevel 'INFO'
            --inputFile '$uncompressed_input' 
            #if $statsType == '--sequenceLengths':
                --sequenceLengths
            #else if $statsType == '--sequenceIntervals':
                --sequenceIntervals
            #else if $statsType == '--alignmentStats':
                --alignmentStats
            #end if
            > '$out_file'
    ]]></command>
    <inputs>
        <expand macro="input_taf_maf"/>
        <param name="statsType" type="select" label="Available statistics">
            <option value="" selected="true">Select a statistic type ...</option>
            <option value="--sequenceLengths">Print sequence lengths of each reference sequence (--sequenceLengths)</option>
            <option value="--sequenceIntervals">Print BED intervals of each reference sequence (only for TAF files) (--sequenceIntervals)</option>
            <option value="--alignmentStats">Print statistics about block number, aligned bases, etc (--alignmentStats)</option>
            <validator type="empty_field" message="You must select a statistic type"/>
        </param>
    </inputs>
    <outputs>
        <data name="out_file" format="tabular">
             <change_format>
                <when input="statsType" value="--sequenceIntervals" format="bed"/>
            </change_format>
        </data>
    </outputs>
    <tests>
        <!-- Test 1: TAF input for alignmentStats -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testTaf.taf"/>
            <param name="statsType" value="--alignmentStats"/>
            <output name="out_file" ftype="tabular">
                <assert_contents>
                    <has_line line="Total blocks:&#009;6"/>
                    <has_line line="Avg. gaps/column:&#009;0.711864"/>
                    <has_n_lines n="8"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 2: TAF input with sequenceIntervals -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testTaf.taf"/>
            <param name="statsType" value="--sequenceIntervals"/>
            <output name="out_file" ftype="bed">
                <assert_contents>
                    <has_line line="Anc0.Anc0refChr0&#009;0&#009;118"/>
                    <has_n_lines n="1"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 3: TAF input with sequenceLengths -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testTaf.taf"/>
            <param name="statsType" value="--sequenceLengths"/>
            <output name="out_file" ftype="tabular">
                <assert_contents>
                    <has_line line="Anc0.Anc0refChr0&#009;4151"/>
                    <has_n_lines n="1"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 4: MAF input with alignmentStats -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testMaf.maf"/>
            <param name="statsType" value="--alignmentStats"/>
            <output name="out_file" ftype="tabular">
                <assert_contents>
                    <has_line line="Total blocks:&#009;6"/>
                    <has_line line="Avg. gaps/column:&#009;0.711864"/>
                    <has_n_lines n="8"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 5: Compressed MAF input (.gz) with alignmentStats -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testMaf.maf.gz"/>
            <param name="statsType" value="--alignmentStats"/>
            <output name="out_file" ftype="tabular">
                <assert_contents>
                    <has_line line="Total blocks:&#009;6"/>
                    <has_line line="Avg. gaps/column:&#009;0.711864"/>
                    <has_n_lines n="8"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 6: Compressed MAF input (.bz2) with alignmentStats -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testMaf.maf.bz2"/>
            <param name="statsType" value="--alignmentStats"/>
            <output name="out_file" ftype="tabular">
                <assert_contents>
                    <has_line line="Total blocks:&#009;6"/>
                    <has_line line="Avg. gaps/column:&#009;0.711864"/>
                    <has_n_lines n="8"/>
                </assert_contents>
            </output>
        </test>
        <!-- Test 7: MAF input with sequenceIntervals -->
        <test expect_failure="true">
            <param name="input_file" value="testMaf.maf"/>
            <param name="statsType" value="--sequenceIntervals"/>
        </test>
        <!-- Test 8: MAF input with sequenceLengths -->
        <test expect_num_outputs="1">
            <param name="input_file" value="testMaf.maf"/>
            <param name="statsType" value="--sequenceLengths"/>
            <output name="out_file" ftype="tabular">
                <assert_contents>
                    <has_line line="Anc0.Anc0refChr0&#009;4151"/>
                    <has_n_lines n="1"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
Taffy stats prints statistics from a TAF or MAF file. Available statistics:

- **Print sequence lengths of each reference sequence:**
  This option reports the total length of each sequence marked as a reference in the alignment.
  The output is a two-column tabular file: ``<sequence_name> <length>``.

- **Print BED intervals of each reference sequence:**
  This option generates a BED file that lists the genomic intervals covered by each reference sequence in the TAF file.
  This option is not compatible with MAF files.

- **Print stats about block number, aligned bases, etc:**
  This option reports a summary of alignment statistics, including: Total number of alignment blocks, columns, aligned bases, and gaps.
  As well as average number of columns per blocks, column depth, bases per column, and gaps per column.
  The output is a two-column tabular file.
    ]]></help>
    <expand macro="citation"/>
    <expand macro="creator"/>
</tool>