<tool id="foldtree" name="Foldtree" version="@TOOL_VERSION@" profile="24.0">
    <description>Infer a phylogenetic tree from protein structures</description>
    <macros>
        <token name="@TOOL_VERSION@">1.1.0rc2</token>
    </macros>
    
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">foldtree</requirement>
    </requirements>


    <command detect_errors="exit_code"><![CDATA[ 
        mkdir workdir;

        #if $input_type.input_type_selector == 'identifiers_txt':
            #set ids_text = str($input_type.input_table).strip()
            #for $line in $ids_text.splitlines():
                echo '${line.strip()}' >> workdir/identifiers.txt;
            #end for
        #elif $input_type.input_type_selector == 'identifiers_file':
            cp '$input_type.input_table' workdir/identifiers.txt;
        #end if

        #if $input_type.input_type_selector == 'pdb':
            mkdir -p workdir/structs;
            
            touch workdir/identifiers.txt;

            tar -xf '$input_type.input_table' -C workdir/structs 2>/dev/null || tar -xzf '$input_type.input_table' -C workdir/structs;

            foldtree --folder workdir -p -c 1 $filter -esa "--conda-frontend conda" -cs;
        #else
            foldtree --folder workdir -p -c 1 $filter -esa "--conda-frontend conda"
            
        #end if

        
    ]]></command>

    <inputs>

        <conditional name="input_type">
            <param name="input_type_selector" type="select" label="Choose input data type">
                <option value="identifiers_txt" selected="true">UniProt identifiers</option>
                <option value="identifiers_file" selected="true">UniProt identifiers (.txt file)</option>
                <option value="pdb">PDB structures</option>
            </param>

            <when value="identifiers_txt">
                <param name="input_table"
                    type="text"
                    area="true"
                    optional="false"
                    label="UniProtKB accessions (one per line)">

                    <sanitizer>
                        <valid initial="string.ascii_letters,string.digits">
                            <add value=" " />
                            <add value="-" />
                            <add value="&#10;" />  <!-- LF -->
                            <add value="&#13;" />  <!-- CR -->
                        </valid>
                        <mapping initial="none" />
                    </sanitizer>

                    <validator
                        message="Provide UniProtKB accession numbers, one per line (e.g. P12345, Q1AAA9, A0A022YWF9, Q9ULZ0-1)."
                        type="regex">\A\s*(?:[OPQ][0-9][A-Z0-9]{3}[0-9]|[A-NR-Z][0-9](?:[A-Z][A-Z0-9]{2}[0-9]){1,2})(?:-\d+)?\s*(?:\r?\n\s*(?:[OPQ][0-9][A-Z0-9]{3}[0-9]|[A-NR-Z][0-9](?:[A-Z][A-Z0-9]{2}[0-9]){1,2})(?:-\d+)?\s*)*\r?\n?\Z</validator>
                </param>
            </when>

            <when value="identifiers_file">
                <param name="input_table" type="data" optional="false" format="txt" label="A newline-separated file listing UniProtKB accession IDs, one ID per line."/>
            </when>

            <when value="pdb">
                <param name="input_table" type="data" optional="false" format="gz" label=".gz-compressed structures (each in PDB format)"/>
            </when>
        </conditional>

        <param name="filter"
            type="boolean"
            checked="false" 
            label="Filter out low quality structures (average pLDDT &lt;50)"
            truevalue="--filter" falsevalue="--no-filter" />

    </inputs>

        
    <outputs>
        <data name="output_tree_ft" format="newick" from_work_dir="workdir/foldtree_struct_tree.PP.nwk.rooted.final" label="Foldtree metric tree"/>
        <data name="output_tree_aln" format="newick" from_work_dir="workdir/alntmscore_struct_tree.PP.nwk.rooted.final" label="TM tree"/>
        <data name="output_tree_lddt" format="newick" from_work_dir="workdir/lddt_struct_tree.PP.nwk.rooted.final" label="LDDT tree"/>
    </outputs>

    <tests>
        <test>
            <param name="input_type_selector" value="identifiers_file"/>
            <param name="input_table" value="identifiers.txt"/>
            
            <output name="output_tree_ft" ftype="newick">
                <assert_contents>
                    <has_text_matching expression="A0A060X1A3"/>
                    <has_text_matching expression="A0A087X979"/>
                    <has_text_matching expression="A0A091CQV1"/>
                    <has_text_matching expression="A0A091F6W6"/>
                </assert_contents>
            </output>

            <output name="output_tree_aln" ftype="newick">
                <assert_contents>
                    <has_text_matching expression="A0A060X1A3"/>
                    <has_text_matching expression="A0A087X979"/>
                    <has_text_matching expression="A0A091CQV1"/>
                    <has_text_matching expression="A0A091F6W6"/>
                </assert_contents>
            </output>

            <output name="output_tree_lddt" ftype="newick">
                <assert_contents>
                    <has_text_matching expression="A0A060X1A3"/>
                    <has_text_matching expression="A0A087X979"/>
                    <has_text_matching expression="A0A091CQV1"/>
                    <has_text_matching expression="A0A091F6W6"/>
                </assert_contents>
            </output>

        </test>

        <test>
            <param name="input_type_selector" value="pdb"/>
            <param name="input_table" value="archael_EF2_rpoB_seed_structures.tar.gz"/>
            
            <output name="output_tree_ft" ftype="newick">
                <assert_contents>
                    <has_text_matching expression="A0A523VPS0"/>
                    <has_text_matching expression="A0A524LBV7"/>
                    <has_text_matching expression="EF2_lokiarchaea"/>
                </assert_contents>
            </output>

            <output name="output_tree_aln" ftype="newick">
                <assert_contents>
                    <has_text_matching expression="A0A523VPS0"/>
                    <has_text_matching expression="A0A524LBV7"/>
                    <has_text_matching expression="EF2_lokiarchaea"/>
                </assert_contents>
            </output>

            <output name="output_tree_lddt" ftype="newick">
                <assert_contents>
                    <has_text_matching expression="A0A523VPS0"/>
                    <has_text_matching expression="A0A524LBV7"/>
                    <has_text_matching expression="EF2_lokiarchaea"/>
                </assert_contents>
            </output>

        </test>


        <test>
            <param name="input_type_selector" value="identifiers_file"/>
            <param name="input_table" value="identifiers-filter.txt"/>
            <param name="filter" value="false"/> 
            <output name="output_tree_ft" ftype="newick">
                <assert_contents>
                    <has_text_matching expression="Q9ULZ0-3"/>
                    <has_text_matching expression="H3BT92"/>
                    <has_text_matching expression="A0A2I2ZF88"/>
                    <has_text_matching expression="A0A2K5IRZ7"/>
                </assert_contents>
            </output>
        </test>

        <test>
            <param name="input_type_selector" value="identifiers_file"/>
            <param name="input_table" value="identifiers-filter.txt"/>
            <param name="filter" value="true"/> 
            <output name="output_tree_ft" ftype="newick">
                <assert_contents>
                    <has_text_matching expression="Q9ULZ0-3"/>
                    <not_has_text text="H3BT92"/>
                    <has_text_matching expression="A0A2I2ZF88"/>
                    <has_text_matching expression="A0A2K5IRZ7"/>
                </assert_contents>
            </output>
        </test>
    </tests>


    <help><![CDATA[
        **What it does**

        Foldtree creates phylogenetic trees from protein structures by using Foldseek to align protein structures and generate distance matrices for tree construction.

        **How to use**

        Provide a list of structures either as UniProtKB identifiers, or in .gz archive (PDB format). 
    ]]></help>

    <citations>
        <citation type="doi">10.1038/s41594-025-01649-8</citation>
    </citations>


</tool>