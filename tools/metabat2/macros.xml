<macros>
    <!-- When updating the TOOL_VERSION: take care to also update the REQUIREMENT_VERSION
    
         metabat creates tagged releases seldomly, but creates a docker for every tested push to their main branch
         those are also considered in bioconda. The docker images are named 2.18-23-gc869c52 where the last tagged
         version is 2.18. We use the first number of the docker specific part in the tool version separated by a '.'
         to conform with PEP404 and maintain an extra token for the requirement version (which uses underscores). -->
    <token name="@TOOL_VERSION@">2.18.23</token>
    <token name="@REQUIREMENT_VERSION@">2.18_23_gc869c52</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">21.01</token>
    <xml name="biotools">
        <xrefs>
            <xref type="bio.tools">MetaBAT_2</xref>
        </xrefs>
    </xml>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@REQUIREMENT_VERSION@">metabat2</requirement>
        </requirements>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.7717/peerj.7359</citation>
        </citations>
    </xml>
</macros>
