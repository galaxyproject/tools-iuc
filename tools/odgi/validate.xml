<tool id="odgi_validate" name="odgi validate" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>validate odgi graph structure</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
odgi validate
--input '$input'
@THREADS@
> '$output'
    ]]></command>
    <inputs>
        <expand macro="graph_input_param_input"/>
    </inputs>
    <outputs>
        <expand macro="standard_text_output"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input" value="note5_out.og" ftype="odgi"/>
            <output name="output" ftype="txt">
                <assert_contents>
                    <has_size min="0"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help format="markdown"><![CDATA[
@HELP_HEADER@

`odgi validate` checks that embedded paths are consistent with the graph topology.

### Inputs

- **Input odgi graph**: Graph to validate.

### Outputs

- **Text**: Validation messages (empty when the graph is valid).
    ]]></help>
    <expand macro="citations"/>
</tool>
