<macros>
    <token name="@TOOL_VERSION@">2.0.0</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <xml name="m_raxmlng_msa">   
        <param name="infile" argument="--msa" type="data" format="fasta,phylip" label="Input file with aligned sequences (FASTA/PHYLIP)"
               help="At least four aligned sequences are needed for RAxML-NG.">
            <validator type="dataset_metadata_in_range" metadata_name="sequences" min="4" 
                       message="Input file contains too few sequences: %s"/>
        </param>
    </xml>
    <xml name="m_raxmlng_tree">   
        <param name="tree_file" type="data" format="nhx,newick" label="Input tree file (NEWICK)" />
    </xml>
    <xml name="m_raxmlng_tree_optional">   
        <param name="tree_file" type="data" format="nhx,newick" optional="true" label="Starting tree file (NEWICK)" />
    </xml>   
    <xml name="m_raxmlng_seqtype">   
         <param name="seq_type" type="select" display="radio" label="Sequence type">
             <option value="DNA" selected="true">Nucleotide</option>
             <option value="AA">Amino Acid</option>
             <option value="BIN">Binary</option>
       <!--  <option value="multistate">Multistate</option>  -->
         </param>
    </xml>
    <xml name="m_raxmlng_model">   
        <conditional name="model">
            <param name="model_type" type="select" display="radio" label="Model type">
                <option value="single_auto" selected="true">Single model (AUTO)</option>
                <option value="single_gui">Single model (GUI)</option>
                <option value="single_string">Single model (string)</option>
                <option value="multi_file">Partitioned model file</option>
            </param>
            <when value="single_auto">
                <param name="auto_seq_type" type="select" display="radio" label="Sequence type">
                   <option value="DNA" selected="true">Nucleotide</option>
                   <option value="AA">Amino Acid</option>
                   <option value="BIN">Binary</option>
       <!--                 <option value="multistate">Multistate</option>  -->
                </param>
            </when>
            <when value="single_gui">
                <conditional name="single_model">
                    <param name="seq_type" type="select" display="radio" label="Sequence type">
                        <option value="nucleotide" selected="true">Nucleotide</option>
                        <option value="aminoacid">Amino Acid</option>
                        <option value="binary">Binary</option>
                        <option value="multistate">Multistate</option>
                    </param>
                    <when value="nucleotide">
                        <param name="subst_matrix" type="select" label="Matrix">
                            <option value="F81">F81</option>
                            <option value="GTR" selected="true">GTR</option>
                            <option value="HKY">HKY</option>
                            <option value="JC">JC</option>
                            <option value="K80">K80</option>
                            <option value="SYM">SYM</option>
                            <option value="TIM1">TIM1</option>
                            <option value="TIM2">TIM2</option>
                            <option value="TIM3">TIM3</option>
                            <option value="TN93">TN93</option>
                            <option value="TPM1">TPM1</option>
                            <option value="TPM2">TPM2</option>
                            <option value="TPM3">TPM3</option>
                            <option value="TVM">TVM</option>
                        </param>            
                    </when>
                    <when value="aminoacid">
                        <param name="subst_matrix" type="select" label="Matrix">
                            <option value="BLOSUM62">BLOSUM62</option>
                            <option value="CPREV">cpREV</option>
                            <option value="DAYHOFF">DAYHOFF</option>
                            <option value="DCMUT">DCMut</option>
                            <option value="DEN">DEN</option>
                            <option value="FLAVI">FLAVI</option>
                            <option value="FLU">FLU</option>
                            <option value="PROTGTR">GTR</option>
                            <option value="HIVB">HIVb</option>
                            <option value="HIVW">HIVw</option>
                            <option value="JTT">JTT</option>
                            <option value="JTT-DCMUT">JTT-DCMut</option>
                            <option value="LG" selected="true">LG</option>
                            <option value="LG4M">LG4M</option>
                            <option value="LG4X">LG4X</option>
                            <option value="MTART">mtART</option>
                            <option value="MTMAM">mtMAM</option>
                            <option value="MTREV">mtREV</option>
                            <option value="MTZOA">mtZOA</option>
                            <option value="PMB">PMB</option>
                            <option value="Q.PFAM">Q.pfam</option>
                            <option value="Q.BIRD">Q.bird</option>
                            <option value="Q.INSECT">Q.insect</option>
                            <option value="Q.MAMMAL">Q.mammal</option>
                            <option value="Q.PLANT">Q.plant</option>
                            <option value="Q.YEAST">Q.yeast</option>
                            <option value="RTREV">rtREV</option>
                            <option value="STMTREV">stmtREV</option>
                            <option value="VT">VT</option>
                            <option value="WAG">WAG</option>
                        </param>
                    </when>
                    <when value="binary">
                        <param name="subst_matrix" type="select" label="Matrix">
                            <option value="BIN">BIN</option>
                        </param>
                    </when>
                    <when value="multistate">
                        <param name="multi_state_count" type="integer" value="2" label="Number of states" />
                        <param name="subst_matrix" type="select" label="Matrix">
                            <option value="MK">MULTIx_MK</option>
                            <option value="GTR">MULTIx_GTR</option>
                        </param>
                    </when>
                </conditional>
               <param name="base_freqs" type="select" label="Stationary base frequencies">
                    <option value="" selected="true">Default</option>
                    <option value="+FO">ML estimate</option>
                    <option value="+F">empirical</option>
                    <option value="+FE">equal</option>
                </param>
                <param name="rhas_model" type="select" label="Rate heterogeneity across sites (RHAS) model">
                    <option value="">None / default</option>
                    <option value="+G" selected="true">GAMMA</option>
                    <option value="+I">Inv</option>
                    <option value="+I+G">Inv+GAMMA</option>
                    <option value="+R">FreeRate</option>
                    <option value="+I+R">Inv+FreeRate</option>
                </param>
                <param name="rhas_cat_count" type="integer" value="" optional="true" label="Number of RHAS categories" help="Typical range: 2..10 (default: 4)"/>
                <param name="paml_file" type="data" format="txt" optional="true" label="User-defined substitution matrix in a PAML file" help="Example: http://www.atgc-montpellier.fr/download/datasets/models/lg_LG.PAML.txt" />
                <param name="charmap_file" type="data" format="txt" optional="true" label="User-defined character-to-state mapping in a text file" help="Help: https://codeberg.org/amkozlov/raxml-ng/wiki/Input-data#user-defined-state-encoding" />
            </when>
            <when value="single_string">
               <param name="model_string" type="text" value="" optional="false" label="Model definition string" help="Help: https://codeberg.org/amkozlov/raxml-ng/wiki/Input-data#single-model" >
               <sanitizer invalid_char="">  
                 <valid initial="string.ascii_letters,string.digits">
                       <add value="+"/>
                       <add value="/"/>
                       <add value="{"/>
                       <add value="}"/>
                       <add value="."/>
                       <add value="-"/>
                       <add value="_"/>
                  </valid>
               </sanitizer>
               </param>
            </when>
            <when value="multi_file">
               <param name="model_file" type="data" format="txt" label="Partitioned model file" help="Help: https://codeberg.org/amkozlov/raxml-ng/wiki/Input-data#multiple-models" />
               <param name="brlen_linkage" type="select" display="radio" label="Branch length linkage among partitions">
                    <option value="linked">Linked identical</option>
                    <option value="scaled" selected="true">Linked proportional</option>
                    <option value="unlinked">Unlinked</option>
               </param>
               <param name="model_file_auto" type="boolean" truevalue="auto=" falsevalue="" label="Use MOOSE to select best-fit model for every partition"/>
            </when>
        </conditional>
    </xml>
    <xml name="m_raxmlng_model_moose">   
        <conditional name="model">
            <param name="model_type" type="select" display="radio" label="Model type">
                <option value="single_auto" selected="true">Single model (AUTO)</option>
                <option value="multi_moose">Partitioned model (AUTO)</option>
            </param>
            <when value="single_auto">
                <param name="auto_seq_type" type="select" display="radio" label="Sequence type">
                   <option value="DNA" selected="true">Nucleotide</option>
                   <option value="AA">Amino Acid</option>
                   <option value="BIN">Binary</option>
       <!--                 <option value="multistate">Multistate</option>  -->
                </param>    
            </when>         
            <when value="multi_moose">
               <param name="model_file" type="data" format="txt" label="Partitioned model file" help="Help: https://codeberg.org/amkozlov/raxml-ng/wiki/Input-data#multiple-models" />
            </when>
        </conditional>
    </xml>
    <xml name="m_raxmlng_bsmetric">   
        <param name="bs_metric" type="select" multiple="true" label="Branch support metric">
            <option value="fbp">Felsenstein bootstrap</option>
            <option value="rbs" selected="true">Rapid bootstrap</option>
            <option value="ebg">Educated Bootstrap Guesser (EBG)</option>
            <option value="sh">SH-like aLRT</option>
            <option value="ps">Parsimony support</option>
            <option value="pbs">Parsimony bootstrap support</option>
            <option value="ic1">Internode certainty (most prevalent)</option>
            <option value="ica">Internode certainty (all)</option>
            <option value="gcf">Gene concordance factor</option>
            <option value="tbe">Transfer bootstrap (TBE)</option>
        </param>
	</xml>
    <xml name="m_raxmlng_bsmetric_support" optional="false">
        <param name="bs_metric" type="select" multiple="true" label="Branch support metric">
            <option value="fbp" selected="true">Felsenstein bootstrap</option>
            <option value="ic1">Internode certainty (most prevalent)</option>
            <option value="ica">Internode certainty (all)</option>
            <option value="gcf">Gene concordance factor</option>
            <option value="tbe">Transfer bootstrap (TBE)</option>
        </param>
    </xml>
    <xml name="m_raxmlng_bsmetric_bootstrap" optional="false">
        <param name="bs_metric" type="select" multiple="false" label="Bootstrap replicate type">
            <option value="fbp">Felsenstein bootstrap</option>
            <option value="rbs" selected="true">Rapid bootstrap</option>
            <option value="ps">Parsimony support</option>
            <option value="pbs">Parsimony bootstrap support</option>
        </param>
    </xml>
    <xml name="m_raxmlng_bstrees">
        <param argument="--bs-trees" type="data" format="nhx,newick" label="Existing set of bootstrap trees (NEWICK)"/>
    </xml>
    <xml name="m_raxmlng_nofiles_filter" token_interim_filetype="">
      <filter>not output_opts['nofiles'] and (not "@INTERIM_FILETYPE@" or output_opts['keep_interim_files'] and "@INTERIM_FILETYPE@" in output_opts['keep_interim_files'])</filter>
    </xml>
</macros>
