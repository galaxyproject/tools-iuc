<tool id="picrust2_combine_domains" name="PICRUSt2 combine domains" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@" license="MIT">
    <description></description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="bio_tool"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        combine_domains.py 
            --table_dom1 '$table_dom1'
            --table_dom2 '$table_dom2'
            --output output.tsv
    ]]></command>
    <inputs>
        <param argument="--table_dom1" type="data" format="tabular" label="Predictions for domain1"/>
        <param argument="--table_dom2" type="data" format="tabular" label="Predictions for domain2"/>
    </inputs>
    <outputs>
        <data name="output" format="tabular" from_work_dir="output.tsv"/>
    </outputs>
    <tests>
        <!-- could not find a real world test case
             test input generated during a run of the full workflow: picrust2_pipeline.py -s study_seqs_test.fasta -i workflow_seq_abun.biom -o picrust2_out_pipeline_split -p 1
             and the output file split in half -->
        <test>
            <param name="table_dom1" value="test/picrust2_out_pipeline_split/bac_EC_predicted.tsv"/>
            <param name="table_dom2" value="test/picrust2_out_pipeline_split/bac_EC_predicted_part2.tsv"/>
            <output name="output" value="combine_domains.tsv"/>
        </test>
    </tests>
    <help><![CDATA[

@HELP_HEADER@

combine domains
================

This script takes in two output tables containing predicted counts from two different domains and combines them into one file that can be used for metagenome prediction.

    ]]></help>
    <expand macro="citations"/>
</tool>