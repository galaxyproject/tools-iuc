                <param name="skip_norm" value="false"/>
            </section>
            <conditional name="predict_pathways">
                <param name="skip_minpath" value="false"/>
                <param name="no_gap_fill" value="true"/>
            </conditional>
            <param name="remove_intermediate" value="place_seqs"/>
