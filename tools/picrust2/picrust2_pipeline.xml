                    <element name="sepp_out/output_alignment_masked" ftype="fasta"><assert_contents><has_size min="1"/></assert_contents></element>
                    <element name="sepp_out/output_placement" ftype="json"><assert_contents><has_size min="1"/></assert_contents></element>
