<macros>
    <import>read_group_macros.xml</import>
    <token name="@TOOL_VERSION@">0.3</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.0</token>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">minibwa</requirement>
            <requirement type="package" version="1.22">samtools</requirement>
        </requirements>
    </xml>
    <xml name="xrefs">
        <xrefs>
            <xref type="bio.tools">minibwa</xref>
        </xrefs>
    </xml>
    <token name="@pipefail@"><![CDATA[set -o | grep -q pipefail && set -o pipefail;]]></token>
    <!-- Symlink the chosen reference FASTA into the working directory and build a
         minibwa index next to it. minibwa (unlike minimap2) requires a pre-built
         index; `minibwa index in.fa prefix` writes prefix.l2b and prefix.mbw, which
         `minibwa map prefix ...` then loads. Both the cached and history reference
         sources are indexed the same way, so cached genomes just reuse the shared
         all_fasta data table (no minibwa-specific index table is needed). -->
    <token name="@set_reference@"><![CDATA[
    #if str($reference_source.reference_source_selector) == "history":
        ln -s '${reference_source.ref_file}' localref.fa &&
    #else:
        ln -s '${reference_source.ref_file.fields.path}' localref.fa &&
    #end if
    minibwa index -t \${GALAXY_SLOTS:-1} localref.fa localref &&
    #set $ref_index = "localref"
    ]]></token>
    <token name="@set_rg_string@">
        #set $rg_string = "@RG\\tID:" + str($rg_id)
        #set $rg_string += $format_read_group("\\tSM:", $rg_sm)
        #set $rg_string += $format_read_group("\\tPL:", $rg_pl)
        #set $rg_string += $format_read_group("\\tLB:", $rg_lb)
        #set $rg_string += $format_read_group("\\tCN:", $rg_cn)
        #set $rg_string += $format_read_group("\\tDS:", $rg_ds)
        #set $rg_string += $format_read_group("\\tDT:", $rg_dt)
        #set $rg_string += $format_read_group("\\tFO:", $rg_fo)
        #set $rg_string += $format_read_group("\\tKS:", $rg_ks)
        #set $rg_string += $format_read_group("\\tPG:", $rg_pg)
        #set $rg_string += $format_read_group("\\tPI:", $rg_pi)
        #set $rg_string += $format_read_group("\\tPU:", $rg_pu)
    </token>
    <macro name="reference_source_conditional">
        <conditional name="reference_source">
            <param name="reference_source_selector" type="select" label="Will you select a reference genome from your history or use a built-in index?" help="Built-in references are indexed transparently with the minibwa index utility before mapping">
                <option value="cached">Use a built-in genome index</option>
                <option value="history">Use a genome from history and build index</option>
            </param>
            <when value="cached">
                <param name="ref_file" type="select" label="Using reference genome" help="Select genome from the list">
                    <options from_data_table="all_fasta">
                        <filter type="sort_by" column="2"/>
                        <validator type="no_options" message="No reference genomes are available"/>
                    </options>
                    <validator type="no_options" message="A built-in reference genome is not available for the build associated with the selected input file"/>
                </param>
            </when>
            <when value="history">
                <param name="ref_file" type="data" format="fasta,fasta.gz" label="Use the following dataset as the reference sequence" help="You can upload a FASTA sequence (optionally gzip-compressed) to the history and use it as reference"/>
            </when>
        </conditional>
    </macro>
    <macro name="dbKeyActions">
        <actions>
            <conditional name="reference_source.reference_source_selector">
                <when value="cached">
                    <action type="metadata" name="dbkey">
                        <option type="from_data_table" name="all_fasta" column="1" offset="0">
                            <filter type="param_value" column="0" value="#" compare="startswith" keep="False"/>
                            <filter type="param_value" ref="reference_source.ref_file" column="0"/>
                        </option>
                    </action>
                </when>
                <when value="history">
                    <action type="metadata" name="dbkey">
                        <option type="from_param" name="reference_source.ref_file" param_attribute="dbkey"/>
                    </action>
                </when>
            </conditional>
        </actions>
    </macro>
    <xml name="creator">
        <creator>
            <person givenName="Saim" familyName="Momin" url="https://github.com/SaimMomin12"/>
            <organization name="Galaxy Europe" url="https://galaxyproject.org/eu/"/>
        </creator>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.48550/arXiv.2606.15357</citation>
        </citations>
    </xml>
</macros>
