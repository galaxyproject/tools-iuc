<tool id="trackastra_ctc_to_napari" name="Trackastra CTC export" version="0.1.0+galaxy1" profile="25.0" license="BSD-3-Clause">
    <description>prepare tracked masks and lineage data for Napari and external CTC tools</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <xrefs>
        <xref type="bio.tools">trackastra-galaxy</xref>
    </xrefs>
    <expand macro="requirements"/>
    <required_files>
        <include path="ctc_to_napari.py"/>
    </required_files>
    <command detect_errors="exit_code"><![CDATA[
mkdir -p 'ctc_masks' &&
#for $i, $mask in enumerate($tracked_masks):
    #set $frame = '%04d' % $i
    ln -s '$mask' 'ctc_masks/man_track${frame}.tif' &&
#end for
python '$__tool_directory__/ctc_to_napari.py' --track-table '$track_table' --masks-dir 'ctc_masks' --tracks-out 'napari_tracks.csv' --graph-out 'napari_graph.json' --archive-out 'trackastra_visualization_bundle.zip'
    ]]></command>
    <inputs>
        <param name="track_table" type="data" format="tabular" label="CTC track table" help="The Trackastra man_track.txt output containing track ID, start frame, end frame, and parent track ID."/>
        <param name="tracked_masks" type="data_collection" collection_type="list" format="tiff" label="Tracked CTC masks" help="Ordered Trackastra mask collection. Collection order defines time and must begin at frame 0."/>
    </inputs>
    <outputs>
        <data name="napari_tracks" format="csv" from_work_dir="napari_tracks.csv" label="${tool.name} on ${on_string}: Napari tracks"/>
        <data name="napari_graph" format="json" from_work_dir="napari_graph.json" label="${tool.name} on ${on_string}: Napari lineage graph"/>
        <data name="ctc_bundle" format="zip" from_work_dir="trackastra_visualization_bundle.zip" label="${tool.name} on ${on_string}: visualization bundle"/>
    </outputs>
    <tests>
        <test expect_num_outputs="3">
            <param name="track_table" value="division_man_track.txt" ftype="tabular"/>
            <param name="tracked_masks">
                <collection type="list">
                    <element name="0000" value="expected_division_0000.tif" ftype="tiff"/>
                    <element name="0001" value="expected_division_0001.tif" ftype="tiff"/>
                    <element name="0002" value="expected_division_0002.tif" ftype="tiff"/>
                </collection>
            </param>
            <output name="napari_tracks">
                <assert_contents>
                    <has_n_lines n="4"/>
                    <has_line line="track_id,t,y,x"/>
                    <has_line line="1,0,32.0,32.0"/>
                    <has_line line="2,1,32.0,26.0"/>
                    <has_line line="3,1,32.0,38.0"/>
                </assert_contents>
            </output>
            <output name="napari_graph">
                <assert_contents>
                    <has_text text="&quot;2&quot;: ["/>
                    <has_text text="&quot;3&quot;: ["/>
                    <has_text text="1" n="2"/>
                </assert_contents>
            </output>
            <output name="ctc_bundle">
                <assert_contents>
                    <has_archive_member path="tracked_ctc/man_track.txt"/>
                    <has_archive_member path="tracked_ctc/man_track0000.tif"/>
                    <has_archive_member path="tracked_ctc/man_track0001.tif"/>
                    <has_archive_member path="tracked_ctc/man_track0002.tif"/>
                    <has_archive_member path="napari_tracks.csv"/>
                    <has_archive_member path="napari_graph.json"/>
                    <has_archive_member path="README.txt"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="3">
            <param name="track_table" value="napari_3d_man_track.txt" ftype="tabular"/>
            <param name="tracked_masks">
                <collection type="list">
                    <element name="0000" value="napari_3d_0000.tif" ftype="tiff"/>
                    <element name="0001" value="napari_3d_0001.tif" ftype="tiff"/>
                </collection>
            </param>
            <output name="napari_tracks">
                <assert_contents>
                    <has_n_lines n="3"/>
                    <has_line line="track_id,t,z,y,x"/>
                    <has_line line="1,0,1.0,3.0,4.0"/>
                    <has_line line="1,1,1.0,3.0,5.0"/>
                </assert_contents>
            </output>
            <output name="napari_graph">
                <assert_contents>
                    <has_n_lines n="1"/>
                    <has_line line="{}"/>
                </assert_contents>
            </output>
            <output name="ctc_bundle">
                <assert_contents>
                    <has_archive_member path="tracked_ctc/man_track.txt"/>
                    <has_archive_member path="tracked_ctc/man_track0000.tif"/>
                    <has_archive_member path="tracked_ctc/man_track0001.tif"/>
                    <has_archive_member path="napari_tracks.csv"/>
                    <has_archive_member path="napari_graph.json"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**Trackastra CTC export** converts the standard Trackastra outputs into files that are convenient for visualization and exchange.

Inputs
======

- A CTC ``man_track.txt`` table from Trackastra.
- The ordered tracked-mask TIFF collection from the same Trackastra job.

Outputs
=======

- **Napari tracks CSV**: one row per tracked object observation, with columns ``track_id,t,y,x`` for 2D data or ``track_id,t,z,y,x`` for 3D data. Rows are sorted by track ID and time as required by Napari's Tracks layer.
- **Napari lineage graph JSON**: maps each child track ID to its parent track ID list.
- **Visualization bundle**: a ZIP archive containing a complete ``tracked_ctc`` directory, the Napari CSV and JSON files, and loading notes. After downloading and extracting the archive, the CTC directory can be opened with the ``napari-trackastra`` plugin.

The tool validates that every label present in each mask agrees with the active tracks in the CTC table. It fails rather than exporting inconsistent tracking data.
    ]]></help>
    <expand macro="citations"/>
</tool>
