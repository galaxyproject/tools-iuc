<?xml version="1.0"?>
<tool id="delly_lr" name="Delly long-read (lr)" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>optimized calling and genotyping of structural variants</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="bio_tools"/>
    <expand macro="requirements"/>
    <expand macro="version_command"/>
    <command detect_errors="aggressive"><![CDATA[
## initialize
@BAM@
@FASTA@
#if len($discovery.alt_alignments) > 0
    : > 'alt_alignments.tsv' &&
    #for $i, $alt in enumerate($discovery.alt_alignments)
        #if $alt.alignment.is_of_type('bam')
            #set $alignment_name = 'alt_alignment_%s.bam' % $i
            ln -s '$alt.alignment' '$alignment_name' &&
            ln -s '$alt.alignment.metadata.bam_index' '${alignment_name}.bai' &&
        #elif $alt.alignment.is_of_type('cram')
            #set $alignment_name = 'alt_alignment_%s.cram' % $i
            ln -s '$alt.alignment' '$alignment_name' &&
            ln -s '$alt.alignment.metadata.cram_index' '${alignment_name}.crai' &&
        #else
            #set $alignment_name = 'alt_alignment_%s.dat' % $i
            ln -s '$alt.alignment' '$alignment_name' &&
        #end if
        #if $alt.reference.is_of_type('fasta')
            #set $reference_name = 'alt_reference_%s.fa' % $i
        #elif $alt.reference.is_of_type('gfa1') or $alt.reference.is_of_type('gfa2')
            #set $reference_name = 'alt_reference_%s.gfa' % $i
        #else
            #set $reference_name = 'alt_reference_%s.dat' % $i
        #end if
        ln -s '$alt.reference' '$reference_name' &&
        printf '%s\t%s\n' '$alignment_name' '$reference_name' >> 'alt_alignments.tsv' &&
    #end for
#end if
## run
delly lr
## generic options
--svtype $generic.svtype
--technology $generic.technology
--genome genome.fa
#if $generic.exclude
    --exclude '$generic.exclude'
#end if
--outfile 'result.bcf'
## discovery options
#if len($discovery.alt_alignments) > 0
    --alt-align 'alt_alignments.tsv'
#end if
--map-qual $discovery.map_qual
--minclip $discovery.minclip
--min-clique-size $discovery.min_clique_size
--minrefsep $discovery.minrefsep
--maxreadsep $discovery.maxreadsep
## consensus options
--max-reads $consensus.max_reads
--cons-window $consensus.cons_window
--flank-size $consensus.flank_size
--flank-quality $consensus.flank_quality
--indel-size $consensus.indel_size
## genotyping options
#if $genotyping.vcffile
    --vcffile '$genotyping.vcffile'
#end if
--geno-qual $genotyping.geno_qual
--max-geno-count $genotyping.max_geno_count
#if 'dump' in $oo.out
    --dump 'dump.tsv.gz'
#end if
## input
#for $i, $current in enumerate($input)
    'input_${i}.bam'
#end for

## postprocessing
@LOG@
@DUMP@
@VCF@
    ]]></command>
    <inputs>
        <expand macro="input" format="bam" multiple="true" label="Select input file(s)"/>
        <section name="generic" title="Generic options" expanded="true">
            <expand macro="svtype"/>
            <param argument="--technology" type="select" label="Select sequencing technology">
                <option value="ont" selected="true">Oxford Nanopore (ont)</option>
                <option value="pb">PacBio (pb)</option>
            </param>
            <expand macro="genome"/>
            <expand macro="exclude"/>
        </section>
        <section name="discovery" title="Discovery options" expanded="true">
            <repeat name="alt_alignments" title="Alternate alignment">
                <param name="alignment" type="data" format="bam,cram,data" label="Select alternate alignment file" help="BAM, CRAM, or graph-alignment input for alternate breakpoint discovery."/>
                <param name="reference" type="data" format="fasta,gfa1,gfa2,data" label="Select alternate reference file" help="FASTA or GFA reference matching the alternate alignment input."/>
            </repeat>
            <param argument="--map-qual" type="integer" value="1" label="Set minimum mapping quality"/>
            <expand macro="minclip"/>
            <expand macro="mincliquesize" default="3"/>
            <expand macro="minrefsep" default="30"/>
            <expand macro="maxreadsep" default="100"/>
        </section>
        <section name="consensus" title="Consensus options" expanded="true">
            <expand macro="maxreads" default="15" label="Set maximum reads for consensus computation"/>
            <param argument="--cons-window" type="integer" value="1000" label="Set consensus window"/>
            <param argument="--flank-size" type="integer" value="100" label="Set minimum flank size"/>
            <param argument="--flank-quality" type="float" min="0.0" max="1.0" value="0.9" label="Set minimum flank quality"/>
            <param argument="--indel-size" type="integer" value="10000" label="Use exact alleles for insertions and deletions below this size"/>
        </section>
        <section name="genotyping" title="Genotyping options" expanded="true">
            <expand macro="vcffile"/>
            <expand macro="genoqual"/>
            <expand macro="maxgenocount" default="250"/>
        </section>
        <section name="oo" title="Output options" expanded="true">
            <param name="out" type="select" multiple="true" optional="false" label="Select output file(s)">
                <option value="bcf" selected="true">BCF</option>
                <option value="log">Log</option>
                <option value="dump">SV-reads</option>
                <option value="vcf">VCF</option>
            </param>
        </section>
    </inputs>
    <outputs>
        <expand macro="bcf"/>
        <expand macro="dump"/>
        <expand macro="log"/>
        <expand macro="vcf"/>
    </outputs>
    <tests>
        <!-- #1 default, single -->
        <test expect_num_outputs="2">
            <param name="input" value="normal.bam"/>
            <section name="generic">
                <param name="genome" value="genome.fasta"/>
            </section>
            <section name="oo">
                <param name="out" value="vcf,bcf"/>
            </section>
            <output name="out_bcf">
                <assert_contents>
                    <has_size value="1152" delta="10"/>
                </assert_contents>
            </output>
            <output name="out_vcf">
                <assert_contents>
                    <has_n_lines n="47"/>
                    <has_line line="#CHROM&#009;POS&#009;ID&#009;REF&#009;ALT&#009;QUAL&#009;FILTER&#009;INFO&#009;FORMAT&#009;normal"/>
                </assert_contents>
            </output>
        </test>
        <!-- #2 default, multi; test data to small, results are empty -->
        <test expect_num_outputs="3">
            <param name="input" value="normal.bam,tumor.bam"/>
            <section name="generic">
                <param name="genome" value="genome.fasta"/>
            </section>
            <section name="oo">
                <param name="out" value="vcf,bcf,log"/>
            </section>
            <output name="out_bcf">
                <assert_contents>
                    <has_size value="1157" delta="10"/>
                </assert_contents>
            </output>
            <output name="out_log">
                <assert_contents>
                    <has_text_matching expression=".+Done.+"/>
                </assert_contents>
            </output>
            <output name="out_vcf">
                <assert_contents>
                    <has_n_lines n="47"/>
                    <has_line line="#CHROM&#009;POS&#009;ID&#009;REF&#009;ALT&#009;QUAL&#009;FILTER&#009;INFO&#009;FORMAT&#009;normal&#009;tumor"/>
                </assert_contents>
            </output>
        </test>
       <!-- #3 -->
        <test expect_num_outputs="4">
            <param name="input" value="normal.bam"/>
            <section name="generic">
                <param name="genome" value="genome.fasta"/>
                <param name="exclude" value="exclude.tsv"/>
            </section>
            <section name="oo">
                <param name="out" value="vcf,bcf,dump,log"/>
            </section>
            <output name="out_bcf">
                <assert_contents>
                    <has_size value="1152" delta="10"/>
                </assert_contents>
            </output>
            <output name="out_dump">
                <assert_contents>
                    <has_n_lines n="0"/>
                </assert_contents>
            </output>
            <output name="out_log">
                <assert_contents>
                    <has_text_matching expression=".+Done.+"/>
                </assert_contents>
            </output>
            <output name="out_vcf">
                <assert_contents>
                    <has_n_lines n="47"/>
                    <has_line line="#CHROM&#009;POS&#009;ID&#009;REF&#009;ALT&#009;QUAL&#009;FILTER&#009;INFO&#009;FORMAT&#009;normal"/>
                </assert_contents>
            </output>
        </test>
        <!-- #4 -->
        <test expect_num_outputs="3">
            <param name="input" value="normal.bam"/>
            <section name="generic">
                <param name="genome" value="genome.fasta"/>
                <param name="svtype" value="DEL"/>
                <param name="technology" value="pb"/>
            </section>
            <section name="discovery">
                <param name="map_qual" value="2"/>
                <param name="minclip" value="24"/>
                <param name="min_clique_size" value="1"/>
                <param name="minrefsep" value="24"/>
                <param name="maxreadsep" value="39"/>
            </section>
            <section name="consensus">
                <param name="max_reads" value="6"/>
                <param name="flank_size" value="399"/>
                <param name="flank_quality" value="0.91"/>
            </section>
            <section name="genotyping">
                <param name="geno_qual" value="4"/>
            </section>
            <section name="oo">
                <param name="out" value="vcf,bcf,log"/>
            </section>
            <output name="out_bcf">
                <assert_contents>
                    <has_size value="1152" delta="10"/>
                </assert_contents>
            </output>
            <output name="out_log">
                <assert_contents>
                    <has_text_matching expression=".+"/>
                </assert_contents>
            </output>
            <output name="out_vcf">
                <assert_contents>
                    <has_n_lines n="47"/>
                    <has_line line="#CHROM&#009;POS&#009;ID&#009;REF&#009;ALT&#009;QUAL&#009;FILTER&#009;INFO&#009;FORMAT&#009;normal"/>
                </assert_contents>
            </output>
        </test>
        <!-- #5 -->
        <test expect_num_outputs="1">
            <param name="input" value="normal.bam"/>
            <section name="generic">
                <param name="genome" value="genome.fasta"/>
                <param name="svtype" value="INS"/>
            </section>
            <section name="oo">
                <param name="out" value="vcf"/>
            </section>
            <output name="out_vcf">
                <assert_contents>
                    <has_n_lines n="47"/>
                    <has_line line="#CHROM&#009;POS&#009;ID&#009;REF&#009;ALT&#009;QUAL&#009;FILTER&#009;INFO&#009;FORMAT&#009;normal"/>
                </assert_contents>
            </output>
        </test>
        <!-- #6 -->
        <test expect_num_outputs="1">
            <param name="input" value="normal.bam"/>
            <section name="generic">
                <param name="genome" value="genome.fasta"/>
                <param name="svtype" value="DUP"/>
            </section>
            <section name="oo">
                <param name="out" value="bcf"/>
            </section>
            <output name="out_bcf">
                <assert_contents>
                    <has_size value="1152" delta="10"/>
                </assert_contents>
            </output>
        </test>
        <!-- #7 -->
        <test expect_num_outputs="1">
            <param name="input" value="normal.bam"/>
            <section name="generic">
                <param name="genome" value="genome.fasta"/>
                <param name="svtype" value="INV"/>
            </section>
            <section name="oo">
                <param name="out" value="log"/>
            </section>
            <output name="out_log">
                <assert_contents>
                    <has_text_matching expression=".+"/>
                </assert_contents>
            </output>
        </test>
        <!-- #8 -->
        <test expect_num_outputs="1">
            <param name="input" value="normal.bam"/>
            <section name="generic">
                <param name="genome" value="genome.fasta"/>
                <param name="svtype" value="BND"/>
            </section>
            <section name="oo">
                <param name="out" value="log"/>
            </section>
            <output name="out_log">
                <assert_contents>
                    <has_text_matching expression=".+"/>
                </assert_contents>
            </output>
        </test>
        <!-- #9 alt-alignments with Delly-formatted genotyping input -->
        <test expect_num_outputs="2">
            <param name="input" value="lr_vcffile.bam"/>
            <section name="generic">
                <param name="genome" value="lr_vcffile.fasta"/>
                <param name="svtype" value="DEL"/>
            </section>
            <section name="discovery">
                <repeat name="alt_alignments">
                    <param name="alignment" value="lr_vcffile.bam"/>
                    <param name="reference" value="lr_vcffile.fasta"/>
                </repeat>
            </section>
            <section name="genotyping">
                <param name="vcffile" value="lr_vcffile.vcf"/>
            </section>
            <section name="oo">
                <param name="out" value="vcf,log"/>
            </section>
            <output name="out_log">
                <assert_contents>
                    <has_text text="--alt-align alt_alignments.tsv"/>
                    <has_text text="Genotyping"/>
                </assert_contents>
            </output>
            <output name="out_vcf">
                <assert_contents>
                    <has_line line="#CHROM&#009;POS&#009;ID&#009;REF&#009;ALT&#009;QUAL&#009;FILTER&#009;INFO&#009;FORMAT&#009;input_0"/>
                    <has_text_matching expression="(?m)^chr1&#009;13790&#009;DEL00000000&#009;N&#009;&lt;DEL&gt;&#009;100&#009;PASS&#009;PRECISE;SVTYPE=DEL;SVMETHOD=EMBL\.DELLYv1\.7\.2;END=13860;PE=3;MAPQ=20;CT=3to5;CIPOS=-5,5;CIEND=-5,5;SRMAPQ=20;INSLEN=0;HOMLEN=0;SR=1;SRQ=0\.9;CONSENSUS=A+;CE=-0;CONSBP=60&#009;GT:GL:GQ:FT:RCL:RC:RCR:RDCN:DR:DV:RR:RV&#009;\./\.:0,0,0:0:LowQual:340:24:335:0:0:0:0:0$"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
.. class:: infomark

**What it does**

@WID@

**Input**

Delly *long-read (lr)* needs a sorted, indexed and duplicate marked BAM file for every input sample. An indexed reference genome is required to identify split-reads.

**Output**

The output is available in BCF and VCF format. Additionally an output file for SV-reads and a log file are provided.

.. class:: infomark

**References**

@REFERENCES@
    ]]></help>
    <expand macro="citations"/>
</tool>
