<tool id="clipkit" name="ClipKIT" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>trim multiple sequence alignments while retaining phylogenetically informative sites</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="stdio"/>
    <command detect_errors="exit_code"><![CDATA[
clipkit '$input'
    -o '$output'
    #if str($mode) and str($mode) != "None":
        -m '$mode'
    #end if
    #if str($gaps).strip() and str($gaps) != "None":
        -g $gaps
    #end if
    #if str($sequence_type) and str($sequence_type) != "None":
        -s '$sequence_type'
    #end if
    #if str($input_file_format) and str($input_file_format) != "None":
        -if '$input_file_format'
    #end if
    #if str($output_file_format) and str($output_file_format) != "None":
        -of '$output_file_format'
    #end if
    #if str($gap_characters).strip():
        -gc '$gap_characters'
    #end if
    #if $auxiliary_file:
        -a '$auxiliary_file'
    #end if
    $codon
    $ends_only
    #if $log_out:
        -l
    #end if
    $complementary
    #if $report_json_out:
        --report_json '$report_json'
    #end if
    #if $plot_report_out:
        --plot_trim_report '$plot_report'
    #end if
    -t \${GALAXY_SLOTS:-1}
    #if $log_out:
        && mv '${output}.log' '$log'
    #end if
    #if str($complementary) == "-c":
        && mv '${output}.complement' '$complement'
    #end if
    ]]></command>
    <inputs>
        <param argument="--input" type="data"
               format="fasta,clustal,phylip,stockholm,maf,xmfa"
               label="Multiple sequence alignment"
               help="Input alignment file. ClipKIT auto-detects the format if no input format is specified below."/>
        <param argument="--mode" type="select" optional="true"
               label="Trimming mode"
               help="Algorithm used to identify sites to trim. Leave unset to use ClipKIT's default (smart-gap).">
            <option value="">ClipKIT default (smart-gap)</option>
            <option value="smart-gap">smart-gap (dynamic gap threshold)</option>
            <option value="gappy">gappy (trim sites above gap threshold)</option>
            <option value="block-gappy">block-gappy (trim contiguous gappy regions)</option>
            <option value="gappyout">gappyout (gap-distribution-inferred threshold)</option>
            <option value="entropy">entropy (trim by Shannon entropy)</option>
            <option value="composition-bias">composition-bias</option>
            <option value="heterotachy">heterotachy</option>
            <option value="kpic">kpic (keep parsimony informative + constant)</option>
            <option value="kpic-smart-gap">kpic-smart-gap</option>
            <option value="kpic-gappy">kpic-gappy</option>
            <option value="kpi">kpi (keep parsimony informative only)</option>
            <option value="kpi-smart-gap">kpi-smart-gap</option>
            <option value="kpi-gappy">kpi-gappy</option>
            <option value="cst">cst (custom sites; requires auxiliary file)</option>
            <option value="c3">c3 (remove every third codon position)</option>
        </param>
        <param argument="--gaps" type="float" optional="true" min="0.0" max="1.0"
               label="Threshold value (-g)"
               help="For gappy/block-gappy/kpi-gappy/kpic-gappy this is the gap fraction (default 0.9). For entropy/composition-bias/heterotachy this is reinterpreted as that score's threshold (default 0.8). Ignored by smart-gap, kpi-smart-gap, kpic-smart-gap, gappyout, kpi, kpic, cst, and c3."/>
        <param argument="--sequence_type" type="select" optional="true"
               label="Sequence type"
               help="Leave unset to auto-detect.">
            <option value="">Auto-detect</option>
            <option value="aa">Amino acid</option>
            <option value="nt">Nucleotide</option>
        </param>
        <param argument="--input_file_format" type="select" optional="true"
               label="Input file format"
               help="Leave unset to auto-detect.">
            <option value="">Auto-detect</option>
            <option value="fasta">fasta</option>
            <option value="clustal">clustal</option>
            <option value="maf">maf</option>
            <option value="mauve">mauve</option>
            <option value="phylip">phylip</option>
            <option value="phylip_sequential">phylip_sequential</option>
            <option value="phylip_relaxed">phylip_relaxed</option>
            <option value="stockholm">stockholm</option>
        </param>
        <param argument="--output_file_format" type="select" optional="true"
               label="Output file format"
               help="Leave unset to match the input format.">
            <option value="">Same as input</option>
            <option value="fasta">fasta</option>
            <option value="clustal">clustal</option>
            <option value="maf">maf</option>
            <option value="mauve">mauve</option>
            <option value="phylip">phylip</option>
            <option value="phylip_sequential">phylip_sequential</option>
            <option value="phylip_relaxed">phylip_relaxed</option>
            <option value="stockholm">stockholm</option>
        </param>
        <param argument="--gap_characters" type="text" optional="true"
               label="Gap characters"
               help="Characters to treat as gaps (e.g. 'NnXx-?'). The first character cannot be '-'. Leave empty to use defaults (aa: Xx-?*, nt: XxNn-?*).">
            <sanitizer invalid_char="">
                <valid initial="string.letters,string.digits">
                    <add value="-"/>
                    <add value="?"/>
                    <add value="*"/>
                </valid>
            </sanitizer>
        </param>
        <param argument="--auxiliary_file" type="data" format="txt,tabular" optional="true"
               label="Auxiliary file (cst mode)"
               help="Tab-delimited file with '&lt;position&gt;\ttrim|keep' per line. Required when mode is set to 'cst'."/>
        <param argument="--codon" type="boolean" truevalue="-co" falsevalue=""
               checked="false"
               label="Codon-aware trimming (-co)"
               help="If any of the three positions in a codon would be trimmed, trim the whole codon."/>
        <param argument="--ends_only" type="boolean" truevalue="-eo" falsevalue=""
               checked="false"
               label="Trim only from the alignment ends (-eo)"/>
        <param argument="--complementary" type="boolean" truevalue="-c" falsevalue=""
               checked="false"
               label="Also output complementary alignment (-c)"
               help="Writes a second alignment containing the trimmed-out sites."/>
        <param name="log_out" type="boolean" checked="false"
               label="Output per-site log file (-l)"/>
        <param name="report_json_out" type="boolean" checked="false"
               label="Output run summary as JSON (--report_json)"/>
        <param name="plot_report_out" type="boolean" checked="false"
               label="Output interactive HTML trim report (--plot_trim_report)"/>
    </inputs>
    <outputs>
        <data name="output" format_source="input" label="${tool.name} on ${on_string}: trimmed alignment">
            <change_format>
                <when input="output_file_format" value="fasta" format="fasta"/>
                <when input="output_file_format" value="clustal" format="clustal"/>
                <when input="output_file_format" value="phylip" format="phylip"/>
                <when input="output_file_format" value="phylip_sequential" format="phylip"/>
                <when input="output_file_format" value="phylip_relaxed" format="phylip"/>
                <when input="output_file_format" value="stockholm" format="stockholm"/>
                <when input="output_file_format" value="maf" format="maf"/>
                <when input="output_file_format" value="mauve" format="xmfa"/>
            </change_format>
        </data>
        <data name="log" format="tabular"
              label="${tool.name} on ${on_string}: log">
            <filter>log_out</filter>
        </data>
        <data name="complement" format_source="input"
              label="${tool.name} on ${on_string}: complementary alignment">
            <filter>complementary</filter>
            <change_format>
                <when input="output_file_format" value="fasta" format="fasta"/>
                <when input="output_file_format" value="clustal" format="clustal"/>
                <when input="output_file_format" value="phylip" format="phylip"/>
                <when input="output_file_format" value="phylip_sequential" format="phylip"/>
                <when input="output_file_format" value="phylip_relaxed" format="phylip"/>
                <when input="output_file_format" value="stockholm" format="stockholm"/>
                <when input="output_file_format" value="maf" format="maf"/>
                <when input="output_file_format" value="mauve" format="xmfa"/>
            </change_format>
        </data>
        <data name="report_json" format="json"
              label="${tool.name} on ${on_string}: report (JSON)">
            <filter>report_json_out</filter>
        </data>
        <data name="plot_report" format="html"
              label="${tool.name} on ${on_string}: trim report (HTML)">
            <filter>plot_report_out</filter>
        </data>
    </outputs>
    <tests>
        <!-- Default run (smart-gap) on a small AA alignment -->
        <test expect_num_outputs="1">
            <param name="input" value="EOG091N44M8_aa.fa" ftype="fasta"/>
            <output name="output" file="EOG091N44M8_aa.fa.clipkit" ftype="fasta" lines_diff="0"/>
        </test>
        <!-- Infer the output format from a non-FASTA input. -->
        <test expect_num_outputs="1">
            <param name="input" value="simple.clustal" ftype="clustal"/>
            <output name="output" ftype="clustal">
                <assert_contents>
                    <has_text text="CLUSTAL"/>
                </assert_contents>
            </output>
        </test>
        <!-- gappy mode with explicit gap threshold -->
        <test expect_num_outputs="2">
            <param name="input" value="EOG091N44M8_aa.fa" ftype="fasta"/>
            <param name="mode" value="gappy"/>
            <param name="gaps" value="0.9"/>
            <param name="log_out" value="true"/>
            <output name="output" ftype="fasta">
                <assert_contents>
                    <has_text text=">"/>
                </assert_contents>
            </output>
            <output name="log" ftype="tabular">
                <assert_contents>
                    <has_line_matching expression="^\d+ (keep|trim) \S+ [0-9.]+$"/>
                </assert_contents>
            </output>
        </test>
        <!-- Exercise every optional output. -->
        <test expect_num_outputs="5">
            <param name="input" value="EOG091N44M8_aa.fa" ftype="fasta"/>
            <param name="complementary" value="true"/>
            <param name="log_out" value="true"/>
            <param name="report_json_out" value="true"/>
            <param name="plot_report_out" value="true"/>
            <output name="output" ftype="fasta">
                <assert_contents>
                    <has_text text=">200_S38|EOG091N44M8"/>
                </assert_contents>
            </output>
            <output name="log" ftype="tabular">
                <assert_contents>
                    <has_line_matching expression="^\d+ (keep|trim) \S+ [0-9.]+$"/>
                </assert_contents>
            </output>
            <output name="complement" ftype="fasta">
                <assert_contents>
                    <has_text text=">200_S38|EOG091N44M8"/>
                </assert_contents>
            </output>
            <output name="report_json" ftype="json">
                <assert_contents>
                    <has_json_property_with_value property="status" value='"completed"'/>
                    <has_json_property_with_value property="mode" value='"smart-gap"'/>
                    <has_json_property_with_value property="input_file_format" value='"fasta"'/>
                    <has_json_property_with_value property="output_file_format" value='"fasta"'/>
                    <has_json_property_with_value property="complement" value="true"/>
                    <has_json_property_with_value property="alignment_length" value="1026"/>
                    <has_json_property_with_value property="output_length" value="791"/>
                    <has_json_property_with_value property="trimmed_length" value="235"/>
                    <has_json_property_with_value property="trimmed_percentage" value="22.904"/>
                </assert_contents>
            </output>
            <output name="plot_report" ftype="html">
                <assert_contents>
                    <has_text text="ClipKIT trim report"/>
                </assert_contents>
            </output>
        </test>
        <!-- Convert both alignments to another supported output format. -->
        <test expect_num_outputs="2">
            <param name="input" value="EOG091N44M8_aa.fa" ftype="fasta"/>
            <param name="output_file_format" value="clustal"/>
            <param name="complementary" value="true"/>
            <output name="output" ftype="clustal">
                <assert_contents>
                    <has_text text="CLUSTAL"/>
                </assert_contents>
            </output>
            <output name="complement" ftype="clustal">
                <assert_contents>
                    <has_text text="CLUSTAL"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
**What it does**

ClipKIT_ is a multiple sequence alignment trimming tool that removes alignment
sites likely to be poorly aligned while retaining phylogenetically informative
sites. It supports a range of trimming algorithms including gap-based modes
(smart-gap, gappy, block-gappy, gappyout), site-statistic modes (entropy,
composition-bias, heterotachy), parsimony-aware modes (kpi, kpic and their
gappy/smart-gap variants), and custom site trimming (cst, c3).

**Inputs**

- A multiple sequence alignment in FASTA, Clustal, Phylip, Stockholm, MAF, or
  Mauve XMFA format.

**Key options**

- *Trimming mode*: which algorithm to apply. The default is ``smart-gap``.
- *Threshold (-g)*: gap fraction for gap-based modes (default 0.9), or the
  per-site score threshold for entropy/composition-bias/heterotachy
  (default 0.8). Ignored by modes that determine their own threshold.
- *Codon* and *Ends only*: refine where trimming may occur.
- *Auxiliary file*: required for ``cst`` (custom site trimming) mode.

**Outputs**

- The trimmed alignment in the chosen format.
- (Optional) Per-site log, complementary alignment, JSON run report, and an
  interactive HTML trim report.

.. _ClipKIT: https://github.com/JLSteenwyk/ClipKIT
    ]]></help>
    <expand macro="citations"/>
    <expand macro="creators"/>
</tool>
