<data_managers>
    <data_manager tool_file="data_manager/samestr_db.xml" id="samestr_db">
        <data_table name="samestr_db">
            <output>
                <column name="value"/>
                <column name="name"/>
                <column name="path" output_ref="out_file">
                    <move type="directory" relativize_symlinks="True">
                        <source>${path}</source>
                        <target base="${GALAXY_DATA_MANAGER_DATA_PATH}">samestr_db/${value}</target>
                    </move>
                    <value_translation>${GALAXY_DATA_MANAGER_DATA_PATH}/samestr_db/${value}</value_translation>
                    <value_translation type="function">abspath</value_translation>
                </column>
                <column name="version_file" output_ref="out_file">
                    <value_translation>${GALAXY_DATA_MANAGER_DATA_PATH}/samestr_db/${value}/${version_file}</value_translation>
                    <value_translation type="function">abspath</value_translation>
                </column>
                <column name="samestr_version"/>
            </output>
        </data_table>
    </data_manager>
</data_managers>
