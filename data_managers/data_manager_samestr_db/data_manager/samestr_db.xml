<tool id="samestr_db" name="SameStr Database Builder" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" tool_type="manage_data" profile="@PROFILE@">
    <description>Build SameStr database from MetaPhlAn markers</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        mkdir -p '$out_file.extra_files_path'/samestr_db/ &&

        #set $database_path = $database.fields.path
        #set $database_value = $database.fields.value
        #set $database_name = $database.fields.name
        #set $database_dbkey = $database.fields.dbkey

        #set $markers_info = $database_path + '/' + $database_value + '.pkl'
        #set $markers_fasta = $database_path + '/' + $database_value + '.fasta'
        #set $db_version_file = $database_path + '/mpa_latest'

        samestr db
        --markers-info '$markers_info'
        --markers-fasta '$markers_fasta'
        --db-version '$db_version_file'
        --output-dir '$out_file.extra_files_path'/samestr_db/
        #if $clade
            --clade '$clade'
        #end if
        &&


        echo '{
            "data_tables": {
                "samestr_db": [
                    {
                        "value": "'$database_dbkey'",
                        "dbkey": "'$database_dbkey'",
                        "name": "'$database_name'",
                        "path": "'$out_file.extra_files_path'/samestr_db/",
                        "clade": "",
                        "version_file": "'$db_version_file'"
                    }
                ]
            }
        }' > '$out_file'
    ]]></command>
    <inputs>

        <param name="database" type="select" label="Marker database" help="MetaPhlAn clade marker database.">
            <options from_data_table="metaphlan_database_versioned">
                <filter type="sort_by" column="2" />
            </options>
        </param>

        <param name="clade" type="text" optional="true" label="Clade selection." help="Names must correspond to the taxonomy of the respective database [e.g. t__SGB10068 for MetaPhlAn]"/>
        
    </inputs>
    <outputs>
        <data name="out_file" format="data_manager_json"/>
    </outputs>
    <tests>
        <test>
            <param name="database" value="mpa_vJan21_TOY_CHOCOPhlAnSGB_202103"/>
            <output name="out_file">
                <assert_contents>
                    <has_text text="data_tables"/>
                    <has_text text="samestr_db"/>
                    <has_text text="value&quot;: &quot;mpa_vJan21_TOY_CHOCOPhlAnSGB_202103"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
    This data manager builds Samestr compatible databases from MetaPhlAn marker files already installed in Galaxy.
    ]]></help>
    <expand macro="citations"/>
</tool>