<?xml version="1.0"?>
<data_managers>
    <data_manager tool_file="data_manager/data_manager_corenlp_models.xml" id="data_manager_corenlp_models">
        <data_table name="corenlp_models">
            <output>
                <column name="value" />
                <column name="name" />
                <column name="lang_code" />
                <column name="version" />
                <column name="models_path" output_ref="out_file">
                    <!-- All JARs for a version are moved into one shared
                         directory so the coreference annotator can find the
                         common models JAR next to a language JAR. -->
                    <move type="file">
                        <source>${models_path}</source>
                        <target base="${GALAXY_DATA_MANAGER_DATA_PATH}">corenlp/${version}/${os.path.basename($models_path)}</target>
                    </move>
                    <value_translation>${GALAXY_DATA_MANAGER_DATA_PATH}/corenlp/${version}/${os.path.basename($models_path)}</value_translation>
                    <value_translation type="function">abspath</value_translation>
                </column>
            </output>
        </data_table>
    </data_manager>
</data_managers>
