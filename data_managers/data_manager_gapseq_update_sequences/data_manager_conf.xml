<data_managers>
    <data_manager tool_file="data_manager/gapseq_update_sequences.xml" id="data_manager_gapseq_update_sequences">
        <data_table name="gapseq_database">
            <output>
                <column name="value"/>
                <column name="name"/>
                <column name="version"/>
                <column name="path" output_ref="out_file">
                    <move type="directory" relativize_symlinks="True">
                        <source>${path}</source>
                        <target base="${GALAXY_DATA_MANAGER_DATA_PATH}">gapseq/${value}</target>
                    </move>
                    <value_translation>${GALAXY_DATA_MANAGER_DATA_PATH}/gapseq/${value}</value_translation>
                    <value_translation type="function">abspath</value_translation>
                </column>
            </output>
        </data_table>
    </data_manager>
</data_managers>