<tool id="data_manager_gapseq_update_sequences" name="Gapseq update sequences" tool_type="manage_data" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="25.01" license="MIT">
    <description>Download gapseq reference sequences</description>
    <macros>
        <token name="@TOOL_VERSION@">2.1.0</token>
        <token name="@VERSION_SUFFIX@">0</token>
    </macros>
    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">gapseq</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
        #for $taxonomy in $t
            gapseq update-sequences
                -t '$taxonomy'
                -D '$out_file.extra_files_path'
                -Z '$Z'
                &&
        #end for
        cp '$dmjson' '$out_file'
    ]]></command>
    <configfiles>
        <configfile name="dmjson"><![CDATA[
            #from datetime import datetime
            {
                "data_tables":{
                "gapseq_database":[
                    {
                    "value":"#echo '+'.join([$taxonomy for $taxonomy in $t])#_v$Z",
                    "name":"#echo '+'.join([$taxonomy for $taxonomy in $t])#_v$Z",
                    "version":"$Z",
                    "path":"$out_file.extra_files_path"
                    }
                ]
                }
            }]]>
            </configfile>
    </configfiles>
    <inputs>
        <param argument="-t" type="select" multiple="true" label="Taxonomy of reference sequence to be downloaded">
            <option value="Bacteria" selected="true">Bacteria</option>
            <option value="Archaea" selected="true">Archaea</option>
        </param>
        <param argument="-Z" type="text" value="20446806" label="Database version as Zenodo ID" help="See help message below for more information"/>
    </inputs>
    <outputs>
        <data name="out_file" format="data_manager_json" label="Gapseq data manager: JSON"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="t" value="Archaea"/>
            <param name="Z" value="20446806"/>
            <output name="out_file">
                <assert_contents>
                    <has_text text="Archaea"/>
                    <has_text text="20446806"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
        
        This tool fetches gapseq reference sequence databases from Zenodo. You can view the available Zenodo records at the following URL: https://doi.org/10.5281/zenodo.10047603

    ]]></help>
    <citations>
        <citation type="doi">10.1186/s13059-021-02295-1</citation>
        <citation type="doi">10.1186/s13059-024-03425-1</citation>
        <citation type="doi">10.5281/zenodo.10047603</citation>
    </citations>
</tool>