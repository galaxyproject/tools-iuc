<?xml version="1.0"?>
<data_managers>
    <data_manager tool_file="data_manager/data_manager_stanza_models.xml" id="data_manager_stanza_models">
        <data_table name="stanza_models">
            <output>
                <column name="value" />
                <column name="name" />
                <column name="lang" />
                <column name="models_path" output_ref="out_file">
                    <move type="directory" relativize_symlinks="True">
                        <source>${models_path}</source>
                        <target base="${GALAXY_DATA_MANAGER_DATA_PATH}">stanza_models/${value}</target>
                    </move>
                    <value_translation>${GALAXY_DATA_MANAGER_DATA_PATH}/stanza_models/${value}</value_translation>
                    <value_translation type="function">abspath</value_translation>
                </column>
            </output>
        </data_table>
    </data_manager>
</data_managers>
