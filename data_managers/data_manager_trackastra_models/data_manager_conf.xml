<data_managers>
    <data_manager tool_file="data_manager/install_trackastra_models.xml" id="data_manager_trackastra_models">
        <data_table name="trackastra_models">
            <output>
                <column name="value"/>
                <column name="name"/>
                <column name="dimensionality"/>
                <column name="version"/>
                <column name="sha256"/>
                <column name="path" output_ref="output_file">
                    <move type="directory">
                        <source>${path}</source>
                        <target base="${GALAXY_DATA_MANAGER_DATA_PATH}">trackastra_models/#echo str($value)#</target>
                    </move>
                    <value_translation>${GALAXY_DATA_MANAGER_DATA_PATH}/trackastra_models/#echo str($value)#</value_translation>
                    <value_translation type="function">abspath</value_translation>
                </column>
                <column name="source"/>
            </output>
        </data_table>
    </data_manager>
</data_managers>
