<data_managers>
    <data_manager tool_file="pmlst_database/pmlst_ssi_database_data_manager.xml" id="pmlst_ssi_database_data_manager">
        <data_table name="pmlst_db">
            <output>
                <column name="value"/>
                <column name="name"/>
                <column name="path" output_ref="out_file">
                    <move type="directory" relativize_symlinks="True">
                        <source>${path}</source>
                        <target base="${GALAXY_DATA_MANAGER_DATA_PATH}">pmlst_db/${value}</target>
                    </move>
                    <value_translation>${GALAXY_DATA_MANAGER_DATA_PATH}/pmlst_db/${value}</value_translation>
                    <value_translation type="function">abspath</value_translation>
                </column>
                <column name="version"/>
            </output>
        </data_table>
    </data_manager>
</data_managers>
