<tool id="pmlst_ssi_database_data_manager" name="pMLST-SSI database" tool_type="manage_data" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>download or update the pMLST-SSI database</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="creator" />
    <expand macro="requirements" />
    <command detect_errors="exit_code"><![CDATA[
mkdir -p '${out_file.extra_files_path}' &&
python '$__tool_directory__/pmlst_ssi_database_data_manager.py'
--out-file '$out_file'
--destination '${out_file.extra_files_path}/pmlst_db'
--data-manager-path '$__app__.config.galaxy_data_manager_data_path'
#if str($test_fixture) == "true"
    --fixture-db '$__tool_directory__/../test-data/pmlst_fixture_db'
#end if
    ]]></command>
    <inputs>
        <param name="test_fixture" type="hidden" value="false"/>
    </inputs>
    <outputs>
        <data name="out_file" format="data_manager_json"/>
    </outputs>
    <tests>
        <test>
            <param name="test_fixture" value="true"/>
            <output name="out_file">
                <assert_contents>
                    <has_text text="pmlst_db"/>
                    <has_text text="pmlst_2023-04-24"/>
                    <has_text text="2023-04-24"/>
                </assert_contents>
            </output>
        </test>
        <test>
            <param name="test_fixture" value="true"/>
            <output name="out_file">
                <assert_contents>
                    <has_text text="pmlst_db"/>
                    <has_text text="&quot;pmlst_db&quot;: []"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
This data manager installs or updates the pMLST database used by the pMLST-SSI.
    ]]></help>
    <expand macro="citations" />
</tool>
