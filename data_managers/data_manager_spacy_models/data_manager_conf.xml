<?xml version="1.0"?>
<data_managers>
    <data_manager tool_file="data_manager/data_manager_spacy_models.xml" id="data_manager_spacy_models">
        <data_table name="spacy_models">
            <output>
                <column name="value" />
                <column name="name" />
                <column name="lang" />
                <column name="version" />
                <column name="model_path" output_ref="out_file">
                    <move type="directory" relativize_symlinks="True">
                        <source>${model_path}</source>
                        <target base="${GALAXY_DATA_MANAGER_DATA_PATH}">spacy_models/${value}</target>
                    </move>
                    <value_translation>${GALAXY_DATA_MANAGER_DATA_PATH}/spacy_models/${value}</value_translation>
                    <value_translation type="function">abspath</value_translation>
                </column>
            </output>
        </data_table>
    </data_manager>
</data_managers>
