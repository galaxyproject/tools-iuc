<tool id="data_manager_fetch_liana_resources" name="Download LIANA Resources" tool_type="manage_data" version="1.8.1+galaxy0" profile="25.0">
    <description>cache ligand-receptor, HCOP ortholog, and Metalinks resources</description>
    <requirements>
        <requirement type="package" version="1.8.1">liana</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
python '$__tool_directory__/liana_resources_downloader.py' \
    --resource '$resource_select' \
    --output '$output_file'
    ]]></command>
    <inputs>
        <param name="resource_select" type="select" label="Resources to download and cache">
            <option value="ligand_receptor_consensus" selected="true">L-R: Consensus only</option>
            <option value="ligand_receptor_main">L-R: Consensus, CellPhoneDB, and CellChatDB</option>
            <option value="ligand_receptor_single_cell">L-R: Main single-cell resources</option>
            <option value="ligand_receptor_all">L-R: All resources reported by LIANA</option>
            <option value="orthologs_common">HCOP: Human to mouse, rat, chicken, and zebrafish</option>
            <option value="orthologs_all_supported">HCOP: All target organisms supported by LIANA 1.8.1</option>
            <option value="hcop_human_mouse">HCOP: Human to Mouse</option>
            <option value="hcop_human_rat">HCOP: Human to Rat</option>
            <option value="hcop_human_chicken">HCOP: Human to Chicken</option>
            <option value="hcop_human_zebrafish">HCOP: Human to Zebrafish</option>
            <option value="hcop_human_anole_lizard">HCOP: Human to Anole Lizard</option>
            <option value="hcop_human_c_elegans">HCOP: Human to C. Elegans</option>
            <option value="hcop_human_cat">HCOP: Human to Cat</option>
            <option value="hcop_human_cattle">HCOP: Human to Cattle</option>
            <option value="hcop_human_chimpanzee">HCOP: Human to Chimpanzee</option>
            <option value="hcop_human_dog">HCOP: Human to Dog</option>
            <option value="hcop_human_fruitfly">HCOP: Human to Fruitfly</option>
            <option value="hcop_human_horse">HCOP: Human to Horse</option>
            <option value="hcop_human_macaque">HCOP: Human to Macaque</option>
            <option value="hcop_human_opossum">HCOP: Human to Opossum</option>
            <option value="hcop_human_pig">HCOP: Human to Pig</option>
            <option value="hcop_human_platypus">HCOP: Human to Platypus</option>
            <option value="hcop_human_s_cerevisiae">HCOP: Human to S. Cerevisiae</option>
            <option value="hcop_human_s_pombe">HCOP: Human to S. Pombe</option>
            <option value="hcop_human_xenopus">HCOP: Human to Xenopus</option>
            <option value="metalinks_all">Metalinks: All edges</option>
            <option value="metalinks_blood">Metalinks: Blood biospecimens</option>
            <option value="metalinks_plasma">Metalinks: Plasma biospecimens</option>
            <option value="metalinks_urine">Metalinks: Urine biospecimens</option>
            <option value="metalinks_bundle_all">Metalinks: All cached presets</option>
            <option value="all">Combined: all L-R, common HCOP, and all Metalinks presets</option>
        </param>
    </inputs>
    <outputs>
        <data name="output_file" format="data_manager_json"/>
    </outputs>
    <tests>
        <test>
            <param name="resource_select" value="ligand_receptor_consensus"/>
            <output name="output_file">
                <assert_contents>
                    <has_text text='"value": "consensus"'/>
                    <has_text text='"data_tables"'/>
                    <has_text text='"liana_resources"'/>
                    <not_has_text text='"type"'/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
Downloads LIANA resources into Galaxy's managed data directory. Each data-table
entry has exactly four fields: ``value``, ``name``, ``description``, and ``path``.
The path points to a directory containing ``<value>.tsv``.

HCOP downloads use LIANA 1.8.1's ``target_organism`` interface, which constructs
the current HGNC Google Cloud Storage URL. Metalinks downloads use the current
filter interface and do not pass the removed ``hmdb`` or ``uniprot`` booleans.
    ]]></help>
    <citations>
        <citation type="doi">10.1038/s41556-024-01469-w</citation>
    </citations>
</tool>
